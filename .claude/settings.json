{
  "permissions": {
    "allow": [
      "Bash(scripts/ship:*)",
      "Bash(scripts/deploy:*)",
      "Bash(scripts/dev:*)",
      "Bash(git:*)",
      "Bash(docker:*)",
      "Bash(uv:*)",
      "Bash(ansible-playbook:*)",
      "Bash(ansible:*)",
      "mcp__claude-context"
    ],
    "additionalDirectories": ["/Users/reto/work/cluster"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/inflight\" --for-hook"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/code-search-up.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/memory-nudge.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-worktree-path.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-sealed-migration.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-commit-on-main.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-git-stash.py\""
          }
        ]
      },
      {
        "matcher": "mcp__precis__put|mcp__precis__edit|mcp__precis__delete|mcp__precis__tag",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-prod-write.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/map-staleness-reminder.py\""
          }
        ]
      }
    ]
  }
}
