# {{ ansible_managed }}
# Read by precis-worker via a systemd drop-in EnvironmentFile. Wires the
# precis-mcp struct_relax job_type (ADR 0043 §23.12) on this node.
#
# PRECIS_NODE lets the §23 #3 node gate claim a node-pinned job here (and the
# struct_relax runner run the container locally, no self-ssh, when it is the
# target node). PRECIS_DFT_* parameterise the container dispatch.
PRECIS_NODE={{ dft_node }}
PRECIS_DFT_NODE={{ dft_node }}
PRECIS_DFT_IMAGE={{ dft_image }}
PRECIS_DFT_CONTAINER_CMD={{ dft_container_cmd }}
PRECIS_DFT_NFS_ROOT={{ dft_nfs_root }}
