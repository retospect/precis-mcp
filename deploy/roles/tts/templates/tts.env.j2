# {{ ansible_managed }}
# Read by precis-worker via a systemd drop-in EnvironmentFile. Enables the
# briefing_audio worker pass (the news-briefing → podcast producer) on this node
# and points it at the precis-tts container.
#
# The TTS engine (Kokoro + misaki) is in the IMAGE, not this venv — the pass
# shells out to `{{ tts_container_cmd }} run {{ tts_image }}` per episode. It
# self-schedules off an un-narrated briefing ref, so no cron. Episodes land on
# {{ tts_podcast_dir }} (the NAS dir the gateway serves).
PRECIS_BRIEFING_AUDIO_ENABLED=1
# cast_audio pass: the daily reading-brief + evening nidra casts (reuses the
# same TTS container + podcast dir as briefing_audio). Self-schedules off an
# un-narrated meta.cast draft; compose runs as the reading_brief/meditation
# coordinator job_types on any node.
PRECIS_CAST_AUDIO_ENABLED=1
PRECIS_TTS_IMAGE={{ tts_image }}
PRECIS_TTS_CONTAINER_CMD={{ tts_container_cmd }}
PRECIS_TTS_SCRATCH={{ tts_scratch_dir }}
PRECIS_PODCAST_DIR={{ tts_podcast_dir }}
PRECIS_BRIEFING_AUDIO_VOICE={{ tts_briefing_voice }}
PRECIS_BRIEFING_AUDIO_LANG={{ tts_briefing_lang }}
