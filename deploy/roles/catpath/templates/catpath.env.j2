# {{ ansible_managed }}
# Read by precis-worker via a systemd drop-in EnvironmentFile. Enables the
# `pathway` kind (catpath[precis]) on this worker and pins catpath compute here.
#
# PRECIS_CATPATH_ENABLED flips the plugin on (the handler InitErrors and hides
# the kind when unset). PRECIS_NODE lets the target_node claim gate run a
# catpath_explore job locally on this node (same value roles/dft sets; harmless
# if both drop-ins are present).
PRECIS_CATPATH_ENABLED=1
PRECIS_NODE={{ catpath_node }}
