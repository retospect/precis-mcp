-- {{ ansible_managed }}
-- ~deploy/.psqlrc — sane interactive psql defaults.

\set QUIET on
\set HISTFILE ~/.psql_history- :DBNAME
\set HISTSIZE 5000
\set HISTCONTROL ignoredups
\set COMP_KEYWORD_CASE upper

-- Coloured, host-aware prompt: tells you at a glance which db you're on.
\set PROMPT1 '%[%033[1;31m%]%n%[%033[0m%]@%[%033[1;33m%]%/%[%033[0m%] %R%# '
\set PROMPT2 '... %R%# '

\timing on
\x auto
\pset null '∅'
\pset linestyle unicode
\pset border 2

\set QUIET off
