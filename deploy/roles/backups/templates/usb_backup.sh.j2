#!/bin/bash
# {{ ansible_managed }}
# Weekly rsync of /shared to USB backup drive
set -euo pipefail

USB_MOUNT="{{ backup_usb_mount | default('/mnt/backup-usb') }}"
SRC="{{ shared_mount }}/"
DST="${USB_MOUNT}/shared-backup/"

if ! mountpoint -q "${USB_MOUNT}" 2>/dev/null; then
    echo "[$(date)] ERROR: USB drive not mounted at ${USB_MOUNT}"
    exit 1
fi

echo "[$(date)] Starting rsync to USB..."
rsync -av --delete \
    --exclude='*.tmp' \
    --exclude='.nfs*' \
    "${SRC}" "${DST}"

echo "[$(date)] USB backup complete"
