#!/bin/bash
# {{ ansible_managed }}
# Daily API credit usage monitor
set -euo pipefail

LOG_DIR="{{ shared_mount }}/logs"
TIMESTAMP=$(date +%Y-%m-%d)

echo "=== API Credit Report ${TIMESTAMP} ==="

# LiteLLM spend tracking (queries the LiteLLM DB)
LITELLM_URL="http://{{ litellm_host }}:{{ litellm_port }}"
echo ""
echo "--- LiteLLM Spend (last 24h) ---"
curl -s "${LITELLM_URL}/spend/logs?start_date=$(date -v-1d +%Y-%m-%d 2>/dev/null || date -d 'yesterday' +%Y-%m-%d)&end_date=${TIMESTAMP}" \
    -H "Authorization: Bearer {{ vault_litellm_master_key }}" \
    | python3 -c "
import sys, json
data = json.load(sys.stdin)
if isinstance(data, list):
    total = sum(r.get('spend', 0) for r in data)
    by_model = {}
    for r in data:
        m = r.get('model', 'unknown')
        by_model[m] = by_model.get(m, 0) + r.get('spend', 0)
    print(f'  Total spend: \${total:.4f}')
    for m, s in sorted(by_model.items(), key=lambda x: -x[1]):
        print(f'  {m}: \${s:.4f}')
else:
    print(f'  Response: {data}')
" 2>/dev/null || echo "  (LiteLLM spend API unavailable)"

echo ""
echo "=== End Report ==="
