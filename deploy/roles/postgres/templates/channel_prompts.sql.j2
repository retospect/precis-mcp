-- {{ ansible_managed }}
-- Per-channel context prompts, editable at runtime by Asa via set_channel_prompt tool

CREATE TABLE IF NOT EXISTS cluster.channel_prompts (
    id              serial PRIMARY KEY,
    channel_type    text NOT NULL DEFAULT 'discord',   -- discord, api, etc.
    guild_id        text,                              -- Discord guild ID (null for non-Discord)
    channel_name    text NOT NULL,                     -- Channel name (e.g. "research", "writing")
    prompt          text NOT NULL DEFAULT '',           -- The context/overlay prompt text
    updated_at      timestamptz NOT NULL DEFAULT now(),
    updated_by      text NOT NULL DEFAULT 'system',    -- Who last edited: "system", Discord username, etc.
    UNIQUE (channel_type, guild_id, channel_name)
);

-- Grant access: agent_rw (tools) reads+writes
GRANT SELECT, INSERT, UPDATE ON cluster.channel_prompts TO agent_rw;
GRANT USAGE, SELECT ON SEQUENCE cluster.channel_prompts_id_seq TO agent_rw;

