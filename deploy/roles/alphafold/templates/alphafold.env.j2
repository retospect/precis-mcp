# {{ ansible_managed }}
# Read by precis-worker via a systemd drop-in EnvironmentFile. Wires the
# precis-mcp `fold` job_type (ADR 0056 slice 4) on this node.
#
# PRECIS_NODE lets the target_node claim gate claim a node-pinned fold job here
# (and the container runner run docker locally, no self-ssh, when it is the
# target node). PRECIS_FOLD_* parameterise the container dispatch
# (precis_bio.jobs._run_container). The protein KIND stays dark on the worker
# (no PRECIS_BIO_ENABLED) — the worker only RUNS jobs; the kind surface lives on
# the gateway (roles/precis_web).
PRECIS_NODE={{ alphafold_node }}
PRECIS_FOLD_NODE={{ alphafold_node }}
PRECIS_FOLD_IMAGE={{ alphafold_image }}
PRECIS_FOLD_MODELS_DIR={{ alphafold_models_dir }}
PRECIS_FOLD_CONTAINER_CMD={{ alphafold_container_cmd }}
PRECIS_FOLD_NFS_ROOT={{ alphafold_nfs_root }}
PRECIS_FOLD_XLA_CACHE={{ alphafold_xla_cache_dir }}
PRECIS_FOLD_MEM_LIMIT={{ alphafold_mem_limit }}
