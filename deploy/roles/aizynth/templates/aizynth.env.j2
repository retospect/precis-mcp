# {{ ansible_managed }}
# Read by precis-worker via a systemd drop-in EnvironmentFile. Wires the
# precis-mcp `retrosynth` job_type (ADR 0056 slice 1b) on this node.
#
# PRECIS_NODE lets the target_node claim gate claim a node-pinned retrosynth job
# here (and the container runner run podman locally, no self-ssh, when it is the
# target node). PRECIS_CHEM_* parameterise the container dispatch
# (precis_chem.jobs._run_container). The route KIND stays dark on the worker
# (no PRECIS_CHEM_ENABLED) — the worker only RUNS jobs; the kind surface lives on
# the gateway (roles/precis_web).
PRECIS_NODE={{ aizynth_node }}
PRECIS_CHEM_ROUTE_NODE={{ aizynth_node }}
PRECIS_CHEM_CONTAINER_CMD={{ aizynth_container_cmd }}
PRECIS_CHEM_NFS_ROOT={{ aizynth_nfs_root }}
PRECIS_CHEM_MODELS_DIR={{ aizynth_models_dir }}
