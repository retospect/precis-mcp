-- {{ ansible_managed }}
-- Daily briefing infrastructure: news ingestion + prompt management

-- ── News items table (hourly RSS + API ingestion) ──
CREATE TABLE IF NOT EXISTS cluster.news_items (
    id              bigserial PRIMARY KEY,
    fingerprint     text NOT NULL,                -- SHA-256 of normalized title+source for dedup
    source          text NOT NULL,                -- Feed URL or "semantic_scholar", "arxiv", etc.
    source_name     text NOT NULL DEFAULT '',      -- Human-readable: "The Guardian", "BBC", etc.
    title           text NOT NULL,
    link            text NOT NULL DEFAULT '',
    summary         text NOT NULL DEFAULT '',      -- RSS description or article abstract
    content         text NOT NULL DEFAULT '',      -- Full content if available
    authors         text NOT NULL DEFAULT '',      -- Comma-separated
    tags            text[] NOT NULL DEFAULT '{}',  -- e.g. {"news","osint"} or {"academic","mof"}
    published_at    timestamptz,                   -- Original publication time
    ingested_at     timestamptz NOT NULL DEFAULT now(),
    metadata        jsonb NOT NULL DEFAULT '{}',   -- Flexible: DOI, arxiv_id, s2_paper_id, etc.
    UNIQUE (fingerprint)
);

CREATE INDEX IF NOT EXISTS idx_news_items_ingested ON cluster.news_items (ingested_at DESC);
CREATE INDEX IF NOT EXISTS idx_news_items_source ON cluster.news_items (source_name);
CREATE INDEX IF NOT EXISTS idx_news_items_tags ON cluster.news_items USING gin (tags);
CREATE INDEX IF NOT EXISTS idx_news_items_published ON cluster.news_items (published_at DESC);

-- ── Briefing prompts table (runtime-editable, versioned) ──
CREATE TABLE IF NOT EXISTS cluster.briefing_prompts (
    id              serial PRIMARY KEY,
    name            text NOT NULL UNIQUE,           -- e.g. "daily_morning_brief", "weekly_science"
    prompt          text NOT NULL,                  -- The full prompt text
    version         integer NOT NULL DEFAULT 1,
    active          boolean NOT NULL DEFAULT true,  -- Only one active per name (enforced in app)
    updated_at      timestamptz NOT NULL DEFAULT now(),
    updated_by      text NOT NULL DEFAULT 'system', -- "system", "asa", Discord username, etc.
    metadata        jsonb NOT NULL DEFAULT '{}'      -- Config: schedule, model, feeds filter, etc.
);

-- ── Briefing runs log (tracks each execution) ──
CREATE TABLE IF NOT EXISTS cluster.briefing_runs (
    id              bigserial PRIMARY KEY,
    prompt_name     text NOT NULL,                  -- FK-ish to briefing_prompts.name
    started_at      timestamptz NOT NULL DEFAULT now(),
    finished_at     timestamptz,
    status          text NOT NULL DEFAULT 'running', -- running, completed, failed
    news_item_count integer NOT NULL DEFAULT 0,     -- How many items were fed to the LLM
    model           text NOT NULL DEFAULT '',        -- Which LLM model was used
    output_path     text,                           -- Path to saved brief
    error           text,                           -- Error message if failed
    tokens_used     integer,                        -- Total tokens consumed
    metadata        jsonb NOT NULL DEFAULT '{}'
);

-- ── RSS feed configuration (managed via Ansible seed, editable at runtime) ──
CREATE TABLE IF NOT EXISTS cluster.rss_feeds (
    id              serial PRIMARY KEY,
    url             text NOT NULL UNIQUE,
    name            text NOT NULL,                  -- Human-readable name
    category        text NOT NULL DEFAULT 'news',   -- news, osint, academic, science, finance
    enabled         boolean NOT NULL DEFAULT true,
    fetch_interval  interval NOT NULL DEFAULT '1 hour',
    last_fetched_at timestamptz,
    last_error      text,
    tags            text[] NOT NULL DEFAULT '{}',   -- Default tags applied to items from this feed
    metadata        jsonb NOT NULL DEFAULT '{}'
);

-- ── Semantic Scholar watch queries (poll API for matching papers) ──
CREATE TABLE IF NOT EXISTS cluster.scholar_watches (
    id              serial PRIMARY KEY,
    query           text NOT NULL,                  -- Search query string
    fields          text NOT NULL DEFAULT 'title,abstract,authors,year,citationCount,externalIds',
    min_citations   integer NOT NULL DEFAULT 0,     -- Filter: minimum citation count
    enabled         boolean NOT NULL DEFAULT true,
    last_polled_at  timestamptz,
    tags            text[] NOT NULL DEFAULT '{}',   -- Tags applied to ingested papers
    metadata        jsonb NOT NULL DEFAULT '{}'
);

-- ── Permissions ──
-- agent_rw reads+writes (runtime/tools)
GRANT SELECT, INSERT, UPDATE ON cluster.news_items TO agent_rw;
GRANT SELECT, INSERT, UPDATE ON cluster.briefing_prompts TO agent_rw;
GRANT SELECT, INSERT, UPDATE ON cluster.briefing_runs TO agent_rw;
GRANT SELECT, INSERT, UPDATE ON cluster.rss_feeds TO agent_rw;
GRANT SELECT, INSERT, UPDATE ON cluster.scholar_watches TO agent_rw;

GRANT USAGE, SELECT ON SEQUENCE cluster.news_items_id_seq TO agent_rw;
GRANT USAGE, SELECT ON SEQUENCE cluster.briefing_prompts_id_seq TO agent_rw;
GRANT USAGE, SELECT ON SEQUENCE cluster.briefing_runs_id_seq TO agent_rw;
GRANT USAGE, SELECT ON SEQUENCE cluster.rss_feeds_id_seq TO agent_rw;
GRANT USAGE, SELECT ON SEQUENCE cluster.scholar_watches_id_seq TO agent_rw;

-- Read-only for agent_ro
GRANT SELECT ON cluster.news_items TO agent_ro;
GRANT SELECT ON cluster.briefing_prompts TO agent_ro;
GRANT SELECT ON cluster.briefing_runs TO agent_ro;
GRANT SELECT ON cluster.rss_feeds TO agent_ro;
GRANT SELECT ON cluster.scholar_watches TO agent_ro;

