{% extends "base.html.j2" %}
{% block title %}{{ ref.title }}{% endblock %}
{% block content %}
<a href="/refs/{{ kind }}" class="text-sm text-slate-500 underline">&larr; {{ kind_label }}</a>
<div class="mt-2 mb-4">
  <h1 class="text-lg font-semibold">{{ ref.title }}</h1>
  <p class="text-sm text-slate-500">
    #{{ ref.id }}
    {% if ref.slug %}· <span class="font-mono">{{ ref.slug }}</span>{% endif %}
    {% if ref.created %}· created {{ ref.created }}{% endif %}
    {% if ref.updated %}· updated {{ ref.updated }}{% endif %}
    {% if ref.set_by %}· by <span class="font-mono">{{ ref.set_by }}</span>{% endif %}
    {% if ref.prio is not none %}· prio {{ ref.prio }}{% endif %}
    {% if ref.auto_refresh_days %}· decays over {{ ref.auto_refresh_days }}d{% if ref.refreshed %} (refreshed {{ ref.refreshed }}){% endif %}{% endif %}
  </p>
</div>

{# Tag strip — every browsable kind gets one. Closed-vocab tags
   render as inert pills (no × button); free OPEN tags carry a ×
   that posts ``remove=ns:value`` to the edit_tags route. New tags
   land via the comma/space-separated input on the right. #}
<div class="mb-4 flex flex-wrap items-center gap-1.5">
  {% for t in tags %}
    {% if t.deletable %}
    <form method="post" action="/refs/{{ kind }}/{{ ref.id }}/tags" class="inline">
      <input type="hidden" name="remove" value="{{ t.value }}" />
      <span class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded bg-slate-100 text-slate-700 border border-slate-200">
        <span class="font-mono">{{ t.value }}</span>
        <button class="text-slate-400 hover:text-rose-600" title="remove tag">×</button>
      </span>
    </form>
    {% else %}
    <span class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded bg-violet-50 text-violet-700 border border-violet-100"
          title="closed-vocab tag — remove via tag(kind='{{ kind }}', id={{ ref.id }}, remove=[...])">
      <span class="font-mono">{{ t.label }}</span>
    </span>
    {% endif %}
  {% else %}
  <span class="text-xs text-slate-400 italic">no tags yet</span>
  {% endfor %}
  <form method="post" action="/refs/{{ kind }}/{{ ref.id }}/tags"
        class="inline-flex items-center gap-1 ml-auto">
    <input name="add" placeholder="+ tag (comma-separated)"
           class="text-xs px-2 py-1 rounded border border-slate-300 w-56" />
    <button class="text-xs px-2 py-1 rounded bg-emerald-600 text-white hover:bg-emerald-700">add</button>
  </form>
</div>

{# YouTube header card — a clickable watch link + the video thumbnail
   ("screenshot") so the detail page isn't just a wall of transcript.
   The thumbnail is itself a link to the video (with a play overlay);
   the deep-link in the body below stays as the plain-text fallback. #}
{% if youtube_meta %}
<div class="mb-4 rounded-lg border border-slate-200 bg-white overflow-hidden sm:flex">
  <a href="{{ youtube_meta.watch_url }}" target="_blank" rel="noopener"
     class="relative block shrink-0 sm:w-64 group"
     title="Watch on YouTube">
    <img src="{{ youtube_meta.thumbnail_url }}" alt="Video thumbnail"
         class="w-full h-full object-cover aspect-video bg-slate-100"
         loading="lazy" referrerpolicy="no-referrer" />
    <span class="absolute inset-0 flex items-center justify-center">
      <span class="rounded-full bg-black/60 group-hover:bg-red-600 transition-colors
                   w-14 h-10 flex items-center justify-center text-white text-xl">▶</span>
    </span>
  </a>
  <div class="p-4 flex flex-col gap-2 min-w-0">
    <a href="{{ youtube_meta.watch_url }}" target="_blank" rel="noopener"
       class="inline-flex items-center gap-1.5 self-start rounded-md bg-red-600 text-white
              text-sm px-3 py-1.5 hover:bg-red-700">
      ▶ Watch on YouTube ↗
    </a>
    <p class="text-xs text-slate-500 space-x-2">
      {% if youtube_meta.channel_name %}
        {% if youtube_meta.channel_url %}
        <a href="{{ youtube_meta.channel_url }}" target="_blank" rel="noopener"
           class="text-sky-700 hover:underline">{{ youtube_meta.channel_name }}</a>
        {% else %}<span>{{ youtube_meta.channel_name }}</span>{% endif %}
      {% endif %}
      {% if youtube_meta.duration %}<span>· {{ youtube_meta.duration }}</span>{% endif %}
      {% if youtube_meta.published_at %}<span>· published {{ youtube_meta.published_at }}</span>{% endif %}
    </p>
    <p class="text-xs text-slate-400 font-mono break-all">{{ youtube_meta.watch_url }}</p>
  </div>
</div>
{% endif %}

{% if body_disabled_notice %}
<div class="mb-3 rounded-lg border border-amber-200 bg-amber-50 p-3 text-xs text-amber-800">
  {{ body_disabled_notice }}
</div>
{% endif %}
{% if is_error %}
<div class="rounded-lg border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800 whitespace-pre-wrap">{{ body | linkify_refs }}</div>
{% elif kind == "anki" %}
{# Cloze cards: render {{cN::answer::hint}} deletions as highlighted spans
   rather than leaking the raw double-brace markup at the reader. #}
<div class="rounded-lg border border-slate-200 bg-white p-4 text-sm text-slate-700 overflow-x-auto whitespace-pre-wrap leading-relaxed">{{ body | render_cloze }}</div>
{% else %}
{# Tab-separated runs (TOON ``Next:`` blocks, tab-delimited oracle shares)
   render as aligned tables via ``linkify_toon``; prose stays whitespace-
   preserved + linkified. The container is a plain div (each segment
   carries its own whitespace handling) rather than a <pre>, whose fixed
   tab-stops made the columns invisible. #}
<div class="rounded-lg border border-slate-200 bg-white p-4 text-xs text-slate-700 overflow-x-auto space-y-1">{{ body | linkify_toon(footnotes) }}</div>
{% endif %}

{# Job actions strip — a job is a thing you unstick (retry → re-mint) or
   read (transcript / parent intent), not a thought you interrogate. This
   replaces the dream-memory "Ask & think" box for kind='job' so an
   operator landing on a closed:failed job (e.g. a swept claim-orphaned
   plan_tick) has the same affordances the /tasks dashboard offers,
   without leaving the page they clicked. #}
{% if job_actions %}
<section class="mt-6" x-data="{ showModel: false }">
  <h2 class="text-sm font-semibold mb-2 text-slate-700">Actions</h2>
  <div class="rounded-lg border border-slate-200 bg-white p-4 space-y-3">
    <div class="flex flex-wrap items-center gap-2">
      {% if job_actions.can_retry %}
      {# Retry clears the parent todo's child-failed: bubble so dispatch
         re-mints a fresh attempt (~1 min). The failed job stays for
         forensics. Redirects to /tasks to watch the re-minted job. #}
      <form method="post" action="/tasks/{{ job_actions.job_id }}/retry"
            class="inline-flex items-center gap-2">
        {% if job_actions.is_llm_planner %}
        <select name="model"
                class="text-xs px-2 py-1.5 rounded border border-slate-300 text-slate-700">
          <option value="">same model</option>
          {% for m in job_actions.retry_models %}
          <option value="{{ m }}">retry on {{ m }}</option>
          {% endfor %}
        </select>
        {% endif %}
        <button class="rounded-md bg-emerald-600 text-white text-sm px-4 py-2 hover:bg-emerald-700">
          ↻ Retry job
        </button>
      </form>
      {% elif job_actions.retryable %}
      <span class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-1.5">
        can't re-mint — this job has no todo parent (legacy orphan)
      </span>
      {% else %}
      <span class="text-xs text-slate-500 bg-slate-50 border border-slate-200 rounded px-2 py-1.5">
        {% if job_actions.status %}STATUS:{{ job_actions.status }}{% else %}not terminal{% endif %} —
        only a failed / cancelled job can be retried
      </span>
      {% endif %}

      {% if job_actions.has_transcript %}
      <a href="/tasks/{{ job_actions.job_id }}/transcript"
         class="rounded-md border border-slate-300 text-sm px-4 py-2 text-slate-700 hover:bg-slate-50">
        📜 View transcript
      </a>
      {% endif %}

      {% if job_actions.parent_id %}
      <a href="/tasks?focus={{ job_actions.parent_id }}"
         class="rounded-md border border-slate-300 text-sm px-4 py-2 text-slate-700 hover:bg-slate-50">
        ↑ Parent todo #{{ job_actions.parent_id }}
      </a>
      {% endif %}
    </div>
    <p class="text-xs text-slate-400">
      Retry clears the parent todo's <span class="font-mono">child-failed:</span>
      bubble so the dispatch worker re-mints a fresh attempt (~1&nbsp;min);
      this failed job stays for forensics. The status &amp; events above
      say <em>what went wrong</em>; the transcript shows the run turn-by-turn.
    </p>
  </div>
</section>
{% endif %}

{# Ask a follow-up — type a question, the server thinks about this
   thought (reusing the dreaming dispatch) and stores the answer as a
   conv thread linked back here. Existing discussions list above the box
   so the thread is reachable from the thought it grew out of. Suppressed
   for jobs (see the Actions strip above). #}
{% if discussions is not none %}
<section class="mt-6">
  <h2 class="text-sm font-semibold mb-2 text-slate-700">Discussion</h2>
  {% if discussions %}
  <ul class="mb-3 rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
    {% for d in discussions %}
    <li class="px-3 py-2 text-sm flex items-center gap-2">
      <span class="text-slate-400">💬</span>
      <a href="{{ d.url }}" class="text-sky-700 hover:underline flex-1">{{ d.title }}</a>
      {% if d.chunk is not none %}
      <span class="text-xs font-mono text-slate-400">on ~{{ d.chunk }}</span>
      {% endif %}
      <span class="text-xs text-slate-400">{{ d.turns }} turn{{ '' if d.turns == 1 else 's' }}</span>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
  <form method="post" action="/refs/{{ kind }}/{{ ref.id }}/ask" class="space-y-2">
    <textarea name="question" rows="2" required
              placeholder="Ask a follow-up about this thought…"
              class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
    <div class="flex items-center gap-2">
      <button class="rounded-md bg-sky-600 text-white text-sm px-4 py-2 hover:bg-sky-700">
        Ask &amp; think
      </button>
      <span class="text-xs text-slate-400">
        runs an agentic pass (can take ~30–60s); the answer lands in a linked thread
      </span>
    </div>
  </form>
</section>
{% endif %}

{# References panel — every ``kind:ref`` handle the linkifier found in
   the body, expanded with title + preview. Helps third parties read a
   dream memory's connections without chasing a dozen links. Includes
   a "Copy all (plain text)" button via Alpine. #}
{% if references %}
<section class="mt-6" x-data="{ copied: '', menuOpen: false }" @click.outside="menuOpen = false">
  <div class="flex items-baseline gap-2 mb-2">
    <h2 class="text-sm font-semibold text-slate-700">
      References <span class="text-slate-400 font-normal">({{ references|length }})</span>
    </h2>
    {# Three export modes — plain text, Markdown, BibTeX. The dropdown
       state plus a tiny shared formatter live entirely in Alpine. #}
    <div class="ml-auto relative">
      <button type="button" @click="menuOpen = !menuOpen"
              class="text-xs px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
        <span x-show="!copied">📋 Copy as… ▾</span>
        <span x-show="copied" x-cloak class="text-emerald-700">✓ copied <span x-text="copied"></span></span>
      </button>
      <div x-show="menuOpen" x-cloak
           class="absolute right-0 top-full mt-1 w-48 rounded-lg border border-slate-200 bg-white shadow-xl z-20 text-xs">
        <button type="button" @click="copyAs('plain'); menuOpen = false"
                class="block w-full text-left px-3 py-2 hover:bg-slate-50">Plain text</button>
        <button type="button" @click="copyAs('markdown'); menuOpen = false"
                class="block w-full text-left px-3 py-2 hover:bg-slate-50">Markdown</button>
        <button type="button" @click="copyAs('bibtex'); menuOpen = false"
                class="block w-full text-left px-3 py-2 hover:bg-slate-50">BibTeX
          <span class="text-slate-400">(papers only)</span>
        </button>
      </div>
    </div>
  </div>
  {# Hidden JSON payload the Alpine formatter reads. Keeps the citation
     fields available without sprinkling data-attrs across every row. #}
  <script type="application/json" id="references-json">
    {{ references | tojson }}
  </script>
  <script>
    function copyAs(mode) {
      const refs = JSON.parse(document.getElementById('references-json').textContent);
      let txt = '';
      if (mode === 'plain') {
        txt = refs.map(r => {
          const t = r.title || '';
          const p = r.preview ? '. ' + r.preview : '';
          return r.handle + ' — ' + t + ' (' + r.kind + ')' + p;
        }).join('\n');
      } else if (mode === 'markdown') {
        txt = refs.map(r => {
          const t = r.title || '';
          const p = r.preview ? '\n  > ' + r.preview : '';
          return '- [' + r.handle + '](' + r.url + ') — ' + t + ' (' + r.kind + ')' + p;
        }).join('\n');
      } else if (mode === 'bibtex') {
        txt = refs.filter(r => r.kind === 'paper' && r.citation && r.citation.cite_key)
          .map(r => {
            const c = r.citation;
            const parts = ['@article{' + c.cite_key + ','];
            if (c.authors && c.authors.length)
              parts.push('  author = {' + c.authors.join(' and ') + '},');
            parts.push('  title = {' + (r.title || '').replace(/[{}]/g, '') + '},');
            if (c.year) parts.push('  year = {' + c.year + '},');
            if (c.doi) parts.push('  doi = {' + c.doi + '},');
            if (c.url) parts.push('  url = {' + c.url + '},');
            parts.push('}');
            return parts.join('\n');
          }).join('\n\n');
        if (!txt) txt = '% No paper-kind references in this body.';
      }
      navigator.clipboard.writeText(txt);
      // Update Alpine state via the closest scope.
      const root = document.querySelector('section[x-data*="copied"]');
      if (root && root._x_dataStack) {
        root._x_dataStack[0].copied = mode;
        setTimeout(() => { root._x_dataStack[0].copied = ''; }, 1500);
      }
    }
  </script>
  <ol class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100 list-decimal pl-8">
    {% for r in references %}
    {# data-ref-line is what the copy button pulls — plain-text cite
       form: "handle — title (kind). preview…". id="ref-N" lets the
       inline [N] footnote markers in the body jump here. #}
    <li class="px-3 py-2 text-xs" id="ref-{{ r.number }}"
        data-ref-line="[{{ r.number }}] {{ r.handle }} — {{ r.title }} ({{ r.kind }}){% if r.preview %}. {{ r.preview }}{% endif %}">
      <div class="flex items-start gap-2">
        {# Verification badge (#191) — colour matches status. #}
        {% if r.status == 'resolved' %}
          <span class="text-emerald-600 shrink-0" title="resolves cleanly">✓</span>
        {% elif r.status == 'stub' %}
          <span class="text-amber-600 shrink-0" title="ref exists but no body chunks yet (e.g. paper stub awaiting fetch)">?</span>
        {% elif r.status == 'deleted' %}
          <span class="text-slate-400 shrink-0" title="soft-deleted">⊘</span>
        {% else %}
          <span class="text-rose-600 shrink-0" title="reference doesn't resolve">✗</span>
        {% endif %}
        <a href="{{ r.url }}" class="font-mono text-sky-700 hover:underline shrink-0">{{ r.handle }}</a>
        <span class="text-slate-400 shrink-0">·</span>
        {% if r.status == 'missing' %}
        <span class="text-rose-700 italic">{{ r.title }}</span>
        {% elif r.status == 'deleted' %}
        <span class="text-slate-400 italic line-through">{{ r.title }}</span>
        {% elif r.status == 'stub' %}
        <span class="text-amber-700 break-words">{{ r.title }} <span class="text-slate-400">(stub — awaiting fetch)</span></span>
        {% else %}
        <span class="text-slate-700 break-words">{{ r.title }}</span>
        {% endif %}
        <span class="ml-auto text-slate-400 shrink-0">{{ r.kind }}</span>
      </div>
      {% if r.preview %}
      <p class="mt-1 text-slate-600 break-words">{{ r.preview }}</p>
      {% endif %}
    </li>
    {% endfor %}
  </ol>
  <p class="mt-2 text-xs text-slate-400">
    Auto-extracted from this memory's body — inline ``[N]`` markers
    cross-link back to this list.
    Badges: <span class="text-emerald-600">✓</span> resolves ·
    <span class="text-amber-600">?</span> stub awaiting fetch ·
    <span class="text-slate-400">⊘</span> deleted ·
    <span class="text-rose-600">✗</span> dead.
  </p>
</section>
{% endif %}

{% if chunks %}
<section class="mt-6">
  <h2 class="text-sm font-semibold mb-2 text-slate-700">
    Chunks <span class="text-slate-400 font-normal">({{ chunks|length }})</span>
  </h2>
  <ul class="space-y-3">
    {% for c in chunks %}
    <li class="rounded-lg border border-slate-200 bg-white">
      <div class="flex items-baseline gap-2 px-4 py-2 border-b border-slate-100 bg-slate-50/60 rounded-t-lg">
        <span class="text-xs font-mono text-slate-500">~{{ c.pos }}</span>
        <span class="text-xs px-1.5 py-0.5 rounded bg-violet-100 text-violet-700 font-medium">{{ c.chunk_kind }}</span>
        {% if c.slug %}<span class="text-xs font-mono text-slate-400">{{ c.slug }}</span>{% endif %}
      </div>
      <pre class="px-4 py-3 text-sm whitespace-pre-wrap break-words text-slate-800 overflow-x-auto">{{ c.text }}</pre>
      {# Ask scoped to this chunk — the answer thread links back to ~pos. #}
      <form method="post" action="/refs/{{ kind }}/{{ ref.id }}/ask"
            class="flex items-center gap-2 px-4 py-2 border-t border-slate-100">
        <input type="hidden" name="chunk" value="{{ c.pos }}" />
        <input name="question" placeholder="Ask about ~{{ c.pos }}…"
               class="flex-1 text-xs px-2 py-1 rounded border border-slate-300" />
        <button class="text-xs px-2 py-1 rounded bg-sky-600 text-white hover:bg-sky-700">ask</button>
      </form>
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}
{% endblock %}
