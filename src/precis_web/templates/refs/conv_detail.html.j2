{% extends "base.html.j2" %}
{% block title %}{{ ref.title }}{% endblock %}
{% block content %}
<a href="/refs/{{ kind }}" class="text-sm text-slate-500 underline">&larr; {{ kind_label }}</a>
<div class="mt-2 mb-4">
  <h1 class="text-lg font-semibold">{{ ref.title }}</h1>
  <p class="text-sm text-slate-500">
    #{{ ref.id }}
    {% if ref.slug %}· <span class="font-mono break-all">{{ ref.slug }}</span>{% endif %}
    {% if ref.updated %}· updated {{ ref.updated }}{% endif %}
    · {{ turns | length }} turn{{ '' if turns | length == 1 else 's' }}
  </p>
</div>

{% if not turns %}
  <p class="text-sm text-slate-500">No turns recorded for this conversation.</p>
{% else %}
<ol class="space-y-3">
  {% for t in turns %}
  <li id="t{{ t.pos }}" class="rounded-lg border border-slate-200 bg-white p-3">
    <div class="flex items-baseline justify-between gap-2 mb-1 flex-wrap">
      <span class="text-sm font-medium text-slate-800">
        {# Deterministic dot colour per author (computed in the route)
           so a thread is easy to skim. #}
        <span class="inline-block w-2 h-2 rounded-full align-middle mr-1 {{ t.dot }}"></span>
        {{ t.author }}
        {% if t.chunk_kind %}
        <span class="ml-1 text-xs px-1.5 py-0.5 rounded bg-violet-100 text-violet-700 font-normal">{{ t.chunk_kind }}</span>
        {% endif %}
      </span>
      <span class="text-xs text-slate-400 shrink-0">
        {% if t.ts %}{{ t.ts }} · {% endif %}<a href="#t{{ t.pos }}" class="hover:underline">~{{ t.pos }}</a>
      </span>
    </div>
    <div class="text-sm leading-relaxed text-slate-700 whitespace-pre-wrap break-words">{{ t.text }}</div>
    {# Full per-turn meta. Stop reason, token counts, msg_id, and any
       other bridge-stamped fields surface here so the operator sees
       the complete record without leaving the page. #}
    {% if t.extra_meta %}
    <dl class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-xs text-slate-500 pt-2 border-t border-slate-100">
      {% for k, v in t.extra_meta %}
      <div class="flex items-baseline gap-1">
        <dt class="font-mono text-slate-400">{{ k }}</dt>
        <dd class="font-mono text-slate-600 break-all">{{ v }}</dd>
      </div>
      {% endfor %}
    </dl>
    {% endif %}
  </li>
  {% endfor %}
</ol>
{% endif %}
{% endblock %}
