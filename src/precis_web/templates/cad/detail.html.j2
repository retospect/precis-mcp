{% extends "base.html.j2" %}
{% block title %}{{ title }}{% endblock %}
{% block content %}

<div class="mb-4">
  <div class="flex items-center gap-3">
    <a href="/cad" class="text-xs text-slate-400 hover:text-slate-600">← CAD</a>
    <h1 class="text-lg font-semibold">{{ title }}</h1>
    <span class="text-xs text-slate-400">{{ slug }} · {{ n_parts }} part{{ '' if n_parts == 1 else 's' }} · {{ n_nodes }} feature{{ '' if n_nodes == 1 else 's' }}</span>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  {# ── left: 3D viewer ── #}
  <div>
    <div class="flex items-center gap-2 mb-2">
      <h2 class="text-sm font-semibold text-slate-700">Model</h2>
      {% if solid_available %}
      <div class="inline-flex rounded-md border border-slate-300 overflow-hidden text-xs ml-auto">
        <button type="button" data-mode="features" class="cad-mode px-2 py-1 hover:bg-slate-100">Features</button>
        <button type="button" data-mode="solid" class="cad-mode px-2 py-1 hover:bg-slate-100 border-l border-slate-300">Solid</button>
      </div>
      {% else %}
      <span class="text-xs text-slate-400 ml-auto">per-feature view · cuts translucent</span>
      {% endif %}
    </div>
    <div id="mol" class="relative w-full rounded-lg border border-slate-200 bg-white" style="height: 460px;"></div>

    {# per-part legend — hover a chip to glow that part's features #}
    {% if legend %}
    <div class="flex flex-wrap gap-2 mt-2">
      {% for e in legend %}
      <span class="cad-hl inline-flex items-center gap-1 text-[11px] text-slate-500 cursor-pointer rounded px-1 hover:bg-amber-50"
            data-part="{{ e.component }}">
        <span class="inline-block w-3 h-3 rounded-full border border-slate-300" style="background: {{ e.color }};"></span>
        {{ e.component }}<span class="text-slate-400">×{{ e.count }}</span>
      </span>
      {% endfor %}
    </div>
    {% endif %}

    <p class="text-[11px] text-slate-400 mt-1">
      Drag to rotate · scroll to zoom · <b>click a feature</b> for details. Parts are coloured; cut/intersect features are translucent tool volumes.
    </p>

    {# click-detail panel #}
    <div id="cad-detail" class="mt-2 rounded-lg border border-slate-200 bg-slate-50 p-3 text-sm min-h-[64px]">
      <span class="text-slate-400 text-xs">Click a feature in the model to inspect it.</span>
    </div>

    {# feature list — hover a row to glow it in the model #}
    {% if nodes %}
    <details class="mt-2 rounded-lg border border-slate-200 bg-white" open>
      <summary class="cursor-pointer px-3 py-2 text-xs font-semibold text-slate-600">
        Features <span class="font-normal text-slate-400">— {{ n_nodes }}</span>
      </summary>
      <div class="px-3 pb-2 max-h-52 overflow-y-auto space-y-0.5">
        {% for n in nodes %}
        <div class="cad-hl flex items-center gap-2 text-xs rounded px-1 py-0.5 cursor-pointer hover:bg-amber-50"
             data-node="{{ n.name }}">
          <span class="inline-block w-2.5 h-2.5 rounded-full border border-slate-300 shrink-0" style="background: {{ n.color }};"></span>
          <code class="text-slate-600 w-24 shrink-0 truncate">{{ n.name }}</code>
          <span class="text-[10px] px-1 rounded
            {%- if n.op == 'cut' %} bg-red-100 text-red-700
            {%- elif n.op == 'intersect' %} bg-purple-100 text-purple-700
            {%- else %} bg-emerald-100 text-emerald-700{% endif %}">{{ n.op }}</span>
          <code class="text-slate-500 truncate">{{ n.config }}</code>
          <span class="ml-auto text-slate-400 truncate">{{ n.pose }}</span>
        </div>
        {% endfor %}
      </div>
    </details>
    {% endif %}
  </div>

  {# ── right: analysis / export panel ── #}
  <div>
    <h2 class="text-sm font-semibold text-slate-700 mb-2">Analysis &amp; export
      <span class="text-xs font-normal text-slate-400">— measured off the analytic IR</span>
    </h2>

    <div class="rounded-lg border border-slate-200 bg-white p-3 space-y-2">
      <div class="grid grid-cols-2 gap-2 text-sm">
        <div>
          <div class="text-[10px] text-slate-400 uppercase tracking-wide">Bounding box (mm)</div>
          <div id="an-bbox" class="tabular-nums text-slate-400">computing…</div>
        </div>
        <div>
          <div class="text-[10px] text-slate-400 uppercase tracking-wide">Volume (mm³)</div>
          <div id="an-volume" class="tabular-nums text-slate-400">computing…</div>
        </div>
      </div>

      <div id="an-warnings" data-slug="{{ slug }}"></div>

      <div id="an-connect" class="text-[11px]"></div>

      <div class="pt-2 border-t border-slate-100">
        <div class="text-[10px] text-slate-400 uppercase tracking-wide mb-1">Download</div>
        <div class="flex flex-wrap gap-1.5">
          <a href="/cad/{{ slug }}/model.gltf" download="{{ slug }}.glb"
             class="rounded border border-slate-300 px-2 py-1 text-xs hover:bg-slate-50">glTF</a>
          <a href="/cad/{{ slug }}/export.scad"
             class="rounded border border-slate-300 px-2 py-1 text-xs hover:bg-slate-50">OpenSCAD</a>
          {% if manifold_available %}
          <a href="/cad/{{ slug }}/export.stl"
             class="rounded border border-slate-300 px-2 py-1 text-xs hover:bg-slate-50">STL</a>
          <a href="/cad/{{ slug }}/export.3mf"
             class="rounded border border-slate-300 px-2 py-1 text-xs hover:bg-slate-50">3MF</a>
          {% else %}
          <span class="rounded border border-dashed border-slate-200 px-2 py-1 text-xs text-slate-300" title="needs the [cad-export] extra">STL/3MF</span>
          {% endif %}
          {% if step_available %}
          <a href="/cad/{{ slug }}/export.step"
             class="rounded border border-slate-300 px-2 py-1 text-xs hover:bg-slate-50">STEP</a>
          {% else %}
          <span class="rounded border border-dashed border-slate-200 px-2 py-1 text-xs text-slate-300" title="needs the [cad-step] extra">STEP</span>
          {% endif %}
        </div>
        <p class="text-[10px] text-slate-400 mt-1">STEP is the exact B-rep (parametric/manufacturing grade); STL/3MF are the folded mesh; glTF is the view.</p>
      </div>
    </div>
  </div>
</div>

{# ── lineage ── #}
{% if lineage.parents or lineage.children %}
<div class="mt-4 text-xs text-slate-500 flex flex-wrap items-center gap-4">
  {% if lineage.parents %}<span>Derived from:
    {% for p in lineage.parents %}<a class="text-emerald-700 hover:underline" href="/cad/{{ p.slug }}">{{ p.slug }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
  </span>{% endif %}
  {% if lineage.children %}<span>Derived designs:
    {% for c in lineage.children %}<a class="text-emerald-700 hover:underline" href="/cad/{{ c.slug }}">{{ c.slug }}</a>{% if not loop.last %}, {% endif %}{% endfor %}
  </span>{% endif %}
</div>
{% endif %}

{# ── further instructions → LLM proposal ── #}
<div id="instruct" class="mt-6">
  <h2 class="text-sm font-semibold text-slate-700 mb-2">Further instructions
    <span class="text-xs font-normal text-slate-400">— an LLM proposes a rewrite; you review &amp; apply to a new design</span>
  </h2>
  <form method="post" action="/cad/{{ slug }}/instruct" class="flex gap-2">
    <input name="instruction" required autocomplete="off"
           placeholder="e.g. add a 6-bolt pattern on a 40mm circle, then widen the plate to r30"
           class="flex-1 rounded border border-slate-300 px-2 py-1 text-sm">
    <button class="rounded bg-slate-700 text-white text-sm px-3 py-1 hover:bg-slate-800 whitespace-nowrap">Propose ▸</button>
  </form>
  <div id="cad-proposal" class="mt-3 space-y-3" data-slug="{{ slug }}">
    <span class="text-xs text-slate-400">No proposal yet — type an instruction above.</span>
  </div>
  {# server-rendered seed so a reload rehydrates outstanding requests instantly #}
  <script type="application/json" id="cad-proposal-init">{{ (proposals or []) | tojson }}</script>
</div>

{% endblock %}

{% block scripts %}
<script type="importmap">
{"imports": {
  "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
  "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
}}
</script>
<script type="module">
import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
import { nodeMesh } from '/static/cad-tessellate.js';

const SLUG = {{ slug | tojson }};
const NODES = {{ nodes | tojson }};
const nodeByName = {};
NODES.forEach((n) => { nodeByName[n.name] = n; });

const el = document.getElementById('mol');
const detail = document.getElementById('cad-detail');
const esc = (s) => String(s == null ? '' : s)
  .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const scene = new THREE.Scene();
scene.background = new THREE.Color(0xffffff);
const camera = new THREE.PerspectiveCamera(45, el.clientWidth / el.clientHeight, 0.1, 100000);
const renderer = new THREE.WebGLRenderer({ antialias: true });
renderer.setPixelRatio(window.devicePixelRatio);
renderer.setSize(el.clientWidth, el.clientHeight);
el.appendChild(renderer.domElement);

scene.add(new THREE.AmbientLight(0xffffff, 0.7));
const key = new THREE.DirectionalLight(0xffffff, 0.9); key.position.set(1, 2, 1.5); scene.add(key);
const fill = new THREE.DirectionalLight(0xffffff, 0.4); fill.position.set(-1, -0.5, -1); scene.add(fill);
scene.add(new THREE.AxesHelper(5));

const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;

const meshesByName = {};   // node name -> [meshes]
let modelRoot = null;

function clearModel() {
  if (modelRoot) { scene.remove(modelRoot); modelRoot = null; }
  for (const k in meshesByName) delete meshesByName[k];
}

function fitCamera(root) {
  const box = new THREE.Box3().setFromObject(root);
  const size = box.getSize(new THREE.Vector3());
  const center = box.getCenter(new THREE.Vector3());
  const maxDim = Math.max(size.x, size.y, size.z) || 1;
  const dist = maxDim / (2 * Math.tan((Math.PI * camera.fov) / 360));
  camera.position.copy(center).add(new THREE.Vector3(dist * 1.1, dist * 0.8, dist * 1.4));
  camera.near = maxDim / 100; camera.far = maxDim * 100; camera.updateProjectionMatrix();
  controls.target.copy(center);
  controls.update();
}

// z-up (IR) → y-up (three.js): (x, y, z) → (x, z, -y). Matches gltf._ZUP_TO_YUP
// so the client build sits in the same frame the server glTF would.
function registerMesh(mesh, name) {
  mesh.name = name;
  mesh.material.emissive = mesh.material.emissive || new THREE.Color(0);
  mesh.userData.emissive = mesh.material.emissive.clone();
  (meshesByName[name] = meshesByName[name] || []).push(mesh);
}

// ── features mode: tessellate the recipe client-side (the "3D-SVG" path) ──
function buildFeatures() {
  fetch('/cad/' + encodeURIComponent(SLUG) + '/scene.json')
    .then((r) => r.json())
    .then((data) => {
      clearModel();
      modelRoot = new THREE.Group();
      const colorFor = {};
      (data.nodes || []).forEach((n) => { colorFor[n.name] = n.color; });
      (data.nodes || []).forEach((node) => {
        const m = nodeMesh(node);              // world-space {verts, tris} (z-up)
        if (!m || !m.verts.length) return;     // chamfer / empty — nothing to draw
        const pos = new Float32Array(m.verts.length * 3);
        m.verts.forEach((v, i) => {            // z-up → y-up
          pos[i * 3] = v[0]; pos[i * 3 + 1] = v[2]; pos[i * 3 + 2] = -v[1];
        });
        const idx = new Uint32Array(m.tris.length * 3);
        m.tris.forEach((t, i) => { idx[i * 3] = t[0]; idx[i * 3 + 1] = t[1]; idx[i * 3 + 2] = t[2]; });
        const geom = new THREE.BufferGeometry();
        geom.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        geom.setIndex(new THREE.BufferAttribute(idx, 1));
        geom.computeVertexNormals();
        const translucent = node.op === 'cut' || node.op === 'intersect';
        const material = new THREE.MeshStandardMaterial({
          color: new THREE.Color(node.color || '#8a9bb0'),
          metalness: 0.1, roughness: 0.6, flatShading: false,
          transparent: translucent, opacity: translucent ? 0.32 : 1.0,
          side: THREE.DoubleSide,
        });
        const mesh = new THREE.Mesh(geom, material);
        registerMesh(mesh, node.name);
        modelRoot.add(mesh);
      });
      scene.add(modelRoot);
      fitCamera(modelRoot);
    })
    .catch((err) => { console.warn('cad scene build failed', err); });
}

// ── solid mode: the true CSG fold needs the server kernel (manifold3d) ──
const loader = new GLTFLoader();
function loadSolid() {
  loader.load(
    '/cad/' + encodeURIComponent(SLUG) + '/model.gltf?mode=solid',
    (gltf) => {
      clearModel();
      modelRoot = gltf.scene;
      modelRoot.traverse((o) => {
        if (o.isMesh) { o.material = o.material.clone(); registerMesh(o, o.name); }
      });
      scene.add(modelRoot);
      fitCamera(modelRoot);
    },
    undefined,
    (err) => { console.warn('cad gltf load failed', err); }
  );
}

function setMode(mode) {
  if (mode === 'solid') loadSolid(); else buildFeatures();
  document.querySelectorAll('.cad-mode').forEach((btn) => {
    const on = btn.getAttribute('data-mode') === mode;
    btn.classList.toggle('bg-slate-700', on);
    btn.classList.toggle('text-white', on);
  });
}

// ── highlight primitive (shared by legend chips + feature rows) ──
let glowing = [];
function clearGlow() {
  glowing.forEach((m) => { if (m.userData.emissive) m.material.emissive.copy(m.userData.emissive); });
  glowing = [];
}
function glow(names) {
  clearGlow();
  names.forEach((name) => (meshesByName[name] || []).forEach((m) => {
    m.material.emissive = new THREE.Color(0xf59e0b);
    m.material.emissiveIntensity = 0.6;
    glowing.push(m);
  }));
}
function namesForPart(part) { return NODES.filter((n) => n.component === part).map((n) => n.name); }

document.addEventListener('mouseover', (ev) => {
  const t = ev.target.closest('[data-node],[data-part]');
  if (!t) return;
  if (t.hasAttribute('data-node')) glow([t.getAttribute('data-node')]);
  else glow(namesForPart(t.getAttribute('data-part')));
});
document.addEventListener('mouseout', (ev) => {
  if (ev.target.closest('[data-node],[data-part]')) clearGlow();
});

// ── click → detail ──
const ray = new THREE.Raycaster();
const ptr = new THREE.Vector2();
renderer.domElement.addEventListener('click', (ev) => {
  const rect = renderer.domElement.getBoundingClientRect();
  ptr.x = ((ev.clientX - rect.left) / rect.width) * 2 - 1;
  ptr.y = -((ev.clientY - rect.top) / rect.height) * 2 + 1;
  ray.setFromCamera(ptr, camera);
  const hits = modelRoot ? ray.intersectObjects(modelRoot.children, true) : [];
  if (!hits.length) return;
  showNode(hits[0].object.name);
});

function row(k, v) {
  return '<div class="flex gap-2"><span class="text-slate-400 w-24 shrink-0">' + k +
         '</span><span class="font-medium text-slate-700">' + v + '</span></div>';
}
function showNode(name) {
  const n = nodeByName[name];
  if (!n) return;
  detail.innerHTML =
    '<div class="flex items-center gap-2 mb-1.5">' +
    '<span class="inline-block w-3.5 h-3.5 rounded-full border border-slate-300" style="background:' + esc(n.color) + ';"></span>' +
    '<code class="font-semibold text-slate-800">' + esc(n.name) + '</code>' +
    '<span class="ml-auto text-[10px] uppercase tracking-wide text-slate-400">feature</span></div>' +
    '<div class="grid grid-cols-1 gap-0.5 text-xs">' +
    row('part', esc(n.component)) + row('op', esc(n.op)) +
    row('config', esc(n.config)) + row('pose', esc(n.pose)) + '</div>';
}

document.querySelectorAll('.cad-mode').forEach((btn) => {
  btn.addEventListener('click', () => setMode(btn.getAttribute('data-mode')));
});

window.addEventListener('resize', () => {
  camera.aspect = el.clientWidth / el.clientHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(el.clientWidth, el.clientHeight);
});

(function animate() {
  requestAnimationFrame(animate);
  controls.update();
  renderer.render(scene, camera);
})();

setMode('features');
</script>

<script>
// ── analysis panel (fetched after first paint; volume/interference are heavier) ──
(function () {
  const warnEl = document.getElementById('an-warnings');
  const bboxEl = document.getElementById('an-bbox');
  const volEl = document.getElementById('an-volume');
  const connEl = document.getElementById('an-connect');
  if (!warnEl) return;
  const slug = warnEl.getAttribute('data-slug');
  const esc = (s) => String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  fetch('/cad/' + encodeURIComponent(slug) + '/analysis')
    .then((r) => r.json())
    .then((a) => {
      if (a && a.bbox) {
        bboxEl.textContent = a.bbox.map((x) => +x).join(' × ');
        bboxEl.classList.remove('text-slate-400');
      } else { bboxEl.textContent = '—'; }
      if (a && a.volume != null) {
        volEl.innerHTML = esc(a.volume) +
          '<span class="text-[10px] text-slate-400"> ±' + esc(a.volume_err) + '%</span>';
        volEl.classList.remove('text-slate-400');
      } else { volEl.textContent = '—'; }
      const warns = (a && a.warnings) || [];
      if (warns.length) {
        warnEl.className = 'space-y-1';
        warnEl.innerHTML = warns.map((w) =>
          '<div class="text-[11px] px-2 py-1 rounded bg-amber-50 text-amber-800 border border-amber-200">⚠ '
          + esc(w) + '</div>').join('');
      } else {
        warnEl.className = 'text-[11px] text-emerald-700';
        warnEl.textContent = '✓ no inter-part interference';
      }
      // connectivity — is the assembly one connected solid?
      const c = a && a.connectivity;
      if (connEl && c) {
        if (c.connected) {
          connEl.className = 'text-[11px] text-emerald-700';
          connEl.textContent = '✓ one connected solid (' + c.groups[0].length + ' parts touching)';
        } else {
          const bodies = (c.groups || []).map((g) => g.join('+')).join(' | ');
          connEl.className = 'text-[11px] px-2 py-1 rounded bg-amber-50 text-amber-800 border border-amber-200';
          connEl.innerHTML = '⚠ ' + (c.groups || []).length + ' disconnected bodies: ' + esc(bodies);
        }
      } else if (connEl) { connEl.textContent = ''; }
    })
    .catch(() => {
      bboxEl.textContent = '—'; volEl.textContent = '—';
      warnEl.className = 'text-[11px] text-slate-400';
      warnEl.textContent = 'analysis unavailable';
    });
})();
</script>

<script>
// ── proposal polling + review (list-aware: every outstanding request) ──
(function () {
  const box = document.getElementById('cad-proposal');
  if (!box) return;
  const slug = box.getAttribute('data-slug');
  const esc = (s) => String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  const inFlight = (d) => d && (d.status === 'queued' || d.status === 'running');

  // One card per proposal job.
  function card(d) {
    const instr = d.instruction
      ? '<div class="text-[11px] text-slate-500 mb-1 truncate" title="' + esc(d.instruction) + '">“' + esc(d.instruction) + '”</div>'
      : '';
    const meta = '<span class="ml-auto text-[10px] text-slate-400">job r' + esc(d.job_id) + ' · ' + esc(d.created) + '</span>';
    if (inFlight(d)) {
      return '<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">'
        + '<div class="flex items-center gap-2 mb-1"><span class="text-xs text-slate-500">⟳ proposing… (' + esc(d.status) + ')</span>' + meta + '</div>'
        + instr + '</div>';
    }
    const p = d.proposal;
    if (!p) {
      return '<div class="rounded-lg border border-red-200 bg-red-50 p-3">'
        + '<div class="flex items-center gap-2 mb-1"><span class="text-xs text-red-600">proposal ' + esc(d.status) + ' — see the job log</span>' + meta + '</div>'
        + instr + '</div>';
    }
    const badge = p.valid
      ? '<span class="text-[10px] px-1.5 py-0.5 rounded-full bg-emerald-100 text-emerald-800">valid</span>'
      : '<span class="text-[10px] px-1.5 py-0.5 rounded-full bg-red-100 text-red-800">invalid: ' + esc(p.error || '') + '</span>';
    const apply = p.valid
      ? '<form method="post" action="/cad/' + encodeURIComponent(slug) + '/apply" class="mt-2 space-y-2">'
        + '<input type="hidden" name="job_id" value="' + esc(d.job_id) + '">'
        + '<div class="flex gap-2">'
        + '<input name="to" required autocomplete="off" value="' + esc(slug) + '-v2" '
        + 'class="flex-1 rounded border border-slate-300 px-2 py-1 text-xs" placeholder="new design slug">'
        + '<button class="rounded bg-emerald-600 text-white text-xs px-3 py-1 hover:bg-emerald-700 whitespace-nowrap">Apply → new design</button>'
        + '</div>'
        + '<label class="flex items-center gap-1.5 text-[11px] text-slate-500">'
        + '<input type="checkbox" name="delete_original" value="1"> soft-delete this design after applying</label>'
        + '</form>'
      : '';
    return '<div class="rounded-lg border border-slate-200 bg-slate-50 p-3">'
      + '<div class="flex items-center gap-2 mb-1"><span class="text-xs font-semibold text-slate-700">Proposed rewrite</span>' + badge + meta + '</div>'
      + instr
      + (p.rationale ? '<p class="text-xs text-slate-500 mb-2">' + esc(p.rationale) + '</p>' : '')
      + '<pre class="text-[11px] font-mono bg-white border border-slate-200 rounded p-2 overflow-x-auto max-h-60">' + esc(p.source || '') + '</pre>'
      + apply
      + '</div>';
  }

  function render(items) {
    if (!items || !items.length) {
      box.innerHTML = '<span class="text-xs text-slate-400">No proposal yet — type an instruction above.</span>';
      return;
    }
    box.innerHTML = items.map(card).join('');
  }

  function poll() {
    fetch('/cad/' + encodeURIComponent(slug) + '/proposals')
      .then((r) => r.json())
      .then((o) => {
        const items = (o && o.proposals) || [];
        render(items);
        if (items.some(inFlight)) setTimeout(poll, 2500);
      })
      .catch(() => {});
  }

  // Paint the server-rendered seed immediately, then poll for updates.
  try {
    const seed = JSON.parse(document.getElementById('cad-proposal-init').textContent);
    if (seed && seed.length) render(seed);
  } catch (e) { /* ignore */ }
  poll();
})();
</script>
