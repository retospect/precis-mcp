{# Compact popover fragment for the inline kind:ref hover preview.
   Loaded via htmx into a sibling span; see linkify.py for the wrapping
   anchor + popover slot markup. #}
<div class="space-y-1">
  <div class="flex items-center gap-2 text-xs">
    <span class="font-mono px-1.5 py-0.5 rounded bg-slate-100 text-slate-700">{{ kind }}</span>
    {% if not missing and ref_id %}
    <span class="text-slate-400">#{{ ref_id }}</span>
    {% endif %}
    {% if not missing and deleted %}
    <span class="text-rose-500">deleted</span>
    {% endif %}
  </div>
  {% if missing %}
  <p class="text-xs text-slate-500 italic">no such {{ label }}</p>
  {% else %}
  {% if title %}<p class="text-sm font-medium text-slate-800 truncate">{{ title }}</p>{% endif %}
  {% if byline %}<p class="text-[11px] text-slate-500 truncate">{{ byline }}</p>{% endif %}
  {% if quote %}
  {# The cited chunk's verbatim quote (≤ ~20 lines) — the "what does it
     actually say?" answer for a citation hover. #}
  {% if chunk_label %}<p class="text-[10px] font-mono text-slate-400">{{ chunk_label }}</p>{% endif %}
  {# render_markdown: bold/code/sub/sup (no ref-linking). Math ($…$) is
     rendered client-side by KaTeX after the htmx swap (see detail page).
     NB: a <div> (not <pre>) — KaTeX auto-render's default ignoredTags
     skips <pre>/<code>/<textarea>, so math inside a <pre> stays literal
     ($2^4$ never renders). whitespace-pre-wrap keeps the verbatim quote. #}
  <div class="text-xs text-slate-700 whitespace-pre-wrap break-words font-sans">{{ quote | render_markdown }}</div>
  {% elif body_preview %}
  <p class="text-xs text-slate-600 break-words">{{ body_preview }}</p>
  {% endif %}
  {# ADR 0052 manufacturing-part rows — a term leaf's attribute bag. Each is
     optional; a patent part / glossary term (empty bag) shows none. Guarded
     with `is defined` so the other routes rendering this template are safe. #}
  {% if callout is defined and callout is not none %}
  <p class="text-[11px] text-slate-500">callout <span class="font-mono text-slate-700">{{ callout }}</span></p>
  {% endif %}
  {% if mpn is defined and mpn %}
  <p class="text-[11px] text-slate-500">MPN <span class="font-mono text-slate-700">{{ mpn }}</span></p>
  {% endif %}
  {% if manufacturer is defined and manufacturer %}
  <p class="text-[11px] text-slate-500">{{ manufacturer }}</p>
  {% endif %}
  {% if datasheet_url is defined and datasheet_url %}
  <p class="text-xs"><a class="text-sky-700 underline decoration-dotted" href="{{ datasheet_url }}" target="_blank" rel="noopener nofollow">datasheet ↗</a></p>
  {% endif %}
  <p class="text-xs text-sky-700">click to open →</p>
  {% endif %}
</div>
