{% extends "base.html.j2" %}
{% block title %}Budget{% endblock %}
{% block content %}
<h1 class="text-lg font-semibold mb-1">Budget</h1>
<p class="text-sm text-slate-500 mb-5 max-w-2xl">
  Two rails, by what a call actually spends. <strong>Real dollars</strong> —
  OpenRouter/OSS LLMs and paid fetches — meter against the caps below. The
  <strong>claude subscription</strong> (the <code>claude -p</code> OAuth lane)
  spends rate-limit <em>quota</em>, not money, so it is gated on the quota
  snapshot, not a dollar figure. Only free local work is never gated; everything
  auto-clears as its window rolls off.
</p>

{% if resume_active %}
<div class="mb-5 rounded-lg border border-amber-200 bg-amber-50 px-4 py-2 text-sm text-amber-800 flex items-center justify-between gap-3">
  <span>Resume override <strong>active</strong> until
    {{ resume_until.strftime('%H:%M UTC') if resume_until else '—' }} — soft trips
    are bypassed (a hard Anthropic rejection still fails).</span>
  <form method="post" action="/budget/resume/clear">
    <button class="text-xs text-amber-700 underline hover:text-rose-600">cancel</button>
  </form>
</div>
{% endif %}

{% if budget.get('tripped') %}
<div class="mb-5 rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-700">
  A dollar cap is reached — paid work (real-money transports) is paused until spend rolls off the window.
</div>
{% endif %}

{% if quota and quota.paused %}
<div class="mb-5 rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-700">
  {{ quota.pause_reason }}
</div>
{% endif %}

{% if budget.get('windows') %}
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  {% for w in budget.windows %}
  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <div class="flex items-baseline justify-between">
      <div class="text-xs uppercase tracking-wide text-slate-400">{{ w.label }}</div>
      <div class="text-sm text-slate-500">
        <span class="font-semibold text-slate-700">${{ '%.2f'|format(w.spent) }}</span>
        / ${{ '%.2f'|format(w.cap) }}
      </div>
    </div>
    <div class="mt-2 h-2 w-full rounded-full bg-slate-100 overflow-hidden">
      <div class="h-2 rounded-full
        {% if w.state == 'red' %}bg-rose-500{% elif w.state == 'amber' %}bg-amber-500{% else %}bg-emerald-500{% endif %}"
        style="width: {{ w.pct }}%"></div>
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<p class="text-sm text-slate-500 mb-6">
  No spend meter available — the budget module needs a store bound (it's dark by
  construction). Caps below still persist for when it is.
</p>
{% endif %}

<div class="rounded-lg border border-slate-200 bg-white p-4 max-w-2xl mb-6">
  <div class="flex items-baseline justify-between mb-3">
    <div class="text-xs uppercase tracking-wide text-slate-400">Claude subscription (OAuth quota)</div>
    <div class="text-[11px] text-slate-400">
      {% if quota and quota.ts %}snapshot {{ quota.ts.strftime('%m-%d %H:%M UTC') }}{% else %}no snapshot{% endif %}
    </div>
  </div>
  {% if quota and quota.windows %}
  <ul class="text-sm divide-y divide-slate-100">
    {% for w in quota.windows %}
    <li class="py-1 flex items-center justify-between gap-2">
      <span class="font-mono text-slate-600">{{ w.name }}</span>
      <span class="flex items-center gap-2 shrink-0">
        {% if w.used is not none %}<span class="text-slate-500">{{ '%.0f'|format(w.used) }}%</span>{% endif %}
        <span class="rounded px-1.5 py-0.5 text-[11px]
          {% if w.status in ('allowed','allowed_warning','ok') %}bg-emerald-50 text-emerald-700
          {% elif w.status in ('rejected','blocked','exhausted') %}bg-rose-50 text-rose-700
          {% else %}bg-slate-100 text-slate-500{% endif %}">{{ w.status }}</span>
        {% if w.resets_at %}<span class="text-[11px] text-slate-400">resets {{ w.resets_at[11:16] }}Z</span>{% endif %}
      </span>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="text-sm text-slate-400">No quota snapshot yet — the <code>quota_check</code> pass writes one on the agent worker.</p>
  {% endif %}
  <div class="flex items-center gap-2 pt-3 mt-2 border-t border-slate-100">
    <form method="post" action="/budget/resume" class="flex items-center gap-2">
      <button type="submit"
              class="rounded bg-amber-600 text-white text-xs px-3 py-1 hover:bg-amber-700 transition">
        Resume paid work now
      </button>
      <input type="number" step="0.5" min="0.25" name="hours" placeholder="{{ 5 }}"
             class="w-16 rounded border border-slate-200 px-2 py-1 text-xs font-mono
                    focus:border-amber-400 focus:outline-none" />
      <span class="text-[11px] text-slate-400">hours (default 5)</span>
    </form>
  </div>
  <p class="text-[11px] text-slate-400 mt-2">
    Lifts a <em>soft</em> pause (dollar cap or a <code>used_percentage</code> ceiling) so the
    factory resumes without waiting for the window. A genuine Anthropic rate-limit rejection
    can't be overridden — those calls will 429 until the window resets.
  </p>
</div>

<div class="rounded-lg border border-slate-200 bg-white p-4 max-w-lg mb-6">
  <div class="text-xs uppercase tracking-wide text-slate-400 mb-3">Caps (real-money transports)</div>
  <form method="post" action="/budget/set" class="space-y-3">
    <div class="flex items-center gap-3">
      <label class="w-28 text-sm text-slate-600">Hourly ($)</label>
      <input type="number" step="0.01" min="0" name="hourly_usd"
             value="{% if hourly_cap is not none %}{{ '%.2f'|format(hourly_cap) }}{% endif %}"
             class="flex-1 rounded border border-slate-200 px-2 py-1 text-sm font-mono
                    focus:border-sky-400 focus:outline-none" />
      <span class="text-[10px] {% if hourly_custom %}text-sky-500{% else %}text-slate-300{% endif %} w-16">
        {{ 'custom' if hourly_custom else 'env default' }}
      </span>
    </div>
    <div class="flex items-center gap-3">
      <label class="w-28 text-sm text-slate-600">24h ($)</label>
      <input type="number" step="0.01" min="0" name="daily_usd"
             value="{% if daily_cap is not none %}{{ '%.2f'|format(daily_cap) }}{% endif %}"
             class="flex-1 rounded border border-slate-200 px-2 py-1 text-sm font-mono
                    focus:border-sky-400 focus:outline-none" />
      <span class="text-[10px] {% if daily_custom %}text-sky-500{% else %}text-slate-300{% endif %} w-16">
        {{ 'custom' if daily_custom else 'env default' }}
      </span>
    </div>
    <div class="flex items-center gap-2 pt-1">
      <button type="submit"
              class="rounded bg-sky-600 text-white text-xs px-3 py-1 hover:bg-sky-700 transition">Save caps</button>
      {% if hourly_custom %}
      <button type="submit" formaction="/budget/reset" name="key" value="budget.hourly_usd"
              class="text-xs text-slate-400 hover:text-rose-600 transition">reset hourly</button>
      {% endif %}
      {% if daily_custom %}
      <button type="submit" formaction="/budget/reset" name="key" value="budget.daily_usd"
              class="text-xs text-slate-400 hover:text-rose-600 transition">reset 24h</button>
      {% endif %}
    </div>
  </form>
  <p class="text-[11px] text-slate-400 mt-3">
    A saved value overrides the <code>PRECIS_BUDGET_*</code> env default in the DB;
    reset reverts to it.
  </p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <div class="text-xs uppercase tracking-wide text-slate-400 mb-1">By model (24h)</div>
    <ul class="text-sm divide-y divide-slate-100">
      {% for m in budget.get('by_model', []) %}
      <li class="py-1 flex justify-between gap-2">
        <span class="font-mono text-slate-600 truncate">{{ m.label }}</span>
        <span class="text-slate-500 shrink-0">{{ m.calls }} · ${{ '%.4f'|format(m.cost) }}</span>
      </li>
      {% else %}
      <li class="py-1 text-slate-400">no priced calls in the last 24h</li>
      {% endfor %}
    </ul>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <div class="text-xs uppercase tracking-wide text-slate-400 mb-1">By source (24h)</div>
    <ul class="text-sm divide-y divide-slate-100">
      {% for s in budget.get('by_source', []) %}
      <li class="py-1 flex justify-between gap-2">
        <span class="font-mono text-slate-600 truncate">{{ s.label }}</span>
        <span class="text-slate-500 shrink-0">{{ s.calls }} · ${{ '%.4f'|format(s.cost) }}</span>
      </li>
      {% else %}
      <li class="py-1 text-slate-400">no priced spend in the last 24h</li>
      {% endfor %}
    </ul>
  </div>
</div>
{% endblock %}
