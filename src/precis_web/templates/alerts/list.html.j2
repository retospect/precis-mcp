{% extends "base.html.j2" %}
{% block title %}Alerts{% endblock %}
{% block content %}

{% set sev_badge = {
  'critical': 'bg-red-100 text-red-800 border-red-300',
  'warn': 'bg-amber-100 text-amber-800 border-amber-300',
  'info': 'bg-sky-100 text-sky-800 border-sky-300'
} %}

<div class="flex items-center gap-3 mb-4">
  <h1 class="text-lg font-semibold">Alerts</h1>
  {# open vs resolved history toggle #}
  <div class="inline-flex rounded-md border border-slate-300 overflow-hidden text-sm">
    <a href="/alerts"
       class="px-3 py-1 {% if state == 'open' %}bg-emerald-600 text-white{% else %}bg-white text-slate-600 hover:bg-slate-50{% endif %}">
      open
    </a>
    <a href="/alerts?state=resolved"
       class="px-3 py-1 {% if state == 'resolved' %}bg-emerald-600 text-white{% else %}bg-white text-slate-600 hover:bg-slate-50{% endif %}">
      resolved
    </a>
  </div>
  <span class="text-sm text-slate-500">{{ total }} {{ state }}</span>
</div>

{% if not groups %}
  {% if state == 'open' %}
  <div class="rounded-md border border-emerald-300 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
    ✓ All clear — no open alerts. Background passes (nursery &amp; friends)
    raise alerts here when they detect spin loops, orphaned todos, stalled
    recurrings, stale claims and the like.
  </div>
  {% else %}
  <p class="text-sm text-slate-500">No resolved alerts in the recent history.</p>
  {% endif %}
{% endif %}

{% for g in groups %}
<section class="mb-5">
  <h2 class="text-sm font-semibold text-slate-700 mb-2 flex items-center gap-2">
    <span class="font-mono">{{ g.source }}</span>
    <span class="text-slate-400 font-normal">{{ g.count }}</span>
  </h2>
  <div class="overflow-hidden rounded-md border border-slate-200">
    <table class="w-full text-sm">
      <tbody>
        {% for a in g.alerts %}
        <tr class="border-t border-slate-100 first:border-t-0 align-top">
          <td class="px-3 py-2 w-20">
            <span class="inline-block rounded border px-1.5 py-0.5 text-[11px] font-medium uppercase {{ sev_badge.get(a.severity, sev_badge['warn']) }}">
              {{ a.severity }}
            </span>
          </td>
          <td class="px-3 py-2">
            <div class="font-medium text-slate-800">
              <a href="/refs/alert/{{ a.ref_id }}" class="hover:underline">{{ a.title }}</a>
            </div>
            {% if a.detail %}
            <div class="text-slate-500 mt-0.5">{{ a.detail }}</div>
            {% endif %}
            <div class="text-[12px] text-slate-400 mt-1 flex flex-wrap gap-x-3 gap-y-0.5">
              {% if a.subject_ref_id is not none %}
              <span>
                subject:
                {% if a.subject_kind %}
                <a href="/refs/{{ a.subject_kind }}/{{ a.subject_ref_id }}"
                   class="text-sky-700 hover:underline font-mono">{{ a.subject_kind }}#{{ a.subject_ref_id }}</a>
                {% else %}
                <span class="font-mono">#{{ a.subject_ref_id }}</span>
                {% endif %}
              </span>
              {% endif %}
              {% if a.seen_count > 1 %}<span>seen {{ a.seen_count }}×</span>{% endif %}
              <span>first {{ a.first_seen }}</span>
              <span>last {{ a.last_seen }}</span>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endfor %}

{% endblock %}
