{# One document block as a 3-column grid row (ADR 0033 web Tier-A).
   content | meta (refs + in-flight) | change box. Collapse is driven by
   the parent `draftDoc` Alpine component via `vis(ancestors)`; heading
   rows carry data-heading so collapse-all can find them. #}
{% macro draft_row(r, ref) %}
<div id="c-{{ r.handle }}"
     {% if r.is_heading %}data-heading="{{ r.handle }}"{% endif %}
     data-anc='{{ r.ancestors | tojson }}'
     class="dr-block grid grid-cols-1 lg:grid-cols-[1fr_20%_22%] gap-3 py-1.5 border-b border-slate-100 scroll-mt-4 group">
  {# ── Col A: content ─────────────────────────────────────────── #
     `raw` (click-to-pin) shows the chunk's verbatim source — the
     markdown + ¶/§ markers behind the rendered view, for debugging. #}
  <div data-content style="padding-left: {{ r.depth }}rem" x-data="{ raw: false }">
    {% if r.is_heading %}
    {# items-baseline so the toggle caret + the small style/review/prompt
       controls sit on the heading's text baseline rather than floating at
       the top of the taller heading line (the alignment that looked off). #}
    <div class="flex items-baseline gap-1.5">
      <button data-toggle="{{ r.handle }}"
              class="dr-toggle font-mono text-xs text-slate-400 hover:text-slate-700 select-none">▾</button>
      <h3 class="min-w-0 break-words font-semibold text-slate-900
                 {% if r.depth == 0 %}text-lg{% elif r.depth == 1 %}text-base{% else %}text-sm{% endif %}">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</h3>
      {# style / review / prompt stay one nowrap cluster pinned top-right;
         min-w-0 on the heading lets it shrink/wrap rather than push these
         onto a second line. #}
      <div class="ml-auto flex shrink-0 flex-nowrap items-baseline gap-2 whitespace-nowrap">
      {# Section style (ADR 0037): set this heading's meta.style. The genre's
         styles, scoped via the draft's doc_type; the scaffold normally sets
         these — this is the manual override. #}
      {% if r.section_styles %}
      <div class="relative shrink-0" x-data="{ sty: false }" @click.outside="sty = false">
        <button @click="sty = !sty"
                class="text-[10px] {% if r.style %}text-sky-600{% else %}text-slate-300 group-hover:text-slate-500{% endif %} hover:text-sky-600">style{% if r.style %}: {{ r.style }}{% endif %} ▾</button>
        <div x-show="sty" x-cloak
             class="absolute right-0 z-30 mt-1 w-44 rounded border border-slate-200 bg-white shadow-lg text-xs">
          {% for slug, label in r.section_styles %}
          <form method="post" action="/drafts/{{ ref.ident }}/style">
            <input type="hidden" name="handle" value="{{ r.handle }}" />
            <input type="hidden" name="style" value="{{ slug }}" />
            <button class="block w-full px-2 py-1 text-left hover:bg-slate-100 {% if r.style == slug %}font-semibold text-sky-700{% endif %}">{{ label }}{% if r.style == slug %} ✓{% endif %}</button>
          </form>
          {% endfor %}
          {% if r.style %}
          <form method="post" action="/drafts/{{ ref.ident }}/style" class="border-t border-slate-100">
            <input type="hidden" name="handle" value="{{ r.handle }}" />
            <input type="hidden" name="style" value="" />
            <button class="block w-full px-2 py-1 text-left text-slate-400 hover:bg-slate-100">Clear style</button>
          </form>
          {% endif %}
        </div>
      </div>
      {% endif %}
      {# Run a standard reviewer on this heading's subtree (the doc root
         heading → whole doc). Files an anchored review-todo → plan_tick. #}
      <div class="relative shrink-0" x-data="{ rev: false }" @click.outside="rev = false">
        <button @click="rev = !rev"
                class="text-[10px] text-slate-300 group-hover:text-slate-500 hover:text-sky-600">review ▾</button>
        <div x-show="rev" x-cloak
             class="absolute right-0 z-30 mt-1 w-40 rounded border border-slate-200 bg-white shadow-lg text-xs">
          {% for rv, label in [('structural', 'Structural'), ('deep_review', 'Deep review'), ('all', 'All (sequential)')] %}
          <form method="post" action="/drafts/{{ ref.ident }}/review">
            <input type="hidden" name="handle" value="{{ r.handle }}" />
            <input type="hidden" name="reviewer" value="{{ rv }}" />
            <button class="block w-full px-2 py-1 text-left hover:bg-slate-100">{{ label }}</button>
          </form>
          {% endfor %}
        </div>
      </div>
      {# Debug: preview the prompt building blocks for this section
         (project context + content + style skill + review lenses) so the
         operator can see what shapes the writing. Opens in a new tab. #}
      <a href="/drafts/{{ ref.ident }}/prompt?handle={{ r.handle }}" target="_blank"
         class="text-[10px] text-slate-300 group-hover:text-slate-500 hover:text-sky-600"
         title="preview the prompt for this section (content + style + review)">prompt ↗</a>
      </div>
    </div>
    {% elif r.is_figure %}
    {# ADR 0034 — figure: image payload from /drafts/blob, caption as the
       face, plus an origin chip + clearance badge. #}
    <figure class="rounded-md border border-slate-200 bg-white p-2">
      <img src="{{ r.blob_url }}" alt="{{ r.text }}" loading="lazy"
           class="max-h-96 w-auto max-w-full rounded" />
      <figcaption class="mt-1.5 text-sm text-slate-700 whitespace-pre-wrap break-words">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</figcaption>
      {% set p = r.figure_permission or {} %}
      <div class="mt-1 flex items-center gap-1.5">
        <span class="rounded px-1.5 py-0.5 text-[10px] font-mono uppercase
                     {% if r.figure_origin == 'third_party' %}bg-violet-100 text-violet-700
                     {% elif r.figure_origin == 'own_graph' %}bg-sky-100 text-sky-700
                     {% else %}bg-slate-100 text-slate-600{% endif %}">{{ r.figure_origin or 'figure' }}</span>
        {# Clearance badge: hover → the paper-trail; click → edit it. #}
        <div class="relative" x-data="{ pop: false, ed: false }">
          <button type="button"
                  @mouseenter="pop = true" @mouseleave="pop = false"
                  @click="ed = !ed; pop = false"
                  class="text-[10px] hover:underline {% if r.figure_cleared %}text-emerald-600{% else %}text-rose-600{% endif %}"
                  title="hover for the provenance; click to edit">
            {% if r.figure_cleared %}✓ cleared{% else %}✗ uncleared{% endif %} ✎</button>

          {# hover popover — provenance at a glance #}
          <div x-show="pop && !ed" x-cloak
               class="absolute left-0 z-30 mt-1 w-64 rounded border border-slate-200 bg-white p-2 text-[11px] shadow-lg">
            {% if r.figure_origin == 'third_party' %}
            <div class="font-semibold text-slate-700">Publisher permission</div>
            <dl class="mt-1 space-y-0.5 text-slate-600">
              {% if p.publisher %}<div><span class="text-slate-400">publisher:</span> {{ p.publisher }}</div>{% endif %}
              {% if p.permission_id %}<div><span class="text-slate-400">permission #:</span> {{ p.permission_id }}</div>{% endif %}
              {% if p.status %}<div><span class="text-slate-400">status:</span> {{ p.status }}</div>{% endif %}
              {% if p.requested_at %}<div><span class="text-slate-400">requested:</span> {{ p.requested_at }}</div>{% endif %}
              {% if p.granted_at %}<div><span class="text-slate-400">granted:</span> {{ p.granted_at }}</div>{% endif %}
              {% if p.expires_at %}<div><span class="text-slate-400">expires:</span> {{ p.expires_at }}</div>{% endif %}
              {% if p.source_paper %}<div><span class="text-slate-400">source:</span> {{ p.source_paper }}</div>{% endif %}
              {% if p.scope %}<div><span class="text-slate-400">scope:</span> {{ p.scope }}</div>{% endif %}
              {% if p.required_credit %}<div class="mt-1 italic">“{{ p.required_credit }}”</div>{% endif %}
              {% if not p %}<div class="text-rose-600">no permission recorded yet</div>{% endif %}
            </dl>
            {% elif r.figure_origin == 'own_graph' %}
            <div class="text-slate-600">Our graph — generated from data (ships a data supplement).</div>
            {% else %}
            <div class="text-slate-600">Our own figure — no third-party permission needed.</div>
            {% endif %}
            <div class="mt-1 text-[10px] text-slate-400">click the badge to edit</div>
          </div>

          {# click → edit provenance, prefilled, posts to the edit route #}
          <form x-show="ed" x-cloak method="post"
                action="/drafts/{{ ref.ident }}/figure/{{ r.handle }}/permission"
                x-data="{ org: '{{ r.figure_origin or 'third_party' }}' }"
                class="absolute left-0 z-30 mt-1 w-64 space-y-1 rounded border border-slate-200 bg-white p-2 shadow-lg">
            <label class="block">
              <span class="text-[9px] text-slate-500">Origin</span>
              <select name="origin" x-model="org"
                      class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]">
                <option value="original">original (ours)</option>
                <option value="own_graph">own graph (from data)</option>
                <option value="third_party">third-party (needs permission)</option>
              </select>
            </label>
            <template x-if="org === 'third_party'">
              <div class="space-y-1 border-l-2 border-violet-300 pl-1.5">
                <label class="block"><span class="text-[9px] text-slate-500">Publisher</span>
                  <input name="publisher" value="{{ p.publisher or '' }}"
                         class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" /></label>
                <label class="block"><span class="text-[9px] text-slate-500">Permission / licence #</span>
                  <input name="permission_id" value="{{ p.permission_id or '' }}"
                         class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" /></label>
                <label class="block"><span class="text-[9px] text-slate-500">Status</span>
                  <select name="status"
                          class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]">
                    {% for s in ['granted', 'requested', 'denied'] %}
                    <option value="{{ s }}" {% if p.status == s %}selected{% endif %}>{{ s }}</option>
                    {% endfor %}
                  </select></label>
                <label class="block"><span class="text-[9px] text-slate-500">Source paper (cite-key)</span>
                  <input name="source_paper" value="{{ p.source_paper or '' }}"
                         class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" /></label>
                <div class="flex gap-1">
                  <label class="min-w-0 flex-1"><span class="text-[9px] text-slate-500">Date requested</span>
                    <input name="requested_at" type="date" value="{{ p.requested_at or '' }}"
                           class="w-full rounded border border-slate-200 px-1 py-0.5 text-[10px]" /></label>
                  <label class="min-w-0 flex-1"><span class="text-[9px] text-slate-500">Date granted</span>
                    <input name="granted_at" type="date" value="{{ p.granted_at or '' }}"
                           class="w-full rounded border border-slate-200 px-1 py-0.5 text-[10px]" /></label>
                </div>
                <label class="block"><span class="text-[9px] text-slate-500">Required credit line</span>
                  <input name="required_credit" value="{{ p.required_credit or '' }}"
                         class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" /></label>
                <label class="block"><span class="text-[9px] text-slate-500">Scope</span>
                  <input name="scope" value="{{ p.scope or '' }}"
                         class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" /></label>
              </div>
            </template>
            <div class="flex items-center gap-2">
              <button class="rounded bg-violet-600 px-2 py-0.5 text-[11px] text-white hover:bg-violet-700">save</button>
              <button type="button" @click="ed = false" class="text-[10px] text-slate-400 hover:text-slate-600">cancel</button>
            </div>
          </form>
        </div>
      </div>
    </figure>
    {% elif r.is_list_container %}
    {# A ulist/olist container (migration 0037) — structural; its `item`
       children carry the content. A faint label names the list type and is
       the natural home for the ul/ol/normal toggle. #}
    <div class="flex items-center gap-2">
      <span class="text-[10px] uppercase tracking-wide text-slate-300 select-none">{{ 'numbered list' if r.chunk_kind == 'olist' else 'bullet list' }}</span>
      {% if r.list_kinds %}
      {# ul / ol / normal switch — posts to /drafts/<id>/listkind. #}
      <div class="relative shrink-0" x-data="{ lk: false }" @click.outside="lk = false">
        <button @click="lk = !lk"
                class="text-[10px] text-slate-300 group-hover:text-slate-500 hover:text-sky-600">list ▾</button>
        <div x-show="lk" x-cloak
             class="absolute left-0 z-30 mt-1 w-40 rounded border border-slate-200 bg-white shadow-lg text-xs">
          {% for slug, label in r.list_kinds %}
          <form method="post" action="/drafts/{{ ref.ident }}/listkind">
            <input type="hidden" name="handle" value="{{ r.handle }}" />
            <input type="hidden" name="kind" value="{{ slug }}" />
            <button class="block w-full px-2 py-1 text-left hover:bg-slate-100 {% if r.chunk_kind == slug %}font-semibold text-sky-700{% endif %}">{{ label }}{% if r.chunk_kind == slug %} ✓{% endif %}</button>
          </form>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
    {% elif r.is_item %}
    {# A list item: bullet (•) or number marker + the item body. The
       depth-based padding (above) indents nested items. #}
    <div class="flex gap-2">
      <span class="mt-0.5 shrink-0 select-none {% if r.list_ordered %}font-mono text-[13px] text-slate-500{% else %}text-slate-400{% endif %}">{{ r.marker }}</span>
      <div class="min-w-0 flex-1">
        <div x-show="view === 'body'"><p class="font-serif text-[15px] leading-relaxed text-slate-800 whitespace-pre-wrap break-words">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</p></div>
        <p x-show="view === 'summary'" x-cloak class="text-sm italic text-slate-600 break-words">{{ r.summary }}</p>
        <p x-show="view === 'keywords'" x-cloak class="text-xs font-mono text-slate-500 break-words">{{ r.keywords }}</p>
      </div>
    </div>
    {% else %}
    {# View slider: full body (default) vs the block's summary vs its
       keywords. Headings (above) always show their title. #}
    <div x-show="view === 'body'">
      {% if r.chunk_kind in ('aside', 'box') %}
      <div class="rounded-md border-l-4 border-amber-300 bg-amber-50 px-3 py-2 text-sm text-slate-700 whitespace-pre-wrap break-words">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</div>
      {% elif r.chunk_kind in ('listing', 'code') %}
      <pre class="rounded-md bg-slate-900 text-slate-100 text-xs p-3 overflow-x-auto whitespace-pre-wrap">{{ r.text }}</pre>
      {% else %}
      <p class="font-serif text-[15px] leading-relaxed text-slate-800 whitespace-pre-wrap break-words">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</p>
      {% endif %}
    </div>
    <p x-show="view === 'summary'" x-cloak class="text-sm italic text-slate-600 break-words">{{ r.summary }}</p>
    <p x-show="view === 'keywords'" x-cloak class="text-xs font-mono text-slate-500 break-words">{{ r.keywords }}</p>
    {% endif %}
    <div class="flex items-center gap-2">
      <a href="#c-{{ r.handle }}"
         class="font-mono text-[10px] text-slate-300 opacity-0 group-hover:opacity-100">{{ r.dc }}</a>
      <button @click="raw = !raw"
              class="text-[10px] text-slate-300 opacity-0 group-hover:opacity-100 hover:text-slate-600"
              x-text="raw ? 'hide raw' : 'raw'"></button>
    </div>
    {# raw source "cookie" — toggled (click-to-pin) under the block #}
    <pre x-show="raw" x-cloak
         class="mt-1 rounded border border-slate-200 bg-slate-50 p-2 text-[11px] text-slate-600 whitespace-pre-wrap break-words">{{ r.text }}</pre>
  </div>

  {# ── Col B: meta — refs + connections + in-flight ───────────── #
     In compact mode the parent #doc carries `draft-compact`, which
     pins `.draft-meta-inner` to the cell and scrolls it — so this
     column stops inflating the row and the text drives the height. #}
  <div class="draft-meta text-xs">
    <div class="draft-meta-inner space-y-1">
    {% if r.refs %}
    {# Each chip carries the cited quote on hover (popover_chip). #}
    <div class="flex flex-wrap gap-1">
      {% for c in r.refs %}{{ c }}{% endfor %}
    </div>
    {% endif %}
    {# Connections: graph links to/from this chunk — derived-from
       provenance, related-to, and dream-memories that reference it.
       Collapsed behind a count; neighbours (prev/next para) fold in
       under a muted sub-line. The dream-output-on-the-draft surface. #}
    {% if r.connections or r.nearby %}
    <div x-data="{ open: false }" class="text-[11px]">
      <button @click="open = !open" class="text-slate-400 hover:text-slate-700">
        <span x-text="open ? '▾' : '▸'"></span>
        {{ r.connections | length }} connection{{ '' if r.connections|length == 1 else 's' }}{% if r.nearby %} (+{{ r.nearby | length }} nearby){% endif %}
      </button>
      <div x-show="open" x-cloak class="mt-1 space-y-1">
        {% if r.connections %}
        <div class="flex flex-wrap gap-1">{% for c in r.connections %}{{ c }}{% endfor %}</div>
        {% endif %}
        {% if r.nearby %}
        <div class="text-slate-400">nearby:
          <span class="flex flex-wrap gap-1">{% for c in r.nearby %}{{ c }}{% endfor %}</span>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}
    {# Edit churn: how many times this block changed (chunk_events). #}
    {% if r.edits %}
    <div class="text-[10px] text-slate-400" title="edits since creation">
      changed {{ r.edits }}×{% if r.edited_at %} · {{ r.edited_at | ago }}{% endif %}
    </div>
    {% endif %}
    {# Change requests for this block — they PERSIST through their
       lifecycle (open→working→done) so you can click in and read the
       LLM run. Done/won't-do are de-emphasised but kept. Click → the
       Tasks view focused on the request (its ⚙ job + captured LLM
       transcript), in a new tab. #}
    {% for t in r.requests %}
    {% set stuck = t.asking or t.failed %}
    <div class="rounded border px-1.5 py-0.5
                {% if stuck %}border-rose-300 bg-rose-50{% elif t.done %}border-slate-200 bg-slate-50 text-slate-400{% else %}border-amber-200 bg-amber-50{% endif %}">
      <div class="flex items-start gap-1">
        <a href="/r/todo/{{ t.ref_id }}" target="_blank" rel="noopener"
           class="min-w-0 flex-1 hover:underline" title="open the LLM run for this request">
          <span class="font-mono text-[10px] uppercase {% if t.done %}text-slate-400{% elif stuck %}text-rose-700{% else %}text-amber-700{% endif %}">{{ t.status }}</span>
          <span class="{% if not t.done %}text-slate-700{% endif %}{% if t.status == "won't-do" %} line-through{% endif %}">{{ t.title }}</span>
        </a>
        {# 📜 the full LLM transcript, once a job has run (debugging). #}
        {% if t.started %}
        <a href="/tasks/{{ t.ref_id }}/transcript" target="_blank" rel="noopener"
           class="shrink-0 leading-none" title="LLM transcript (what it asked / did)">📜</a>
        {% endif %}
        {# X to close a request: cancel one not yet started, OR clear a
           finished one (done / won't-do / failed). A running request — a
           job minted but not yet terminal — gets no X so you can't delete
           it mid-run. #}
        {% if t.done or t.failed or not t.started %}
        <form method="post" action="/drafts/{{ ref.ident }}/todo/{{ t.ref_id }}/delete"
              onsubmit="return confirm('Remove this change request?')">
          <button class="{% if t.done %}text-slate-400{% elif t.failed %}text-rose-400{% else %}text-amber-600{% endif %} hover:text-rose-600 leading-none"
                  title="{% if t.done or t.failed %}close — remove this finished request{% else %}cancel this not-yet-started request{% endif %}">×</button>
        </form>
        {% endif %}
      </div>
      {# Attention: waiting on you (ask-user) or a failed child job — the
         "it's stuck" signal that was missing on the draft page. #}
      {% if t.asking %}
      <a href="/r/todo/{{ t.ref_id }}" target="_blank" rel="noopener"
         class="block text-rose-700 hover:underline" title="open the LLM run to see why it asked">
        🔔 asks: {{ t.asking }}
      </a>
      {% elif t.failed %}
      <a href="/r/todo/{{ t.ref_id }}" target="_blank" rel="noopener"
         class="block text-rose-700 hover:underline">⚠ failed{% if t.fail_reason %} — {{ t.fail_reason }}{% else %} — open to debug{% endif %}</a>
      {% endif %}
    </div>
    {% endfor %}
    </div>{# /.draft-meta-inner #}
  </div>

  {# ── Col C: change box — needs-you panel + "around here…" + add-figure ── #}
  <div class="space-y-1" x-data="{ figopen: false, org: 'original' }">
    {# Promoted "needs you" panel: when a request anchored here is waiting on
       a human, surface the whole exchange right in the change column — the
       original request, the LLM's question, and an answer box — so the
       operator unblocks it in place instead of hunting the Asks tab. Submits
       to the shared /asks answer route (strips the ask-user tag, appends the
       answer) and returns to this draft. #}
    {% for t in r.requests if t.asking %}
    <div class="space-y-1 rounded border border-amber-300 bg-amber-50 p-2 text-xs">
      <div class="flex items-center gap-1 font-medium text-amber-900">
        <span class="rounded bg-amber-200 px-1.5 py-0.5">✋ needs you</span>
        <a href="/r/todo/{{ t.ref_id }}" target="_blank" rel="noopener"
           class="font-mono text-[10px] text-amber-700 hover:underline">todo:{{ t.ref_id }}</a>
      </div>
      <p class="text-slate-500"><span class="text-slate-400">your request:</span> {{ t.request }}</p>
      <p class="text-amber-900"><span class="text-amber-700">asks:</span> {{ t.asking }}</p>
      <form method="post" action="/asks/{{ t.ref_id }}/answer" class="space-y-1">
        <input type="hidden" name="remove" value="{{ t.ask_tag }}" />
        <input type="hidden" name="next" value="/drafts/{{ ref.ident }}" />
        <textarea name="response" required rows="2" placeholder="your answer…"
                  class="w-full resize-y rounded border border-amber-300 px-2 py-1 text-xs focus:border-amber-500 focus:outline-none"></textarea>
        <button class="rounded bg-amber-600 px-2 py-1 text-xs text-white hover:bg-amber-700">answer</button>
      </form>
    </div>
    {% endfor %}
    <form method="post" action="/drafts/{{ ref.ident }}/request" x-data="{ model: 'opus' }" class="space-y-1">
      <input type="hidden" name="handle" value="{{ r.handle }}" />
      <div class="flex items-start gap-1">
      {# Auto-grow: a one-row textarea that expands to fit the request as
         you type (and snaps back on reset), so longer change notes stay
         visible. Enter submits; Shift+Enter inserts a newline. #}
      <textarea name="text" required placeholder="around here…" rows="1"
                x-init="$nextTick(() => { $el.style.height='auto'; $el.style.height=$el.scrollHeight+'px' })"
                @input="$el.style.height='auto'; $el.style.height=$el.scrollHeight+'px'"
                @keydown.enter.prevent="if (!$event.shiftKey) { $el.form.requestSubmit() } else { $el.value += '\n'; $el.dispatchEvent(new Event('input')) }"
                class="min-w-0 flex-1 resize-none overflow-hidden rounded border border-slate-200 px-2 py-1 text-xs leading-snug focus:border-sky-400 focus:outline-none"></textarea>
      <button class="shrink-0 rounded bg-sky-600 px-2 py-1 text-xs text-white hover:bg-sky-700"
              title="file a change request anchored here">⤳</button>
      </div>
      {# Model tier for the planner tick this files (sets the LLM:<model>
         tag). Reset returns model→opus and clears the box. #}
      <div class="flex items-center gap-2 text-[10px] text-slate-400">
        <label class="flex items-center gap-1">model
          <select name="model" x-model="model"
                  class="rounded border border-slate-200 bg-white px-1 py-0.5 text-[10px]">
            <option value="opus">opus</option>
            <option value="sonnet">sonnet</option>
            <option value="haiku">haiku</option>
          </select>
        </label>
        <button type="button"
                @click="model='opus'; const ta=$el.closest('form').querySelector('textarea'); ta.value=''; ta.dispatchEvent(new Event('input'))"
                class="hover:text-sky-600">reset</button>
      </div>
    </form>

    {# Add a figure after this block (ADR 0034). Bytes upload multipart →
       /drafts/{ident}/figure → put(chunk_kind='figure'). A third-party
       image reveals the permission paper-trail (required to clear). #}
    <button type="button" @click="figopen = !figopen"
            class="text-[10px] text-slate-400 hover:text-sky-600"
            x-text="figopen ? '− figure' : '＋ figure'"></button>
    <form x-show="figopen" x-cloak method="post" enctype="multipart/form-data"
          action="/drafts/{{ ref.ident }}/figure"
          class="space-y-1 rounded border border-slate-200 bg-slate-50 p-1.5">
      <input type="hidden" name="handle" value="{{ r.handle }}" />
      <input type="file" name="file" accept="image/*" required
             class="block w-full text-[10px]" />
      <input name="caption" required placeholder="caption…"
             class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
      <select name="origin" x-model="org"
              class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]">
        <option value="original">original (ours)</option>
        <option value="own_graph">own graph (from data)</option>
        <option value="third_party">third-party (needs permission)</option>
      </select>
      {# Permission paper-trail — only for a third-party image; the fields
         are removed from the DOM otherwise, so `required` doesn't block
         an original/own_graph upload. #}
      <template x-if="org === 'third_party'">
        {# Each field carries a small legend above it so the paper-trail is
           self-explanatory (the two dates especially). #}
        <div class="space-y-1.5 rounded border-l-2 border-violet-300 pl-1.5">
          <p class="text-[10px] font-semibold uppercase tracking-wide text-violet-700">Publisher permission</p>
          <label class="block">
            <span class="text-[9px] text-slate-500">Publisher</span>
            <input name="publisher" required placeholder="e.g. Springer Nature"
                   class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          </label>
          <label class="block">
            <span class="text-[9px] text-slate-500">Permission / licence #</span>
            <input name="permission_id" required placeholder="e.g. SNCSC-2026-0451"
                   class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          </label>
          <label class="block">
            <span class="text-[9px] text-slate-500">Status</span>
            <select name="status" required
                    class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]">
              <option value="granted">granted</option>
              <option value="requested">requested</option>
              <option value="denied">denied</option>
            </select>
          </label>
          <label class="block">
            <span class="text-[9px] text-slate-500">Source paper (cite-key)</span>
            <input name="source_paper" required placeholder="e.g. smith19"
                   class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          </label>
          <div class="flex gap-1">
            <label class="min-w-0 flex-1">
              <span class="text-[9px] text-slate-500">Date requested</span>
              <input name="requested_at" type="date"
                     class="w-full rounded border border-slate-200 px-1 py-0.5 text-[10px]" />
            </label>
            <label class="min-w-0 flex-1">
              <span class="text-[9px] text-slate-500">Date granted</span>
              <input name="granted_at" type="date"
                     class="w-full rounded border border-slate-200 px-1 py-0.5 text-[10px]" />
            </label>
          </div>
          <label class="block">
            <span class="text-[9px] text-slate-500">Required credit line</span>
            <input name="required_credit" placeholder="“Reprinted by permission …”"
                   class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          </label>
          <label class="block">
            <span class="text-[9px] text-slate-500">Scope</span>
            <input name="scope" placeholder="e.g. print + electronic, worldwide"
                   class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          </label>
        </div>
      </template>
      <button class="rounded bg-violet-600 px-2 py-0.5 text-[11px] text-white hover:bg-violet-700"
              title="upload the image as a figure after this block">add figure</button>
    </form>
  </div>
</div>
{% endmacro %}
