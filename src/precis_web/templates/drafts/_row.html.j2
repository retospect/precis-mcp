{# One document block as a 3-column grid row (ADR 0033 web Tier-A).
   content | meta (refs + in-flight) | change box. Collapse is driven by
   the parent `draftDoc` Alpine component via `vis(ancestors)`; heading
   rows carry data-heading so collapse-all can find them. #}
{% macro draft_row(r, ref) %}
<div id="c-{{ r.handle }}"
     {% if r.is_heading %}data-heading="{{ r.handle }}"{% endif %}
     data-anc='{{ r.ancestors | tojson }}'
     x-show="vis({{ r.ancestors | tojson }})" x-cloak
     class="grid grid-cols-1 lg:grid-cols-[1fr_20%_22%] gap-3 py-1.5 border-b border-slate-100 scroll-mt-4 group">
  {# ── Col A: content ─────────────────────────────────────────── #
     `raw` (click-to-pin) shows the chunk's verbatim source — the
     markdown + ¶/§ markers behind the rendered view, for debugging. #}
  <div data-content style="padding-left: {{ r.depth }}rem" x-data="{ raw: false }">
    {% if r.is_heading %}
    <div class="flex items-start gap-1.5">
      <button @click="toggle('{{ r.handle }}')"
              class="mt-0.5 font-mono text-xs text-slate-400 hover:text-slate-700 select-none"
              x-text="isC('{{ r.handle }}') ? '▸' : '▾'"></button>
      <h3 class="font-semibold text-slate-900
                 {% if r.depth == 0 %}text-lg{% elif r.depth == 1 %}text-base{% else %}text-sm{% endif %}">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</h3>
      {# Run a standard reviewer on this heading's subtree (the doc root
         heading → whole doc). Files an anchored review-todo → plan_tick. #}
      <div class="relative ml-auto shrink-0" x-data="{ rev: false }" @click.outside="rev = false">
        <button @click="rev = !rev"
                class="text-[10px] text-slate-300 group-hover:text-slate-500 hover:text-sky-600">review ▾</button>
        <div x-show="rev" x-cloak
             class="absolute right-0 z-30 mt-1 w-40 rounded border border-slate-200 bg-white shadow-lg text-xs">
          {% for rv, label in [('structural', 'Structural'), ('deep_review', 'Deep review'), ('all', 'All (sequential)')] %}
          <form method="post" action="/drafts/{{ ref.ident }}/review">
            <input type="hidden" name="handle" value="{{ r.handle }}" />
            <input type="hidden" name="reviewer" value="{{ rv }}" />
            <button class="block w-full px-2 py-1 text-left hover:bg-slate-100">{{ label }}</button>
          </form>
          {% endfor %}
        </div>
      </div>
    </div>
    {% elif r.is_figure %}
    {# ADR 0034 — figure: image payload from /drafts/blob, caption as the
       face, plus an origin chip + clearance badge. #}
    <figure class="rounded-md border border-slate-200 bg-white p-2">
      <img src="{{ r.blob_url }}" alt="{{ r.text }}" loading="lazy"
           class="max-h-96 w-auto max-w-full rounded" />
      <figcaption class="mt-1.5 text-sm text-slate-700 whitespace-pre-wrap break-words">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</figcaption>
      <div class="mt-1 flex items-center gap-1.5">
        <span class="rounded px-1.5 py-0.5 text-[10px] font-mono uppercase
                     {% if r.figure_origin == 'third_party' %}bg-violet-100 text-violet-700
                     {% elif r.figure_origin == 'own_graph' %}bg-sky-100 text-sky-700
                     {% else %}bg-slate-100 text-slate-600{% endif %}">{{ r.figure_origin or 'figure' }}</span>
        {% if r.figure_cleared %}
        <span class="text-[10px] text-emerald-600" title="figure cleared">✓ cleared</span>
        {% else %}
        <span class="text-[10px] text-rose-600" title="permission missing or not granted">✗ uncleared</span>
        {% endif %}
      </div>
    </figure>
    {% else %}
    {# View slider: full body (default) vs the block's summary vs its
       keywords. Headings (above) always show their title. #}
    <div x-show="view === 'body'">
      {% if r.chunk_kind in ('aside', 'box') %}
      <div class="rounded-md border-l-4 border-amber-300 bg-amber-50 px-3 py-2 text-sm text-slate-700 whitespace-pre-wrap break-words">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</div>
      {% elif r.chunk_kind in ('listing', 'code') %}
      <pre class="rounded-md bg-slate-900 text-slate-100 text-xs p-3 overflow-x-auto whitespace-pre-wrap">{{ r.text }}</pre>
      {% else %}
      <p class="font-serif text-[15px] leading-relaxed text-slate-800 whitespace-pre-wrap break-words">{{ r.text | linkify_refs(markdown=True, compact=True, abbrevs=r.abbrevs) }}</p>
      {% endif %}
    </div>
    <p x-show="view === 'summary'" x-cloak class="text-sm italic text-slate-600 break-words">{{ r.summary }}</p>
    <p x-show="view === 'keywords'" x-cloak class="text-xs font-mono text-slate-500 break-words">{{ r.keywords }}</p>
    {% endif %}
    <div class="flex items-center gap-2">
      <a href="#c-{{ r.handle }}"
         class="font-mono text-[10px] text-slate-300 opacity-0 group-hover:opacity-100">¶{{ r.handle }}</a>
      <button @click="raw = !raw"
              class="text-[10px] text-slate-300 opacity-0 group-hover:opacity-100 hover:text-slate-600"
              x-text="raw ? 'hide raw' : 'raw'"></button>
    </div>
    {# raw source "cookie" — toggled (click-to-pin) under the block #}
    <pre x-show="raw" x-cloak
         class="mt-1 rounded border border-slate-200 bg-slate-50 p-2 text-[11px] text-slate-600 whitespace-pre-wrap break-words">{{ r.text }}</pre>
  </div>

  {# ── Col B: meta — refs + connections + in-flight ───────────── #
     In compact mode the parent #doc carries `draft-compact`, which
     pins `.draft-meta-inner` to the cell and scrolls it — so this
     column stops inflating the row and the text drives the height. #}
  <div class="draft-meta text-xs">
    <div class="draft-meta-inner space-y-1">
    {% if r.refs %}
    {# Each chip carries the cited quote on hover (popover_chip). #}
    <div class="flex flex-wrap gap-1">
      {% for c in r.refs %}{{ c }}{% endfor %}
    </div>
    {% endif %}
    {# Connections: graph links to/from this chunk — derived-from
       provenance, related-to, and dream-memories that reference it.
       Collapsed behind a count; neighbours (prev/next para) fold in
       under a muted sub-line. The dream-output-on-the-draft surface. #}
    {% if r.connections or r.nearby %}
    <div x-data="{ open: false }" class="text-[11px]">
      <button @click="open = !open" class="text-slate-400 hover:text-slate-700">
        <span x-text="open ? '▾' : '▸'"></span>
        {{ r.connections | length }} connection{{ '' if r.connections|length == 1 else 's' }}{% if r.nearby %} (+{{ r.nearby | length }} nearby){% endif %}
      </button>
      <div x-show="open" x-cloak class="mt-1 space-y-1">
        {% if r.connections %}
        <div class="flex flex-wrap gap-1">{% for c in r.connections %}{{ c }}{% endfor %}</div>
        {% endif %}
        {% if r.nearby %}
        <div class="text-slate-400">nearby:
          <span class="flex flex-wrap gap-1">{% for c in r.nearby %}{{ c }}{% endfor %}</span>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}
    {# Edit churn: how many times this block changed (chunk_events). #}
    {% if r.edits %}
    <div class="text-[10px] text-slate-400" title="edits since creation">
      changed {{ r.edits }}×{% if r.edited_at %} · {{ r.edited_at | ago }}{% endif %}
    </div>
    {% endif %}
    {# Change requests for this block — they PERSIST through their
       lifecycle (open→working→done) so you can click in and read the
       LLM run. Done/won't-do are de-emphasised but kept. Click → the
       Tasks view focused on the request (its ⚙ job + captured LLM
       transcript), in a new tab. #}
    {% for t in r.requests %}
    {% set stuck = t.asking or t.failed %}
    <div class="rounded border px-1.5 py-0.5
                {% if stuck %}border-rose-300 bg-rose-50{% elif t.done %}border-slate-200 bg-slate-50 text-slate-400{% else %}border-amber-200 bg-amber-50{% endif %}">
      <div class="flex items-start gap-1">
        <a href="/r/todo/{{ t.ref_id }}" target="_blank" rel="noopener"
           class="min-w-0 flex-1 hover:underline" title="open the LLM run for this request">
          <span class="font-mono text-[10px] uppercase {% if t.done %}text-slate-400{% elif stuck %}text-rose-700{% else %}text-amber-700{% endif %}">{{ t.status }}</span>
          <span class="{% if not t.done %}text-slate-700{% endif %}{% if t.status == "won't-do" %} line-through{% endif %}">{{ t.title }}</span>
        </a>
        {# 📜 the full LLM transcript, once a job has run (debugging). #}
        {% if t.started %}
        <a href="/tasks/{{ t.ref_id }}/transcript" target="_blank" rel="noopener"
           class="shrink-0 leading-none" title="LLM transcript (what it asked / did)">📜</a>
        {% endif %}
        {# X to close a request: cancel one not yet started, OR clear a
           finished one (done / won't-do / failed). A running request — a
           job minted but not yet terminal — gets no X so you can't delete
           it mid-run. #}
        {% if t.done or t.failed or not t.started %}
        <form method="post" action="/drafts/{{ ref.ident }}/todo/{{ t.ref_id }}/delete"
              onsubmit="return confirm('Remove this change request?')">
          <button class="{% if t.done %}text-slate-400{% elif t.failed %}text-rose-400{% else %}text-amber-600{% endif %} hover:text-rose-600 leading-none"
                  title="{% if t.done or t.failed %}close — remove this finished request{% else %}cancel this not-yet-started request{% endif %}">×</button>
        </form>
        {% endif %}
      </div>
      {# Attention: waiting on you (ask-user) or a failed child job — the
         "it's stuck" signal that was missing on the draft page. #}
      {% if t.asking %}
      <a href="/r/todo/{{ t.ref_id }}" target="_blank" rel="noopener"
         class="block text-rose-700 hover:underline" title="open the LLM run to see why it asked">
        🔔 asks: {{ t.asking }}
      </a>
      {% elif t.failed %}
      <a href="/r/todo/{{ t.ref_id }}" target="_blank" rel="noopener"
         class="block text-rose-700 hover:underline">⚠ failed — open to debug</a>
      {% endif %}
    </div>
    {% endfor %}
    </div>{# /.draft-meta-inner #}
  </div>

  {# ── Col C: change box — "around here…" + add-figure ──────────── #}
  <div class="space-y-1" x-data="{ figopen: false, org: 'original' }">
    <form method="post" action="/drafts/{{ ref.ident }}/request" class="flex items-start gap-1">
      <input type="hidden" name="handle" value="{{ r.handle }}" />
      <input name="text" required placeholder="around here…"
             class="min-w-0 flex-1 rounded border border-slate-200 px-2 py-1 text-xs focus:border-sky-400 focus:outline-none" />
      <button class="shrink-0 rounded bg-sky-600 px-2 py-1 text-xs text-white hover:bg-sky-700"
              title="file a change request anchored here">⤳</button>
    </form>

    {# Add a figure after this block (ADR 0034). Bytes upload multipart →
       /drafts/{ident}/figure → put(chunk_kind='figure'). A third-party
       image reveals the permission paper-trail (required to clear). #}
    <button type="button" @click="figopen = !figopen"
            class="text-[10px] text-slate-400 hover:text-sky-600"
            x-text="figopen ? '− figure' : '＋ figure'"></button>
    <form x-show="figopen" x-cloak method="post" enctype="multipart/form-data"
          action="/drafts/{{ ref.ident }}/figure"
          class="space-y-1 rounded border border-slate-200 bg-slate-50 p-1.5">
      <input type="hidden" name="handle" value="{{ r.handle }}" />
      <input type="file" name="file" accept="image/*" required
             class="block w-full text-[10px]" />
      <input name="caption" required placeholder="caption…"
             class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
      <select name="origin" x-model="org"
              class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]">
        <option value="original">original (ours)</option>
        <option value="own_graph">own graph (from data)</option>
        <option value="third_party">third-party (needs permission)</option>
      </select>
      {# Permission paper-trail — only for a third-party image; the fields
         are removed from the DOM otherwise, so `required` doesn't block
         an original/own_graph upload. #}
      <template x-if="org === 'third_party'">
        <div class="space-y-1 rounded border-l-2 border-violet-300 pl-1.5">
          <input name="publisher" required placeholder="publisher"
                 class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          <input name="permission_id" required placeholder="permission / licence #"
                 class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          <select name="status" required
                  class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]">
            <option value="granted">granted</option>
            <option value="requested">requested</option>
            <option value="denied">denied</option>
          </select>
          <input name="source_paper" required placeholder="source cite-key (e.g. smith19)"
                 class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          <div class="flex gap-1">
            <input name="requested_at" type="date" title="requested"
                   class="min-w-0 flex-1 rounded border border-slate-200 px-1 py-0.5 text-[10px]" />
            <input name="granted_at" type="date" title="granted"
                   class="min-w-0 flex-1 rounded border border-slate-200 px-1 py-0.5 text-[10px]" />
          </div>
          <input name="required_credit" placeholder="required credit line"
                 class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
          <input name="scope" placeholder="scope (e.g. print + electronic)"
                 class="w-full rounded border border-slate-200 px-1 py-0.5 text-[11px]" />
        </div>
      </template>
      <button class="rounded bg-violet-600 px-2 py-0.5 text-[11px] text-white hover:bg-violet-700"
              title="upload the image as a figure after this block">add figure</button>
    </form>
  </div>
</div>
{% endmacro %}
