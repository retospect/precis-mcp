{% extends "base.html.j2" %}
{% block title %}Drafts{% endblock %}
{% block content %}
<div x-data="{ open: false }">
<div class="flex items-center justify-between mb-4">
  <h1 class="text-lg font-semibold">Drafts</h1>
  <div class="flex items-center gap-3">
    <span class="text-sm text-slate-500">{{ drafts | length }} draft(s)</span>
    <button type="button" @click="open = !open"
            class="rounded bg-sky-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-sky-700">
      + New draft
    </button>
  </div>
</div>

<form x-show="open" x-cloak method="post" action="/drafts/new"
      class="mb-4 rounded-lg border border-slate-200 bg-white p-4 space-y-3">
  <div>
    <label class="block text-xs font-medium text-slate-600 mb-1">Title <span class="text-rose-500">*</span></label>
    <input name="title" required maxlength="200" placeholder="Nanoscale Transistors" x-init="$el.focus()"
           class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm" />
  </div>
  <div>
    <label class="block text-xs font-medium text-slate-600 mb-1">Document type</label>
    <select name="doctype"
            class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm bg-white">
      {% for dt in doctypes %}
      <option value="{{ dt.value }}"{% if dt.default %} selected{% endif %}>{{ dt.label }}</option>
      {% endfor %}
    </select>
  </div>
  <div>
    <label class="block text-xs font-medium text-slate-600 mb-1">Slug <span class="text-slate-400">(optional — derived from title)</span></label>
    <input name="slug" maxlength="40" placeholder="nanotrans"
           class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm font-mono" />
  </div>
  <div>
    <label class="block text-xs font-medium text-slate-600 mb-1">Summary / brief <span class="text-slate-400">(optional — the project's standing guidance)</span></label>
    <textarea name="summary" rows="3" placeholder="What this write-up is about, scope, voice, what to avoid…"
              class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm"></textarea>
  </div>
  <div class="flex justify-end">
    <button type="submit" class="rounded bg-sky-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-sky-700">Create draft</button>
  </div>
</form>
</div>

{% if not drafts %}
<p class="text-sm text-slate-500">
  No drafts yet — use <span class="font-medium">+ New draft</span> above, or an agent can
  <code class="text-xs">put(kind='draft', id='…', project=&lt;todo&gt;)</code>.
</p>
{% else %}
<ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
  {% for d in drafts %}
  <li class="px-4 py-3 hover:bg-slate-50">
    <a href="/drafts/{{ d.ident }}" class="flex items-center justify-between">
      <span class="text-sm font-medium text-slate-800">{{ d.title }}</span>
      {% if d.slug %}<span class="font-mono text-xs text-slate-400">{{ d.slug }}</span>{% endif %}
    </a>
  </li>
  {% endfor %}
</ul>
{% endif %}
{% endblock %}
