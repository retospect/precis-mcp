{% extends "base.html.j2" %}
{% block title %}Prompt · {{ ident }}{% endblock %}
{% block content %}
<div class="max-w-3xl mx-auto space-y-5">
  <div class="flex items-center justify-between">
    <h1 class="text-lg font-semibold">Section prompt — debug</h1>
    <a href="/drafts/{{ ident }}#c-{{ handle }}" class="text-sm text-sky-600 hover:underline">← back to draft</a>
  </div>
  <p class="text-xs text-slate-500">
    These are the building blocks the writer assembles for this section
    (<span class="font-mono">{{ handle }}</span>): project context, the section's
    content + style, and the review lenses. Tune the style skill or the brief to
    change how it writes. The genre, project context, and per-heading style are
    all set with the
    <a href="/drafts/{{ ident }}" class="text-sky-600 hover:underline">genre</a>
    /<span class="font-mono">style ▾</span> controls on the draft.
  </p>

  {# ── Project context (always in the writer's prompt) ─────────────── #}
  <section>
    <h2 class="text-sm font-semibold text-slate-700 mb-1">
      Project context{% if doc_type %} · <span class="font-mono text-xs text-sky-700">{{ doc_type }}</span>{% endif %}
    </h2>
    {% if brief %}
    <pre class="rounded border border-slate-200 bg-slate-50 p-3 text-xs whitespace-pre-wrap">{{ brief }}</pre>
    {% else %}
    <p class="text-xs text-slate-400 italic">
      No project brief set — add one with the
      <a href="/drafts/{{ ident }}" class="text-sky-600 hover:underline">genre</a>
      button on the draft. It sets the document genre and the standing
      guidance injected as this <span class="font-mono">## Project context</span>
      on every writer tick.
    </p>
    {% endif %}
  </section>

  {# ── Seed material (if any) ──────────────────────────────────────── #}
  {% if seeds and (seeds.text or seeds.tags) %}
  <section>
    <h2 class="text-sm font-semibold text-slate-700 mb-1">Seed material</h2>
    {% if seeds.text %}<pre class="rounded border border-slate-200 bg-slate-50 p-3 text-xs whitespace-pre-wrap">{{ seeds.text }}</pre>{% endif %}
    {% if seeds.tags %}<p class="mt-1 text-xs text-slate-500">tags: {{ seeds.tags | join(', ') }}</p>{% endif %}
  </section>
  {% endif %}

  {# ── Content: the section itself ─────────────────────────────────── #}
  <section>
    <h2 class="text-sm font-semibold text-slate-700 mb-1">Content (this section)</h2>
    <pre class="rounded border border-slate-200 bg-slate-50 p-3 text-xs whitespace-pre-wrap">{{ heading }}</pre>
    {% if word_target %}
    <p class="mt-1 text-xs text-slate-500">word target: {{ word_target.min }}–{{ word_target.max }}</p>
    {% endif %}
  </section>

  {# ── Style: the section-style skill the writer follows ───────────── #}
  <section>
    <h2 class="text-sm font-semibold text-slate-700 mb-1">
      Style{% if style_slug %} · <span class="font-mono text-xs text-sky-700">{{ style_slug }}</span>{% endif %}
    </h2>
    {% if style_skill %}
    <pre class="rounded border border-slate-200 bg-slate-50 p-3 text-xs whitespace-pre-wrap max-h-96 overflow-y-auto">{{ style_skill }}</pre>
    {% elif style_slug %}
    <p class="text-xs text-slate-400 italic">Style skill "{{ style_slug }}" not found.</p>
    {% elif doc_type %}
    <p class="text-xs text-slate-400 italic">No section style set — pick one with the "style ▾" button next to this heading.</p>
    {% else %}
    <p class="text-xs text-slate-400 italic">
      No section style set. The per-heading "style ▾" picker only appears
      once the draft has a genre — set one (paper / patent / report / review)
      with the <a href="/drafts/{{ ident }}" class="text-sky-600 hover:underline">genre</a>
      button on the draft.
    </p>
    {% endif %}
  </section>

  {# ── Review lenses available for this section ────────────────────── #}
  <section>
    <h2 class="text-sm font-semibold text-slate-700 mb-1">Review lenses</h2>
    <ul class="space-y-1">
      {% for slug, desc in review_lenses %}
      <li class="text-xs text-slate-600"><span class="font-mono text-sky-700">{{ slug }}</span> — {{ desc }}</li>
      {% endfor %}
    </ul>
    <p class="mt-1 text-xs text-slate-400">Run one from the "review ▾" button next to the heading.</p>
  </section>
</div>
{% endblock %}
