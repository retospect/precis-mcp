{# An un-hydrated document block (on-demand loading).

   DELIBERATELY INERT — no Alpine directives. A 10k-chunk draft would
   otherwise pay Alpine reactivity per block (the "works but with a minute
   lag" bug). Collapse, hydration, and find are driven imperatively by the
   `draftDoc` controller via plain `data-*` hooks:

     data-ph       — marks a placeholder for the IntersectionObserver
     data-handle   — the block to hydrate (GET /drafts/<id>/rows?handles=…)
     data-anc      — ancestor heading handles (vanilla collapse visibility)
     data-heading  — present on heading rows (collapse-all target)
     data-toggle   — a heading's collapse button (delegated click)

   `content-visibility:auto` lets the browser skip layout/paint of
   off-screen placeholders; `contain-intrinsic-size` reserves ~the real
   row's height so the scrollbar is honest. Heading placeholders show the
   title + collapse caret (the outline is navigable before bodies load);
   body placeholders are blank sized boxes that fill in on hydrate. #}
{% macro draft_placeholder(p) %}
<div id="c-{{ p.handle }}"
     {% if p.is_heading %}data-heading="{{ p.handle }}"{% endif %}
     data-anc='{{ p.ancestors | tojson }}'
     data-ph="1" data-handle="{{ p.handle }}"
     style="content-visibility:auto;contain-intrinsic-size:auto {{ (p.est_rem * 16) | round | int }}px"
     class="dr-block grid grid-cols-1 lg:grid-cols-[1fr_20%_22%] gap-3 py-1.5 border-b border-slate-100 scroll-mt-4">
  <div style="padding-left: {{ p.depth }}rem">
    {% if p.is_heading %}
    <div class="flex items-start gap-1.5">
      <button data-toggle="{{ p.handle }}"
              class="dr-toggle mt-0.5 font-mono text-xs text-slate-400 hover:text-slate-700 select-none">▾</button>
      <h3 class="font-semibold text-slate-900
                 {% if p.depth == 0 %}text-lg{% elif p.depth == 1 %}text-base{% else %}text-sm{% endif %}">{{ p.title }}</h3>
    </div>
    {% endif %}
  </div>
  <div></div>
  <div></div>
</div>
{% endmacro %}
