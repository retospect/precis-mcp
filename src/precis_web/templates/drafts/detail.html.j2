// Reveal-on-cursor: style each reference token as a subtle chip, EXCEPT the one
// the caret is inside (that shows raw so you can edit it). Recomputes on every
// selection change (props.decorations runs per state). Pure client, no fetch.
const REF_TOKEN = /\[(?:§[A-Za-z][\w~.-]*|\[?[a-z]{2}\d+\]?|¶[\w-]+)\]/g;
