{% extends "base.html.j2" %}
{% block title %}{{ ref.title }}{% endblock %}
{% block content %}
<style>
  [x-cloak]{display:none!important}
  /* collapse hides a block + its subtree imperatively (vanilla, no Alpine
     per-node binding — the reason a 10k-block draft stays responsive). */
  .dr-hidden{display:none!important}
  /* in-draft find: every match gets a soft band, the active one a ring */
  .find-hit{background-color:#fef9c3}
  .find-current{box-shadow:0 0 0 2px #f59e0b;border-radius:.25rem}
  mark.find-word{background:#fde047;color:inherit;border-radius:2px;padding:0 1px}
  /* abbreviation recall: an INSTANT custom tooltip (no native <abbr>
     title delay). Definition rides in .pa-pop, shown on hover/focus. */
  .pa{position:relative;text-decoration:underline dotted;
      text-decoration-color:#94a3b8;cursor:help}
  .pa>.pa-pop{display:none;position:absolute;bottom:100%;left:0;z-index:50;
      margin-bottom:3px;width:max-content;max-width:18rem;white-space:normal;
      border-radius:4px;background:#1e293b;color:#fff;
      padding:2px 6px;font-size:11px;font-weight:400;line-height:1.3}
  .pa:hover>.pa-pop,.pa:focus>.pa-pop,.pa:focus-within>.pa-pop{display:block}
  /* Compact view: the content column drives each row's height. The
     meta column (links + in-flight) is taken out of flow so it stops
     inflating the row track, then capped to the cell and scrolled. */
  .draft-compact .draft-meta{position:relative;min-height:0}
  .draft-compact .draft-meta>.draft-meta-inner{position:absolute;inset:0;
      overflow-y:auto;padding-right:2px}
  .draft-compact .draft-meta>.draft-meta-inner::-webkit-scrollbar{width:6px}
  .draft-compact .draft-meta>.draft-meta-inner::-webkit-scrollbar-thumb{
      background:#cbd5e1;border-radius:3px}
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />

<div x-data="draftDoc('{{ ref.ident }}')" x-init="init()">
  <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-xl font-semibold">{{ ref.title }}</h1>
      {% if ref.slug %}<span class="font-mono text-xs text-slate-400">draft:{{ ref.slug }}</span>{% endif %}
      {# Word count badge (proposal writing). Server-rendered initial
         value; polls /wordcount so it tracks edits. Amber when any
         section is over/under its meta.word_target. #}
      {% if wordcount %}
      <span class="ml-2 inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-xs"
            x-data="{ wc: {{ wordcount | tojson }} }"
            x-init="setInterval(async () => {
                       try {
                         const r = await fetch('/drafts/{{ ref.ident }}/wordcount');
                         if (r.ok) wc = await r.json();
                       } catch (e) {}
                     }, 15000)"
            :class="wc.flagged ? 'bg-amber-100 text-amber-800 border border-amber-300' : 'bg-slate-100 text-slate-600'"
            :title="wc.flagged ? wc.flagged + ' section(s) over/under target' : 'all sections within target'">
        <span x-text="wc.total + ' words'"></span>
        <template x-if="wc.flagged"><span x-text="'· ⚠ ' + wc.flagged"></span></template>
      </span>
      {% endif %}
    </div>
    <div class="flex items-center gap-3 text-xs">
      {# live-refresh indicator + the "you were typing, here's a manual refresh" pill #}
      <button x-show="stale" x-cloak @click="forceRefresh()"
              class="rounded bg-amber-100 border border-amber-300 px-2 py-0.5 text-amber-800 hover:bg-amber-200">
        document changed — refresh
      </button>
      <button @click="live = !live"
              class="flex items-center gap-1"
              :title="live ? 'live updates on — click to pause' : 'live updates paused'">
        <span class="inline-block h-2 w-2 rounded-full"
              :class="live ? 'bg-emerald-500' : 'bg-slate-300'"></span>
        <span class="text-slate-500" x-text="live ? 'live' : 'paused'"></span>
      </button>
      {# Compact: let each block's text drive its row height; the
         links/in-flight column is capped to it and scrolls internally. #}
      <button @click="toggleCompact()"
              class="flex items-center gap-1"
              :title="compact ? 'compact rows on — text drives height, links scroll' : 'compact rows off — tallest column drives height'">
        <span class="inline-block h-2 w-2 rounded-full"
              :class="compact ? 'bg-sky-500' : 'bg-slate-300'"></span>
        <span class="text-slate-500">compact</span>
      </button>
      {# Export. .docx downloads synchronously (toolchain-free, OMML math
         + Word endnotes). "download PDF" compiles on the web host and
         serves it, cached by the draft's version token — so it's always
         current (recompiles only after an edit) and the only slow hit is
         the first per version. "export →project" starts a background job
         that persists the PDF into the project workspace for the task
         page (durable artifact, not an ephemeral download). #}
      <a href="/drafts/{{ ref.ident }}/export.docx"
         class="text-slate-500 underline hover:text-slate-800">download .docx</a>
      <a href="/drafts/{{ ref.ident }}/pdf"
         class="text-slate-500 underline hover:text-slate-800">download PDF</a>
      <form method="post" action="/drafts/{{ ref.ident }}/export.pdf" class="inline">
        <button type="submit" class="text-slate-500 underline hover:text-slate-800">export →project</button>
      </form>
      <a href="/drafts" class="text-slate-500 underline hover:text-slate-800">all drafts</a>
      {# Delete the whole draft. Two-step: a button reveals a type-the-name
         confirm (the server re-checks the name and soft-deletes the ref +
         retires its chunks in one transaction). The owning project stays. #}
      <div class="relative" x-data="{ del: false }" @click.outside="del = false">
        <button @click="del = !del"
                class="text-rose-500 underline hover:text-rose-700">delete</button>
        <form x-show="del" x-cloak method="post"
              action="/drafts/{{ ref.ident }}/delete"
              @submit="if (!confirm('Delete this draft? It can be recovered by an admin, but disappears from the app.')) $event.preventDefault()"
              class="absolute right-0 z-40 mt-1 w-72 space-y-1.5 rounded border border-rose-300 bg-white p-2 text-left shadow-lg">
          <p class="text-[11px] text-slate-600">Type the draft name
            <span class="font-semibold text-slate-800">{{ ref.title }}</span>
            to delete it (recoverable):</p>
          <input name="confirm" autocomplete="off" placeholder="draft name…"
                 class="w-full rounded border border-slate-200 px-2 py-1 text-xs focus:border-rose-400 focus:outline-none" />
          <div class="flex items-center gap-2">
            <button class="rounded bg-rose-600 px-2 py-0.5 text-[11px] text-white hover:bg-rose-700">delete draft</button>
            <button type="button" @click="del = false" class="text-[10px] text-slate-400 hover:text-slate-600">cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  {# Work in progress — stuck / in-flight todos working on this draft
     (walked draft→project→subtree). A failed enrichment job otherwise
     parks its parent silently and never shows up against the draft. #}
  {% if work %}
  <div class="mb-3 rounded border border-amber-200 bg-amber-50 px-3 py-2 text-xs">
    <div class="mb-1 font-semibold text-amber-800">Work in progress</div>
    <ul class="space-y-0.5">
      {% for w in work %}
      <li class="flex flex-wrap items-center gap-2">
        {% if w.blocked %}
        <span class="rounded bg-red-100 px-1.5 py-0.5 font-medium text-red-700">⚠ blocked</span>
        {% else %}
        <span class="rounded bg-sky-100 px-1.5 py-0.5 font-medium text-sky-700">⚙ in flight</span>
        {% endif %}
        <a href="/tasks/{{ w.todo_id }}" class="font-mono text-slate-500 hover:text-slate-800">todo:{{ w.todo_id }}</a>
        <span class="text-slate-700">{{ w.title }}</span>
        {% for j in w.jobs %}
        <span class="font-mono text-slate-400">job:{{ j.id }} {{ j.status }}</span>
        {% endfor %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {# Figure clearance (ADR 0034 §4) — a top warning when any figure is not
     cleared to ship; an all-clear note rides at the very end. #}
  {% if clearance and clearance.uncleared %}
  <div class="mb-3 rounded border border-rose-300 bg-rose-50 px-3 py-2 text-xs">
    <div class="mb-1 font-semibold text-rose-800">
      ⚠ {{ clearance.uncleared | length }} of {{ clearance.total }} figure(s) not cleared to ship
    </div>
    <ul class="space-y-0.5">
      {% for f in clearance.uncleared %}
      <li class="flex flex-wrap items-center gap-2">
        <a href="/c/{{ f.dc }}" class="font-mono text-rose-700 hover:underline">{{ f.dc }}</a>
        <span class="text-slate-700">{{ f.caption }}</span>
        <span class="text-rose-600">— {{ f.reason }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {# In-draft find bar — verbatim (Ctrl-F over the prose, doc order) vs
     semantic (cosine-ranked over this draft's embeddings). ‹ › cycle the
     matches starting from whatever is currently in view; a hit in a
     collapsed section auto-expands its ancestors. #}
  <div class="sticky top-0 z-30 -mx-2 mb-2 flex flex-wrap items-center gap-2
              border-b border-slate-200 bg-white px-2 py-2 text-xs shadow-sm">
    <input x-model="findQuery" @input.debounce.300ms="runFind()"
           @keydown.enter.prevent="findHits.length ? findNext() : runFind()"
           @keydown.escape="clearFind()"
           placeholder="find in document…"
           class="w-64 rounded border border-slate-200 px-2 py-1 focus:border-sky-400 focus:outline-none" />
    <div class="flex items-center rounded border border-slate-200 p-0.5">
      <template x-for="opt in ['verbatim', 'semantic']" :key="opt">
        <button @click="setFindMode(opt)" class="px-1.5 py-0.5 rounded capitalize"
                :class="findMode === opt ? 'bg-slate-700 text-white' : 'text-slate-500 hover:text-slate-800'"
                x-text="opt"></button>
      </template>
    </div>
    <button @click="findPrev()" :disabled="!findHits.length"
            class="rounded border border-slate-200 px-1.5 py-0.5 disabled:opacity-30" title="previous match">‹</button>
    <button @click="findNext()" :disabled="!findHits.length"
            class="rounded border border-slate-200 px-1.5 py-0.5 disabled:opacity-30" title="next match">›</button>
    <span class="text-slate-400" x-show="findQuery" x-cloak
          x-text="findHits.length ? (findIdx + 1) + '/' + findHits.length : 'no matches'"></span>
    {# View slider (body / summary / keywords — 3-stop, persisted per draft)
       + collapse controls live here so they float with the find bar. #}
    <div class="ml-auto flex items-center gap-2">
      <div class="flex items-center rounded border border-slate-200 p-0.5">
        <template x-for="opt in ['body', 'summary', 'keywords']" :key="opt">
          <button @click="setView(opt)"
                  class="px-1.5 py-0.5 rounded capitalize"
                  :class="view === opt ? 'bg-slate-700 text-white' : 'text-slate-500 hover:text-slate-800'"
                  x-text="opt"></button>
        </template>
      </div>
      <button @click="collapseAll()" class="text-slate-500 underline hover:text-slate-800">collapse all</button>
      <button @click="expandAll()" class="text-slate-500 underline hover:text-slate-800">expand all</button>
    </div>
  </div>

  {# Column legend #}
  <div class="hidden lg:grid lg:grid-cols-[1fr_20%_22%] gap-3 border-b border-slate-200 pb-1 mb-1
              text-[10px] uppercase tracking-wide text-slate-400">
    <div>Document</div><div>Links &amp; in-flight</div><div>Request a change</div>
  </div>

  {# Virtual scroller: only the on-screen window of rows lives in the DOM.
     #dr-top / #dr-bot are sized spacers standing in for the off-screen
     blocks (so the scrollbar is right); #dr-win holds the live rows. The
     first window is server-rendered (correct + visible even with JS off);
     the skeleton below drives windowing for everything else. #}
  <div id="doc" :class="compact ? 'draft-compact' : ''">
    <div id="dr-top" style="height:0px"></div>
    <div id="dr-win">
      {% from "drafts/_row.html.j2" import draft_row %}
      {% for r in window_rows %}{{ draft_row(r, ref) }}{% endfor %}
    </div>
    <div id="dr-bot" style="height:{{ botpad }}px"></div>
  </div>
  <script type="application/json" id="dr-skel">{{ skeleton | tojson }}</script>

  {# All-clear note at the very end — shown only when there are figures and
     every one is cleared to ship (ADR 0034 §4). #}
  {% if clearance and clearance.all_clear %}
  <div class="mt-3 rounded border border-emerald-300 bg-emerald-50 px-3 py-2 text-xs text-emerald-800">
    ✓ all {{ clearance.total }} figure(s) cleared to ship.
  </div>
  {% endif %}
</div>

<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
  onload="window.__renderDocMath && window.__renderDocMath()"></script>
<script>
function __renderMath(el) {
  if (!window.renderMathInElement || !el) return;
  renderMathInElement(el, {
    delimiters: [{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}],
    throwOnError: false,
  });
}
function __renderDocMath() { __renderMath(document.getElementById('doc')); }

// Hover popovers load lazily via htmx AFTER the initial KaTeX pass, so
// render math in each popover fragment as it swaps in (the cited quote
// has $…$ too). The swap target is the .ref-popover span.
document.body.addEventListener('htmx:afterSwap', function (e) {
  const t = (e.detail && e.detail.target) || e.target;
  if (t && t.classList && t.classList.contains('ref-popover')) __renderMath(t);
});

// Per-draft viewer — a TRUE virtual scroller. Only the on-screen window of
// rows lives in the DOM (fetched via /rows?handles=…); #dr-top / #dr-bot are
// sized spacers standing in for the off-screen blocks. A `skel` (one tiny
// record per block) drives which blocks are where. This is what keeps a
// 10k-block draft to ~a screenful of nodes instead of 10k — the prior
// approach (a DOM node per block) made the browser style/lay-out/Alpine-walk
// all of them ("works but with a minute lag").
function draftDoc(ident) {
  const key = 'draft-collapsed:' + ident;
  return {
    ident,
    version: 0,
    live: true,
    stale: false,
    view: localStorage.getItem('draft-view:' + ident) || 'body',
    setView(v) {
      if (v === this.view) return;
      // Each view renders blocks at a different height (body paragraph vs a
      // one-line summary / keyword list), so the *measured* heights are
      // view-specific — keeping them would leave the scroller sized for the
      // old view (the bug: summary/keywords stopped scrolling, bottom blank).
      // Drop them, re-window on the view-aware estimates, then re-measure the
      // on-screen rows once Alpine has toggled the columns. Anchor-preserve
      // so the row under the reader stays put across the height change.
      const a = this._anchor();
      this.view = v;
      localStorage.setItem('draft-view:' + this.ident, v);
      this.heights = {};
      this.recum();
      this.$nextTick(() => {
        this._remeasureWin();
        this.recum();
        this.render();
        this._restore(a);
      });
    },
    // Re-measure every *hydrated* row currently in #dr-win into `heights`
    // (placeholders keep their estimate). Used after a view switch and on
    // first paint when a non-body view is persisted.
    _remeasureWin() {
      const win = document.getElementById('dr-win');
      for (const node of win.children) {
        if (node.dataset && node.dataset.ph) continue;
        const h = node.id.slice(2);
        this.heights[h] = node.offsetHeight || this.heights[h] || 0;
      }
    },
    compact: localStorage.getItem('draft-compact:' + ident) !== '0',
    toggleCompact() {
      this.compact = !this.compact;
      localStorage.setItem('draft-compact:' + ident, this.compact ? '1' : '0');
    },
    findQuery: '',
    findMode: 'verbatim',
    findHits: [],
    findIdx: -1,
    collapsed: JSON.parse(localStorage.getItem(key) || '[]'),
    save() { localStorage.setItem(key, JSON.stringify(this.collapsed)); },

    // ── virtual-scroll state ─────────────────────────────────────
    skel: [],        // all blocks: {h,dc,kind,depth,anc,heading,title,est}
    vis: [],         // collapse-filtered blocks, in document order
    cum: [0],        // cum[i] = px offset of vis[i] from top of #doc
    heights: {},     // h -> measured px (falls back to est)
    nodes: {},       // h -> live row node (only those currently in #dr-win)
    lo: 0, hi: -1,   // current rendered window = vis[lo..hi]
    _inflight: {},
    _raf: null,
    MARGIN: 1000,    // px of off-screen overscan kept rendered

    esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; },
    // Per-view height estimate for an un-measured block. Body uses the
    // length-derived estimate; summary / keywords collapse each block to a
    // single line (estS), so reusing the body estimate over-reserves space
    // and strands the bottom of the doc behind a giant spacer.
    _est(b) { return (this.view !== 'body' && b.estS != null) ? b.estS : b.est; },
    _h(i) { const b = this.vis[i]; return (b && (this.heights[b.h] || this._est(b))) || 0; },
    rebuildVis() {
      const set = new Set(this.collapsed);
      this.vis = this.skel.filter((b) => !b.anc.some((a) => set.has(a)));
      this.recum();
    },
    recum() {
      const c = new Array(this.vis.length + 1); c[0] = 0;
      for (let i = 0; i < this.vis.length; i++) c[i + 1] = c[i] + this._h(i);
      this.cum = c;
    },
    total() { return this.cum[this.vis.length] || 0; },
    // first visible index whose BOTTOM is below y (binary search on cum)
    idxAt(y) {
      let lo = 0, hi = this.vis.length;
      while (lo < hi) { const m = (lo + hi) >> 1; if (this.cum[m + 1] <= y) lo = m + 1; else hi = m; }
      return Math.max(0, Math.min(lo, this.vis.length - 1));
    },
    _docY() { return document.getElementById('doc').getBoundingClientRect().top + window.scrollY; },
    setPads() {
      const top = document.getElementById('dr-top'), bot = document.getElementById('dr-bot');
      top.style.height = this.cum[Math.max(0, this.lo)] + 'px';
      const end = this.hi >= 0 ? this.cum[this.hi + 1] : 0;
      bot.style.height = Math.max(0, this.total() - end) + 'px';
    },
    // The topmost rendered block touching the viewport + its screen-y —
    // captured before a height/pad change and restored after, so measuring
    // or collapsing never makes the page jump under the reader.
    _anchor() {
      const win = document.getElementById('dr-win');
      for (const c of win.children) {
        const r = c.getBoundingClientRect();
        if (r.bottom > 0) return { h: c.id.slice(2), y: r.top };
      }
      return null;
    },
    _restore(a) {
      if (!a) return;
      const el = document.getElementById('c-' + a.h);
      if (!el) return;
      const d = el.getBoundingClientRect().top - a.y;
      if (Math.abs(d) > 0.5) window.scrollBy(0, d);
    },
    makePlaceholder(b) {
      const ph = document.createElement('div');
      ph.id = 'c-' + b.h;
      ph.dataset.ph = '1';
      ph.dataset.handle = b.h;
      ph.dataset.anc = JSON.stringify(b.anc);
      if (b.heading) ph.dataset.heading = b.h;
      ph.style.minHeight = (this.heights[b.h] || this._est(b)) + 'px';
      ph.className = 'dr-block grid grid-cols-1 lg:grid-cols-[1fr_20%_22%] '
        + 'gap-3 py-1.5 border-b border-slate-100 scroll-mt-4';
      if (b.heading) {
        const sz = b.depth === 0 ? 'text-lg' : (b.depth === 1 ? 'text-base' : 'text-sm');
        ph.innerHTML = '<div style="padding-left:' + b.depth + 'rem">'
          + '<div class="flex items-start gap-1.5">'
          + '<button data-toggle="' + b.h + '" class="dr-toggle mt-0.5 font-mono text-xs '
          + 'text-slate-400 hover:text-slate-700 select-none">'
          + (this.collapsed.includes(b.h) ? '▸' : '▾') + '</button>'
          + '<h3 class="font-semibold text-slate-900 ' + sz + '">' + this.esc(b.title) + '</h3>'
          + '</div></div><div></div><div></div>';
      } else {
        ph.innerHTML = '<div></div><div></div><div></div>';
      }
      return ph;
    },
    // Reconcile #dr-win to exactly the blocks intersecting the viewport
    // (± MARGIN). Reuses existing nodes (no Alpine churn for blocks that
    // stay); only entering/leaving blocks touch the DOM.
    render() {
      const win = document.getElementById('dr-win');
      if (!this.vis.length) { win.replaceChildren(); this.lo = 0; this.hi = -1; this.setPads(); return; }
      const top = window.scrollY - this._docY() - this.MARGIN;
      const bot = window.scrollY - this._docY() + window.innerHeight + this.MARGIN;
      const lo = this.idxAt(Math.max(0, top));
      const hi = this.idxAt(Math.max(0, bot));
      const need = this.vis.slice(lo, hi + 1);
      const needSet = new Set(need.map((b) => b.h));
      for (const child of [...win.children]) {
        const h = child.id.slice(2);
        if (!needSet.has(h)) { win.removeChild(child); delete this.nodes[h]; }
      }
      const toHydrate = [];
      for (let j = 0; j < need.length; j++) {
        const b = need[j];
        const existing = win.children[j];
        if (existing && existing.id === 'c-' + b.h) continue;
        let node = this.nodes[b.h];
        if (!node) { node = this.makePlaceholder(b); toHydrate.push(b.h); }
        win.insertBefore(node, existing || null);
      }
      this.lo = lo; this.hi = hi;
      this.setPads();
      if (toHydrate.length) this.hydrate(toHydrate);
    },
    hydrate(hs) {
      const todo = hs.filter((h) => !this._inflight[h]);
      if (!todo.length) return Promise.all(hs.map((h) => this._inflight[h]).filter((x) => x && x.then));
      const qs = todo.map(encodeURIComponent).join(',');
      const p = fetch(`/drafts/${this.ident}/rows?handles=${qs}`, {cache: 'no-store'})
        .then((r) => r.text()).then((html) => {
          const tpl = document.createElement('template'); tpl.innerHTML = html.trim();
          const a = this._anchor();
          [...tpl.content.children].forEach((node) => {
            const h = node.id.slice(2);
            const ph = document.getElementById(node.id);
            if (ph && ph.dataset.ph && ph.parentElement) {
              ph.replaceWith(node);                  // Alpine binds via MutationObserver
              this.nodes[h] = node;
              if (window.htmx) window.htmx.process(node);
              __renderMath(node);
              this.heights[h] = node.offsetHeight || this.heights[h] || 0;
            }
          });
          this.recum(); this.setPads(); this._restore(a);
          if (this.findQuery.trim()) this._markHits();
        }).catch(() => {}).finally(() => { todo.forEach((h) => { delete this._inflight[h]; }); });
      todo.forEach((h) => { this._inflight[h] = p; });
      return p;
    },
    onScroll() {
      if (this._raf) return;
      this._raf = requestAnimationFrame(() => { this._raf = null; this.render(); });
    },
    // ── collapse (recompute the visible set, re-window) ──────────
    toggle(h) {
      const a = this._anchor();
      const i = this.collapsed.indexOf(h);
      if (i >= 0) this.collapsed.splice(i, 1); else this.collapsed.push(h);
      this.save();
      const btn = document.querySelector('[data-toggle="' + (window.CSS ? CSS.escape(h) : h) + '"]');
      if (btn) btn.textContent = this.collapsed.includes(h) ? '▸' : '▾';
      this.rebuildVis(); this.render(); this._restore(a);
    },
    collapseAll() {
      this.collapsed = this.skel.filter((b) => b.heading).map((b) => b.h);
      this.save(); this.rebuildVis(); window.scrollTo(0, 0); this.render();
    },
    expandAll() { this.collapsed = []; this.save(); this.rebuildVis(); this.render(); },
    // Make block h visible: expand its ancestors, scroll it into view,
    // render the window there, and hydrate it. Used by find + deep-link.
    ensureVisible(h) {
      const b = this.skel.find((x) => x.h === h);
      if (!b) return Promise.resolve();
      let changed = false;
      b.anc.forEach((a) => {
        const i = this.collapsed.indexOf(a);
        if (i >= 0) { this.collapsed.splice(i, 1); changed = true; }
      });
      if (changed) { this.save(); this.rebuildVis(); }
      const idx = this.vis.findIndex((x) => x.h === h);
      if (idx < 0) return Promise.resolve();
      window.scrollTo(0, Math.max(0, this._docY() + this.cum[idx] - 100));
      this.render();
      const el = document.getElementById('c-' + h);
      if (el && el.dataset.ph) return this.hydrate([h]).then(() => { this.render(); });
      return Promise.resolve();
    },
    // back-compat alias used by find/deep-link
    ensureLoaded(h) { return this.ensureVisible(h); },
    // ── in-draft find ────────────────────────────────────────────
    setFindMode(m) { this.findMode = m; if (this.findQuery.trim()) this.runFind(); },
    _clearMarks() {
      document.querySelectorAll('#doc .find-hit, #doc .find-current')
        .forEach((e) => e.classList.remove('find-hit', 'find-current'));
      this._clearWordMarks();
    },
    _clearWordMarks() {
      document.querySelectorAll('#doc mark.find-word').forEach((m) => {
        m.replaceWith(document.createTextNode(m.textContent));
      });
    },
    _markWord(handle) {
      // Wrap each verbatim match of the query in <mark> inside the block's
      // content column — so the actual word is highlighted, not just the
      // block banded. Walks text nodes (skips tooltips / existing marks).
      const row = document.getElementById('c-' + handle);
      const el = row && row.querySelector('[data-content]');
      const q = this.findQuery.trim().toLowerCase();
      if (!el || !q) return;
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
        acceptNode: (n) =>
          n.nodeValue && n.nodeValue.toLowerCase().includes(q)
          && !n.parentElement.closest('.pa-pop, mark.find-word, script, style')
            ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT,
      });
      const nodes = [];
      while (walker.nextNode()) nodes.push(walker.currentNode);
      nodes.forEach((node) => {
        const text = node.nodeValue, low = text.toLowerCase();
        const frag = document.createDocumentFragment();
        let i = 0, p;
        while ((p = low.indexOf(q, i)) !== -1) {
          if (p > i) frag.append(document.createTextNode(text.slice(i, p)));
          const mk = document.createElement('mark');
          mk.className = 'find-word';
          mk.textContent = text.slice(p, p + q.length);
          frag.append(mk);
          i = p + q.length;
        }
        if (i < text.length) frag.append(document.createTextNode(text.slice(i)));
        node.replaceWith(frag);
      });
    },
    _markHits() {
      // Verbatim = band EVERY match (Ctrl-F style) AND highlight the
      // matched word inside each block. Semantic returns a long
      // cosine-ranked list, so banding all of it would light up most of
      // the doc — there we only ring the current result and step
      // through best-first with ‹ ›.
      if (this.findMode !== 'verbatim') return;
      this.findHits.forEach((h) => {
        const e = document.getElementById('c-' + h);
        if (e && !e.dataset.ph) e.classList.add('find-hit');  // skip inert placeholders
        this._markWord(h);
      });
    },
    clearFind() { this.findQuery = ''; this.findHits = []; this.findIdx = -1; this._clearMarks(); },
    async runFind() {
      this._clearMarks();
      const q = this.findQuery.trim();
      if (!q) { this.findHits = []; this.findIdx = -1; return; }
      let data;
      try {
        const url = `/drafts/${this.ident}/find?q=${encodeURIComponent(q)}&mode=${this.findMode}`;
        data = await (await fetch(url, {cache: 'no-store'})).json();
      } catch (e) { return; }
      this.findHits = data.handles || [];
      this.findMode = data.mode || this.findMode;  // reflect a semantic→verbatim degrade
      this._markHits();
      if (!this.findHits.length) { this.findIdx = -1; return; }
      this.gotoHit(this._startIdx());
    },
    _startIdx() {
      // Start at the first match at/below the current scroll position
      // (using skeleton offsets, since most hits aren't in the DOM); wrap
      // to the first hit if none are below.
      const y = window.scrollY - this._docY();
      const pos = {};
      for (let i = 0; i < this.vis.length; i++) pos[this.vis[i].h] = this.cum[i];
      for (let i = 0; i < this.findHits.length; i++) {
        const o = pos[this.findHits[i]];
        if (o != null && o >= y) return i;
      }
      return 0;
    },
    async gotoHit(i) {
      const n = this.findHits.length;
      if (!n) return;
      this.findIdx = ((i % n) + n) % n;
      const h = this.findHits[this.findIdx];
      // expand ancestors + scroll the block into view + hydrate it.
      await this.ensureVisible(h);
      const el = document.getElementById('c-' + h);
      if (!el) return;
      this._clearMarks();
      this._markHits();
      el.classList.add('find-current');
      this.$nextTick(() => el.scrollIntoView({block: 'center', behavior: 'smooth'}));
    },
    findNext() { this.gotoHit(this.findIdx + 1); },
    findPrev() { this.gotoHit(this.findIdx - 1); },
    init() {
      // Run ONCE. Alpine auto-calls a data method named `init()` AND we have
      // `x-init="init()"`, so without this guard init runs twice — attaching
      // two delegated click listeners, so every caret click fires toggle()
      // twice and the fold cancels itself out (the "folding doesn't work" bug).
      if (this._inited) return;
      this._inited = true;
      // 1) load the skeleton (one tiny record per block).
      try { this.skel = JSON.parse(document.getElementById('dr-skel').textContent || '[]'); }
      catch (e) { this.skel = []; }
      // 2) adopt the server-rendered first window into the node cache +
      //    measure it (so the engine knows their real heights).
      const win = document.getElementById('dr-win');
      [...win.children].forEach((node) => {
        const h = node.id.slice(2);
        this.nodes[h] = node;
        this.heights[h] = node.offsetHeight || this.heights[h] || 0;
      });
      this.rebuildVis();
      // 3) delegated caret clicks (placeholders are inert; one handler for
      //    both placeholder and hydrated headings).
      const doc = document.getElementById('doc');
      doc.addEventListener('click', (e) => {
        const b = e.target.closest('[data-toggle]');
        if (b && doc.contains(b)) { e.preventDefault(); this.toggle(b.dataset.toggle); }
      });
      // 4) drive windowing off scroll + resize.
      this._onScroll = () => this.onScroll();
      window.addEventListener('scroll', this._onScroll, {passive: true});
      window.addEventListener('resize', this._onScroll, {passive: true});
      // 5) FIRST render + deep link AFTER Alpine finishes its init walk.
      //    render() reconciles #dr-win (removes server rows outside the
      //    viewport); doing that synchronously here mutates the DOM mid-walk,
      //    which orphaned the rows' Alpine scope (`view is not defined`) and
      //    left handlers bound to a stale component (collapse/scroll dead).
      //    $nextTick defers it until the tree is fully wired.
      this.$nextTick(async () => {
        // Server rows were measured (step 2) while the body column was the
        // only visible one — summary/keywords are x-cloak'd until Alpine
        // runs. If a non-body view is persisted, those heights are now wrong;
        // re-measure against the view Alpine just applied before windowing.
        if (this.view !== 'body') {
          this.heights = {};
          this._remeasureWin();
          this.recum();
        }
        this.render();
        const id = location.hash.slice(1);
        if (id && id.startsWith('c-')) await this.ensureVisible(id.slice(2));
      });
      this.startPoll();
    },
    async fetchVersion() {
      const r = await fetch(`/drafts/${this.ident}/version`, {cache: 'no-store'});
      return (await r.json()).version;
    },
    async startPoll() {
      try { this.version = await this.fetchVersion(); } catch (e) { /* offline */ }
      setInterval(() => this.tick(), 4000);
    },
    _typing() {
      const a = document.activeElement;
      return a && document.getElementById('doc').contains(a)
        && (a.tagName === 'INPUT' || a.tagName === 'TEXTAREA');
    },
    async tick() {
      if (!this.live) return;
      let v;
      try { v = await this.fetchVersion(); } catch (e) { return; }
      if (v === this.version) return;
      if (this._typing()) { this.stale = true; return; }  // defer; don't clobber
      await this.swapAll(v);
    },
    async forceRefresh() {
      let v;
      try { v = await this.fetchVersion(); } catch (e) { return; }
      await this.swapAll(v);
    },
    async swapAll(v) {
      try {
        // Refetch the skeleton (structure may have changed) and re-window.
        // Drop the node cache so changed/added blocks re-hydrate fresh; the
        // current scroll position is preserved by render() off scrollY.
        const data = await (await fetch(`/drafts/${this.ident}/skeleton`,
                                        {cache: 'no-store'})).json();
        this.skel = data.skeleton || [];
        document.getElementById('dr-win').replaceChildren();
        this.nodes = {};
        this.heights = {};
        this.rebuildVis();
        this.render();
        this.version = v;
        this.stale = false;
        if (this.findQuery.trim()) this.runFind();  // the swap wiped the marks
      } catch (e) { /* leave the page as-is on a failed fetch */ }
    },
  };
}
</script>
{% endblock %}
