      if (ac) { try { ac.update(); } catch (e) { /* never break editing */ } }
      if (tr.docChanged) {
        const text = docToText(ns.doc);
        opts.onChange && opts.onChange(text);
        clearTimeout(timer);
        timer = setTimeout(() => validate(view, text, opts.validateUrl), 350);
      }
