  // programmatically (caret handoff / split / merge), the just-revealed
  // contenteditable isn't focusable yet on this tick, so a lone view.focus()
  // silently no-ops and the block opens blurred (looks like it "didn't open").
  view.focus();
  requestAnimationFrame(() => { try { view.focus(); } catch (e) { /* torn down */ } });
  setTimeout(() => validate(view, seedText, opts.validateUrl), 40);
  return {
    getText() { return docToText(view.state.doc); },
    focus() { view.focus(); },
    destroy() { clearTimeout(timer); if (ac) ac.destroy(); view.destroy(); },
  };
};
