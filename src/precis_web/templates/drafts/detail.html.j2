{% extends "base.html.j2" %}
{% block title %}{{ ref.title }}{% endblock %}
{% block content %}
<style>
  [x-cloak]{display:none!important}
  /* collapse hides a block + its subtree imperatively (vanilla, no Alpine
     per-node binding — the reason a 10k-block draft stays responsive). */
  .dr-hidden{display:none!important}
  /* in-draft find: every match gets a soft band, the active one a ring */
  .find-hit{background-color:#fef9c3}
  .find-current{box-shadow:0 0 0 2px #f59e0b;border-radius:.25rem}
  mark.find-word{background:#fde047;color:inherit;border-radius:2px;padding:0 1px}
  /* abbreviation recall: an INSTANT custom tooltip (no native <abbr>
     title delay). Definition rides in .pa-pop, shown on hover/focus. */
  .pa{position:relative;text-decoration:underline dotted;
      text-decoration-color:#94a3b8;cursor:help}
  .pa>.pa-pop{display:none;position:absolute;bottom:100%;left:0;z-index:50;
      margin-bottom:3px;width:max-content;max-width:18rem;white-space:normal;
      border-radius:4px;background:#1e293b;color:#fff;
      padding:2px 6px;font-size:11px;font-weight:400;line-height:1.3}
  .pa:hover>.pa-pop,.pa:focus>.pa-pop,.pa:focus-within>.pa-pop{display:block}
  /* Compact view: the content column drives each row's height. The
     meta column (links + in-flight) is taken out of flow so it stops
     inflating the row track, then capped to the cell and scrolled. */
  .draft-compact .draft-meta{position:relative;min-height:0}
  .draft-compact .draft-meta>.draft-meta-inner{position:absolute;inset:0;
      overflow-y:auto;padding-right:2px}
  .draft-compact .draft-meta>.draft-meta-inner::-webkit-scrollbar{width:6px}
  .draft-compact .draft-meta>.draft-meta-inner::-webkit-scrollbar-thumb{
      background:#cbd5e1;border-radius:3px}
  /* A pa/pc ref hover-popover (`.ref-popover`, w-96) is far wider than this
     ~20% column. The compact scroll box above is `overflow-y:auto`, which
     (per CSS: one axis auto forces the other off `visible`) also CLIPS the X
     axis — so the card was cut off and painted under the "Request a change"
     column instead of popping over it. While a popover is actually open
     (Alpine `x-show` has NOT set inline `display:none`), drop the scroll box's
     clipping so the card escapes the column and can be read. Closed rows keep
     scrolling. */
  .draft-compact .draft-meta:has(.ref-popover:not([style*="display: none"]))
      >.draft-meta-inner{overflow:visible}
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />

<div x-data="draftDoc('{{ ref.ident }}')" x-init="init()">
  <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-xl font-semibold">{{ ref.title }}</h1>
      {# Author byline + affiliations (utils.authors.build_byline). Names
         carry superscript marks only when >1 distinct affiliation; each
         affiliation links to its ROR id when known. #}
      {% if ref.byline and ref.byline.authors %}
      <div class="mt-0.5 text-sm text-slate-700">
        {% for a in ref.byline.authors %}{% if not loop.first %}, {% endif %}{{ a.name }}{% if a.sup %}<sup>{{ a.sup }}</sup>{% endif %}{% endfor %}
      </div>
      {% if ref.byline.affiliations %}
      <div class="mt-0.5 text-xs italic text-slate-500">
        {% for aff in ref.byline.affiliations %}{% if not loop.first %} · {% endif %}{% if ref.byline.multi %}<sup>{{ aff.index }}</sup> {% endif %}{% if aff.ror %}<a href="{{ aff.ror }}" class="hover:underline" target="_blank" rel="noopener">{{ aff.org or aff.ror }}</a>{% else %}{{ aff.org }}{% endif %}{% endfor %}
      </div>
      {% endif %}
      {% endif %}
      {% if ref.slug %}<span class="font-mono text-xs text-slate-400">draft:{{ ref.slug }}</span>{% endif %}
      {# Word count badge (proposal writing). Server-rendered initial
         value; polls /wordcount so it tracks edits. Amber when any
         section is over/under its meta.word_target. #}
      {% if wordcount %}
      <span class="ml-2 inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-xs"
            {# forceescape: `tojson` emits double quotes that would terminate
               this double-quoted attribute (the classic broken-x-data bug);
               HTML-entity-escaping keeps the attribute intact and the browser
               decodes it back to valid JSON for Alpine. #}
            x-data="{ wc: {{ wordcount | tojson | forceescape }} }"
            x-init="setInterval(async () => {
                       try {
                         const r = await fetch('/drafts/{{ ref.ident }}/wordcount');
                         if (r.ok) wc = await r.json();
                       } catch (e) {}
                     }, 15000)"
            :class="wc.flagged ? 'bg-amber-100 text-amber-800 border border-amber-300' : 'bg-slate-100 text-slate-600'"
            :title="wc.flagged ? wc.flagged + ' section(s) over/under target' : 'all sections within target'">
        <span x-text="wc.total + ' words'"></span>
        <template x-if="wc.flagged"><span x-text="'· ⚠ ' + wc.flagged"></span></template>
      </span>
      {% endif %}
    </div>
    <div class="flex items-center gap-3 text-xs">
      {# live-refresh indicator + the "you were typing, here's a manual refresh" pill #}
      <button x-show="stale" x-cloak @click="forceRefresh()"
              class="rounded bg-amber-100 border border-amber-300 px-2 py-0.5 text-amber-800 hover:bg-amber-200">
        document changed — refresh
      </button>
      <button @click="live = !live"
              class="flex items-center gap-1"
              :title="live ? 'live updates on — click to pause' : 'live updates paused'">
        <span class="inline-block h-2 w-2 rounded-full"
              :class="live ? 'bg-emerald-500' : 'bg-slate-300'"></span>
        <span class="text-slate-500" x-text="live ? 'live' : 'paused'"></span>
      </button>
      {# Compact: let each block's text drive its row height; the
         links/in-flight column is capped to it and scrolls internally. #}
      <button @click="toggleCompact()"
              class="flex items-center gap-1"
              :title="compact ? 'compact rows on — text drives height, links scroll' : 'compact rows off — tallest column drives height'">
        <span class="inline-block h-2 w-2 rounded-full"
              :class="compact ? 'bg-sky-500' : 'bg-slate-300'"></span>
        <span class="text-slate-500">compact</span>
      </button>
      {# Export. .docx downloads synchronously (toolchain-free, OMML math
         + Word endnotes). "download PDF" compiles on the web host and
         serves it, cached by the draft's version token — so it's always
         current (recompiles only after an edit) and the only slow hit is
         the first per version. "export →project" starts a background job
         that persists the PDF into the project workspace for the task
         page (durable artifact, not an ephemeral download). #}
      <a href="/drafts/{{ ref.ident }}/export.docx"
         class="text-slate-500 underline hover:text-slate-800">download .docx</a>
      <a href="/drafts/{{ ref.ident }}/pdf"
         class="text-slate-500 underline hover:text-slate-800">download PDF</a>
      <form method="post" action="/drafts/{{ ref.ident }}/export.pdf" class="inline">
        <button type="submit" class="text-slate-500 underline hover:text-slate-800">export →project</button>
      </form>
      <a href="/drafts" class="text-slate-500 underline hover:text-slate-800">all drafts</a>
      {# Author byline editor — the web twin of edit(kind='draft',
         authors=…). One author per line, "Name | Affiliation | ROR"
         (affiliation + ROR optional). Replaces the whole byline; empty
         clears it. Prefilled from the current authors via
         _draft_author_lines. #}
      <div class="relative" x-data="{ au: false }" @click.outside="au = false">
        <button @click="au = !au"
                class="text-slate-500 underline hover:text-slate-800"
                title="edit the author byline + affiliations">authors ▾</button>
        <form x-show="au" x-cloak method="post"
              action="/drafts/{{ ref.ident }}/authors"
              class="absolute right-0 z-40 mt-1 w-96 space-y-2 rounded border border-slate-200 bg-white p-3 text-left shadow-lg">
          <div>
            <label class="block text-[11px] font-semibold text-slate-600">Authors — one per line</label>
            <textarea name="authors" rows="4"
                      placeholder="Doe, Jane | Massachusetts Institute of Technology | https://ror.org/042nb2s44&#10;Roe, John | Caltech&#10;Solo Author"
                      class="mt-0.5 w-full resize-y rounded border border-slate-200 px-2 py-1 font-mono text-xs leading-snug focus:border-sky-400 focus:outline-none">{{ author_lines }}</textarea>
            <p class="mt-0.5 text-[10px] text-slate-400"><span class="font-mono">Name | Affiliation | ROR</span> — affiliation + ROR optional; a shared ROR collapses to one numbered affiliation. Replaces the whole byline.</p>
          </div>
          <div class="flex items-center gap-2">
            <button class="rounded bg-sky-600 px-2 py-0.5 text-[11px] text-white hover:bg-sky-700">save authors</button>
            <button type="button" @click="au = false" class="text-[10px] text-slate-400 hover:text-slate-600">cancel</button>
          </div>
        </form>
      </div>
      {# Genre + project context (ADR 0037). Imported drafts never went
         through the /drafts/new picker, so doc_type/brief are unset — the
         per-heading "style ▾" picker stays empty and the planner has no
         "## Project context". This sets them after the fact (writes the
         draft + its project workspace). #}
      <div class="relative" x-data="{ gen: false }" @click.outside="gen = false">
        <button @click="gen = !gen"
                class="text-slate-500 underline hover:text-slate-800"
                title="set the document genre + project context">genre{% if cur_doctype %}: {{ cur_doctype }}{% endif %}</button>
        <form x-show="gen" x-cloak method="post"
              action="/drafts/{{ ref.ident }}/workspace"
              class="absolute right-0 z-40 mt-1 w-80 space-y-2 rounded border border-slate-200 bg-white p-3 text-left shadow-lg">
          <div>
            <label class="block text-[11px] font-semibold text-slate-600">Genre (document type)</label>
            <select name="doctype"
                    class="mt-0.5 w-full rounded border border-slate-200 px-2 py-1 text-xs focus:border-sky-400 focus:outline-none">
              <option value="" {% if not cur_doctype %}selected{% endif %}>— none —</option>
              {% for d in doctypes %}
              <option value="{{ d.value }}" {% if cur_doctype == d.value %}selected{% endif %}>{{ d.label }}</option>
              {% endfor %}
            </select>
            <p class="mt-0.5 text-[10px] text-slate-400">paper / patent / report / review unlock the per-heading style picker.</p>
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-slate-600">Project context (planner brief)</label>
            <textarea name="brief" rows="4"
                      placeholder="Standing guidance injected into every planner tick's ## Project context…"
                      class="mt-0.5 w-full resize-y rounded border border-slate-200 px-2 py-1 text-xs leading-snug focus:border-sky-400 focus:outline-none">{{ cur_brief }}</textarea>
          </div>
          <div class="flex items-center gap-2">
            <button class="rounded bg-sky-600 px-2 py-0.5 text-[11px] text-white hover:bg-sky-700">save</button>
            <button type="button" @click="gen = false" class="text-[10px] text-slate-400 hover:text-slate-600">cancel</button>
          </div>
        </form>
      </div>
      {# Delete the whole draft. Two-step: a button reveals a type-the-name
         confirm (the server re-checks the name and soft-deletes the ref +
         retires its chunks in one transaction). The owning project stays. #}
      <div class="relative" x-data="{ del: false }" @click.outside="del = false">
        <button @click="del = !del"
                class="text-rose-500 underline hover:text-rose-700">delete</button>
        <form x-show="del" x-cloak method="post"
              action="/drafts/{{ ref.ident }}/delete"
              @submit="if (!confirm('Delete this draft? It can be recovered by an admin, but disappears from the app.')) $event.preventDefault()"
              class="absolute right-0 z-40 mt-1 w-72 space-y-1.5 rounded border border-rose-300 bg-white p-2 text-left shadow-lg">
          <p class="text-[11px] text-slate-600">Type the draft name
            <span class="font-semibold text-slate-800">{{ ref.title }}</span>
            to delete it (recoverable):</p>
          <input name="confirm" autocomplete="off" placeholder="draft name…"
                 class="w-full rounded border border-slate-200 px-2 py-1 text-xs focus:border-rose-400 focus:outline-none" />
          <div class="flex items-center gap-2">
            <button class="rounded bg-rose-600 px-2 py-0.5 text-[11px] text-white hover:bg-rose-700">delete draft</button>
            <button type="button" @click="del = false" class="text-[10px] text-slate-400 hover:text-slate-600">cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  {# Work in progress — stuck / in-flight todos working on this draft
     (walked draft→project→subtree). A failed enrichment job otherwise
     parks its parent silently and never shows up against the draft. #}
  {% if work %}
  <div class="mb-3 rounded border border-amber-200 bg-amber-50 px-3 py-2 text-xs">
    <div class="mb-1 font-semibold text-amber-800">Work in progress</div>
    <ul class="space-y-0.5">
      {% for w in work %}
      <li class="flex flex-wrap items-center gap-2">
        {% if w.asks %}
        <span class="rounded bg-amber-200 px-1.5 py-0.5 font-medium text-amber-900">✋ needs you</span>
        {% elif w.blocked %}
        <span class="rounded bg-red-100 px-1.5 py-0.5 font-medium text-red-700">⚠ blocked</span>
        {% else %}
        <span class="rounded bg-sky-100 px-1.5 py-0.5 font-medium text-sky-700">⚙ in flight</span>
        {% endif %}
        <a href="/refs/todo/{{ w.todo_id }}" class="font-mono text-slate-500 hover:text-slate-800 hover:underline">todo:{{ w.todo_id }}</a>
        <span class="text-slate-700">{{ w.title }}</span>
        {% for j in w.jobs %}
        <a href="/refs/job/{{ j.id }}"
           class="font-mono hover:underline {% if j.status == 'failed' %}text-rose-600{% else %}text-slate-400 hover:text-slate-700{% endif %}">job:{{ j.id }} {{ j.status }}</a>
        {% endfor %}
      </li>
      {# Why a job failed — surfaced from its job_summary chunk so the
         operator sees the reason (API error, timeout, …) without opening
         the job. #}
      {% for j in w.jobs %}
      {% if j.reason %}
      <li class="ml-7 mb-1 text-rose-700">
        <a href="/refs/job/{{ j.id }}" class="font-mono text-rose-500 hover:underline">job:{{ j.id }}</a>
        — {{ j.reason }}
      </li>
      {% endif %}
      {% endfor %}
      {# Stuck-on-a-question: show the ask + an inline answer box, so the
         operator unblocks the work right here instead of hunting the Asks
         tab. Submits to the shared /asks answer route (strips the ask-user
         tag, appends the answer) and returns to this draft. #}
      {% if w.asks %}
      <li class="ml-7 mb-1">
        <form method="post" action="/asks/{{ w.todo_id }}/answer" class="space-y-1">
          {% for a in w.asks %}
          <p class="text-amber-900">{% if a.question %}{{ a.question }}{% else %}<span class="italic text-slate-500">(any answer unblocks this)</span>{% endif %}</p>
          <input type="hidden" name="remove" value="{{ a.tag }}" />
          {% endfor %}
          <input type="hidden" name="next" value="/drafts/{{ ref.ident }}" />
          <div class="flex items-start gap-1">
            <input name="response" required placeholder="your answer…"
                   class="min-w-0 flex-1 rounded border border-amber-300 px-2 py-1 text-xs focus:border-amber-500 focus:outline-none" />
            <button class="shrink-0 rounded bg-amber-600 px-2 py-1 text-xs text-white hover:bg-amber-700">answer</button>
          </div>
        </form>
      </li>
      {% endif %}
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {# Figure clearance (ADR 0034 §4) — a top warning when any figure is not
     cleared to ship; an all-clear note rides at the very end. #}
  {% if clearance and clearance.uncleared %}
  <div class="mb-3 rounded border border-rose-300 bg-rose-50 px-3 py-2 text-xs">
    <div class="mb-1 font-semibold text-rose-800">
      ⚠ {{ clearance.uncleared | length }} of {{ clearance.total }} figure(s) not cleared to ship
    </div>
    <ul class="space-y-0.5">
      {% for f in clearance.uncleared %}
      <li class="flex flex-wrap items-center gap-2">
        <a href="/c/{{ f.dc }}" class="font-mono text-rose-700 hover:underline">{{ f.dc }}</a>
        <span class="text-slate-700">{{ f.caption }}</span>
        <span class="text-rose-600">— {{ f.reason }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {# In-draft find bar — verbatim (Ctrl-F over the prose, doc order) vs
     semantic (cosine-ranked over this draft's embeddings). ‹ › cycle the
     matches starting from whatever is currently in view; a hit in a
     collapsed section auto-expands its ancestors. #}
  <div class="sticky top-0 z-30 -mx-2 mb-2 flex flex-wrap items-center gap-2
              border-b border-slate-200 bg-white px-2 py-2 text-xs shadow-sm">
    <input x-model="findQuery" @input.debounce.300ms="runFind()"
           @keydown.enter.prevent="findHits.length ? findNext() : runFind()"
           @keydown.escape="clearFind()"
           placeholder="find in document…"
           class="w-64 rounded border border-slate-200 px-2 py-1 focus:border-sky-400 focus:outline-none" />
    <div class="flex items-center rounded border border-slate-200 p-0.5">
      <template x-for="opt in ['verbatim', 'semantic']" :key="opt">
        <button @click="setFindMode(opt)" class="px-1.5 py-0.5 rounded capitalize"
                :class="findMode === opt ? 'bg-slate-700 text-white' : 'text-slate-500 hover:text-slate-800'"
                x-text="opt"></button>
      </template>
    </div>
    <button @click="findPrev()" :disabled="!findHits.length"
            class="rounded border border-slate-200 px-1.5 py-0.5 disabled:opacity-30" title="previous match">‹</button>
    <button @click="findNext()" :disabled="!findHits.length"
            class="rounded border border-slate-200 px-1.5 py-0.5 disabled:opacity-30" title="next match">›</button>
    <span class="text-slate-400" x-show="findQuery" x-cloak
          x-text="findHits.length ? (findIdx + 1) + '/' + findHits.length : 'no matches'"></span>
    {# View slider (body / summary / keywords — 3-stop, persisted per draft)
       + collapse controls live here so they float with the find bar. #}
    <div class="ml-auto flex items-center gap-2">
      <div class="flex items-center rounded border border-slate-200 p-0.5">
        <template x-for="opt in ['body', 'summary', 'keywords']" :key="opt">
          <button @click="setView(opt)"
                  class="px-1.5 py-0.5 rounded capitalize"
                  :class="view === opt ? 'bg-slate-700 text-white' : 'text-slate-500 hover:text-slate-800'"
                  x-text="opt"></button>
        </template>
      </div>
      <button @click="collapseAll()" class="text-slate-500 underline hover:text-slate-800">collapse all</button>
      <button @click="expandAll()" class="text-slate-500 underline hover:text-slate-800">expand all</button>
    </div>
  </div>

  {# Column legend #}
  <div class="hidden lg:grid lg:grid-cols-[1fr_20%_22%] gap-3 border-b border-slate-200 pb-1 mb-1
              text-[10px] uppercase tracking-wide text-slate-400">
    <div>Document</div><div>Links &amp; in-flight</div><div>Request a change</div>
  </div>

  {# Virtual scroller: only the on-screen window of rows lives in the DOM.
     #dr-top / #dr-bot are sized spacers standing in for the off-screen
     blocks (so the scrollbar is right); #dr-win holds the live rows. The
     first window is server-rendered (correct + visible even with JS off);
     the skeleton below drives windowing for everything else. #}
  {# Transient note after an inline edit (soft warnings / "saved"). #}
  <div x-show="editToast" x-cloak x-transition
       class="fixed bottom-4 right-4 z-50 max-w-sm rounded bg-slate-800 px-3 py-2 text-xs text-white shadow-lg"
       x-text="editToast"></div>
  <div id="doc" :class="compact ? 'draft-compact' : ''">
    <div id="dr-top" style="height:0px"></div>
    <div id="dr-win">
      {% from "drafts/_row.html.j2" import draft_row %}
      {% for r in window_rows %}{{ draft_row(r, ref) }}{% endfor %}
    </div>
    <div id="dr-bot" style="height:{{ botpad }}px"></div>
  </div>
  <script type="application/json" id="dr-skel">{{ skeleton | tojson }}</script>

  {# All-clear note at the very end — shown only when there are figures and
     every one is cleared to ship (ADR 0034 §4). #}
  {% if clearance and clearance.all_clear %}
  <div class="mt-3 rounded border border-emerald-300 bg-emerald-50 px-3 py-2 text-xs text-emerald-800">
    ✓ all {{ clearance.total }} figure(s) cleared to ship.
  </div>
  {% endif %}
</div>

<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
  onload="window.__renderDocMath && window.__renderDocMath()"></script>

{# Inline rich editor (slice 2b-ii): a per-block ProseMirror surface with a
   live red squiggle on references that don't resolve. It edits raw source
   (refs / $…$ stay literal text — reveal-on-cursor is a later polish) and
   mirrors its text into the block's hidden <textarea>, so the existing save /
   validate flow is unchanged. If the module fails to load or mount, the row
   falls back to that plain textarea (today's behaviour) — so this can only
   add, never regress. #}
<style>
  .pm-editor { border: 1px solid #7dd3fc; background: #fff; border-radius: 0.375rem;
               padding: 0.5rem; }
  .pm-editor .ProseMirror { white-space: pre-wrap; word-wrap: break-word; outline: none;
               min-height: 3.25rem; font: 13px/1.4 ui-monospace, SFMono-Regular, Menlo, monospace;
               color: #1e293b; }
  .pm-editor .ProseMirror:focus { outline: none; }
  .pm-editor .pm-block { min-height: 1.4em; }
  /* dangling-reference squiggle — a distinct wavy rose underline (NOT the
     browser's spellcheck red, and NOT the amber link chips). */
  .ref-bad { text-decoration: underline wavy #f43f5e; text-underline-offset: 3px; }
  /* reveal-on-cursor: a reference token shows as a subtle chip unless the caret
     is inside it (then it's raw, for editing). A broken ref keeps its squiggle. */
  .ref-chip { background: #eff6ff; color: #0369a1; border-radius: 3px;
              padding: 0 2px; box-decoration-break: clone; -webkit-box-decoration-break: clone; }
  .ref-chip.ref-bad { color: #be123c; }
  /* `[` citation autocomplete dropdown (positioned at the caret, on <body>). */
  .pm-ac { position: absolute; z-index: 60; max-width: 30rem; max-height: 16rem;
           overflow-y: auto; background: #fff; border: 1px solid #cbd5e1;
           border-radius: 0.375rem; box-shadow: 0 4px 14px rgba(0,0,0,0.12); }
  .pm-ac-item { display: flex; gap: 0.5rem; align-items: baseline;
                padding: 0.25rem 0.6rem; cursor: pointer; }
  .pm-ac-item.pm-ac-sel, .pm-ac-item:hover { background: #e0f2fe; }
  .pm-ac-label { color: #1e293b; font-size: 12px; overflow: hidden;
                 text-overflow: ellipsis; white-space: nowrap; }
  .pm-ac-sub { color: #94a3b8; font-family: ui-monospace, monospace; font-size: 11px;
               flex-shrink: 0; }
</style>
<script type="module">
import * as PM from '/static/prosemirror.bundle.mjs';
const { EditorState, EditorView, Schema, keymap, baseKeymap, TextSelection,
        history, undo, redo, Plugin, PluginKey, Decoration, DecorationSet } = PM;

// One block of plain text; newlines are hard_breaks (preserved verbatim on
// serialize). Round-trip is identity (tests/headless-verified) so an edit
// never mangles the source.
const schema = new Schema({ nodes: {
  doc: { content: 'block' },
  block: { content: 'inline*', toDOM: () => ['div', { class: 'pm-block' }, 0] },
  text: { group: 'inline' },
