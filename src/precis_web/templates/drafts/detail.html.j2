              schema.nodes.hard_break.create()).scrollIntoView());
            return true;
          },
          // Arrow past the top/bottom line hands off to the neighbouring block
          // (or moves the `[` picker selection when it's open).
          'ArrowUp': (state, dispatch, view) => {
            if (ac && ac.key('up')) return true;
            if (view && view.endOfTextblock('up')) { opts.onLeave && opts.onLeave('up'); return true; }
            return false;
          },
          'ArrowDown': (state, dispatch, view) => {
            if (ac && ac.key('down')) return true;
            if (view && view.endOfTextblock('down')) { opts.onLeave && opts.onLeave('down'); return true; }
            return false;
          },
          // Backspace at the very start merges this block into the previous one
          // (an empty block just gets deleted; caret lands at the join point).
          'Backspace': (state) => {
            const sel = state.selection;
