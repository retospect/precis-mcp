      const h = this.findHits[this.findIdx];
      // expand ancestors + scroll the block into view + hydrate it.
      await this.ensureVisible(h);
      const el = document.getElementById('c-' + h);
      if (!el) return;
      this._clearMarks();
      this._markHits();
      el.classList.add('find-current');
      this.$nextTick(() => el.scrollIntoView({block: 'center', behavior: 'smooth'}));
    },
    findNext() { this.gotoHit(this.findIdx + 1); },
    findPrev() { this.gotoHit(this.findIdx - 1); },
    init() {
      // Run ONCE. Alpine auto-calls a data method named `init()` AND we have
      // `x-init="init()"`, so without this guard init runs twice — attaching
      // two delegated click listeners, so every caret click fires toggle()
      // twice and the fold cancels itself out (the "folding doesn't work" bug).
      if (this._inited) return;
      this._inited = true;
      // 1) load the skeleton (one tiny record per block).
      try { this.skel = JSON.parse(document.getElementById('dr-skel').textContent || '[]'); }
      catch (e) { this.skel = []; }
      // 2) adopt the server-rendered first window into the node cache +
      //    measure it (so the engine knows their real heights).
      const win = document.getElementById('dr-win');
      [...win.children].forEach((node) => {
        const h = node.id.slice(2);
        this.nodes[h] = node;
        this.heights[h] = node.offsetHeight || this.heights[h] || 0;
      });
      this.rebuildVis();
      // 3) delegated caret clicks (placeholders are inert; one handler for
      //    both placeholder and hydrated headings).
      const doc = document.getElementById('doc');
      doc.addEventListener('click', (e) => {
        const b = e.target.closest('[data-toggle]');
        if (b && doc.contains(b)) { e.preventDefault(); this.toggle(b.dataset.toggle); }
      });
      // Inline edit saved → re-hydrate just that block in place + flash a note
      // (the row's own editor component can't do this: its node is replaced).
      window.addEventListener('draft:edited', (e) => {
        const h = e.detail && e.detail.handle;
        if (h) this.rehydrateOne(h);
        const w = (e.detail && e.detail.warnings) || [];
        this.flashEdit(w.length ? ('saved · ' + w.join(' · ')) : 'saved');
      });
      // Inline add / delete of a block (no LLM): rebuild the skeleton so the
      // structural change shows, then (for an add) auto-open the new block.
      window.addEventListener('draft:inserted', (e) => {
        const h = e.detail && e.detail.handle;
        if (h) this.insertedBlock(h);
      });
      window.addEventListener('draft:removed', (e) => {
        const h = e.detail && e.detail.handle;
        if (h) this.removedBlock(h);
      });
      // Enter-split: current block now holds `before`; refresh + open the new
      // (tail) block with the caret at its start.
      window.addEventListener('draft:split', async (e) => {
        await this.forceRefresh();
        await this.openEditor(e.detail.newHandle, 'start');
      });
      // Caret handoff: open the neighbour of `handle` in the arrow direction.
      window.addEventListener('draft:goto', async (e) => {
        const nb = this._neighbour(e.detail.handle, e.detail.dir);
        if (nb) await this.openEditor(nb, e.detail.dir === 'up' ? 'end' : 'start');
      });
      // Backspace-merge: this block folded into `prev`; refresh (prev now holds
      // the joined text, this block is gone) and open prev at the join point.
      window.addEventListener('draft:merged', async (e) => {
        await this.forceRefresh();
        await this.openEditor(e.detail.prev, e.detail.caret != null ? e.detail.caret : 'end');
      });
      // 4) drive windowing off scroll + resize.
      this._onScroll = () => this.onScroll();
      window.addEventListener('scroll', this._onScroll, {passive: true});
      window.addEventListener('resize', this._onScroll, {passive: true});
      // 5) FIRST render + deep link AFTER Alpine finishes its init walk.
      //    render() reconciles #dr-win (removes server rows outside the
      //    viewport); doing that synchronously here mutates the DOM mid-walk,
      //    which orphaned the rows' Alpine scope (`view is not defined`) and
      //    left handlers bound to a stale component (collapse/scroll dead).
      //    $nextTick defers it until the tree is fully wired.
      this.$nextTick(async () => {
        // Server rows were measured (step 2) while the body column was the
        // only visible one — summary/keywords are x-cloak'd until Alpine
        // runs. If a non-body view is persisted, those heights are now wrong;
        // re-measure against the view Alpine just applied before windowing.
        if (this.view !== 'body') {
          this.heights = {};
          this._remeasureWin();
          this.recum();
        }
        this.render();
        const id = location.hash.slice(1);
        if (id && id.startsWith('c-')) await this.ensureVisible(id.slice(2));
      });
      this.startPoll();
    },
    async fetchVersion() {
      const r = await fetch(`/drafts/${this.ident}/version`, {cache: 'no-store'});
      return (await r.json()).version;
    },
    async startPoll() {
      try { this.version = await this.fetchVersion(); } catch (e) { /* offline */ }
      setInterval(() => this.tick(), 4000);
    },
    _typing() {
      const a = document.activeElement;
      return a && document.getElementById('doc').contains(a)
        && (a.tagName === 'INPUT' || a.tagName === 'TEXTAREA');
    },
    // A row is "busy" — must not be recycled/refreshed under the user — when
    // it holds focus or carries unsaved change-request text. We protect it
    // even after blur: typing a note then scrolling/clicking away must not
    // let the next poll (or windowing) eat what you wrote.
    _rowBusy(node) {
      if (!node || node.dataset.ph) return false;
      const af = document.activeElement;
      if (af && node.contains(af)) return true;
      const ta = node.querySelector('textarea[name="text"]');
      return !!(ta && ta.value.trim());
    },
    _dirty() {
      const win = document.getElementById('dr-win');
      return [...win.children].some((n) => this._rowBusy(n));
    },
    async tick() {
      if (!this.live) return;
      let v;
      try { v = await this.fetchVersion(); } catch (e) { return; }
      if (v === this.version) return;
      // Defer while a change box is focused OR holds unsaved text — a swap
      // would clobber it. The amber "document changed — refresh" badge shows
      // so the user can pull the update once they're done.
      if (this._typing() || this._dirty()) { this.stale = true; return; }
      await this.swapAll(v);
    },
    async forceRefresh() {
      // The explicit badge button: a full hard rebuild. (The live poll uses
      // the steady in-place path below; this is the escape hatch.)
      // NB: don't early-return if the version probe hiccups — do the rebuild
      // anyway (it's the part that matters); just skip stamping the version.
      let v = null;
      try { v = await this.fetchVersion(); } catch (e) { /* rebuild anyway */ }
      try {
        const data = await (await fetch(`/drafts/${this.ident}/skeleton`,
                                        {cache: 'no-store'})).json();
        this.skel = data.skeleton || [];
        document.getElementById('dr-win').replaceChildren();
        this.nodes = {};
        this.heights = {};
        this.rebuildVis();
        this.render();
        if (v != null) this.version = v;
        this.stale = false;
        if (this.findQuery.trim()) this.runFind();  // the swap wiped the marks
      } catch (e) { /* leave the page as-is on a failed fetch */ }
    },
    // Re-hydrate exactly one mounted block (after an inline edit) — swap it
    // for a fresh placeholder and pull the new fragment, mirroring swapAll's
    // per-row refresh. The version bump from the edit is left for the poll to
    // reconcile; this just makes the author's own change appear immediately.
    rehydrateOne(h) {
      const node = this.nodes[h];
      if (!node || node.dataset.ph) return;
      const n = this.skel.find((b) => b.h === h);
      if (!n) return;
      const ph = this.makePlaceholder(n);   // keeps the old measured height
      this.nodes[h] = ph;
      node.replaceWith(ph);
      this.hydrate([h]);
    },
    flashEdit(msg) {
      this.editToast = msg;
      clearTimeout(this._toastT);
      this._toastT = setTimeout(() => { this.editToast = ''; }, 4000);
    },
    // A block was inserted: rebuild the skeleton (now includes it), scroll it
    // into view + hydrate it; its init() consumes __draftAutoEdit and opens
    // the editor so you type straight into the new empty block.
    async insertedBlock(h) {
      window.__draftAutoEdit = h;
      await this.forceRefresh();
      await this.ensureVisible(h);
      this.flashEdit('block added');
    },
    // Open a block's editor at `caret` ('start' | 'end'), scrolling it into
    // view + hydrating it first. Retries briefly for the (re)hydrated row's
    // Alpine component to register itself, so it works whether the target was a
    // live row, an off-window placeholder, or a recycled node.
    async openEditor(h, caret) {
      await this.ensureVisible(h);
      for (let i = 0; i < 20; i++) {
        const ed = window.__dEditors && window.__dEditors[h];
        if (ed && ed.startEdit && document.getElementById('c-' + h)) { ed.startEdit(caret); return; }
        await new Promise((r) => setTimeout(r, 25));
      }
    },
    // The nearest EDITABLE prose block above/below `h` in the visible order
    // (skips figures/tables so an arrow-hop lands somewhere you can type).
    _neighbour(h, dir) {
      const ok = new Set(['paragraph', 'heading', 'item', 'aside', 'box', 'callout', 'term']);
      const i = this.vis.findIndex((b) => b.h === h);
      if (i < 0) return null;
      const step = dir === 'up' ? -1 : 1;
      for (let j = i + step; j >= 0 && j < this.vis.length; j += step) {
        if (ok.has(this.vis[j].kind)) return this.vis[j].h;
      }
      return null;
    },
    async removedBlock(h) {
      // Pull the authoritative fresh skeleton, then drop every mounted row no
      // longer in it — so a deleted block AND a cascaded heading's whole
      // subtree vanish at once. Done by direct node removal (not forceRefresh)
      // so a version-probe hiccup can't leave the row (and its 🗑) on screen.
      let skel = null;
      try {
        skel = (await (await fetch(`/drafts/${this.ident}/skeleton`,
                                   {cache: 'no-store'})).json()).skeleton;
      } catch (e) { /* fall back to dropping just this handle below */ }
      if (skel) this.skel = skel;
      else this.skel = this.skel.filter((b) => b.h !== h);
      const live = new Set(this.skel.map((b) => b.h));
      const win = document.getElementById('dr-win');
      for (const node of [...win.children]) {
        const nh = node.id.slice(2);
        if (!live.has(nh)) { node.remove(); delete this.nodes[nh]; delete this.heights[nh]; }
      }
      this.rebuildVis();
      this.render();
      this.flashEdit('block removed');
      try { this.version = await this.fetchVersion(); } catch (e) { /* ignore */ }
    },
    async swapAll(v) {
      try {
        // Non-destructive live refresh: reconcile the skeleton *in place* so
        // the page stays steady. Every surviving row keeps its node and its
        // measured height (no flash, no scroll jump from estimate-based
        // re-layout); only blocks whose content actually changed re-hydrate,
        // and a row the user is editing is left strictly untouched. Most
        // version bumps are background metadata writes (embed / keywords /
        // summaries) that don't alter visible body text — those now no-op
        // visually instead of flashing the whole document.
        const a = this._anchor();
        const data = await (await fetch(`/drafts/${this.ident}/skeleton`,
                                        {cache: 'no-store'})).json();
        const prev = new Map(this.skel.map((b) => [b.h, b]));
        this.skel = data.skeleton || [];
        const live = new Set(this.skel.map((b) => b.h));
        // forget blocks that vanished from the doc
        for (const h of Object.keys(this.nodes)) {
          if (!live.has(h)) { this.nodes[h].remove(); delete this.nodes[h]; }
        }
        for (const h of Object.keys(this.heights)) if (!live.has(h)) delete this.heights[h];
        // re-hydrate only mounted rows whose content changed — skip busy ones.
        const win = document.getElementById('dr-win');
        const refresh = [];
        for (const node of [...win.children]) {
          if (node.dataset.ph) continue;
          const h = node.id.slice(2);
          if (this._rowBusy(node)) continue;
          const o = prev.get(h), n = this.skel.find((b) => b.h === h);
          if (!n) continue;
          const changed = !o || o.est !== n.est || o.estS !== n.estS
            || o.title !== n.title || o.heading !== n.heading || o.depth !== n.depth;
          if (!changed) continue;
          const ph = this.makePlaceholder(n);  // keeps the old measured height
          this.nodes[h] = ph;
          node.replaceWith(ph);
          refresh.push(h);
        }
        this.rebuildVis();
        this.render();
        if (refresh.length) this.hydrate(refresh);
        this._restore(a);
        this.version = v;
        this.stale = false;
        if (this.findQuery.trim()) this.runFind();  // re-mark after content swaps
      } catch (e) { /* leave the page as-is on a failed fetch */ }
    },
  };
}
</script>
{% endblock %}
