    const sel = view.state.selection;
    if (!sel.empty) { close(); return; }
    const before = textUpTo(view.state.doc, sel.from);
    const lb = before.lastIndexOf('[');
    if (lb === -1) { close(); return; }
    const q = before.slice(lb + 1);
    if (q.includes(']') || q.includes('\n') || q.length > 60) { close(); return; }
    st.from = 1 + lb;   // doc pos of the '['
    clearTimeout(timer);
    if (q.trim().length < 2) { close(); return; }
