// `[`-triggered citation autocomplete. Detects a `[query` run before the caret,
// searches papers, and inserts the picked token. All display/DOM; wrapped so a
// failure can never break the editor (worst case: `[` just types literally).
function makeAutocomplete(view, url) {
  const box = document.createElement('div');
  box.className = 'pm-ac'; box.style.display = 'none';
  document.body.appendChild(box);
