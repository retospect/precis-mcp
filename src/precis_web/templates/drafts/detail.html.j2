// Mount a PM editor into `mountEl`, seeded from `seedText`. Returns a small
// controller; opts carries the callbacks the Alpine row wires up.
window.__mountDraftPM = function (mountEl, seedText, opts) {
  let timer = null;
  let ac = null;   // `[` autocomplete controller (assigned after the view exists)
  const view = new EditorView(mountEl, {
    state: EditorState.create({
      doc: textToDoc(seedText),
      plugins: [
        history(),
        keymap({
          'Mod-z': undo, 'Mod-y': redo, 'Shift-Mod-z': redo,
          'Mod-Enter': () => { opts.onSave && opts.onSave(); return true; },
          'Escape': () => {
            if (ac && ac.key('esc')) return true;   // dismiss the picker first
            opts.onCancel && opts.onCancel(); return true;
          },
          // Enter splits the block at the caret into two chunks (this one keeps
          // the text before, a new one gets the text after). When the `[` picker
          // is open, Enter accepts the highlighted result instead.
          'Enter': (state) => {
            if (ac && ac.key('enter')) return true;
            const before = textUpTo(state.doc, state.selection.from);
            const after = docToText(state.doc).slice(before.length);
            opts.onSplit && opts.onSplit(before, after);
            return true;
          },
          'Tab': () => { if (ac && ac.key('enter')) return true; return false; },
          // Shift-Enter is a soft line break within the same block.
          'Shift-Enter': (state, dispatch) => {
