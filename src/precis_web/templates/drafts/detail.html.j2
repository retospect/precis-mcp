{% extends "base.html.j2" %}
{% block title %}{{ ref.title }}{% endblock %}
{% block content %}
<style>
  [x-cloak]{display:none!important}
  /* in-draft find: every match gets a soft band, the active one a ring */
  .find-hit{background-color:#fef9c3}
  .find-current{box-shadow:0 0 0 2px #f59e0b;border-radius:.25rem}
  mark.find-word{background:#fde047;color:inherit;border-radius:2px;padding:0 1px}
  /* abbreviation recall: an INSTANT custom tooltip (no native <abbr>
     title delay). Definition rides in .pa-pop, shown on hover/focus. */
  .pa{position:relative;text-decoration:underline dotted;
      text-decoration-color:#94a3b8;cursor:help}
  .pa>.pa-pop{display:none;position:absolute;bottom:100%;left:0;z-index:50;
      margin-bottom:3px;width:max-content;max-width:18rem;white-space:normal;
      border-radius:4px;background:#1e293b;color:#fff;
      padding:2px 6px;font-size:11px;font-weight:400;line-height:1.3}
  .pa:hover>.pa-pop,.pa:focus>.pa-pop,.pa:focus-within>.pa-pop{display:block}
</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />

<div x-data="draftDoc('{{ ref.ident }}')" x-init="init()">
  <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
    <div>
      <h1 class="text-xl font-semibold">{{ ref.title }}</h1>
      {% if ref.slug %}<span class="font-mono text-xs text-slate-400">draft:{{ ref.slug }}</span>{% endif %}
    </div>
    <div class="flex items-center gap-3 text-xs">
      {# View slider: show each block's full body, its summary, or its
         keywords (3-stop). Persisted per draft. #}
      <div class="flex items-center rounded border border-slate-200 p-0.5">
        <template x-for="opt in ['body', 'summary', 'keywords']" :key="opt">
          <button @click="setView(opt)"
                  class="px-1.5 py-0.5 rounded capitalize"
                  :class="view === opt ? 'bg-slate-700 text-white' : 'text-slate-500 hover:text-slate-800'"
                  x-text="opt"></button>
        </template>
      </div>
      {# live-refresh indicator + the "you were typing, here's a manual refresh" pill #}
      <button x-show="stale" x-cloak @click="forceRefresh()"
              class="rounded bg-amber-100 border border-amber-300 px-2 py-0.5 text-amber-800 hover:bg-amber-200">
        document changed — refresh
      </button>
      <button @click="live = !live"
              class="flex items-center gap-1"
              :title="live ? 'live updates on — click to pause' : 'live updates paused'">
        <span class="inline-block h-2 w-2 rounded-full"
              :class="live ? 'bg-emerald-500' : 'bg-slate-300'"></span>
        <span class="text-slate-500" x-text="live ? 'live' : 'paused'"></span>
      </button>
      <button @click="collapseAll()" class="text-slate-500 underline hover:text-slate-800">collapse all</button>
      <button @click="expandAll()" class="text-slate-500 underline hover:text-slate-800">expand all</button>
      <a href="/drafts" class="text-slate-500 underline hover:text-slate-800">all drafts</a>
    </div>
  </div>

  {# In-draft find bar — verbatim (Ctrl-F over the prose, doc order) vs
     semantic (cosine-ranked over this draft's embeddings). ‹ › cycle the
     matches starting from whatever is currently in view; a hit in a
     collapsed section auto-expands its ancestors. #}
  <div class="sticky top-0 z-30 -mx-2 mb-2 flex flex-wrap items-center gap-2
              border-b border-slate-200 bg-white px-2 py-2 text-xs shadow-sm">
    <input x-model="findQuery" @input.debounce.300ms="runFind()"
           @keydown.enter.prevent="findHits.length ? findNext() : runFind()"
           @keydown.escape="clearFind()"
           placeholder="find in document…"
           class="w-64 rounded border border-slate-200 px-2 py-1 focus:border-sky-400 focus:outline-none" />
    <div class="flex items-center rounded border border-slate-200 p-0.5">
      <template x-for="opt in ['verbatim', 'semantic']" :key="opt">
        <button @click="setFindMode(opt)" class="px-1.5 py-0.5 rounded capitalize"
                :class="findMode === opt ? 'bg-slate-700 text-white' : 'text-slate-500 hover:text-slate-800'"
                x-text="opt"></button>
      </template>
    </div>
    <button @click="findPrev()" :disabled="!findHits.length"
            class="rounded border border-slate-200 px-1.5 py-0.5 disabled:opacity-30" title="previous match">‹</button>
    <button @click="findNext()" :disabled="!findHits.length"
            class="rounded border border-slate-200 px-1.5 py-0.5 disabled:opacity-30" title="next match">›</button>
    <span class="text-slate-400" x-show="findQuery" x-cloak
          x-text="findHits.length ? (findIdx + 1) + '/' + findHits.length : 'no matches'"></span>
  </div>

  {# Column legend #}
  <div class="hidden lg:grid lg:grid-cols-[1fr_20%_22%] gap-3 border-b border-slate-200 pb-1 mb-1
              text-[10px] uppercase tracking-wide text-slate-400">
    <div>Document</div><div>Links &amp; in-flight</div><div>Request a change</div>
  </div>

  <div id="doc">
    {% include "drafts/_rows.html.j2" %}
  </div>
</div>

<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
  onload="window.__renderDocMath && window.__renderDocMath()"></script>
<script>
function __renderMath(el) {
  if (!window.renderMathInElement || !el) return;
  renderMathInElement(el, {
    delimiters: [{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}],
    throwOnError: false,
  });
}
function __renderDocMath() { __renderMath(document.getElementById('doc')); }

// Hover popovers load lazily via htmx AFTER the initial KaTeX pass, so
// render math in each popover fragment as it swaps in (the cited quote
// has $…$ too). The swap target is the .ref-popover span.
document.body.addEventListener('htmx:afterSwap', function (e) {
  const t = (e.detail && e.detail.target) || e.target;
  if (t && t.classList && t.classList.contains('ref-popover')) __renderMath(t);
});

// Per-draft viewer: heading collapse (localStorage) + a poll that keeps
// the page live as the agent edits — full-row-set swap when the version
// token bumps, deferred to a manual pill while a change box is focused so
// the agent's typing is never clobbered.
function draftDoc(ident) {
  const key = 'draft-collapsed:' + ident;
  return {
    ident,
    version: 0,
    live: true,
    stale: false,
    view: localStorage.getItem('draft-view:' + ident) || 'body',
    setView(v) { this.view = v; localStorage.setItem('draft-view:' + ident, v); },
    // in-draft find
    findQuery: '',
    findMode: 'verbatim',
    findHits: [],
    findIdx: -1,
    collapsed: JSON.parse(localStorage.getItem(key) || '[]'),
    save() { localStorage.setItem(key, JSON.stringify(this.collapsed)); },
    toggle(h) {
      const i = this.collapsed.indexOf(h);
      if (i >= 0) this.collapsed.splice(i, 1); else this.collapsed.push(h);
      this.save();
    },
    isC(h) { return this.collapsed.includes(h); },
    vis(anc) { return !anc.some((x) => this.collapsed.includes(x)); },
    collapseAll() {
      this.collapsed = Array.from(document.querySelectorAll('[data-heading]'))
        .map((e) => e.dataset.heading);
      this.save();
    },
    expandAll() { this.collapsed = []; this.save(); },
    // ── in-draft find ────────────────────────────────────────────
    setFindMode(m) { this.findMode = m; if (this.findQuery.trim()) this.runFind(); },
    _clearMarks() {
      document.querySelectorAll('#doc .find-hit, #doc .find-current')
        .forEach((e) => e.classList.remove('find-hit', 'find-current'));
      this._clearWordMarks();
    },
    _clearWordMarks() {
      document.querySelectorAll('#doc mark.find-word').forEach((m) => {
        m.replaceWith(document.createTextNode(m.textContent));
      });
    },
    _markWord(handle) {
      // Wrap each verbatim match of the query in <mark> inside the block's
      // content column — so the actual word is highlighted, not just the
      // block banded. Walks text nodes (skips tooltips / existing marks).
      const row = document.getElementById('c-' + handle);
      const el = row && row.querySelector('[data-content]');
      const q = this.findQuery.trim().toLowerCase();
      if (!el || !q) return;
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
        acceptNode: (n) =>
          n.nodeValue && n.nodeValue.toLowerCase().includes(q)
          && !n.parentElement.closest('.pa-pop, mark.find-word, script, style')
            ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT,
      });
      const nodes = [];
      while (walker.nextNode()) nodes.push(walker.currentNode);
      nodes.forEach((node) => {
        const text = node.nodeValue, low = text.toLowerCase();
        const frag = document.createDocumentFragment();
        let i = 0, p;
        while ((p = low.indexOf(q, i)) !== -1) {
          if (p > i) frag.append(document.createTextNode(text.slice(i, p)));
          const mk = document.createElement('mark');
          mk.className = 'find-word';
          mk.textContent = text.slice(p, p + q.length);
          frag.append(mk);
          i = p + q.length;
        }
        if (i < text.length) frag.append(document.createTextNode(text.slice(i)));
        node.replaceWith(frag);
      });
    },
    _markHits() {
      // Verbatim = band EVERY match (Ctrl-F style) AND highlight the
      // matched word inside each block. Semantic returns a long
      // cosine-ranked list, so banding all of it would light up most of
      // the doc — there we only ring the current result and step
      // through best-first with ‹ ›.
      if (this.findMode !== 'verbatim') return;
      this.findHits.forEach((h) => {
        const e = document.getElementById('c-' + h);
        if (e) e.classList.add('find-hit');
        this._markWord(h);
      });
    },
    clearFind() { this.findQuery = ''; this.findHits = []; this.findIdx = -1; this._clearMarks(); },
    async runFind() {
      this._clearMarks();
      const q = this.findQuery.trim();
      if (!q) { this.findHits = []; this.findIdx = -1; return; }
      let data;
      try {
        const url = `/drafts/${this.ident}/find?q=${encodeURIComponent(q)}&mode=${this.findMode}`;
        data = await (await fetch(url, {cache: 'no-store'})).json();
      } catch (e) { return; }
      this.findHits = data.handles || [];
      this.findMode = data.mode || this.findMode;  // reflect a semantic→verbatim degrade
      this._markHits();
      if (!this.findHits.length) { this.findIdx = -1; return; }
      this.gotoHit(this._startIdx());
    },
    _startIdx() {
      // Start at the first match at/below the current viewport top
      // ("currently visible"); wrap to the first hit if none are below.
      for (let i = 0; i < this.findHits.length; i++) {
        const el = document.getElementById('c-' + this.findHits[i]);
        if (el && el.getBoundingClientRect().top >= 0) return i;
      }
      return 0;
    },
    gotoHit(i) {
      const n = this.findHits.length;
      if (!n) return;
      this.findIdx = ((i % n) + n) % n;
      const el = document.getElementById('c-' + this.findHits[this.findIdx]);
      if (!el) return;
      // a hit inside a collapsed section: expand its ancestors first.
      if (el.dataset.anc) {
        const anc = JSON.parse(el.dataset.anc);
        const next = this.collapsed.filter((x) => !anc.includes(x));
        if (next.length !== this.collapsed.length) { this.collapsed = next; this.save(); }
      }
      this._clearMarks();
      this._markHits();
      el.classList.add('find-current');
      this.$nextTick(() => el.scrollIntoView({block: 'center', behavior: 'smooth'}));
    },
    findNext() { this.gotoHit(this.findIdx + 1); },
    findPrev() { this.gotoHit(this.findIdx - 1); },
    init() {
      this.$nextTick(() => {
        // A #c-<handle> deep link must land visible: expand its ancestors.
        const id = location.hash.slice(1);
        if (id) {
          const el = document.getElementById(id);
          if (el && el.dataset.anc) {
            const anc = JSON.parse(el.dataset.anc);
            this.collapsed = this.collapsed.filter((x) => !anc.includes(x));
            this.save();
          }
          if (el) el.scrollIntoView();
        }
      });
      this.startPoll();
    },
    async fetchVersion() {
      const r = await fetch(`/drafts/${this.ident}/version`, {cache: 'no-store'});
      return (await r.json()).version;
    },
    async startPoll() {
      try { this.version = await this.fetchVersion(); } catch (e) { /* offline */ }
      setInterval(() => this.tick(), 4000);
    },
    _typing() {
      const a = document.activeElement;
      return a && document.getElementById('doc').contains(a)
        && (a.tagName === 'INPUT' || a.tagName === 'TEXTAREA');
    },
    async tick() {
      if (!this.live) return;
      let v;
      try { v = await this.fetchVersion(); } catch (e) { return; }
      if (v === this.version) return;
      if (this._typing()) { this.stale = true; return; }  // defer; don't clobber
      await this.swapAll(v);
    },
    async forceRefresh() {
      let v;
      try { v = await this.fetchVersion(); } catch (e) { return; }
      await this.swapAll(v);
    },
    async swapAll(v) {
      try {
        const html = await (await fetch(`/drafts/${this.ident}/rows`,
                                        {cache: 'no-store'})).text();
        document.getElementById('doc').innerHTML = html;  // Alpine binds new rows
        __renderDocMath();
        this.version = v;
        this.stale = false;
        if (this.findQuery.trim()) this.runFind();  // the swap wiped the marks
      } catch (e) { /* leave the page as-is on a failed fetch */ }
    },
  };
}
</script>
{% endblock %}
