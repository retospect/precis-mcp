      const row = document.createElement('div');
      row.className = 'pm-ac-item' + (i === st.sel ? ' pm-ac-sel' : '');
      const l = document.createElement('span'); l.className = 'pm-ac-label'; l.textContent = it.label;
      const s = document.createElement('span'); s.className = 'pm-ac-sub'; s.textContent = it.token;
      row.appendChild(l); row.appendChild(s);
      row.addEventListener('mousedown', (e) => { e.preventDefault(); choose(i); });
      box.appendChild(row);
