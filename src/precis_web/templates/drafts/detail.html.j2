    else if (typeof opts.caret === 'number')
      sel = TextSelection.create(_d, Math.max(1, Math.min(1 + opts.caret, _d.content.size - 1)));
    else sel = TextSelection.atEnd(_d);
    view.dispatch(view.state.tr.setSelection(sel));
  } catch (e) { view.dispatch(view.state.tr.setSelection(TextSelection.atEnd(_d))); }
