  let timer = null;
  function close() { st.active = false; box.style.display = 'none'; }
  function choose(i) {
    const it = st.items[i]; if (!it) { close(); return; }
    view.dispatch(view.state.tr.insertText(it.token, st.from, view.state.selection.from));
    close(); view.focus();
