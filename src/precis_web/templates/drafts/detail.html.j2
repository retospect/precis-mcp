  if (opts.refSearchUrl) { try { ac = makeAutocomplete(view, opts.refSearchUrl); } catch (e) { ac = null; } }
  // Place the caret (end by default; 'start' from the block above / after a
  // split; a number = string offset, e.g. the merge join point — doc pos is
  // 1 + offset since every char is one position) and focus.
  const _d = view.state.doc;
