{% extends "base.html.j2" %}
{% block title %}Secrets{% endblock %}
{% block content %}
<h1 class="text-lg font-semibold mb-1">Secrets</h1>
<p class="text-sm text-slate-500 mb-5 max-w-2xl">
  Encrypted at rest in the DB vault. This page shows only a masked hint — it
  never decrypts. Updates are <strong>write-only</strong>: type a new value to
  replace one secret; leaving a field blank changes nothing.
</p>

<div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wide">
      <tr>
        <th class="text-left font-medium px-4 py-2">Name</th>
        <th class="text-left font-medium px-4 py-2">Current</th>
        <th class="text-left font-medium px-4 py-2 w-1/3">Replace value</th>
        <th class="px-4 py-2"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {% for r in rows %}
      <tr>
        <td class="px-4 py-2 font-mono text-xs text-slate-700 align-middle">{{ r.name }}</td>
        <td class="px-4 py-2 align-middle">
          <span class="font-mono text-xs text-slate-400">{{ r.hint }}</span>
          <span class="text-[10px] text-slate-300 ml-2">{{ r.updated_at | ago }}</span>
        </td>
        <td class="px-4 py-2 align-middle">
          <form method="post" action="/secrets/set" class="flex gap-2"
                x-data="{ v: '' }">
            <input type="hidden" name="name" value="{{ r.name }}" />
            <input type="password" name="value" autocomplete="new-password"
                   x-model="v" placeholder="(unchanged)"
                   class="flex-1 rounded border border-slate-200 px-2 py-1 text-xs
                          font-mono focus:border-sky-400 focus:outline-none" />
            <button type="submit" x-bind:disabled="!v"
                    class="rounded bg-sky-600 text-white text-xs px-3 py-1
                           disabled:opacity-30 disabled:cursor-not-allowed
                           hover:bg-sky-700 transition">Save</button>
          </form>
        </td>
        <td class="px-4 py-2 align-middle text-right">
          <form method="post" action="/secrets/delete"
                onsubmit="return confirm('Delete {{ r.name }}?')">
            <input type="hidden" name="name" value="{{ r.name }}" />
            <button type="submit"
                    class="text-xs text-slate-400 hover:text-rose-600 transition">delete</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="4" class="px-4 py-6 text-center text-slate-400">
        The vault is empty. Add one below.
      </td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<div class="mt-6 rounded-lg border border-slate-200 bg-white p-4 max-w-2xl">
  <div class="text-xs uppercase tracking-wide text-slate-400 mb-3">Add a secret</div>
  <form method="post" action="/secrets/set" class="flex gap-2" x-data="{ n: '', v: '' }">
    <input type="text" name="name" x-model="n" placeholder="NAME (e.g. PERPLEXITY_API_KEY)"
           class="w-1/2 rounded border border-slate-200 px-2 py-1 text-xs font-mono
                  focus:border-sky-400 focus:outline-none" />
    <input type="password" name="value" autocomplete="new-password" x-model="v"
           placeholder="value"
           class="flex-1 rounded border border-slate-200 px-2 py-1 text-xs font-mono
                  focus:border-sky-400 focus:outline-none" />
    <button type="submit" x-bind:disabled="!n || !v"
            class="rounded bg-emerald-600 text-white text-xs px-3 py-1
                   disabled:opacity-30 disabled:cursor-not-allowed
                   hover:bg-emerald-700 transition">Add</button>
  </form>
</div>
{% endblock %}
