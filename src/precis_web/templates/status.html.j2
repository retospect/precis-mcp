{% extends "base.html.j2" %}
{% block title %}Status{% endblock %}
{% block content %}
<h1 class="text-lg font-semibold mb-4">Status</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <div class="text-xs uppercase tracking-wide text-slate-400">Papers</div>
    <div class="mt-1 text-2xl font-semibold">{{ papers.get('total', 0) }}</div>
    <div class="text-sm text-slate-500">
      {{ papers.get('held', 0) }} held · {{ papers.get('stub', 0) }} stubs
    </div>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-4 md:col-span-2">
    <div class="text-xs uppercase tracking-wide text-slate-400 mb-2">Refs by kind</div>
    <div class="flex flex-wrap gap-2">
      {% for k in kind_counts %}
      <a href="/tags/refs?kind={{ k.kind | urlencode }}"
         class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-700 hover:bg-sky-100 hover:text-sky-800 transition">
        {{ k.kind }} <span class="font-semibold">{{ k.count }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</div>

<div class="rounded-lg border border-slate-200 bg-white p-4 mb-6 text-sm">
  <span class="text-xs uppercase tracking-wide text-slate-400">PDF corpus root</span>
  <span class="ml-2 font-mono text-slate-700 break-all">{{ corpus_dir }}</span>
  <span class="text-slate-400">(set via <span class="font-mono">PRECIS_CORPUS_DIR</span>)</span>
  <span class="ml-2 text-slate-300">·</span>
  <span class="text-xs uppercase tracking-wide text-slate-400 ml-2">version</span>
  <span class="ml-1 font-mono text-slate-700">{{ app_version }}</span>
</div>

<!-- Machines: heartbeat (temp + load) joined with log liveness. -->
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Machines</h2>
  <div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
      <thead class="text-xs uppercase tracking-wide text-slate-400 bg-slate-50">
        <tr>
          <th class="text-left px-4 py-2 font-medium">Host</th>
          <th class="text-left px-4 py-2 font-medium">Core temp</th>
          <th class="text-left px-4 py-2 font-medium">Load (1/5/15m)</th>
          <th class="text-left px-4 py-2 font-medium">Reported</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {% for h in heartbeats %}
        <tr>
          <td class="px-4 py-2 font-mono">
            <span class="inline-block w-2 h-2 rounded-full mr-1 align-middle {% if h.stale %}bg-slate-300{% else %}bg-emerald-500{% endif %}"></span>
            {{ h.host }}
          </td>
          <td class="px-4 py-2">
            {% if h.temp_c is not none %}
            <span class="{% if h.temp_c >= 85 %}text-rose-700 font-semibold{% elif h.temp_c >= 70 %}text-amber-700{% else %}text-slate-700{% endif %}">
              {{ '%.1f'|format(h.temp_c) }} °C
            </span>
            {% else %}
            <span class="text-slate-400" title="no temperature sensor reported (set PRECIS_TEMP_CMD)">—</span>
            {% endif %}
          </td>
          <td class="px-4 py-2 font-mono text-slate-600">
            {% if h.load1 is not none %}
            {{ '%.2f'|format(h.load1) }} / {{ '%.2f'|format(h.load5) }} / {{ '%.2f'|format(h.load15) }}
            {% else %}<span class="text-slate-400">—</span>{% endif %}
          </td>
          <td class="px-4 py-2 {% if h.stale %}text-slate-400{% else %}text-slate-600{% endif %}">{{ h.ago or '—' }}</td>
        </tr>
        {% else %}
        <tr><td colspan="4" class="px-4 py-3 text-sm text-slate-500">
          No heartbeats yet. Run <span class="font-mono">precis heartbeat</span> on each host (on a timer).
        </td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if hosts %}
  <div class="mt-2 flex flex-wrap gap-2">
    {% for hl in hosts %}
    <span class="text-xs px-2 py-1 rounded {% if hl.stale %}bg-slate-100 text-slate-500{% else %}bg-emerald-50 text-emerald-700{% endif %}">
      {{ hl.host }} · logged {{ hl.ago }}{% if hl.problems %} · <span class="text-rose-600 font-semibold">{{ hl.problems }} err/warn 24h</span>{% endif %}
    </span>
    {% endfor %}
  </div>
  {% endif %}
</section>

<!-- Liveness — the "is it alive" heartbeat: last activity per pipeline
     stage (ingest → extract → index → summarise) plus the scheduled
     watches (news / briefing) and dreams. Scheduled signals turn amber
     when overdue; pipeline stages are informational (idle is normal on
     a quiet corpus). -->
{% if liveness %}
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Liveness</h2>
  <div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
      <tbody class="divide-y divide-slate-100">
        {% for s in liveness %}
        <tr class="hover:bg-slate-50">
          <td class="px-4 py-2 text-slate-700">
            <span class="inline-block w-2 h-2 rounded-full mr-1 align-middle
              {% if s.unknown %}bg-slate-300{% elif s.stale %}bg-amber-500{% else %}bg-emerald-500{% endif %}"></span>
            {{ s.label }}
            {% if s.scheduled %}<span class="text-xs text-slate-400">· scheduled</span>{% endif %}
          </td>
          <td class="px-4 py-2 text-right tabular-nums {% if s.stale %}text-amber-700 font-semibold{% else %}text-slate-500{% endif %}">
            {{ s.ago }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endif %}

<!-- Background health — spin loops (a worker re-claiming the same ref
     every pass) + failed worker passes, both over 24h. These are the
     derived-queue failure modes that are otherwise invisible until
     someone reads ref_events by hand. Green "all clear" when empty. -->
{% set spin = bg_health.get('spin_loops', []) %}
{% set fails = bg_health.get('failed_passes', []) %}
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Background health</h2>
  {% if not spin and not fails %}
  <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-700">
    <span class="inline-block w-2 h-2 rounded-full mr-1 align-middle bg-emerald-500"></span>
    No spin loops or failed passes in the last 24h.
  </div>
  {% else %}
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {% if spin %}
    <div class="rounded-lg border border-rose-200 bg-white overflow-hidden">
      <div class="px-4 py-2 text-xs uppercase tracking-wide text-rose-600 bg-rose-50 font-medium">
        Spin loops ({{ spin|length }}) — same ref re-claimed every pass
      </div>
      <table class="w-full text-sm">
        <tbody class="divide-y divide-slate-100">
          {% for s in spin %}
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2 font-mono text-slate-700">#{{ s.ref_id }}</td>
            <td class="px-4 py-2 font-mono text-slate-600">{{ s.source }}</td>
            <td class="px-4 py-2 text-slate-500">{{ s.last_event }}</td>
            <td class="px-4 py-2 text-right font-semibold text-rose-700 tabular-nums">{{ s.count }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
    {% if fails %}
    <div class="rounded-lg border border-amber-200 bg-white overflow-hidden">
      <div class="px-4 py-2 text-xs uppercase tracking-wide text-amber-700 bg-amber-50 font-medium">
        Failed passes ({{ fails|length }}) — 24h, by handler
      </div>
      <table class="w-full text-sm">
        <tbody class="divide-y divide-slate-100">
          {% for f in fails %}
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2 font-mono text-slate-700">{{ f.host }}</td>
            <td class="px-4 py-2 font-mono text-slate-600">{{ f.handler }}</td>
            <td class="px-4 py-2 text-right font-semibold text-amber-700 tabular-nums">{{ f.failed }}</td>
            <td class="px-4 py-2 text-right text-slate-400">{{ f.ago }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
  </div>
  {% endif %}
</section>

<!-- Claude OAuth quota — snapshot of the Anthropic rate-limit headers
     written by the agent-worker `quota_check` pass. Mirrors Claude
     Code's own `/usage` panel. Updated every ~10 min while the agent
     worker is running; shows "snapshot unavailable" before first
     refresh. -->
{% if quota.get('windows') %}
<section class="mb-6">
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-sm font-semibold">Claude OAuth quota</h2>
    {% if quota.get('ts') %}
    <span class="text-xs text-slate-400">snapshot {{ quota.ts }}</span>
    {% endif %}
  </div>
  <div class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
    {% for w in quota.windows %}
    <div class="p-3 flex items-center gap-3">
      <div class="w-44 shrink-0 text-sm">
        <div class="font-medium text-slate-700">{{ w.label }}</div>
        {% if w.resets_at %}
        <div class="text-xs text-slate-400">resets {{ w.resets_at }}</div>
        {% endif %}
      </div>
      {% if w.used_percentage is not none %}
      <div class="flex-1">
        {% set pct = w.used_percentage %}
        {% set safe_pct = (pct if pct < 100 else 100) %}
        <div class="h-2 rounded bg-slate-100 overflow-hidden">
          <div class="h-2 {% if pct >= 90 %}bg-rose-500{% elif pct >= 70 %}bg-amber-500{% else %}bg-emerald-500{% endif %}"
               style="width: {{ '%.1f'|format(safe_pct) }}%"></div>
        </div>
      </div>
      <div class="w-16 text-right shrink-0 text-sm font-medium tabular-nums
                  {% if pct >= 90 %}text-rose-600{% elif pct >= 70 %}text-amber-600{% else %}text-slate-700{% endif %}">
        {{ '%.0f'|format(pct) }}%
      </div>
      {% else %}
      {# Stream-json snapshots carry status but no used_percentage —
         show the status pill in the bar slot and leave the right
         column blank rather than misleading with a 0% bar. #}
      <div class="flex-1">
        {% set st = w.status or 'unknown' %}
        <span class="inline-block text-xs px-2 py-0.5 rounded font-medium
                     {% if st == 'exceeded' %}bg-rose-100 text-rose-700
                     {% elif st == 'warning' %}bg-amber-100 text-amber-700
                     {% elif st == 'active' or st == 'allowed' %}bg-emerald-100 text-emerald-700
                     {% else %}bg-slate-100 text-slate-600{% endif %}">{{ st }}</span>
      </div>
      <div class="w-16 text-right shrink-0 text-xs text-slate-400">—</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% if quota.get('representative_claim') %}
  <p class="mt-2 text-xs text-slate-500">
    Binding window: <code>{{ quota.representative_claim }}</code>
  </p>
  {% endif %}
</section>
{% else %}
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Claude OAuth quota</h2>
  <p class="text-sm text-slate-500">
    No snapshot yet — the agent-worker <code>quota_check</code> pass
    writes one after its first claude -p call (within ~10 min of
    deploy). Anthropic only returns rate-limit headers for Claude.ai
    Pro/Max subscribers, so free-tier accounts will stay empty.
  </p>
</section>
{% endif %}

<!-- Claude usage rolled up from ref_events.cost_usd. -->
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Claude usage</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-slate-400">Last 24h</div>
      <div class="mt-1 text-2xl font-semibold">${{ '%.2f'|format(usage.get('day', {}).get('cost', 0)) }}</div>
      <div class="text-sm text-slate-500">{{ usage.get('day', {}).get('calls', 0) }} calls</div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-slate-400">Last 7d</div>
      <div class="mt-1 text-2xl font-semibold">${{ '%.2f'|format(usage.get('week', {}).get('cost', 0)) }}</div>
      <div class="text-sm text-slate-500">{{ usage.get('week', {}).get('calls', 0) }} calls</div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-slate-400 mb-1">By model (7d)</div>
      <ul class="text-sm divide-y divide-slate-100">
        {% for m in usage.get('by_model', []) %}
        <li class="py-1 flex justify-between gap-2">
          <span class="font-mono text-slate-600 truncate">{{ m.label }}</span>
          <span class="text-slate-500 shrink-0">{{ m.calls }} · ${{ '%.2f'|format(m.cost) }}</span>
        </li>
        {% else %}
        <li class="py-1 text-slate-400">no LLM cost recorded</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <section>
    <h2 class="text-sm font-semibold mb-2">Todos by status</h2>
    <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
      {% for t in todo_status %}
      {# Click-through → /tags/refs filters refs by tag, scoped to
         kind=todo and namespace=STATUS for the relevant status. Each
         count is the population landing on the filtered list. #}
      <li class="px-4 py-2 flex justify-between text-sm hover:bg-slate-50">
        <a href="/tags/refs?kind=todo&namespace=STATUS&value={{ t.status }}"
           class="flex-1 text-slate-700 hover:text-emerald-700">{{ t.status }}</a>
        <span class="font-semibold">{{ t.count }}</span>
      </li>
      {% else %}
      <li class="px-4 py-2 text-sm text-slate-500">no todos</li>
      {% endfor %}
    </ul>
  </section>

  <section>
    <h2 class="text-sm font-semibold mb-2">Recent activity
      <span class="font-normal text-xs text-slate-400">(ref_events — per-ref)</span>
    </h2>
    <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
      {% for e in events %}
      <li class="px-4 py-2 text-xs flex items-center gap-2">
        <span class="text-slate-400 w-28 shrink-0">{{ e.ts }}</span>
        <span class="font-mono text-slate-600">{{ e.event }}</span>
        <span class="text-slate-400">{{ e.source }}</span>
        {% if e.ref_id %}<span class="ml-auto text-slate-400">#{{ e.ref_id }}</span>{% endif %}
      </li>
      {% else %}
      <li class="px-4 py-2 text-sm text-slate-500">no events</li>
      {% endfor %}
    </ul>
    <p class="mt-1 text-xs text-slate-400">
      Per-ref events only — chunk_keywords, embed, summarize batches
      log to <code>worker_logs</code> instead (panel below).
    </p>
  </section>
</div>

{# Three focused recent-N panels: dreams, todo work-done, worker
   passes. These exist so a quiet ref_events stream doesn't read
   as "the cluster is dead" — dreams + pass batches keep ticking
   even when no status flips. #}
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
  <section>
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="text-sm font-semibold">Recent dreams</h2>
      {# Synthetic-insight badge: dreams promoted by the agent's own
         Step-7 self-review (cited refs verified + cross-kind +
         specific mechanism named). Click for the full filtered list. #}
      {% if insight_count > 0 %}
      <a href="/tags/refs?namespace=tier&value=synthetic-insight"
         class="text-xs text-emerald-700 hover:underline">
        ✨ {{ insight_count }} synthetic insight{{ '' if insight_count == 1 else 's' }} →
      </a>
      {% endif %}
    </div>
    <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
      {% for d in recent_dreams %}
      <li class="px-4 py-2 text-xs flex items-center gap-2">
        <span class="text-slate-400 w-16 shrink-0">{{ d.ago }}</span>
        {% if d.is_insight %}<span class="text-emerald-600" title="agent-verified synthetic insight">✨</span>{% endif %}
        <a class="text-slate-700 hover:underline truncate"
           href="/refs/memory/{{ d.ref_id }}">{{ d.title }}</a>
      </li>
      {% else %}
      <li class="px-4 py-2 text-sm text-slate-500">no dreams yet</li>
      {% endfor %}
    </ul>
  </section>

  <section>
    <h2 class="text-sm font-semibold mb-2">Recent todo work-done</h2>
    <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
      {% for t in recent_todo_done %}
      <li class="px-4 py-2 text-xs flex items-center gap-2">
        <span class="text-slate-400 w-16 shrink-0">{{ t.ago }}</span>
        <span class="font-mono text-violet-600 w-20 shrink-0">{{ t.event }}</span>
        <a class="text-slate-700 hover:underline truncate"
           href="/tasks#row-{{ t.ref_id }}">{{ t.title }}</a>
      </li>
      {% else %}
      <li class="px-4 py-2 text-sm text-slate-500">no completions recorded</li>
      {% endfor %}
    </ul>
  </section>

  <section>
    <h2 class="text-sm font-semibold mb-2">Recent worker passes
      <span class="font-normal text-xs text-slate-400">(productive)</span>
    </h2>
    <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
      {% for p in recent_passes %}
      <li class="px-4 py-2 text-xs flex items-center gap-2">
        <span class="text-slate-400 w-16 shrink-0">{{ p.ago }}</span>
        <span class="font-mono text-slate-600 w-32 shrink-0">{{ p.pass }}</span>
        <span class="text-slate-400 w-20 shrink-0">{{ p.host }}</span>
        <span class="ml-auto tabular-nums text-slate-500">
          claimed {{ p.claimed }} · ok {{ p.ok }}{% if p.failed %} · <span class="text-rose-600">failed {{ p.failed }}</span>{% endif %}
        </span>
      </li>
      {% else %}
      <li class="px-4 py-2 text-sm text-slate-500">no productive batches recorded</li>
      {% endfor %}
    </ul>
  </section>
</div>

{# Recent LLM-agent fires: dream / structural reviewer / deep_review
   / job_claude_inproc / quota_check. Each is one ``claude -p`` call
   per row — failed rows render in red so silent-failure streaks
   stand out. #}
<section class="mt-6">
  <h2 class="text-sm font-semibold mb-2">Recent LLM agent activity
    <span class="font-normal text-xs text-slate-400">(dream, reviewers, job runner, quota)</span>
  </h2>
  <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
    {% for a in recent_agents %}
    <li class="px-4 py-2 text-xs flex items-center gap-2 {% if not a.ok_flag %}bg-rose-50{% endif %}">
      <span class="text-slate-400 w-16 shrink-0">{{ a.ago }}</span>
      <span class="font-mono {% if a.ok_flag %}text-violet-700{% else %}text-rose-700{% endif %} w-44 shrink-0">{{ a.pass }}</span>
      <span class="text-slate-500 w-20 shrink-0">{{ a.host }}</span>
      <span class="ml-auto tabular-nums {% if a.ok_flag %}text-emerald-700{% else %}text-rose-700 font-medium{% endif %}">
        {% if a.ok_flag %}ok{% else %}FAILED{% endif %}
        <span class="text-slate-400">·</span> claimed {{ a.claimed }} · ok {{ a.ok }} · failed {{ a.failed }}
      </span>
    </li>
    {% else %}
    <li class="px-4 py-2 text-sm text-slate-500">no agent fires recorded yet</li>
    {% endfor %}
  </ul>
</section>

{# Chunk-pipeline backlog: how many chunks are still waiting on each
   pass. ``pending = 0`` means the worker is caught up; a growing
   number means the embedder / keyword extractor / summarizer can't
   keep up with ingest. -1 = query failed (schema drift). #}
<section class="mt-6">
  <h2 class="text-sm font-semibold mb-2">Chunk pipeline backlog
    <span class="font-normal text-xs text-slate-400">(pending 0 = caught up)</span>
  </h2>
  {# Counts are scoped to each pass's *eligible* universe (the chunks its
     claim query would actually process — skipped kinds / no_index / short
     / un-embedded chunks are excluded), so ``pending`` is the real
     claimable backlog. The stacked bar splits the universe three ways:
     done (green) + pending (blue) + failed (red). ``failed`` = terminal
     ``status='failed'`` rows the worker never retries (embed/summarize
     only); a non-zero red tail flags chunks stuck out of the corpus. #}
  <div class="flex items-center gap-3 mb-2 text-[11px] text-slate-500">
    <span class="flex items-center gap-1"><span class="inline-block w-3 h-2 rounded-sm bg-emerald-500"></span>done</span>
    <span class="flex items-center gap-1"><span class="inline-block w-3 h-2 rounded-sm bg-sky-500"></span>pending</span>
    <span class="flex items-center gap-1"><span class="inline-block w-3 h-2 rounded-sm bg-rose-500"></span>failed (terminal, never retried)</span>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
    {% for pass_name, row in backlog.items() %}
    {% set failed = row.failed|default(0) %}
    {% set total = row.pending + row.done + failed %}
    {# ``pct`` is percent *complete* (done / total). ``pct_pend`` /
       ``pct_fail`` size the other two segments so they stack to 100%. #}
    {% set pct = ((row.done / total) * 100) if total > 0 else 100 %}
    {% set pct_pend = ((row.pending / total) * 100) if total > 0 else 0 %}
    {% set pct_fail = ((failed / total) * 100) if total > 0 else 0 %}
    <div class="px-4 py-2 text-xs flex items-center gap-2">
      <span class="font-mono text-slate-700 w-36 shrink-0">{{ pass_name }}</span>
      {% if row.pending == -1 %}
      <span class="text-rose-600">(query failed — see logs)</span>
      {% else %}
      <span class="w-44 shrink-0 tabular-nums" title="{{ '{:,}'.format(total) }} eligible chunks">
        <span class="font-medium {% if row.pending > 0 %}text-amber-700{% else %}text-emerald-700{% endif %}">{{ '{:,}'.format(row.pending) }}</span><span class="text-slate-400"> pending</span>{% if failed > 0 %}<span class="text-rose-600"> · {{ '{:,}'.format(failed) }} failed</span>{% endif %}
      </span>
      <div class="flex-1 h-2 rounded bg-slate-100 overflow-hidden flex"
           title="done {{ '{:,}'.format(row.done) }} · pending {{ '{:,}'.format(row.pending) }} · failed {{ '{:,}'.format(failed) }}">
        <div class="h-2 bg-emerald-500" style="width: {{ '%.1f'|format(pct) }}%"></div>
        <div class="h-2 bg-sky-500" style="width: {{ '%.1f'|format(pct_pend) }}%"></div>
        <div class="h-2 bg-rose-500" style="width: {{ '%.1f'|format(pct_fail) }}%"></div>
      </div>
      <span class="w-20 text-right text-slate-500 tabular-nums">{{ '%.1f'|format(pct) }}% done</span>
      <span class="w-24 text-right text-slate-400 shrink-0 tabular-nums"
            title="last productive batch{% if row.last_ts %} — {{ row.last_ts | abs_ts }}{% endif %}">
        {% if row.last_ts %}{{ row.last_ts | ago }}{% else %}—{% endif %}
      </span>
      {% endif %}
    </div>
    {% else %}
    <div class="px-4 py-2 text-sm text-slate-500">no backlog data</div>
    {% endfor %}
  </div>
</section>
{% endblock %}
