{% extends "base.html.j2" %}
{% block title %}Status{% endblock %}
{% block content %}
<h1 class="text-lg font-semibold mb-4">Status</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <div class="text-xs uppercase tracking-wide text-slate-400">Papers</div>
    <div class="mt-1 text-2xl font-semibold">{{ papers.get('total', 0) }}</div>
    <div class="text-sm text-slate-500">
      {{ papers.get('held', 0) }} held · {{ papers.get('stub', 0) }} stubs
    </div>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-4 md:col-span-2">
    <div class="text-xs uppercase tracking-wide text-slate-400 mb-2">Refs by kind</div>
    <div class="flex flex-wrap gap-2">
      {% for k in kind_counts %}
      <span class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-700">
        {{ k.kind }} <span class="font-semibold">{{ k.count }}</span>
      </span>
      {% endfor %}
    </div>
  </div>
</div>

<div class="rounded-lg border border-slate-200 bg-white p-4 mb-6 text-sm">
  <span class="text-xs uppercase tracking-wide text-slate-400">PDF corpus root</span>
  <span class="ml-2 font-mono text-slate-700 break-all">{{ corpus_dir }}</span>
  <span class="text-slate-400">(set via <span class="font-mono">PRECIS_CORPUS_DIR</span>)</span>
  <span class="ml-2 text-slate-300">·</span>
  <span class="text-xs uppercase tracking-wide text-slate-400 ml-2">version</span>
  <span class="ml-1 font-mono text-slate-700">{{ app_version }}</span>
</div>

<!-- Machines: heartbeat (temp + load) joined with log liveness. -->
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Machines</h2>
  <div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
      <thead class="text-xs uppercase tracking-wide text-slate-400 bg-slate-50">
        <tr>
          <th class="text-left px-4 py-2 font-medium">Host</th>
          <th class="text-left px-4 py-2 font-medium">Core temp</th>
          <th class="text-left px-4 py-2 font-medium">Load (1/5/15m)</th>
          <th class="text-left px-4 py-2 font-medium">Reported</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {% for h in heartbeats %}
        <tr>
          <td class="px-4 py-2 font-mono">
            <span class="inline-block w-2 h-2 rounded-full mr-1 align-middle {% if h.stale %}bg-slate-300{% else %}bg-emerald-500{% endif %}"></span>
            {{ h.host }}
          </td>
          <td class="px-4 py-2">
            {% if h.temp_c is not none %}
            <span class="{% if h.temp_c >= 85 %}text-rose-700 font-semibold{% elif h.temp_c >= 70 %}text-amber-700{% else %}text-slate-700{% endif %}">
              {{ '%.1f'|format(h.temp_c) }} °C
            </span>
            {% else %}
            <span class="text-slate-400" title="no temperature sensor reported (set PRECIS_TEMP_CMD)">—</span>
            {% endif %}
          </td>
          <td class="px-4 py-2 font-mono text-slate-600">
            {% if h.load1 is not none %}
            {{ '%.2f'|format(h.load1) }} / {{ '%.2f'|format(h.load5) }} / {{ '%.2f'|format(h.load15) }}
            {% else %}<span class="text-slate-400">—</span>{% endif %}
          </td>
          <td class="px-4 py-2 {% if h.stale %}text-slate-400{% else %}text-slate-600{% endif %}">{{ h.ago or '—' }}</td>
        </tr>
        {% else %}
        <tr><td colspan="4" class="px-4 py-3 text-sm text-slate-500">
          No heartbeats yet. Run <span class="font-mono">precis heartbeat</span> on each host (on a timer).
        </td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% if hosts %}
  <div class="mt-2 flex flex-wrap gap-2">
    {% for hl in hosts %}
    <span class="text-xs px-2 py-1 rounded {% if hl.stale %}bg-slate-100 text-slate-500{% else %}bg-emerald-50 text-emerald-700{% endif %}">
      {{ hl.host }} · logged {{ hl.ago }}{% if hl.problems %} · <span class="text-rose-600 font-semibold">{{ hl.problems }} err/warn 24h</span>{% endif %}
    </span>
    {% endfor %}
  </div>
  {% endif %}
</section>

<!-- Claude OAuth quota — snapshot of the Anthropic rate-limit headers
     written by the agent-worker `quota_check` pass. Mirrors Claude
     Code's own `/usage` panel. Updated every ~10 min while the agent
     worker is running; shows "snapshot unavailable" before first
     refresh. -->
{% if quota.get('windows') %}
<section class="mb-6">
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-sm font-semibold">Claude OAuth quota</h2>
    {% if quota.get('ts') %}
    <span class="text-xs text-slate-400">snapshot {{ quota.ts }}</span>
    {% endif %}
  </div>
  <div class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
    {% for w in quota.windows %}
    <div class="p-3 flex items-center gap-3">
      <div class="w-44 shrink-0 text-sm">
        <div class="font-medium text-slate-700">{{ w.label }}</div>
        {% if w.resets_at %}
        <div class="text-xs text-slate-400">resets {{ w.resets_at }}</div>
        {% endif %}
      </div>
      <div class="flex-1">
        {% set pct = w.used_percentage if w.used_percentage is not none else 0 %}
        {% set safe_pct = (pct if pct < 100 else 100) %}
        <div class="h-2 rounded bg-slate-100 overflow-hidden">
          <div class="h-2 {% if pct >= 90 %}bg-rose-500{% elif pct >= 70 %}bg-amber-500{% else %}bg-emerald-500{% endif %}"
               style="width: {{ '%.1f'|format(safe_pct) }}%"></div>
        </div>
      </div>
      <div class="w-16 text-right shrink-0 text-sm font-medium tabular-nums
                  {% if pct >= 90 %}text-rose-600{% elif pct >= 70 %}text-amber-600{% else %}text-slate-700{% endif %}">
        {{ '%.0f'|format(pct) }}%
      </div>
    </div>
    {% endfor %}
  </div>
  {% if quota.get('representative_claim') %}
  <p class="mt-2 text-xs text-slate-500">
    Binding window: <code>{{ quota.representative_claim }}</code>
  </p>
  {% endif %}
</section>
{% else %}
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Claude OAuth quota</h2>
  <p class="text-sm text-slate-500">
    No snapshot yet — the agent-worker <code>quota_check</code> pass
    writes one after its first claude -p call (within ~10 min of
    deploy). Anthropic only returns rate-limit headers for Claude.ai
    Pro/Max subscribers, so free-tier accounts will stay empty.
  </p>
</section>
{% endif %}

<!-- Claude usage rolled up from ref_events.cost_usd. -->
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Claude usage</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-slate-400">Last 24h</div>
      <div class="mt-1 text-2xl font-semibold">${{ '%.2f'|format(usage.get('day', {}).get('cost', 0)) }}</div>
      <div class="text-sm text-slate-500">{{ usage.get('day', {}).get('calls', 0) }} calls</div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-slate-400">Last 7d</div>
      <div class="mt-1 text-2xl font-semibold">${{ '%.2f'|format(usage.get('week', {}).get('cost', 0)) }}</div>
      <div class="text-sm text-slate-500">{{ usage.get('week', {}).get('calls', 0) }} calls</div>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <div class="text-xs uppercase tracking-wide text-slate-400 mb-1">By model (7d)</div>
      <ul class="text-sm divide-y divide-slate-100">
        {% for m in usage.get('by_model', []) %}
        <li class="py-1 flex justify-between gap-2">
          <span class="font-mono text-slate-600 truncate">{{ m.label }}</span>
          <span class="text-slate-500 shrink-0">{{ m.calls }} · ${{ '%.2f'|format(m.cost) }}</span>
        </li>
        {% else %}
        <li class="py-1 text-slate-400">no LLM cost recorded</li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <section>
    <h2 class="text-sm font-semibold mb-2">Todos by status</h2>
    <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
      {% for t in todo_status %}
      <li class="px-4 py-2 flex justify-between text-sm">
        <span>{{ t.status }}</span><span class="font-semibold">{{ t.count }}</span>
      </li>
      {% else %}
      <li class="px-4 py-2 text-sm text-slate-500">no todos</li>
      {% endfor %}
    </ul>
  </section>

  <section>
    <h2 class="text-sm font-semibold mb-2">Recent activity</h2>
    <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
      {% for e in events %}
      <li class="px-4 py-2 text-xs flex items-center gap-2">
        <span class="text-slate-400 w-28 shrink-0">{{ e.ts }}</span>
        <span class="font-mono text-slate-600">{{ e.event }}</span>
        <span class="text-slate-400">{{ e.source }}</span>
        {% if e.ref_id %}<span class="ml-auto text-slate-400">#{{ e.ref_id }}</span>{% endif %}
      </li>
      {% else %}
      <li class="px-4 py-2 text-sm text-slate-500">no events</li>
      {% endfor %}
    </ul>
  </section>
</div>
{% endblock %}
