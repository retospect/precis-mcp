{% extends "base.html.j2" %}
{% block title %}Factory{% endblock %}
{% block content %}
<h1 class="text-lg font-semibold mb-1">Factory</h1>
<p class="text-sm text-slate-500 mb-3">
  Everything the factory runs — one row per pass, job-type, compute
  service, daemon, and serving endpoint — from the ServiceSpec registry,
  joined to its live <code>service_config</code> prio and last activity.
  Editing writes <code>service_config</code> for the selected host; the
  worker picks it up on its next cycle (no redeploy).
</p>

{# ── Host selector — edits apply to this host ('*' = all) ─────── #}
<form method="get" action="/factory" class="mb-4 flex items-center gap-2 text-sm">
  <label class="text-slate-500">Editing host</label>
  <select name="host" onchange="this.form.submit()"
          class="rounded-md border border-slate-300 text-sm px-2 py-1.5">
    {% for h in host_options %}
    <option value="{{ h }}" {% if h == selected_host %}selected{% endif %}>{{ '* (all hosts)' if h == '*' else h }}</option>
    {% endfor %}
  </select>
  <span class="text-xs text-slate-400">prio 0 = off · 1–10 = claim weight · blank = env/profile default ({{ default_prio }})</span>
</form>

{# ── Host strip ───────────────────────────────────────────────── #}
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2">Hosts</h2>
  {% if not hosts %}
  <p class="text-xs text-slate-500">No host heartbeats — running outside the cluster?</p>
  {% else %}
  <div class="flex flex-wrap gap-2">
    {% for h in hosts %}
    <div class="rounded-lg border {% if h.alive %}border-emerald-200 bg-emerald-50{% else %}border-rose-200 bg-rose-50{% endif %} px-3 py-2 text-xs">
      <div class="flex items-center gap-2">
        <span class="font-mono font-semibold text-slate-800">{{ h.host }}</span>
        {% if h.alive %}
        <span class="text-emerald-700">● live</span>
        {% else %}
        <span class="text-rose-700">● stale ({{ h.ago }})</span>
        {% endif %}
      </div>
      <div class="text-slate-500 mt-0.5">
        load
        <span class="font-mono">{{ '%.2f'|format(h.load1) if h.load1 is not none else '—' }}</span>
        /
        <span class="font-mono">{{ '%.2f'|format(h.load5) if h.load5 is not none else '—' }}</span>
        /
        <span class="font-mono">{{ '%.2f'|format(h.load15) if h.load15 is not none else '—' }}</span>
        {% if h.temp_c is not none %}
        · <span class="font-mono">{{ '%.0f'|format(h.temp_c) }}°C</span>
        {% endif %}
      </div>
      {% if h.top_cpu %}
      {# top processes by CPU% — so "why is load high?" is answerable here #}
      {# instead of SSH-ing in. A postgres backend shows as `postgres`; the #}
      {# exact query still needs pg_stat_activity. #}
      <div class="mt-0.5 flex flex-wrap gap-x-2 gap-y-0.5 text-[11px] text-slate-500"
        title="Top processes by CPU% at last heartbeat (host-local `ps`).">
        <span class="text-slate-400">top</span>
        {% for p in h.top_cpu %}
        <span class="font-mono {% if p.cpu >= 90 %}text-rose-700 font-semibold{% elif p.cpu >= 50 %}text-amber-700{% endif %}">{{ p.cmd }}&nbsp;{{ '%.0f'|format(p.cpu) }}</span>
        {% endfor %}
      </div>
      {% endif %}
      {% if h.slots %}
      <div class="mt-1 flex flex-wrap gap-1" title="Resources this host advertises (heartbeat self-probe). free/capacity slots; differ once reserve-at-claim lands. Soft gauges (mem) show memory-pressure headroom: green=plenty, amber=low, red=under pressure.">
        {% for sl in h.slots %}
        {% if sl.pressure %}
        {# soft memory-pressure gauge (6d): colour by headroom so RAM pressure #}
        {# (what to watch when a host runs a container runtime) is legible. #}
        <span class="rounded px-1 py-0.5 font-mono text-[11px] border
          {% if sl.pressure == 'crit' %}bg-red-100 border-red-300 text-red-700
          {% elif sl.pressure == 'warn' %}bg-amber-100 border-amber-300 text-amber-700
          {% else %}bg-emerald-50 border-emerald-200 text-emerald-700{% endif %}"
          title="Memory-pressure headroom on {{ h.host }}: {{ sl.free }}/{{ sl.capacity }} ({{ 'under pressure' if sl.pressure == 'crit' else ('low' if sl.pressure == 'warn' else 'plenty') }}). 0 = jetsam risk.">RAM {{ sl.free }}/{{ sl.capacity }}</span>
        {% else %}
        <span class="rounded bg-white/70 border border-slate-200 px-1 py-0.5 font-mono text-[11px] text-slate-600 cursor-help"
          title="{{ sl.desc }}">{{ sl.resource }} {{ sl.free }}/{{ sl.capacity }}</span>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}
      {# ── recent errors (last 6h) — mouse over for the newest few ── #}
      <div class="mt-1">
        {% if h.errors %}
        <span class="rounded px-1 py-0.5 text-[11px] bg-rose-100 border border-rose-300 text-rose-700 cursor-help"
          title="{% for e in h.errors.samples %}{{ e.ago }} · {{ e.pass }} · {{ e.msg }}&#10;{% endfor %}{% if h.errors.count > h.errors.samples|length %}…and {{ h.errors.count - h.errors.samples|length }} more{% endif %}">⚠ {{ h.errors.count }} error{{ '' if h.errors.count == 1 else 's' }} (6h)</span>
        {% else %}
        <span class="text-[11px] text-emerald-600" title="No ERROR/CRITICAL worker logs from {{ h.host }} in the last 6h.">no recent errors</span>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
</section>

{# ── One list per category ───────────────────────────────────── #}
{% for cat in categories %}
<section class="mb-6">
  <h2 class="text-sm font-semibold mb-2 capitalize">{{ cat.name }}</h2>
  <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full text-xs">
      <thead class="bg-slate-50 text-slate-500">
        <tr>
          <th class="text-left font-medium px-3 py-2">service</th>
          <th class="text-left font-medium px-3 py-2">kind</th>
          <th class="text-left font-medium px-3 py-2">profile</th>
          <th class="text-left font-medium px-3 py-2">needs</th>
          <th class="text-left font-medium px-3 py-2">prio ({{ selected_host }})</th>
          <th class="text-left font-medium px-3 py-2">model</th>
          <th class="text-left font-medium px-3 py-2">last ok</th>
          <th class="text-left font-medium px-3 py-2">last fail</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {% for s in cat.services %}
        <tr class="align-top">
          <td class="px-3 py-2">
            <div class="flex items-center gap-2">
              <span class="font-mono font-semibold text-slate-800">{{ s.name }}</span>
              {% if s.has_agent %}
              <a href="/env?agent={{ s.name }}" class="text-emerald-700 hover:underline" title="agent env inspector">env↗</a>
              {% endif %}
            </div>
            <div class="text-slate-500 mt-0.5">{{ s.one_line }}</div>
          </td>
          <td class="px-3 py-2 text-slate-600">{{ s.kind }}</td>
          <td class="px-3 py-2 font-mono text-slate-600">
            {{ s.profiles }}
            {% if s.enable_env %}<div class="text-slate-400">{{ s.enable_env }}</div>{% endif %}
          </td>
          <td class="px-3 py-2">
            {% if s.requires %}
            <span class="font-mono text-amber-700">{{ ', '.join(s.requires) }}</span>
            {% endif %}
            {% if s.uses_model %}<span class="text-sky-700">model</span>{% endif %}
            {% if s.external %}<div class="text-slate-400 font-mono">{{ ', '.join(s.external) }}</div>{% endif %}
            {% if not s.requires and not s.uses_model and not s.external %}<span class="text-slate-300">—</span>{% endif %}
          </td>
          {# ── editable prio ── #}
          <td class="px-3 py-2">
            <form method="post" action="/factory/prio" class="flex items-center gap-1">
              <input type="hidden" name="host" value="{{ selected_host }}">
              <input type="hidden" name="service" value="{{ s.name }}">
              <input type="number" name="prio" min="0" max="10"
                     value="{{ s.prio if s.prio is not none else '' }}"
                     placeholder="{{ default_prio }}"
                     class="w-14 rounded border {% if s.prio == 0 %}border-rose-300 bg-rose-50{% else %}border-slate-300{% endif %} px-1 py-0.5 text-xs">
              <button class="rounded bg-slate-700 text-white px-1.5 py-0.5 text-[11px]">set</button>
            </form>
            {% if s.prio is not none %}
            <form method="post" action="/factory/clear" class="mt-0.5">
              <input type="hidden" name="host" value="{{ selected_host }}">
              <input type="hidden" name="service" value="{{ s.name }}">
              <button class="text-[11px] text-slate-400 hover:text-rose-600 hover:underline">clear</button>
            </form>
            {% endif %}
            {% if s.others %}<div class="text-[11px] text-slate-400 mt-0.5">others: {{ s.others }}</div>{% endif %}
          </td>
          {# ── model picker (model-using rows) ── #}
          <td class="px-3 py-2">
            {% if s.uses_model %}
            <form method="post" action="/factory/model" class="flex items-center gap-1">
              <input type="hidden" name="host" value="{{ selected_host }}">
              <input type="hidden" name="service" value="{{ s.name }}">
              <select name="model" onchange="this.form.submit()"
                      class="rounded border border-slate-300 px-1 py-0.5 text-xs max-w-[10rem]">
                <option value="" {% if not s.model_pref %}selected{% endif %}>(auto)</option>
                {% for m in models %}
                <option value="{{ m }}" {% if m == s.model_pref %}selected{% endif %}>{{ m }}</option>
                {% endfor %}
                {% if s.model_pref and s.model_pref not in models %}
                <option value="{{ s.model_pref }}" selected>{{ s.model_pref }} (?)</option>
                {% endif %}
              </select>
            </form>
            {% else %}
            <span class="text-slate-300">—</span>
            {% endif %}
          </td>
          <td class="px-3 py-2 {% if s.last_ok %}text-emerald-700{% else %}text-slate-300{% endif %}">{{ s.last_ok or '—' }}</td>
          <td class="px-3 py-2 {% if s.last_fail %}text-rose-700{% else %}text-slate-300{% endif %}">{{ s.last_fail or '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endfor %}

{# ── Quests tab — the other substrate: which strivings get attention ── #}
<section class="mt-8">
  <h2 class="text-sm font-semibold mb-1">Quests</h2>
  <p class="text-xs text-slate-500 mb-3">
    Same model as services — set a priority, the system allocates
    proportionally — on the striving substrate. Each active quest's spend
    over the trailing {{ quests.window_days }}-day window against its
    priority-weighted share of the budget
    {% if quests.budget %}(${{ '%.2f'|format(quests.budget) }}){% else %}(no budget set — spend only){% endif %}.
    A quest at 100% is one the allocator skips this round.
  </p>
  {% if not quests.rows %}
  <p class="text-xs text-slate-500">No active quests.</p>
  {% else %}
  <div class="overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead>
        <tr class="text-left text-xs text-slate-500 border-b border-slate-200">
          <th class="py-1 pr-3">quest</th>
          <th class="py-1 pr-3">prio</th>
          <th class="py-1 pr-3">spend ({{ quests.window_days }}d)</th>
          <th class="py-1 pr-3 w-64">share consumed</th>
        </tr>
      </thead>
      <tbody>
        {% for q in quests.rows %}
        <tr class="border-b border-slate-100">
          <td class="py-1.5 pr-3">
            <span class="text-slate-800">{{ q.title }}</span>
            <span class="text-xs text-slate-400 font-mono">qu{{ q.id }}</span>
          </td>
          <td class="py-1.5 pr-3 font-mono text-xs">{{ q.prio if q.prio is not none else '—' }}</td>
          <td class="py-1.5 pr-3 font-mono text-xs">${{ '%.4f'|format(q.spend) }}</td>
          <td class="py-1.5 pr-3">
            {% if q.pct is not none %}
            <div class="flex items-center gap-2">
              <div class="flex-1 h-2 rounded bg-slate-100 overflow-hidden">
                <div class="h-2 {% if q.over %}bg-rose-500{% elif q.pct >= 75 %}bg-amber-500{% else %}bg-emerald-500{% endif %}"
                     style="width: {{ q.pct }}%"></div>
              </div>
              <span class="text-xs {% if q.over %}text-rose-700 font-semibold{% else %}text-slate-500{% endif %}">{{ q.pct }}%</span>
            </div>
            {% else %}
            <span class="text-xs text-slate-400">— (no budget share)</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</section>
{% endblock %}
