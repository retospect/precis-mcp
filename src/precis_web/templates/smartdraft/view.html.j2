{% extends "base.html.j2" %}
{% block title %}{{ ref.title }} — smartdraft{% endblock %}
{% block content %}
{# One URL builder for the whole panel — every control overrides one param.
   Params are to_* so they don't shadow the render-context globals they
   default to (a macro can't see template-level {% set %} vars). #}
{% macro slink(to_focus=None, to_q=None, to_sig=None, to_view=None, to_rel=None, to_debug=None) -%}
/smartdraft/{{ ident }}?focus={{ to_focus if to_focus is not none else focus_dc }}&relevance={{ '1' if (to_rel if to_rel is not none else relevance) else '0' }}&q={{ (to_q if to_q is not none else q) | urlencode }}&sig={{ to_sig if to_sig is not none else active_sig }}&sview={{ to_view if to_view is not none else sview }}&debug={{ '1' if (to_debug if to_debug is not none else debug) else '0' }}
{%- endmacro %}
{% macro qs(dc) %}{{ slink(to_focus=dc) }}{% endmacro %}

<div class="mb-2 flex items-center justify-between">
  <h1 class="truncate text-base font-semibold">{{ ref.title }}</h1>
  <div class="flex items-center gap-3 text-[11px] text-slate-500">
    <a href="{{ slink(to_debug=(not debug)) }}" class="{% if debug %}text-sky-700{% else %}hover:text-slate-800{% endif %}" title="show chunk ids (debug)">ids</a>
    <a href="/drafts/{{ ident }}" class="hover:text-slate-800">open in classic ↗</a>
  </div>
</div>

<div id="sd-content" class="grid grid-cols-1 items-start gap-3 lg:grid-cols-[28%_44%_28%]">

  {# ── LEFT: fisheye TOC nav (sticky sidebar; the middle flows so its
       hover-preview popovers aren't clipped by an overflow container) ── #}
  <div class="sticky top-2 self-start rounded border border-slate-200 bg-white">
    {# header: search + signal toggles + fisheye/full + results view #}
    <div class="space-y-1.5 border-b border-slate-100 p-2">
      <form method="get" action="/smartdraft/{{ ident }}">
        <input type="hidden" name="focus" value="{{ focus_dc }}">
        <input type="hidden" name="relevance" value="{{ '1' if relevance else '0' }}">
        <input type="hidden" name="sig" value="{{ active_sig }}">
        <input type="hidden" name="sview" value="{{ sview }}">
        <input name="q" value="{{ q }}" placeholder="search…" autocomplete="off"
               class="w-full rounded border border-slate-200 px-2 py-1 text-xs focus:border-sky-400 focus:outline-none">
      </form>
      <div class="flex items-center gap-1">
        {% for s in [('v','verbatim text'),('k','keywords'),('t','tags'),('s','semantic (embedding)')] %}
        {% set on = s[0] in active_sig %}
        {% set nsig = (active_sig|replace(s[0],'')) if on else (active_sig ~ s[0]) %}
        <a href="{{ slink(to_sig=nsig) }}" title="{{ s[1] }} — click to toggle"
           class="inline-flex h-6 w-6 items-center justify-center rounded-full border text-[11px] font-semibold
                  {% if on %}border-sky-500 bg-sky-600 text-white{% else %}border-slate-200 text-slate-300 hover:text-slate-500{% endif %}">{{ s[0]|upper }}</a>
        {% endfor %}
        <a href="{{ slink(to_rel=(not relevance)) }}" title="fisheye vs full document"
           class="ml-auto rounded border border-slate-200 px-1.5 py-0.5 text-[11px] {% if relevance %}bg-sky-600 text-white{% else %}text-slate-500{% endif %}">{{ '🔍' if relevance else '📄' }}</a>
      </div>
      {% if q %}
      <div class="flex items-center gap-2 text-[10px] text-slate-500">
        <span>{{ hits | length }} hit{{ 's' if hits | length != 1 }}</span>
        <a href="{{ slink(to_view='list') }}" class="{% if sview == 'list' %}font-semibold text-sky-700{% else %}hover:text-slate-700{% endif %}">list</a>
        <a href="{{ slink(to_view='toc') }}" class="{% if sview == 'toc' %}font-semibold text-sky-700{% else %}hover:text-slate-700{% endif %}">in-toc</a>
        <a href="{{ slink(to_q='') }}" class="ml-auto hover:text-rose-600">clear</a>
      </div>
      {% if sem_degraded and 's' in active_sig %}
      <div class="text-[10px] text-amber-600" title="the web embedder returned nothing — semantic search is unavailable right now">⚠ semantic unavailable (embedder warming?) — V/K/T only</div>
      {% endif %}
      {% endif %}
    </div>

    <div class="max-h-[calc(100vh-9rem)] overflow-auto py-1 text-xs">
      {% if q and sview == 'list' %}
      {# ── search results (ranked list) ── #}
      {% for h in hits %}
      {% set n = h.node %}
      <a href="{{ slink(to_focus=n.dc) }}"
         class="flex items-center gap-1 px-2 py-1 hover:bg-sky-100 {% if n.dc == focus_dc %}bg-sky-100 ring-1 ring-inset ring-sky-400{% else %}bg-sky-50{% endif %}">
        {% for b in [('v', h.v, 'V', 'bg-sky-600'), ('k', h.k, 'K', 'bg-teal-600'), ('t', h.t, 'T', 'bg-amber-600')] %}
          {% if b[1] %}<span title="{{ b[0] }} match{{ '' if b[0] in active_sig else ' (off — not counted)' }}"
             class="inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full text-[9px] font-semibold text-white {% if b[0] in active_sig %}{{ b[3] }}{% else %}bg-slate-300{% endif %}">{{ b[2] }}</span>{% endif %}
        {% endfor %}
        {% if h.s_rank %}<span title="semantic rank #{{ h.s_rank }}{{ '' if 's' in active_sig else ' (off)' }}"
           class="inline-flex h-4 shrink-0 items-center justify-center rounded-full px-1 text-[9px] font-semibold text-white {% if 's' in active_sig %}bg-violet-600{% else %}bg-slate-300{% endif %}">S{{ h.s_rank }}</span>{% endif %}
        <span class="min-w-0 flex-1 truncate text-slate-600">{{ n.summary }}</span>
      </a>
      {% else %}
      <div class="px-2 py-3 text-slate-400">No matches.</div>
      {% endfor %}

      {% else %}
      {# ── fisheye TOC (default; in-toc search view tints hits) ── #}
      {% set hit_dcs = hits | map(attribute='node') | map(attribute='dc') | list %}
      {% for row in view.toc %}
        {% if row.collapsed_nodes %}
        {% set first = row.collapsed_nodes[0] %}
        <a href="{{ qs(first.dc) }}"
           title="{{ row.collapsed_nodes | map(attribute='summary') | join('\n') }}"
           class="block px-2 py-0.5 text-slate-300 hover:bg-slate-50 hover:text-slate-500">⋯ {{ row.collapsed_nodes | length }} paras ⋯</a>
        {% else %}
        {% set n = row.node %}
        <a id="toc-{{ n.dc }}" href="{{ qs(n.dc) }}"
           style="padding-left: {{ 0.4 + n.depth * 0.75 }}rem"
           class="flex items-start gap-1 py-0.5 pr-2 hover:bg-slate-50
                  {% if q and n.dc in hit_dcs %}bg-sky-100{% elif n.dc == focus_dc %}bg-amber-50 ring-1 ring-inset ring-amber-400{% elif row.shared %}bg-emerald-50{% elif row.pressure >= 0.4 %}bg-sky-50{% endif %}">
          <span class="min-w-0 flex-1 truncate
                       {% if n.is_heading %}font-semibold text-slate-800{% else %}text-slate-600{% endif %}"
                >{% if debug %}<span class="font-mono text-[9px] text-sky-500">{{ n.dc }}</span> {% endif %}{% if n.is_heading %}{{ n.summary }}{% else %}<span class="text-slate-400">·</span> {{ n.summary }}{% endif %}</span>
          <span class="shrink-0 text-[10px]">
            {%- if row.shared %}<span title="shares a keyword with the focus">🔑</span>{% endif -%}
            {%- if n.pinned %}📌{% endif -%}
            {%- if n.locked %}🔒{% endif -%}
          </span>
        </a>
        {% endif %}
      {% else %}
        <div class="px-2 py-3 text-slate-400">No chunks yet.</div>
      {% endfor %}
      {% endif %}
    </div>
  </div>

  {# ── MIDDLE: the focus + its neighbourhood. NOT an overflow container —
       it flows with the page so linkify hover-preview popovers escape freely
       (an overflow-auto ancestor would clip them at the panel edge). ── #}
  <div class="rounded border border-slate-200 bg-white">
    <div class="border-b border-slate-100 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-slate-400">Focus</div>
    <div class="space-y-2 p-3 text-sm">
      {% for m in view.middle %}
        {% set n = m.node %}
        {% set hd = 'font-semibold text-slate-900 text-base' if n.is_heading else '' %}
        {% if m.mode == 'full' %}
        {# NB: never pass raw chunk text through x-data (its quotes/newlines break
           the attribute) — the raw text is server-rendered into the <textarea>
           and read via $refs on save. #}
        <div id="mid-focus" class="rounded border border-amber-200 bg-amber-50 p-2"
             x-data="smartEdit('{{ ident }}', '{{ n.base58 }}', '{{ n.sha }}', {{ n.editable | tojson }})">
          <div class="mb-1 flex items-center gap-2 text-[10px] text-amber-700">
            <span>{% if debug %}<span class="font-mono text-sky-500">{{ n.dc }}</span> {% endif %}{% if n.locked %}🔒{% endif %}</span>
            <div class="ml-auto flex items-center gap-2" x-show="!editing">
              <button onclick="smartPin('{{ n.dc }}')"
                      class="{% if focus_pinned %}font-semibold text-amber-800{% else %}text-slate-400 hover:text-amber-700{% endif %}"
                      title="pin/unpin this para (key: p)">📌 {{ 'unpin' if focus_pinned else 'pin' }}</button>
              <button x-show="canEdit" @click="start()" class="text-slate-400 hover:text-slate-700">✎ edit</button>
            </div>
          </div>
          {# rendered view (with links) — hidden while editing #}
          <div x-show="!editing" class="whitespace-pre-wrap text-slate-800 {{ hd }}">{{ m.display | linkify_refs(markdown=True, compact=True) }}</div>
          {# inline editor — raw text server-rendered into the textarea; saves
             through the shipped /drafts/{id}/text #}
          <div x-show="editing" x-cloak>
            <textarea x-ref="ta" rows="10" class="w-full rounded border border-amber-300 px-2 py-1 font-mono text-xs focus:border-amber-500 focus:outline-none">{{ n.text }}</textarea>
            <div class="mt-1 flex items-center gap-2">
              <button @click="save()" :disabled="saving" class="rounded bg-amber-600 px-2 py-0.5 text-[11px] text-white hover:bg-amber-700 disabled:opacity-40">save</button>
              <button @click="cancel()" class="text-[11px] text-slate-500 hover:text-slate-800">cancel</button>
              <span class="text-[11px] text-rose-600" x-show="msg" x-text="msg"></span>
            </div>
          </div>
        </div>
        {% elif m.mode == 'doc' %}
        {# full-doc mode: every chunk verbatim, plain (focus is the amber box above) #}
        <a href="{{ qs(n.dc) }}" class="block whitespace-pre-wrap rounded px-2 py-1 text-slate-700 hover:bg-slate-50 {{ hd }}">{% if debug %}<span class="font-mono text-[9px] text-sky-500">{{ n.dc }} </span>{% endif %}{{ m.display | linkify_refs(markdown=True, compact=True) }}</a>
        {% elif m.mode in ('tail', 'head') %}
        {# ±1 neighbour: verbatim, truncated toward the focus (tail leads in, head flows out) #}
        <a href="{{ qs(n.dc) }}" class="block whitespace-pre-wrap rounded px-2 py-1 text-slate-500 hover:bg-slate-50 {{ hd }}">{% if debug %}<span class="font-mono text-[9px] text-sky-500">{{ n.dc }} </span>{% endif %}{{ m.display | linkify_refs(markdown=True, compact=True) }}</a>
        {% else %}
        {# ±2 neighbour: one-line summary #}
        <a href="{{ qs(n.dc) }}" class="block truncate rounded px-2 py-0.5 text-slate-400 hover:bg-slate-50 {{ hd }}" title="{{ n.text[:400] }}">{% if debug %}<span class="font-mono text-[9px] text-sky-500">{{ n.dc }} </span>{% endif %}· {{ m.display }}</a>
        {% endif %}
      {% else %}
        <div class="text-slate-400">Empty draft.</div>
      {% endfor %}
      {# "Relevant elsewhere" is not injected here — it broke the reading
         sequence. Distant-but-relevant chunks light up in the TOC (left) at
         their real location instead (sky tint), so the map carries relevance
         and the middle stays a clean read. #}
    </div>
  </div>

  {# ── RIGHT: collaboration (working set + request box) — sticky sidebar ── #}
  <div class="sticky top-2 self-start rounded border border-slate-200 bg-white" x-data="smartAsk('{{ ident }}', '{{ focus_dc }}')">
    <div class="border-b border-slate-100 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-slate-400">Collaborate</div>
    <div class="space-y-2 p-2 text-xs">
      {% if needs %}
      <div class="rounded border border-amber-200 bg-amber-50 p-1.5">
        <div class="mb-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-700">Needs · in-flight</div>
        {% for w in needs %}
        <div class="flex items-center gap-1 py-0.5 text-[10px]">
          {% if w.asks %}<span title="{{ w.asks | join('; ') }}">✋</span>{% endif %}
          <a href="/r/todo/{{ w.todo_id }}" target="_blank" rel="noopener" class="min-w-0 flex-1 truncate text-slate-700 hover:underline">{{ w.title }}</a>
          <span class="shrink-0 rounded px-1 {% if w.blocked %}bg-rose-100 text-rose-700{% else %}bg-slate-200 text-slate-600{% endif %}">{{ w.status }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}
      <div class="flex items-center gap-2 text-slate-500">
        <span>Pinned: 📌 {{ eye_count }}</span>
        {% if eye_count %}<button onclick="smartClearPins()" class="text-[10px] text-slate-400 hover:text-rose-600">unpin all</button>
        {% else %}<span class="text-[10px] text-slate-400">nothing pinned — the ask works on the current para</span>{% endif %}
      </div>
      <textarea x-model="text" rows="3" placeholder="Ask the LLM (works on the pinned context, or the current para if nothing is pinned)…"
                class="w-full rounded border border-slate-200 px-2 py-1"></textarea>
      <div class="flex items-center gap-2">
        <select x-model="model" class="rounded border border-slate-200 px-1 py-0.5 text-slate-600">
          <option>opus</option><option>sonnet</option><option>haiku</option>
        </select>
        <span class="text-slate-400" x-show="msg" x-text="msg"></span>
        <button @click="send()" :disabled="!text.trim()" class="ml-auto rounded bg-slate-800 px-2 py-1 text-white disabled:opacity-40">Send ▸</button>
      </div>
    </div>
  </div>

</div>

<script>
// Keyboard nav (when NOT editing): ↑/↓ step the TOC linearly; →/Tab indent to
// the next deeper chunk (child), ←/Shift-Tab outdent to the parent (nearest
// shallower). Frames the active TOC entry + scrolls it into view on load.
(function () {
  const IDENT = {{ ident | tojson }};
  const ORDER = {{ view.order | tojson }};      // [[dc, depth], ...]
  const HITS = {{ (hits | map(attribute='node') | map(attribute='dc') | list) | tojson }};  // search hits, in rank order
  const FOCUS = {{ focus_dc | tojson }};
  const Q = {{ q | tojson }};
  // Navigate preserving EVERY current param (q/sig/sview/relevance) — only focus
  // changes, so arrowing never drops the search.
  const jump = (dc) => {
    const p = new URLSearchParams(location.search);
    p.set('focus', dc);
    location = `/smartdraft/${IDENT}?` + p.toString();
  };
  const clearSearch = () => {
    const p = new URLSearchParams(location.search);
    p.set('q', '');
    location = `/smartdraft/${IDENT}?` + p.toString();
  };
  // Highlight the query term wherever it shows (light blue) — a find-style mark.
  function highlightTerm(root, term) {
    if (!root || !term || term.length < 2) return;
    const re = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
      acceptNode(n) {
        const p = n.parentNode;
        if (!n.nodeValue.trim() || !p) return NodeFilter.FILTER_REJECT;
        // skip marks/scripts/inputs and links (don't disturb linkify internals)
        if (['MARK', 'SCRIPT', 'STYLE', 'TEXTAREA', 'BUTTON', 'A'].includes(p.tagName)) return NodeFilter.FILTER_REJECT;
        return re.test(n.nodeValue) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
      },
    });
    const nodes = []; while (walker.nextNode()) nodes.push(walker.currentNode);
    nodes.forEach((n) => {
      const span = document.createElement('span');
      span.innerHTML = n.nodeValue.replace(re, '<mark class="rounded bg-sky-200 text-inherit">$1</mark>');
      n.parentNode.replaceChild(span, n);
    });
  }
  window.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('toc-' + FOCUS);
    if (el) el.scrollIntoView({ block: 'center' });
    const mid = document.getElementById('mid-focus');
    if (mid) mid.scrollIntoView({ block: 'center' });
    if (Q) highlightTerm(document.getElementById('sd-content'), Q);
  });
  document.addEventListener('keydown', (e) => {
    const t = document.activeElement;
    const inField = t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable);
    if (e.key === 'Escape' && Q) { e.preventDefault(); clearSearch(); return; }
    if (e.key === '/' && !inField) {   // focus the search box
      e.preventDefault();
      const box = document.querySelector('input[name="q"]');
      if (box) box.focus();
      return;
    }
    if (inField) return;
    if (e.key === 'p' || e.key === 'P') {   // toggle pin/unpin the focus
      e.preventDefault();
      fetch(`/drafts/${IDENT}/marks`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ op: 'eye', handles: [FOCUS] }),
      }).then(() => location.reload());
      return;
    }
    // In search mode the arrows step through the RESULTS (not the outline).
    if (HITS && HITS.length) {
      let hi = HITS.indexOf(FOCUS);
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') hi = hi < 0 ? 0 : Math.min(HITS.length - 1, hi + 1);
      else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') hi = hi < 0 ? 0 : Math.max(0, hi - 1);
      else return;
      e.preventDefault(); jump(HITS[hi]); return;
    }
    const i = ORDER.findIndex((o) => o[0] === FOCUS);
    if (i < 0) return;
    const depth = ORDER[i][1];
    let j = -1;
    if (e.key === 'ArrowDown') j = Math.min(ORDER.length - 1, i + 1);
    else if (e.key === 'ArrowUp') j = Math.max(0, i - 1);
    else if (e.key === 'ArrowRight' || (e.key === 'Tab' && !e.shiftKey)) {
      for (let k = i + 1; k < ORDER.length; k++) { if (ORDER[k][1] > depth) { j = k; break; } if (ORDER[k][1] < depth) break; }
    } else if (e.key === 'ArrowLeft' || (e.key === 'Tab' && e.shiftKey)) {
      for (let k = i - 1; k >= 0; k--) { if (ORDER[k][1] < depth) { j = k; break; } }
    } else return;
    if (j >= 0 && j !== i) { e.preventDefault(); jump(ORDER[j][0]); }
  });
})();

// Pin/unpin any chunk (a persistent context eye) — used by the focus header
// and the TOC rows. POSTs the shipped /marks toggle, then reloads.
function smartPin(dc) {
  fetch(`/drafts/{{ ident }}/marks`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ op: 'eye', handles: [dc] }),
  }).then(() => location.reload()).catch(() => {});
}
function smartClearPins() {
  fetch(`/drafts/{{ ident }}/marks`, {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ op: 'clear' }),
  }).then(() => location.reload()).catch(() => {});
}

// Inline text edit of the focus para — saves through the shipped
// /drafts/{id}/text (validation + link-sync single-sourced with the MCP path).
// A 422 (broken ref introduced) / 409 (stale) surfaces its message in place.
function smartEdit(ident, handle, sha, canEdit) {
  return {
    ident, handle, sha, canEdit,
    editing: false, saving: false, msg: '',
    start() { this.msg = ''; this.editing = true; },
    cancel() { this.editing = false; this.msg = ''; },
    async save() {
      const text = this.$refs.ta ? this.$refs.ta.value : '';
      this.saving = true; this.msg = '';
      try {
        const r = await fetch(`/drafts/${this.ident}/text`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ handle: this.handle, text, base_sha: this.sha }),
        });
        const d = await r.json();
        if (d.ok) { location.reload(); }
        else { this.msg = d.error || (d.hard ? ('broke: ' + d.hard.join(', ')) : 'save failed'); this.saving = false; }
      } catch (e) { this.msg = 'network error'; this.saving = false; }
    },
  };
}

function smartAsk(ident, focus) {
  return {
    ident, focus, text: '', model: 'opus', msg: '',
    async send() {
      if (!this.text.trim()) return;
      this.msg = 'sending…';
      try {
        // `anchor` = the current focus, so with nothing pinned the request still
        // works on the current para + its fisheye (server falls back to it).
        const r = await fetch(`/drafts/${this.ident}/request-ws`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: this.text, model: this.model, anchor: this.focus }),
        });
        const d = await r.json();
        this.msg = d.ok ? 'sent ✓' : ('error: ' + (d.error || ''));
        if (d.ok) this.text = '';
      } catch (e) { this.msg = 'network error'; }
    },
  };
}
</script>
{% endblock %}
