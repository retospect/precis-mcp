<!doctype html>
<html lang="en" class="h-full bg-slate-50">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% block title %}precis{% endblock %} · precis web</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.3" defer></script>
  <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</head>
<body class="h-full text-slate-800">
  <div class="min-h-full">
    <header class="bg-slate-900 text-slate-100">
      <div class="mx-auto max-w-6xl px-4">
        <nav class="flex flex-wrap items-center gap-1 py-2">
          <span class="font-semibold tracking-tight text-emerald-400 mr-4">precis</span>
          {% set tabs = [('tasks','Tasks','/tasks'), ('asks','Asks','/asks'), ('papers','Papers','/papers'), ('papers-needed','Papers Needed','/papers-needed'), ('triage','Triage','/papers/triage'), ('clusters','Clusters','/clusters'), ('tags','Tags','/tags')] %}
          {% for key, label, href in tabs %}
          <a href="{{ href }}"
             class="px-3 py-2 rounded-md text-sm font-medium transition
                    {% if active_tab == key %}bg-slate-700 text-white{% else %}text-slate-300 hover:bg-slate-800 hover:text-white{% endif %}">
            {{ label }}
          </a>
          {% endfor %}
          <span class="mx-2 h-5 w-px bg-slate-700"></span>
          {# Refs is the consolidated browser (memory/conv/gripe/pres
             pre-checked + checkboxes for the rest). Oracle and Patents
             keep their own tabs — Oracle for its "roll the dice" UX,
             Patents because of the OPS remote-search affordances. #}
          {% set ref_tabs = [('refs','Refs','/refs'), ('refs:oracle','Oracle','/refs/oracle'),
                             ('refs:patent','Patents','/refs/patent')] %}
          {% for key, label, href in ref_tabs %}
          <a href="{{ href }}"
             class="px-3 py-2 rounded-md text-sm font-medium transition
                    {% if active_tab == key %}bg-slate-700 text-white{% else %}text-slate-300 hover:bg-slate-800 hover:text-white{% endif %}">
            {{ label }}
          </a>
          {% endfor %}
          <span class="mx-2 h-5 w-px bg-slate-700"></span>
          {% set util_tabs = [('alerts','Alerts','/alerts'), ('console','Console','/console'), ('env','Env','/env'), ('status','Status','/status')] %}
          {% for key, label, href in util_tabs %}
          <a href="{{ href }}"
             class="px-3 py-2 rounded-md text-sm font-medium transition
                    {% if active_tab == key %}bg-slate-700 text-white{% else %}text-slate-300 hover:bg-slate-800 hover:text-white{% endif %}">
            {{ label }}
          </a>
          {% endfor %}
          {# 🔍 loupe — global cross-kind search. Submits to /refs with
             ``all=1`` so every browsable kind is in scope; the user can
             then uncheck irrelevant ones on the results page. #}
          <form method="get" action="/refs" class="ml-auto flex items-center gap-1">
            <input type="hidden" name="all" value="1" />
            <input name="q" placeholder="🔍 search everything…"
                   class="bg-slate-800 border border-slate-700 text-slate-100 placeholder-slate-400 text-sm px-3 py-1 rounded w-48 focus:w-72 focus:outline-none focus:ring-1 focus:ring-emerald-500 transition-all" />
          </form>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-6">
      {% block content %}{% endblock %}
    </main>
  </div>
</body>
</html>
