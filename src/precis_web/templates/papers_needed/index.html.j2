{% extends "base.html.j2" %}
{% block title %}Papers we need{% endblock %}
{% block content %}
<div class="flex items-center justify-between mb-3">
  <h1 class="text-lg font-semibold">Papers we need</h1>
  <div class="flex items-center gap-2 text-sm">
    <a href="/papers-needed"
       class="px-3 py-1 rounded-md {% if not awaiting %}bg-slate-800 text-white{% else %}bg-slate-100 text-slate-700{% endif %}">
      All backlog
    </a>
    <a href="/papers-needed?awaiting=1"
       class="px-3 py-1 rounded-md {% if awaiting %}bg-slate-800 text-white{% else %}bg-slate-100 text-slate-700{% endif %}">
      Awaiting next fetch
    </a>
  </div>
</div>

<p class="text-sm text-slate-500 mb-4">
  Stub paper refs — minted with a DOI / arXiv ID but no PDF yet. The
  <code class="text-xs">fetch_oa</code> worker auto-tries Unpaywall → arXiv →
  Semantic Scholar. Stubs that survive every retry need manual help:
  paywall pay-out, file upload, or marking the cite won't-do.
</p>

{% if not rows %}
  <p class="text-sm text-slate-500">
    {% if awaiting %}
      Nothing waiting for the next fetch pass — the cascade is caught up.
    {% else %}
      No stub paper refs. Every paper in the corpus has a PDF, or none
      have external identifiers.
    {% endif %}
  </p>
{% else %}
<div class="rounded-lg border border-slate-200 bg-white overflow-hidden">
  <table class="min-w-full text-sm">
    <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
      <tr>
        <th class="text-left px-3 py-2">#</th>
        <th class="text-left px-3 py-2">Title / cite key</th>
        <th class="text-left px-3 py-2">Identifier</th>
        <th class="text-left px-3 py-2">Requested</th>
        <th class="text-right px-3 py-2">Tries</th>
        <th class="text-left px-3 py-2">Last attempt</th>
        <th class="text-left px-3 py-2">State</th>
        <th class="text-left px-3 py-2">Flag</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {% for row in rows %}
      <tr class="hover:bg-slate-50">
        <td class="px-3 py-2 text-xs text-slate-400">#{{ row.id }}</td>
        <td class="px-3 py-2">
          {% if row.title %}
            <a href="/papers/{{ row.id }}" class="text-sky-700 hover:underline font-medium">{{ row.title }}</a>
          {% else %}
            <a href="/papers/{{ row.id }}" class="text-slate-500 hover:underline italic">title TBD</a>
          {% endif %}
          {% if row.cite_key %}
            <span class="text-xs text-slate-400 ml-2">{{ row.cite_key }}</span>
          {% endif %}
        </td>
        <td class="px-3 py-2 text-xs">
          {% if row.identifier_url %}
            <a href="{{ row.identifier_url }}" target="_blank" rel="noopener"
               class="text-sky-700 hover:underline">{{ row.identifier }}</a>
          {% else %}
            <span class="text-slate-500">{{ row.identifier }}</span>
          {% endif %}
          {% if row.uol_url or row.scholar_url %}
            <span class="block text-slate-400">
              {% if row.uol_url %}
                <a href="{{ row.uol_url }}" target="_blank" rel="noopener"
                   class="text-sky-700 hover:underline">UoL</a>
              {% endif %}
              {% if row.uol_url and row.scholar_url %}<span class="px-0.5">·</span>{% endif %}
              {% if row.scholar_url %}
                <a href="{{ row.scholar_url }}" target="_blank" rel="noopener"
                   class="text-sky-700 hover:underline">Scholar</a>
              {% endif %}
            </span>
          {% endif %}
        </td>
        <td class="px-3 py-2 text-xs text-slate-500">
          {% if row.created_at %}
            <span title="{{ row.created_at | abs_ts }}">{{ row.created_at | ago }}</span>
          {% else %}
            —
          {% endif %}
          {% if row.requested_by %}
            <span class="block text-slate-400">by {{ row.requested_by }}</span>
          {% endif %}
        </td>
        <td class="px-3 py-2 text-xs text-right tabular-nums {% if row.attempts >= 6 %}text-amber-700 font-medium{% else %}text-slate-500{% endif %}"
            title="{{ row.attempts }} autofetch pass{{ '' if row.attempts == 1 else 'es' }} run so far">
          {{ row.attempts }}
        </td>
        <td class="px-3 py-2 text-xs text-slate-500">
          {% if row.last_attempt %}
            <span title="{{ row.last_attempt | abs_ts }}">{{ row.last_attempt | ago }}</span>
          {% else %}
            —
          {% endif %}
          {% if row.last_event %}
            <span class="block text-slate-400">{{ row.last_event }}</span>
          {% endif %}
        </td>
        <td class="px-3 py-2 text-xs">
          {% if 'fetch_ok' in row.last_event %}
            <span class="px-1.5 py-0.5 rounded bg-emerald-100 text-emerald-700">{{ row.state }}</span>
          {% elif 'failed' in row.last_event or 'no_oa_version' in row.last_event %}
            <span class="px-1.5 py-0.5 rounded bg-amber-100 text-amber-800">{{ row.state }}</span>
          {% else %}
            <span class="px-1.5 py-0.5 rounded bg-slate-200 text-slate-600">{{ row.state }}</span>
          {% endif %}
        </td>
        <td class="px-3 py-2">
          {% set ref_kind = 'paper' %}
          {% set ref_id = row.id %}
          {% set active = row.flags %}
          {% include "_flag_buttons.html.j2" with context %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% set qs = 'awaiting=1&' if awaiting else '' %}
{% macro pagelink(p, label, current=false, disabled=false) %}
  {% if disabled %}
  <span class="rounded-md border border-slate-200 px-3 py-1 text-slate-300">{{ label }}</span>
  {% elif current %}
  <span class="rounded-md border border-slate-800 bg-slate-800 px-3 py-1 text-white">{{ label }}</span>
  {% else %}
  <a href="/papers-needed?{{ qs }}page={{ p }}"
     class="rounded-md border border-slate-300 px-3 py-1 hover:bg-slate-100">{{ label }}</a>
  {% endif %}
{% endmacro %}

<div class="mt-3 flex flex-col gap-2 text-xs">
  <div class="text-slate-500">
    Showing <span class="font-medium text-slate-700">{{ offset + 1 }}–{{ offset + rows | length }}</span>
    of <span class="font-medium text-slate-700">{{ total }}</span> stub{{ '' if total == 1 else 's' }}
    · Page {{ page }} of {{ total_pages }}
  </div>
  <div class="flex flex-wrap items-center gap-1.5">
    {{ pagelink(page - 1, '&larr; Prev', disabled=(page <= 1)) }}

    {# leading first page + ellipsis when the window is detached from 1 #}
    {% if page_window[0] > 1 %}
      {{ pagelink(1, '1') }}
      {% if page_window[0] > 2 %}<span class="px-1 text-slate-400">…</span>{% endif %}
    {% endif %}

    {% for p in page_window %}
      {{ pagelink(p, p, current=(p == page)) }}
    {% endfor %}

    {# trailing ellipsis + last page when the window is detached from the end #}
    {% if page_window[-1] < total_pages %}
      {% if page_window[-1] < total_pages - 1 %}<span class="px-1 text-slate-400">…</span>{% endif %}
      {{ pagelink(total_pages, total_pages) }}
    {% endif %}

    {{ pagelink(page + 1, 'Next &rarr;', disabled=(not has_next)) }}
  </div>
</div>
{% endif %}

{# Ingest drop-zones — where to put files for the watch daemon to
   pick up. Watch_dir is read from com.precis.watch.plist on the
   web host; when unreadable we surface a fallback hint instead. #}
<section class="mt-6">
  <h2 class="text-sm font-semibold mb-2">Manual ingest — drop-zones</h2>
  {% if watch_dir %}
  <p class="text-xs text-slate-500 mb-3">
    Watch host: melchior. Daemon polls
    <code class="text-slate-700">{{ watch_dir }}</code> for new files and
    routes by sub-directory:
  </p>
  <ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
    {% for d in dropzones %}
    <li class="px-4 py-3 text-xs">
      <div class="flex items-center gap-2 mb-1">
        <span class="font-semibold text-slate-700">{{ d.label }}</span>
        <code class="ml-auto text-slate-700 bg-slate-50 px-1.5 py-0.5 rounded select-all">{{ d.path }}</code>
      </div>
      <p class="text-slate-500">{{ d.description }}</p>
    </li>
    {% endfor %}
  </ul>
  <p class="text-xs text-slate-400 mt-2">
    Files dropped in <code>{{ watch_dir }}/tagging/&lt;slug&gt;/</code>
    get a <code>topic:&lt;slug&gt;</code> tag on the ingested ref.
    Errors land in <code>{{ watch_dir }}/errors/&lt;timestamp&gt;/</code>
    with a sibling note explaining why.
  </p>
  {% else %}
  <p class="text-xs text-slate-500">
    Watch-daemon plist not readable from the web host — running
    outside the cluster, or the watch daemon isn't installed here.
    Drop-zone paths would be shown if it were.
  </p>
  {% endif %}
</section>
{% endblock %}
