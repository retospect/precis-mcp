{% extends "base.html.j2" %}
{% block title %}Items{% endblock %}
{% block content %}
<div class="mb-3 flex items-start gap-3" x-data="{ open: false, kind: 'draft' }">
  <div class="min-w-0">
    <h1 class="text-lg font-semibold">Items</h1>
    <p class="text-sm text-slate-500">
      One cross-kind search over everything you've collected — papers,
      patents, slides, cached answers, and more. One best-matching passage
      per source; the same query the LLM runs. Flag what you want to read.
    </p>
  </div>
  {# + New — mirrors Drive's dropdown; reuses /drafts/new + /drive/new. #}
  <div class="ml-auto relative shrink-0">
    <button type="button" @click="open = !open"
            class="rounded bg-sky-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-sky-700">
      + New <span class="text-[9px]">▾</span>
    </button>
    <form x-show="open" x-cloak @click.outside="open = false"
          method="post"
          :action="kind === 'draft' ? '/drafts/new' : '/drive/new'"
          class="absolute right-0 mt-1 w-64 z-20 rounded-lg border border-slate-200 bg-white p-3 shadow-lg space-y-2">
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Kind</label>
        <select x-model="kind" name="kind"
                class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm bg-white">
          <option value="draft">Draft (document)</option>
          <option value="cad">CAD (3D solid)</option>
          <option value="structure">DFT (atomistic cell)</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Title <span class="text-rose-500">*</span></label>
        <input name="title" required autocomplete="off" x-init="$el.focus()"
               placeholder="new document"
               class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm">
      </div>
      <div class="flex justify-end">
        <button type="submit"
                class="rounded bg-emerald-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-emerald-700">
          Create ▸
        </button>
      </div>
    </form>
  </div>
</div>

<form method="get" action="/items" class="mb-4 space-y-2"
      x-data='itemsFilter({{ kind_defs | tojson }}, {{ artifact_kind_defs | tojson }}, {{ selected_kinds | tojson }}, {{ tags | tojson }})'>
  {# submitted=1 tells the server the checkboxes are authoritative (so
     "none checked" means none, and the choice is remembered in a cookie). #}
  <input type="hidden" name="submitted" value="1" />
  <div class="flex flex-wrap items-end gap-2">
    <div class="flex-1 min-w-[16rem]">
      <label class="block text-xs text-slate-500 mb-0.5">Search</label>
      <input type="text" name="q" value="{{ q }}" autofocus
             placeholder="e.g. MOF CO₂ capture"
             class="w-full rounded-md border border-slate-300 px-3 py-1.5 text-sm" />
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-0.5">Sort</label>
      <select name="sort" class="rounded-md border border-slate-300 px-3 py-1.5 text-sm">
        <option value="relevance" {% if sort != 'recency' %}selected{% endif %}>Relevance</option>
        <option value="recency" {% if sort == 'recency' %}selected{% endif %}>Newest first</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-0.5">Show</label>
      <select name="state" class="rounded-md border border-slate-300 px-3 py-1.5 text-sm">
        <option value="all" {% if state != 'stub' %}selected{% endif %}>All</option>
        <option value="stub" {% if state == 'stub' %}selected{% endif %}>Stubs (to get)</option>
      </select>
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-0.5">Since</label>
      <input type="date" name="since" value="{{ since }}"
             class="rounded-md border border-slate-300 px-2 py-1.5 text-sm" />
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-0.5">Until</label>
      <input type="date" name="until" value="{{ until }}"
             class="rounded-md border border-slate-300 px-2 py-1.5 text-sm" />
    </div>
    {% if folder_options %}
    <div>
      <label class="block text-xs text-slate-500 mb-0.5">Folder</label>
      <select name="folder" class="rounded-md border border-slate-300 px-3 py-1.5 text-sm max-w-[12rem]">
        <option value="">Any</option>
        {% for f in folder_options %}
        <option value="{{ f.id }}" {% if folder == f.id | string %}selected{% endif %}>{{ f.label }}</option>
        {% endfor %}
      </select>
    </div>
    {% endif %}
    <button type="submit"
            class="rounded-md bg-slate-800 text-white px-4 py-1.5 text-sm hover:bg-slate-700">
      Search
    </button>
  </div>

  {# Kind chips — click to toggle; All / None; remembered via cookie.
     Two facets per the proposal: "Source" (ingested docs + cached
     answers) and "Author" (role='artifact' — drafts, cad, structure, …). #}
  <div class="flex flex-wrap items-center gap-1.5 text-xs">
    <span class="text-slate-500 mr-1">Source</span>
    <button type="button" @click="allKinds()" class="px-1.5 py-0.5 rounded border border-slate-300 text-slate-600 hover:bg-slate-50">All</button>
    <button type="button" @click="noKinds()" class="px-1.5 py-0.5 rounded border border-slate-300 text-slate-600 hover:bg-slate-50">None</button>
    <template x-for="kk in sourceKinds" :key="kk">
      <label class="inline-flex items-center gap-1 px-2 py-0.5 rounded border cursor-pointer select-none"
             :class="kinds.includes(kk) ? 'bg-sky-100 border-sky-300 text-sky-800' : 'border-slate-200 text-slate-400 hover:bg-slate-50'">
        <input type="checkbox" name="k" :value="kk" x-model="kinds" class="sr-only" />
        <span x-text="kk"></span>
      </label>
    </template>
  </div>
  {% if artifact_kind_defs %}
  <div class="flex flex-wrap items-center gap-1.5 text-xs">
    <span class="text-slate-500 mr-1">Author</span>
    <template x-for="kk in artifactKinds" :key="kk">
      <label class="inline-flex items-center gap-1 px-2 py-0.5 rounded border cursor-pointer select-none"
             :class="kinds.includes(kk) ? 'bg-amber-100 border-amber-300 text-amber-800' : 'border-slate-200 text-slate-400 hover:bg-slate-50'">
        <input type="checkbox" name="k" :value="kk" x-model="kinds" class="sr-only" />
        <span x-text="kk"></span>
      </label>
    </template>
  </div>
  {% endif %}

  {# Tag filter — type to autocomplete (substring), click to add a chip,
     ✕ to remove. Selected tags submit as repeated ?tag= params. #}
  <div class="flex flex-wrap items-center gap-1.5 text-xs">
    <span class="text-slate-500 mr-1">Tags</span>
    <template x-for="(t, i) in tags" :key="t">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded bg-violet-100 text-violet-800">
        <span x-text="t"></span>
        <button type="button" @click="removeTag(i)" class="text-violet-500 hover:text-violet-900 leading-none">&times;</button>
        <input type="hidden" name="tag" :value="t" />
      </span>
    </template>
    <div class="relative">
      <input type="text" x-model="tagQuery" @input.debounce.200ms="suggest()"
             @keydown.escape="suggestions = []" placeholder="filter by tag…"
             class="rounded border border-slate-300 px-2 py-0.5 text-xs w-44" />
      <div x-show="suggestions.length" x-cloak @click.outside="suggestions = []"
           class="absolute left-0 mt-1 z-30 w-56 max-h-56 overflow-auto rounded-md border border-slate-200 bg-white py-1 shadow-lg">
        <template x-for="s in suggestions" :key="s.tag">
          <button type="button" @click="addTag(s.tag)" x-text="s.label"
                  class="block w-full text-left px-3 py-1 text-xs text-slate-600 hover:bg-slate-100"></button>
        </template>
      </div>
    </div>
  </div>
</form>

<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('itemsFilter', (sourceKinds, artifactKinds, selectedKinds, selectedTags) => ({
      sourceKinds: sourceKinds,
      artifactKinds: artifactKinds,
      kinds: selectedKinds,
      tags: selectedTags,
      tagQuery: '',
      suggestions: [],
      allKinds() { this.kinds = [...this.sourceKinds, ...this.artifactKinds]; },
      noKinds() { this.kinds = []; },
      removeTag(i) { this.tags.splice(i, 1); },
      addTag(t) {
        if (!this.tags.includes(t)) this.tags.push(t);
        this.tagQuery = '';
        this.suggestions = [];
      },
      async suggest() {
        const term = this.tagQuery.trim();
        if (term.length < 2) { this.suggestions = []; return; }
        try {
          const r = await fetch('/items/tags/suggest?q=' + encodeURIComponent(term));
          this.suggestions = await r.json();
        } catch (e) { this.suggestions = []; }
      },
    }));
  });
</script>

{% macro item_list(items) %}
<ul class="rounded-lg border border-slate-200 bg-white divide-y divide-slate-100">
  {% for row in items %}
  <li class="px-4 py-3 hover:bg-slate-50" x-data="{ hover: false }">
    <div class="flex items-start gap-3">
      {% if row.thumbnail %}
      <img src="{{ row.thumbnail }}" loading="lazy" alt=""
           class="mt-0.5 shrink-0 w-12 h-12 rounded object-cover border border-slate-200" />
      {% endif %}
      {# marker group: [kind] [stub|chunks] #}
      <div class="mt-0.5 shrink-0 flex items-center gap-1">
        <span class="text-[10px] px-1.5 py-0.5 rounded bg-slate-100 text-slate-500" title="kind">{{ row.kind }}</span>
        {% for b in row.state %}
          <span class="text-[10px] px-1.5 py-0.5 rounded {{ b.cls }}" title="{{ b.title }}">{{ b.label }}</span>
        {% endfor %}
      </div>
      <div class="min-w-0 flex-1 relative"
           @mouseenter="hover = true" @mouseleave="hover = false">
        <a href="{{ row.open_url }}" class="text-sky-700 hover:underline font-medium">{{ row.title }}</a>
        {% if row.tags %}
          <span class="ml-1 inline-flex flex-wrap gap-1 align-middle">
            {% for t in row.tags %}
            <a href="{{ t.href }}" class="text-[10px] px-1.5 py-0.5 rounded bg-violet-50 text-violet-700 hover:bg-violet-100">{{ t.label }}</a>
            {% endfor %}
          </span>
        {% endif %}
        {% if row.preview %}
          <p class="text-xs text-slate-500 mt-0.5">{{ row.preview }}</p>
        {% elif row.created_at %}
          <p class="text-xs text-slate-400 mt-0.5">added <span title="{{ row.created_at | abs_ts }}">{{ row.created_at | ago }}</span></p>
        {% endif %}
        {% if row.links %}
          <p class="text-xs text-slate-400 mt-0.5">
            find:
            {% for l in row.links %}
              <a href="{{ l.href }}" target="_blank" rel="noopener" class="text-sky-700 hover:underline">{{ l.label }}</a>{% if not loop.last %} · {% endif %}
            {% endfor %}
          </p>
        {% endif %}
        {% if row.actions %}
          <p class="text-xs mt-0.5">
            {% for a in row.actions %}
              <a href="{{ a.href }}" class="text-amber-700 hover:underline">{{ a.label }}</a>{% if not loop.last %} · {% endif %}
            {% endfor %}
          </p>
        {% endif %}
        {# Hover popover — the richer peek (abstract + wider chunk). Only
           worth a floating box when it says more than the row preview. #}
        {% if row.hover_preview and row.hover_preview != row.preview %}
        <div x-show="hover" x-cloak
             class="absolute left-0 top-full mt-1 z-20 w-96 max-w-[90vw] rounded-md border border-slate-200 bg-white p-3 text-xs text-slate-600 shadow-lg whitespace-pre-line">
          {{ row.hover_preview }}
        </div>
        {% endif %}
      </div>
      <div class="shrink-0">
        {% set ref_kind = row.kind %}
        {% set ref_id = row.id %}
        {% set active = row.flags %}
        {% include "_flag_buttons.html.j2" with context %}
      </div>
    </div>
  </li>
  {% endfor %}
</ul>
{% endmacro %}

{% macro pager() %}
{% if prev_url or next_url %}
<div class="mt-3 flex items-center gap-2 text-xs">
  {% if prev_url %}
  <a href="{{ prev_url }}" class="rounded-md border border-slate-300 px-3 py-1 hover:bg-slate-100">&larr; Prev</a>
  {% else %}
  <span class="rounded-md border border-slate-200 px-3 py-1 text-slate-300">&larr; Prev</span>
  {% endif %}
  <span class="text-slate-500">Page {{ page }}</span>
  {% if next_url %}
  <a href="{{ next_url }}" class="rounded-md border border-slate-300 px-3 py-1 hover:bg-slate-100">Next &rarr;</a>
  {% else %}
  <span class="rounded-md border border-slate-200 px-3 py-1 text-slate-300">Next &rarr;</span>
  {% endif %}
</div>
{% endif %}
{% endmacro %}

{% if q %}
  {% if not rows %}
  <p class="text-sm text-slate-500">
    No matches for <span class="font-medium text-slate-700">{{ q }}</span>{% if since or until %} in that date window{% endif %}.
  </p>
  {% else %}
  {{ item_list(rows) }}
  <p class="mt-2 text-xs text-slate-400">
    Showing up to {{ rows | length }} best-matching source{{ '' if rows | length == 1 else 's' }} · one passage per item.
  </p>
  {{ pager() }}
  {% endif %}
{% else %}
  {# Default landing: the recent list (or stub queue) under the search. #}
  <h2 class="text-sm font-semibold text-slate-600 mb-2">
    {% if state == 'stub' %}Stubs — papers to get{% else %}Recently added{% endif %}
  </h2>
  {% if recent %}
    {{ item_list(recent) }}
    <p class="mt-2 text-xs text-slate-400">
      {% if state == 'stub' %}
        The {{ recent | length }} newest stub{{ '' if recent | length == 1 else 's' }} — use the find: links to track a copy down.
      {% else %}
        The {{ recent | length }} newest source item{{ '' if recent | length == 1 else 's' }}. Search above to go deeper.
      {% endif %}
    </p>
    {{ pager() }}
  {% else %}
    <p class="text-sm text-slate-400">
      {% if state == 'stub' %}No stubs in the selected kinds — nothing waiting to be fetched.{% else %}Nothing here yet — ingest a paper or run a search above.{% endif %}
    </p>
  {% endif %}
{% endif %}
{% endblock %}
