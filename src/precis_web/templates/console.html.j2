{% extends "base.html.j2" %}
{% block title %}Console{% endblock %}
{% block content %}
<h1 class="text-lg font-semibold mb-3">Tool console</h1>
<p class="text-sm text-slate-500 mb-4">
  Call the seven verbs interactively. Arguments are
  <span class="font-mono">key=value</span> tokens (quote values with spaces),
  e.g. <span class="font-mono">q="two-photon absorption" kind=paper page_size=5</span>.
</p>

<form method="post" action="/console/run" class="space-y-3">
  <div class="flex items-center gap-2">
    <select name="verb" class="rounded-md border border-slate-300 text-sm px-2 py-2">
      {% for v in verbs %}
      <option value="{{ v }}" {% if v == verb %}selected{% endif %}>{{ v }}</option>
      {% endfor %}
    </select>
    <input name="args_text" value="{{ args_text }}" placeholder="key=value key=value …"
           class="flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm font-mono" />
    <button class="rounded-md bg-emerald-600 text-white text-sm px-4 py-2">Run</button>
  </div>
</form>

{# Smart-resolve: paste any handle (cite_key, DOI, arXiv id, YouTube
   id, kind:slug, discord handle) and we route to the canonical view.
   Falls back to a cross-kind search when the shape isn't recognised
   so the operator always lands somewhere. #}
<form method="post" action="/console/resolve" class="mt-4">
  <div class="flex items-center gap-2">
    <span class="text-xs text-slate-500 w-16 shrink-0">Resolve:</span>
    <input name="handle" placeholder="charlier07~374 · 10.1234/foo · dQw4w9WgXcQ · paper:acheson26 · …"
           class="flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm font-mono" />
    <button class="rounded-md bg-violet-600 text-white text-sm px-4 py-2">Go</button>
  </div>
  <p class="mt-1 text-xs text-slate-500">
    Detects: kind:slug · bare paper cite_keys (acheson26, xu25f~12) ·
    DOIs (10.x/...) · arXiv ids (2501.01234) · YouTube ids · discord conv handles.
    Free text falls back to a cross-kind search.
  </p>
</form>

{# Quick-query shortcuts for the common external-service kinds. The
   service dropdown picks the kind; the mode dropdown maps to
   verb (online→get, cache→search). Wires the assembled call into
   the result panel and echoes it as a breadcrumb so the operator
   can copy it into the main form to tweak. #}
<form method="post" action="/console/quick" class="mt-4 space-y-2">
  <div class="flex items-center gap-2">
    <select name="service" x-data="{}"
            class="rounded-md border border-slate-300 text-sm px-2 py-2">
      {% for s in quick_services %}
      <option value="{{ s.value }}" {% if s.value == quick_service %}selected{% endif %}>{{ s.label }}</option>
      {% endfor %}
    </select>
    <select name="mode" class="rounded-md border border-slate-300 text-sm px-2 py-2">
      <option value="online" {% if quick_mode == 'online' %}selected{% endif %}>online · get</option>
      <option value="cache"  {% if quick_mode == 'cache'  %}selected{% endif %}>cache · search</option>
    </select>
    <input name="query" value="{{ quick_query }}" placeholder="query / video id / expression"
           class="flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm font-mono" />
    <button class="rounded-md bg-sky-600 text-white text-sm px-4 py-2">Quick run</button>
  </div>
  <div class="text-xs text-slate-500 space-y-0.5">
    {% for s in quick_services %}
    <p><span class="font-medium text-slate-600">{{ s.label }}:</span> {{ s.hint }}</p>
    {% endfor %}
    <p class="italic">
      <span class="font-mono">online</span> hits the upstream API (may
      cost) and is cached on success; <span class="font-mono">cache</span>
      searches what's already stored.
    </p>
  </div>
  {% if quick_call %}
  <p class="text-xs text-sky-700">
    Ran <span class="font-mono">{{ quick_call }}</span>
  </p>
  {% endif %}
</form>

{% if result is not none %}
<div class="mt-5">
  <h2 class="text-sm font-semibold mb-2 {% if is_error %}text-rose-700{% else %}text-slate-700{% endif %}">
    {% if is_error %}error{% else %}result{% endif %}
  </h2>
  <pre class="rounded-lg border {% if is_error %}border-rose-200 bg-rose-50 text-rose-800{% else %}border-slate-200 bg-white text-slate-700{% endif %} p-3 text-xs whitespace-pre-wrap overflow-x-auto">{{ result | linkify_refs }}</pre>
</div>
{% endif %}
{% endblock %}
