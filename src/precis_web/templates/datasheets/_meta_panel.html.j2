{# Datasheet Meta tab — vendor / sub-type / documented part, plus the title.
   Rendered inside the shared reader's Meta tab (_reader/reader.html.j2). These
   three meta fields flow into the bibliography + docx reference line when the
   datasheet is cited (export.latex / export.docx). Context: doc (the reader
   shell dict), ds (current values), ds_subtypes ([(value, label), …]). #}
<div class="space-y-3">
  <div class="flex items-center gap-2">
    <span class="rounded bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-800">
      {{ ds.subtype_label }}
    </span>
    {% if ds.vendor %}<span class="text-xs text-slate-500">{{ ds.vendor }}</span>{% endif %}
  </div>

  <form method="post" action="/datasheets/{{ doc.id }}/edit" class="space-y-2">
    <h2 class="mb-1 text-xs font-semibold uppercase tracking-wide text-slate-500">Datasheet</h2>

    <label class="block">
      <span class="text-xs text-slate-500">Title</span>
      <input name="title" value="{{ doc.title }}"
             class="w-full rounded border border-slate-300 px-2 py-1"/>
    </label>

    <label class="block">
      <span class="text-xs text-slate-500">Vendor / manufacturer</span>
      <input name="vendor" value="{{ ds.vendor }}" placeholder="Espressif Systems"
             class="w-full rounded border border-slate-300 px-2 py-1"/>
    </label>

    <div class="flex gap-2">
      <label class="block flex-1">
        <span class="text-xs text-slate-500">Sub-type</span>
        <select name="subtype" class="w-full rounded border border-slate-300 px-2 py-1">
          {% for value, label in ds_subtypes %}
          <option value="{{ value }}" {% if ds.subtype == value %}selected{% endif %}>{{ label }}</option>
          {% endfor %}
        </select>
      </label>
      <label class="block w-36">
        <span class="text-xs text-slate-500">Part (LCSC)</span>
        <input name="part_lcsc" value="{{ ds.part_lcsc }}" placeholder="C25804"
               class="w-full rounded border border-slate-300 px-2 py-1 font-mono"/>
      </label>
    </div>

    <button type="submit"
            class="rounded bg-slate-800 px-3 py-1.5 text-sm text-white hover:bg-slate-700">Save</button>
  </form>

  {% if ds.part_lcsc %}
  <div class="border-t border-slate-100 pt-2 text-sm">
    <span class="text-xs uppercase tracking-wide text-slate-500">Documents part</span>
    {# Plain C-number: `part` is a catalog kind with no web detail route yet,
       so this stays text (get(kind='part', id=…) reads it via the MCP). #}
    <div class="font-mono text-slate-700">{{ ds.part_lcsc }}</div>
  </div>
  {% endif %}
</div>
