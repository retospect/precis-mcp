{% extends "base.html.j2" %}
{% block title %}{{ paper.title }}{% endblock %}
{% block content %}
<a href="/papers" class="text-sm text-slate-500 underline">&larr; papers</a>
<div class="mt-2 mb-4">
  <h1 class="text-lg font-semibold">{{ paper.title }}</h1>
  <p class="text-sm text-slate-500">
    #{{ paper.id }}
    {% if paper.slug %}· <span class="font-mono">{{ paper.slug }}</span>{% endif %}
    {% if paper.year %}· {{ paper.year }}{% endif %}
  </p>
  {% if authors %}
  <p class="text-sm text-slate-600 mt-1">
    {{ authors | map(attribute='family') | select | join(', ') }}
  </p>
  {% endif %}
  {% if paper.links.doi_url or paper.links.arxiv_url %}
  <p class="mt-2 flex flex-wrap gap-3 text-sm">
    {% if paper.links.doi_url %}
    <a href="{{ paper.links.doi_url }}" target="_blank" rel="noopener"
       class="text-sky-700 hover:underline">DOI: {{ paper.links.doi }}</a>
    {% endif %}
    {% if paper.links.arxiv_url %}
    <a href="{{ paper.links.arxiv_url }}" target="_blank" rel="noopener"
       class="text-sky-700 hover:underline">arXiv: {{ paper.links.arxiv }}</a>
    {% endif %}
  </p>
  {% endif %}
  {# Edit / delete affordances. Edit is an Alpine-toggled inline form
     so an operator who wants to repair a parse error (wrong DOI, missing
     authors, off-by-one year) can fix it without leaving the page. The
     delete button is a confirm-on-click POST — soft-deletes the ref so
     the row is reversible at the DB level. #}
  <div class="mt-3 flex items-center gap-2 text-xs" x-data="{ editing: false }">
    <button type="button" @click="editing = !editing"
            class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
      <span x-show="!editing">✎ Edit metadata</span>
      <span x-show="editing" x-cloak>Cancel</span>
    </button>
    <form method="post" action="/papers/{{ paper.id }}/delete"
          onsubmit="return confirm('Delete this paper? Soft-delete (reversible at the DB level). The PDF on disk is NOT removed.');"
          class="inline">
      <button type="submit"
              class="px-2 py-1 rounded border border-rose-300 bg-rose-50 text-rose-700 hover:bg-rose-100">
        🗑 Delete paper
      </button>
    </form>
    <div x-show="editing" x-cloak class="basis-full mt-2">
      <form method="post" action="/papers/{{ paper.id }}/edit" class="space-y-2">
        <p class="text-slate-500">
          Leave a field blank to keep its current value.
          Authors: one per line, ``Lastname, First`` or ``Lastname`` alone.
        </p>
        <div class="grid grid-cols-2 gap-2">
          <label class="block">
            <span class="text-slate-500">Title</span>
            <input name="title" value="{{ paper.title }}"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs" />
          </label>
          <label class="block">
            <span class="text-slate-500">Year</span>
            <input name="year" value="{{ paper.year or '' }}" inputmode="numeric"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs" />
          </label>
          <label class="block">
            <span class="text-slate-500">DOI</span>
            <input name="doi" value="{{ paper.links.doi or '' }}" placeholder="10.xxxx/yyyy"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs font-mono" />
          </label>
          <label class="block">
            <span class="text-slate-500">arXiv id</span>
            <input name="arxiv" value="{{ paper.links.arxiv or '' }}" placeholder="2501.01234"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs font-mono" />
          </label>
        </div>
        <label class="block">
          <span class="text-slate-500">Authors (one per line)</span>
          <textarea name="authors" rows="4" placeholder="Smith, Jane&#10;Jones, Bob"
                    class="w-full rounded border border-slate-300 px-2 py-1 text-xs font-mono">{% for a in authors -%}
{{ a.family }}{% if a.given %}, {{ a.given }}{% endif %}
{% endfor -%}</textarea>
        </label>
        <label class="block">
          <span class="text-slate-500">Abstract</span>
          <textarea name="abstract" rows="4"
                    class="w-full rounded border border-slate-300 px-2 py-1 text-xs">{{ paper.abstract or '' }}</textarea>
        </label>
        <button type="submit"
                class="px-3 py-1.5 rounded bg-emerald-600 text-white hover:bg-emerald-700">
          Save changes
        </button>
      </form>
    </div>
  </div>
</div>

{% if pdf_on_disk %}
  <iframe src="/papers/{{ paper.id }}/pdf" class="w-full rounded-lg border border-slate-200 bg-white"
          style="height: 80vh"></iframe>
{% elif not paper.has_pdf %}
  <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
    No PDF on disk for this paper (it's a stub — queued for fetch).
  </div>
{% else %}
  <div class="rounded-lg border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800">
    <p class="font-medium">This paper is held but the file isn't where the server looked.</p>
    {% if cite_key %}
      <p class="mt-1">cite_key: <span class="font-mono break-all">{{ cite_key }}</span></p>
      <p class="mt-1">Looked at:</p>
      <ul class="mt-0.5 ml-4 list-disc">
        {% for p in pdf_lookup_paths | default([], true) %}
        <li class="font-mono break-all">{{ p }}</li>
        {% else %}
        <li>(none)</li>
        {% endfor %}
      </ul>
      <p class="mt-2 text-rose-700">
        If the file lives elsewhere (e.g. an NFS mount mounted at a
        different path on this host), add its root to
        <span class="font-mono">PRECIS_CORPUS_DIR</span> for the web
        process (multiple roots are
        <span class="font-mono">{{ ':' }}</span>-separated) and restart.
      </p>
    {% else %}
      <p class="mt-1">This paper has no <span class="font-mono">cite_key</span> (slug),
        so the server can't address a file for it on disk
        (layout is <span class="font-mono">&lt;corpus_dir&gt;/&lt;letter&gt;/&lt;cite_key&gt;.pdf</span>).</p>
      <p class="mt-1">corpus roots:
        <span class="font-mono break-all">{{ (corpus_dirs | default([], true)) | join(', ') or "(unset)" }}</span></p>
    {% endif %}
  </div>
{% endif %}
{% endblock %}
