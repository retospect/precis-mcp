{% extends "base.html.j2" %}
{% block title %}{{ paper.title }}{% endblock %}
{% block content %}
<a href="/papers" class="text-sm text-slate-500 underline">&larr; papers</a>
<div class="mt-2 mb-4">
  <h1 class="text-lg font-semibold">{{ paper.title }}</h1>
  <p class="text-sm text-slate-500">
    #{{ paper.id }}
    {% if paper.slug %}· <span class="font-mono">{{ paper.slug }}</span>{% endif %}
    {% if paper.year %}· {{ paper.year }}{% endif %}
  </p>
  {% if authors_display %}
  <p class="text-sm text-slate-600 mt-1">
    {{ authors_display }}
  </p>
  {% endif %}
  {# Ingestion timeline — when the ref was minted, when its PDF landed,
     and when the first body chunk was written. Each shows relative time
     with the absolute UTC timestamp on hover. Stages that haven't
     happened yet (stub with no PDF / un-chunked) read "—". #}
  <p class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-slate-500">
    <span>
      <span class="text-slate-400">ref</span>
      <span title="{{ ingested.ref | abs_ts }}">{{ ingested.ref | ago or '—' }}</span>
    </span>
    <span>
      <span class="text-slate-400">PDF</span>
      <span title="{{ ingested.pdf | abs_ts }}">{{ ingested.pdf | ago or '—' }}</span>
    </span>
    <span>
      <span class="text-slate-400">first chunk</span>
      <span title="{{ ingested.first_chunk | abs_ts }}">{{ ingested.first_chunk | ago or '—' }}</span>
    </span>
  </p>
  {% if paper.links.doi_url or paper.links.arxiv_url %}
  <p class="mt-2 flex flex-wrap gap-3 text-sm">
    {% if paper.links.doi_url %}
    <a href="{{ paper.links.doi_url }}" target="_blank" rel="noopener"
       class="text-sky-700 hover:underline">DOI: {{ paper.links.doi }}</a>
    {% endif %}
    {% if paper.links.arxiv_url %}
    <a href="{{ paper.links.arxiv_url }}" target="_blank" rel="noopener"
       class="text-sky-700 hover:underline">arXiv: {{ paper.links.arxiv }}</a>
    {% endif %}
  </p>
  {% endif %}
  {# Triage panel — shown for papers tagged needs-triage (metadata
     automation gave up). The operator pastes the real title; the server
     looks it up on Semantic Scholar and re-renders this page with the
     edit form pre-filled. Saving applies it and clears needs-triage. #}
  {% if is_triage %}
  <div class="mt-3 rounded-lg border border-amber-300 bg-amber-50 p-3 text-xs">
    <p class="font-medium text-amber-800">Needs triage — metadata couldn't be recovered automatically.</p>
    {% if triage_msg %}
    <p class="mt-1 text-amber-900">{{ triage_msg }}</p>
    {% endif %}
    <form method="post" action="/papers/{{ paper.id }}/triage-lookup"
          class="mt-2 flex flex-wrap items-end gap-2">
      <label class="block grow">
        <span class="text-amber-700">Paste the paper's real title</span>
        <input name="title" value="{{ prefill.title if prefill else '' }}"
               placeholder="e.g. Ballistic carbon nanotube field-effect transistors"
               class="w-full rounded border border-amber-300 px-2 py-1 text-xs" />
      </label>
      <button type="submit"
              class="px-3 py-1.5 rounded bg-amber-600 text-white hover:bg-amber-700">
        Look up on Semantic Scholar
      </button>
    </form>
  </div>
  {% endif %}
  {# Edit / delete affordances. Edit is an Alpine-toggled inline form
     so an operator who wants to repair a parse error (wrong DOI, missing
     authors, off-by-one year) can fix it without leaving the page.
     Delete is disabled for now: the `paper` kind doesn't yet support the
     `delete` verb (exposing it also exposes paper-deletion on the agent
     MCP surface — a deliberate policy call). Grayed out until that's
     wired; the POST route stays in place behind it. #}
  <div class="mt-3 flex items-center gap-2 text-xs"
       x-data="{ editing: {{ 'true' if prefill else 'false' }} }">
    <button type="button" @click="editing = !editing"
            class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
      <span x-show="!editing">✎ Edit metadata</span>
      <span x-show="editing" x-cloak>Cancel</span>
    </button>
    <button type="button" disabled
            title="Delete isn't wired up yet for papers."
            class="px-2 py-1 rounded border border-slate-200 bg-slate-50 text-slate-400 cursor-not-allowed">
      🗑 Delete paper
    </button>
    <div x-show="editing" x-cloak class="basis-full mt-2">
      <form method="post" action="/papers/{{ paper.id }}/edit" class="space-y-2">
        <p class="text-slate-500">
          Leave a field blank to keep its current value.
          Authors: one per line, ``Lastname, First`` or ``Lastname`` alone.
        </p>
        <div class="grid grid-cols-2 gap-2">
          <label class="block">
            <span class="text-slate-500">Title</span>
            <input name="title" value="{{ prefill.title if prefill else paper.title }}"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs" />
          </label>
          <label class="block">
            <span class="text-slate-500">Year</span>
            <input name="year" value="{{ prefill.year if prefill else (paper.year or '') }}" inputmode="numeric"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs" />
          </label>
          <label class="block">
            <span class="text-slate-500">DOI</span>
            <input name="doi" value="{{ prefill.doi if prefill else (paper.links.doi or '') }}" placeholder="10.xxxx/yyyy"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs font-mono" />
          </label>
          <label class="block">
            <span class="text-slate-500">arXiv id</span>
            <input name="arxiv" value="{{ prefill.arxiv if prefill else (paper.links.arxiv or '') }}" placeholder="2501.01234"
                   class="w-full rounded border border-slate-300 px-2 py-1 text-xs font-mono" />
          </label>
        </div>
        <label class="block">
          <span class="text-slate-500">Authors (one per line)</span>
          <textarea name="authors" rows="4" placeholder="Smith, Jane&#10;Jones, Bob"
                    class="w-full rounded border border-slate-300 px-2 py-1 text-xs font-mono">{% if prefill %}{{ prefill.authors }}{% else %}{% for line in author_lines -%}
{{ line }}
{% endfor -%}{% endif %}</textarea>
        </label>
        <label class="block">
          <span class="text-slate-500">Abstract</span>
          <textarea name="abstract" rows="4"
                    class="w-full rounded border border-slate-300 px-2 py-1 text-xs">{{ prefill.abstract if prefill else (abstract or '') }}</textarea>
        </label>
        <button type="submit"
                class="px-3 py-1.5 rounded bg-emerald-600 text-white hover:bg-emerald-700">
          Save changes
        </button>
      </form>
    </div>
  </div>
</div>

{% if pdf_on_disk %}
  <iframe src="/papers/{{ paper.id }}/pdf" class="w-full rounded-lg border border-slate-200 bg-white"
          style="height: 80vh"></iframe>
{% elif not paper.has_pdf %}
  <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
    No PDF on disk for this paper (it's a stub — queued for fetch).
  </div>
{% else %}
  <div class="rounded-lg border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800">
    <p class="font-medium">This paper is held but the file isn't where the server looked.</p>
    {% if cite_key %}
      <p class="mt-1">cite_key: <span class="font-mono break-all">{{ cite_key }}</span></p>
      <p class="mt-1">Looked at:</p>
      <ul class="mt-0.5 ml-4 list-disc">
        {% for p in pdf_lookup_paths | default([], true) %}
        <li class="font-mono break-all">{{ p }}</li>
        {% else %}
        <li>(none)</li>
        {% endfor %}
      </ul>
      <p class="mt-2 text-rose-700">
        If the file lives elsewhere (e.g. an NFS mount mounted at a
        different path on this host), add its root to
        <span class="font-mono">PRECIS_CORPUS_DIR</span> for the web
        process (multiple roots are
        <span class="font-mono">{{ ':' }}</span>-separated) and restart.
      </p>
    {% else %}
      <p class="mt-1">This paper has no <span class="font-mono">cite_key</span> (slug),
        so the server can't address a file for it on disk
        (layout is <span class="font-mono">&lt;corpus_dir&gt;/&lt;letter&gt;/&lt;cite_key&gt;.pdf</span>).</p>
      <p class="mt-1">corpus roots:
        <span class="font-mono break-all">{{ (corpus_dirs | default([], true)) | join(', ') or "(unset)" }}</span></p>
    {% endif %}
  </div>
{% endif %}
{% endblock %}
