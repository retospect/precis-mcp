{% extends "base.html.j2" %}
{% block title %}Papers{% endblock %}
{% block content %}
<h1 class="text-lg font-semibold mb-3">Papers</h1>
<form method="get" action="/papers" class="mb-4 flex flex-wrap items-center gap-2">
  <input name="q" value="{{ q }}" placeholder="Search the corpus…"
         class="w-80 rounded-md border border-slate-300 px-3 py-2 text-sm" />
  <button class="rounded-md bg-emerald-600 text-white text-sm px-4 py-2">Search</button>
  {# Presence filters — submit the same form so they compose with the
     query. ``value="1"`` + ``checked`` mirrors the route's 0/1 ints. #}
  <label class="inline-flex items-center gap-1.5 text-sm text-slate-600 ml-2">
    <input type="checkbox" name="has_pdf" value="1" {% if has_pdf %}checked{% endif %}
           onchange="this.form.submit()" class="rounded border-slate-300" />
    has PDF
  </label>
  <label class="inline-flex items-center gap-1.5 text-sm text-slate-600">
    <input type="checkbox" name="has_chunks" value="1" {% if has_chunks %}checked{% endif %}
           onchange="this.form.submit()" class="rounded border-slate-300" />
    ingested (has chunks)
  </label>
  {% if q or has_pdf or has_chunks %}<a href="/papers" class="text-sm text-slate-500 underline">clear</a>{% endif %}
</form>

{% if not papers %}
  <p class="text-sm text-slate-500">No papers{% if q %} match “{{ q }}”{% endif %}.</p>
{% else %}
<ul class="divide-y divide-slate-100 rounded-lg border border-slate-200 bg-white overflow-visible">
  {% for p in papers %}
  <li class="group relative px-4 py-3 flex items-center gap-3">
    <span class="text-xs text-slate-400 w-12 shrink-0">#{{ p.id }}</span>
    <a href="/papers/{{ p.id }}" class="text-sm font-medium text-sky-700 hover:underline flex-1">
      {{ p.title }}{% if p.year %} <span class="text-slate-400">({{ p.year }})</span>{% endif %}
    </a>
    {% if p.has_chunks %}
      <span class="text-xs px-1.5 py-0.5 rounded bg-sky-100 text-sky-700" title="ingested — has body chunks">chunks</span>
    {% endif %}
    {% if p.has_pdf %}
      <span class="text-xs px-1.5 py-0.5 rounded bg-emerald-100 text-emerald-700">PDF</span>
    {% else %}
      <span class="text-xs px-1.5 py-0.5 rounded bg-slate-200 text-slate-500">stub</span>
    {% endif %}
    {# Hover card: authors + abstract. Shown on row hover; positioned
       below the row, doesn't intercept clicks. #}
    <div class="pointer-events-none absolute left-12 top-full z-20 hidden group-hover:block
                w-[40rem] max-w-[90vw] rounded-lg border border-slate-200 bg-white shadow-xl p-3">
      {% if p.authors %}
      <p class="text-xs font-medium text-slate-700 mb-1">{{ p.authors }}</p>
      {% endif %}
      {% if p.abstract %}
      <p class="text-xs leading-relaxed text-slate-600">{{ p.abstract }}</p>
      {% else %}
      <p class="text-xs text-slate-400 italic">No abstract on file.</p>
      {% endif %}
      {# Verification links — clickable even though the card itself
         ignores pointer events (so it doesn't block the row click). #}
      {% if p.links.doi_url or p.links.arxiv_url %}
      <div class="pointer-events-auto mt-2 pt-2 border-t border-slate-100 flex flex-wrap gap-3 text-xs">
        {% if p.links.doi_url %}
        <a href="{{ p.links.doi_url }}" target="_blank" rel="noopener"
           class="text-sky-700 hover:underline">DOI: {{ p.links.doi }}</a>
        {% endif %}
        {% if p.links.arxiv_url %}
        <a href="{{ p.links.arxiv_url }}" target="_blank" rel="noopener"
           class="text-sky-700 hover:underline">arXiv: {{ p.links.arxiv }}</a>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </li>
  {% endfor %}
</ul>

{% if paged %}
{% set qs = 'has_pdf=1&' if has_pdf else '' %}{% set qs = qs + ('has_chunks=1&' if has_chunks else '') %}
<div class="mt-4 flex items-center gap-3 text-sm">
  {% if page > 1 %}
  <a href="/papers?{{ qs }}page={{ page - 1 }}"
     class="rounded-md border border-slate-300 px-3 py-1 hover:bg-slate-100">&larr; Prev</a>
  {% endif %}
  <span class="text-slate-400">Page {{ page }}</span>
  {% if has_next %}
  <a href="/papers?{{ qs }}page={{ page + 1 }}"
     class="rounded-md border border-slate-300 px-3 py-1 hover:bg-slate-100">Next &rarr;</a>
  {% endif %}
</div>
{% endif %}
{% endif %}
{% endblock %}
