{% extends "base.html.j2" %}
{% block title %}Duplicate identifier{% endblock %}
{% block content %}
<a href="/papers/{{ ref_id }}" class="text-sm text-slate-500 underline">&larr; back to paper #{{ ref_id }}</a>
<div class="mt-2 rounded-lg border border-amber-300 bg-amber-50 p-6">
  <h1 class="text-lg font-semibold text-amber-900">Duplicate identifier</h1>
  <p class="mt-2 text-sm text-amber-900">
    The {{ field }} <span class="font-mono">{{ value }}</span> you assigned to
    paper <span class="font-mono">#{{ ref_id }}</span> already belongs to paper
    <span class="font-mono">#{{ owner_id }}</span>. These are almost certainly
    the same paper held twice. Inspect the existing one, then delete whichever
    copy is redundant.
  </p>

  {% if owner %}
  <div class="mt-4 rounded border border-amber-200 bg-white p-3 text-sm">
    <p class="font-medium">Existing paper #{{ owner_id }}</p>
    <p class="mt-1">
      {{ owner.title or '(no title)' }}{% if owner.year %} · {{ owner.year }}{% endif %}
      {% if owner.slug %}· <span class="font-mono text-slate-500">{{ owner.slug }}</span>{% endif %}
    </p>
    <p class="mt-2 flex flex-wrap gap-4">
      <a href="/papers/{{ owner_id }}" class="text-sky-700 hover:underline">View paper #{{ owner_id }}</a>
      {% if owner_pdf %}
      <a href="/papers/{{ owner_id }}/pdf" target="_blank" rel="noopener"
         class="text-sky-700 hover:underline">Open its PDF in a new tab &nearr;</a>
      {% else %}
      <span class="text-slate-400">(no PDF on disk)</span>
      {% endif %}
    </p>
  </div>
  {% else %}
  <p class="mt-3 text-sm text-amber-800">
    Paper #{{ owner_id }} couldn't be loaded (it may itself be deleted).
  </p>
  {% endif %}

  <div class="mt-5 border-t border-amber-200 pt-4">
    <p class="text-sm text-amber-900">
      If this paper (#{{ ref_id }}) is the redundant copy, delete it:
    </p>
    <form method="post" action="/papers/{{ ref_id }}/delete" class="mt-2"
          onsubmit="return confirm('Delete this paper #{{ ref_id }}? It soft-deletes the duplicate.');">
      <input type="hidden" name="return_to" value="/papers/triage" />
      <button type="submit"
              class="px-3 py-1.5 rounded bg-rose-600 text-white hover:bg-rose-700">
        🗑 Delete this paper (#{{ ref_id }})
      </button>
    </form>
    <p class="mt-3 text-xs text-amber-700">
      To keep this one instead, open #{{ owner_id }} above, delete that copy,
      then re-save the metadata here.
    </p>
  </div>
</div>
{% endblock %}
