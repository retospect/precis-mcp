{% extends "base.html.j2" %}
{% block title %}Duplicate identifier{% endblock %}
{% block content %}
<a href="/papers/{{ ref_id }}" class="text-sm text-slate-500 underline">&larr; back to paper #{{ ref_id }}</a>
<div class="mt-2 rounded-lg border border-amber-300 bg-amber-50 p-6">
  <h1 class="text-lg font-semibold text-amber-900">Duplicate identifier</h1>
  <p class="mt-2 text-sm text-amber-900">
    The {{ field }} <span class="font-mono">{{ value }}</span> you assigned to
    paper <span class="font-mono">#{{ ref_id }}</span> already belongs to paper
    <span class="font-mono">#{{ owner_id }}</span>. These are almost certainly
    the same paper held twice. Inspect the existing one, then delete whichever
    copy is redundant.
  </p>

  {% if owner %}
  <div class="mt-4 rounded border border-amber-200 bg-white p-3 text-sm">
    <p class="font-medium">Existing paper #{{ owner_id }}</p>
    <p class="mt-1">
      {{ owner.title or '(no title)' }}{% if owner.year %} · {{ owner.year }}{% endif %}
      {% if owner.slug %}· <span class="font-mono text-slate-500">{{ owner.slug }}</span>{% endif %}
    </p>
    <p class="mt-2 flex flex-wrap gap-4">
      <a href="/papers/{{ owner_id }}" class="text-sky-700 hover:underline">View paper #{{ owner_id }}</a>
      {% if owner_pdf %}
      <a href="/papers/{{ owner_id }}/pdf" target="_blank" rel="noopener"
         class="text-sky-700 hover:underline">Open its PDF in a new tab &nearr;</a>
      {% else %}
      <span class="text-slate-400">(no PDF on disk)</span>
      {% endif %}
    </p>
  </div>
  {% else %}
  <p class="mt-3 text-sm text-amber-800">
    Paper #{{ owner_id }} couldn't be loaded (it may itself be deleted).
  </p>
  {% endif %}

  {# Hidden carry of the pending edit so "keep this" can re-apply the
     metadata onto the survivor once the duplicate's identifiers free up.
     Defined once, macro'd into each merge form below. #}
  {% macro pending_fields() %}
    {% for name in ['title','year','doi','arxiv','abstract','authors','cite_key'] %}
    <input type="hidden" name="{{ name }}" value="{{ form.get(name, '') }}" />
    {% endfor %}
  {% endmacro %}

  {% if not owner %}
  {# The conflicting owner couldn't be loaded — fall back to a plain delete
     of this copy (no link migration possible without a live survivor). #}
  <div class="mt-5 border-t border-amber-200 pt-4">
    <p class="text-sm text-amber-900">
      If this paper (#{{ ref_id }}) is the redundant copy, delete it:
    </p>
    <form method="post" action="/papers/{{ ref_id }}/delete" class="mt-2"
          onsubmit="return confirm('Delete this paper #{{ ref_id }}? It soft-deletes the duplicate.');">
      <input type="hidden" name="return_to" value="/papers/triage" />
      <button type="submit"
              class="rounded bg-rose-600 px-3 py-1.5 text-white hover:bg-rose-700">
        🗑 Delete this paper (#{{ ref_id }})
      </button>
    </form>
  </div>
  {% else %}
  <div class="mt-5 grid gap-4 border-t border-amber-200 pt-4 sm:grid-cols-2">
    {# Keep this paper, absorb the other — the usual case when #{{ owner_id }}
       is an empty stub and this copy holds the PDF. #}
    <div class="rounded border border-emerald-200 bg-emerald-50 p-3">
      <p class="text-sm font-medium text-emerald-900">Keep this one (#{{ ref_id }})</p>
      <p class="mt-1 text-xs text-emerald-800">
        Deletes #{{ owner_id }}, redirects every link pointing at it to this
        paper, and re-applies your edit here.
      </p>
      <form method="post" action="/papers/{{ ref_id }}/resolve-duplicate" class="mt-2"
            onsubmit="return confirm('Delete #{{ owner_id }} and absorb it into #{{ ref_id }}?');">
        <input type="hidden" name="owner_id" value="{{ owner_id }}" />
        <input type="hidden" name="keep" value="this" />
        {{ pending_fields() }}
        <button type="submit"
                class="rounded bg-emerald-600 px-3 py-1.5 text-sm text-white hover:bg-emerald-700">
          Keep #{{ ref_id }}, delete &amp; absorb #{{ owner_id }}
        </button>
      </form>
    </div>

    {# Keep the existing paper, absorb this copy into it. #}
    <div class="rounded border border-rose-200 bg-rose-50 p-3">
      <p class="text-sm font-medium text-rose-900">Keep the existing one (#{{ owner_id }})</p>
      <p class="mt-1 text-xs text-rose-800">
        Deletes this paper (#{{ ref_id }}) and redirects every link pointing
        at it to #{{ owner_id }}. Your pending edit here is discarded.
      </p>
      <form method="post" action="/papers/{{ ref_id }}/resolve-duplicate" class="mt-2"
            onsubmit="return confirm('Delete this paper #{{ ref_id }} and absorb it into #{{ owner_id }}?');">
        <input type="hidden" name="owner_id" value="{{ owner_id }}" />
        <input type="hidden" name="keep" value="other" />
        <button type="submit"
                class="rounded bg-rose-600 px-3 py-1.5 text-sm text-white hover:bg-rose-700">
          Keep #{{ owner_id }}, delete &amp; absorb #{{ ref_id }}
        </button>
      </form>
    </div>
  </div>
  {% endif %}
</div>
{% endblock %}
