{% extends "base.html.j2" %}
{% block title %}{{ title }}{% endblock %}
{% block content %}

<div class="mb-4">
  <a href="/agentlogs" class="text-xs text-sky-700 hover:underline">← all agent logs</a>
  <h1 class="text-lg font-semibold mt-1">{{ title }}</h1>
  <div class="text-[12px] text-slate-400 mt-1 flex flex-wrap gap-x-3 gap-y-0.5">
    {% if source %}<span>source: <span class="font-mono">{{ source }}</span></span>{% endif %}
    {% if model %}<span>model: <span class="font-mono">{{ model }}</span></span>{% endif %}
    {% if status %}<span>status: {{ status }}</span>{% endif %}
    {% if parent_ref_id is not none %}
    <a href="/tasks?focus={{ parent_ref_id }}" class="text-sky-700 hover:underline">todo #{{ parent_ref_id }}</a>
    {% endif %}
    {% if job_ref_id is not none %}
    <a href="/tasks/{{ job_ref_id }}/transcript" class="text-sky-700 hover:underline">📜 full transcript</a>
    {% endif %}
    <span>{{ created }}</span>
  </div>
</div>

{# Chunks this run wrote or moved — the blast radius. #}
<section class="mb-5">
  <h2 class="text-sm font-semibold text-slate-700 mb-2">
    Touched {{ touched | length }} chunk{{ '' if touched|length == 1 else 's' }}
  </h2>
  {% if not touched %}
  <p class="text-sm text-slate-500">This run touched no chunks (a planning-only tick).</p>
  {% else %}
  <div class="overflow-hidden rounded-md border border-slate-200">
    <table class="w-full text-sm">
      <tbody>
        {% for c in touched %}
        <tr class="border-t border-slate-100 first:border-t-0 align-top">
          <td class="px-3 py-2 w-40">
            <a href="{{ c.href }}" class="font-mono text-[12px] text-sky-700 hover:underline">{{ c.kind }}:{{ c.ident }} ¶{{ c.handle }}</a>
          </td>
          <td class="px-3 py-2 text-slate-600">{{ c.clip }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</section>

{# The full assembled prompt the run was handed (system + user). #}
<section class="mb-5">
  <h2 class="text-sm font-semibold text-slate-700 mb-2">Assembled prompt</h2>
  {% if prompt %}
  <pre class="rounded-md border border-slate-200 bg-slate-50 p-3 text-[12px] text-slate-700 whitespace-pre-wrap break-words max-h-[36rem] overflow-y-auto">{{ prompt }}</pre>
  {% else %}
  <p class="text-sm text-slate-500">No prompt captured for this run.</p>
  {% endif %}
</section>

{% endblock %}
