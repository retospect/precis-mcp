{% extends "base.html.j2" %}
{% block title %}Asks{% endblock %}
{% block content %}
<div class="flex items-baseline justify-between mb-4">
  <h1 class="text-lg font-semibold">Asks</h1>
  <span class="text-sm text-slate-500">
    {{ asks|length }} todo{{ '' if asks|length == 1 else 's' }} waiting on you
  </span>
</div>

{% if not asks %}
<p class="text-sm text-slate-500">
  Nothing's waiting on you. Open todos carrying an
  <span class="font-mono">ask-user</span> tag will appear here.
</p>
{% else %}
<ul class="space-y-3">
  {% for a in asks %}
  {% set first_line = (a.title or '').split('\n', 1)[0] %}
  <li class="rounded-lg border border-slate-200 bg-white px-4 py-3">
    <div class="flex items-baseline gap-2">
      <span class="text-xs text-slate-400 w-12 shrink-0 font-mono">#{{ a.id }}</span>
      <a href="/tasks" class="text-sm font-medium text-slate-800 hover:text-emerald-700 break-words">
        {{ first_line | linkify_refs }}
      </a>
    </div>
    {% if a.questions %}
    <div class="mt-2 ml-14 space-y-2">
      {% for q in a.questions %}
      <div class="text-sm text-slate-700 bg-amber-50 border-l-4 border-amber-300 px-3 py-2 rounded whitespace-pre-line break-words">
        {{ q | linkify_refs }}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="mt-2 ml-14 text-xs text-slate-400">
      tagged <span class="font-mono">ask-user</span> (no question text)
    </div>
    {% endif %}
    <form method="post" action="/asks/{{ a.id }}/answer" class="mt-3 ml-14">
      {% for tag in a.tags %}
      <input type="hidden" name="remove" value="{{ tag }}"/>
      {% endfor %}
      <textarea name="response" required rows="3"
                placeholder="Type your answer to unlock this todo…"
                class="w-full rounded-md border border-slate-300 text-sm px-3 py-2 font-mono"></textarea>
      <div class="mt-2 flex justify-end">
        <button class="rounded-md bg-emerald-600 text-white text-sm px-4 py-1.5 hover:bg-emerald-700">
          Answer &amp; unlock
        </button>
      </div>
    </form>
  </li>
  {% endfor %}
</ul>

{% if page > 1 or has_next %}
<div class="mt-4 flex items-center gap-3 text-sm">
  {% if page > 1 %}
  <a href="/asks?page={{ page - 1 }}"
     class="rounded-md border border-slate-300 px-3 py-1 hover:bg-slate-100">&larr; Prev</a>
  {% endif %}
  <span class="text-slate-400">Page {{ page }}</span>
  {% if has_next %}
  <a href="/asks?page={{ page + 1 }}"
     class="rounded-md border border-slate-300 px-3 py-1 hover:bg-slate-100">Next &rarr;</a>
  {% endif %}
</div>
{% endif %}
{% endif %}
{% endblock %}
