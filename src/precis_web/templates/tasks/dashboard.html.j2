{% extends "base.html.j2" %}
{% block title %}Tasks{% endblock %}
{# Inline the current tag filter as hidden inputs so write POSTs
   round-trip the filter and the redirect lands on the same view. #}
{% macro filter_inputs() %}
  {% for r in require_tags %}<input type="hidden" name="require" value="{{ r }}"/>{% endfor %}
  {% for x in exclude_tags %}<input type="hidden" name="exclude" value="{{ x }}"/>{% endfor %}
  {% if focus_id %}<input type="hidden" name="focus" value="{{ focus_id }}"/>{% endif %}
  {% if show_jobs and show_jobs != 'active' %}<input type="hidden" name="show_jobs" value="{{ show_jobs }}"/>{% endif %}
{% endmacro %}
{# Build a query string preserving the current state with the given
   overrides. ``require_add`` adds a pseudo-tag to require (so a
   status / level / kind badge becomes a one-click filter).
   ``show_jobs_override`` swaps the show_jobs param (used by the
   toggle); leave None to inherit the current state. #}
{% macro state_qs(new_focus, require_add=None, exclude_add=None, show_jobs_override=None, tree_override=-1) %}
  {%- set parts = [] -%}
  {%- for r in require_tags -%}{%- set _ = parts.append('require=' ~ r|urlencode) -%}{%- endfor -%}
  {%- if require_add and require_add not in require_tags -%}{%- set _ = parts.append('require=' ~ require_add|urlencode) -%}{%- endif -%}
  {%- for x in exclude_tags -%}{%- set _ = parts.append('exclude=' ~ x|urlencode) -%}{%- endfor -%}
  {%- if exclude_add and exclude_add not in exclude_tags -%}{%- set _ = parts.append('exclude=' ~ exclude_add|urlencode) -%}{%- endif -%}
  {%- if new_focus -%}{%- set _ = parts.append('focus=' ~ new_focus) -%}{%- endif -%}
  {%- set sj = show_jobs_override if show_jobs_override is not none else show_jobs -%}
  {%- if sj and sj != 'active' -%}{%- set _ = parts.append('show_jobs=' ~ sj) -%}{%- endif -%}
  {%- set td = tree_override if tree_override != -1 else tree_depth -%}
  {%- if td -%}{%- set _ = parts.append('tree=' ~ td) -%}{%- endif -%}
  {%- if parts -%}?{{ parts|join('&') }}{%- endif -%}
{% endmacro %}
{# Compat alias for existing callsites that just want to swap focus. #}
{% macro focus_qs(new_focus) %}{{ state_qs(new_focus) }}{% endmacro %}
{% block content %}
{# Tag filter bar. ``require`` and ``exclude`` are repeating GET
   params; AND semantics within each list; matching todos pull in
   their ancestor chain so the tree shape stays legible. #}
<form method="get" action="/tasks"
      class="mb-4 rounded-lg border border-slate-200 bg-white px-4 py-3 flex flex-wrap items-end gap-3">
  <div class="flex flex-col">
    <label class="text-xs text-slate-400 mb-0.5">Require tags (AND)</label>
    <input name="require" value="{{ require_tags|join(' ') }}"
           placeholder="e.g. STATUS:doing ask-user"
           class="w-64 rounded-md border border-slate-300 px-3 py-1.5 text-sm" />
    <span class="text-xs text-slate-400 mt-0.5">space / comma separated</span>
  </div>
  <div class="flex flex-col">
    <label class="text-xs text-slate-400 mb-0.5">Exclude tags</label>
    <input name="exclude" value="{{ exclude_tags|join(' ') }}"
           placeholder="e.g. STATUS:done level:strategic"
           class="w-64 rounded-md border border-slate-300 px-3 py-1.5 text-sm" />
    <span class="text-xs text-slate-400 mt-0.5">matches STATUS:*, level:*, or free tags</span>
  </div>
  <button class="rounded-md bg-emerald-600 text-white text-sm px-4 py-1.5">Apply</button>
  {# Hidden so the operator's tag input doesn't drop the focus / show_jobs
     state when they apply the form. #}
  {% if focus_id %}<input type="hidden" name="focus" value="{{ focus_id }}"/>{% endif %}
  {% if show_jobs and show_jobs != 'active' %}<input type="hidden" name="show_jobs" value="{{ show_jobs }}"/>{% endif %}
  {% if filter_active %}
  {%- set clear_parts = [] -%}
  {%- if focus_id -%}{%- set _ = clear_parts.append('focus=' ~ focus_id) -%}{%- endif -%}
  {%- if show_jobs and show_jobs != 'active' -%}{%- set _ = clear_parts.append('show_jobs=' ~ show_jobs) -%}{%- endif -%}
  <a href="/tasks{% if clear_parts %}?{{ clear_parts|join('&') }}{% endif %}"
     class="text-sm text-slate-500 underline pb-1.5">clear filter</a>
  {% endif %}
  <div class="flex items-center gap-2 ml-auto">
    {# show_jobs toggle: hides terminal-state job rows by default so
       a flurry of failed plan_tick / fix_gripe attempts doesn't bury
       the live work. #}
    {% if show_jobs == 'active' %}
    <a href="/tasks{{ state_qs(focus_id, show_jobs_override='all') }}"
       class="text-xs px-2 py-1 rounded border border-slate-300 text-slate-600 hover:bg-slate-100"
       title="show kind='job' rows in failed / succeeded / done / won't-do states">
      + show closed jobs
    </a>
    {% else %}
    <a href="/tasks{{ state_qs(focus_id, show_jobs_override='active') }}"
       class="text-xs px-2 py-1 rounded bg-amber-100 border border-amber-300 text-amber-800 hover:bg-amber-200">
      − hide closed jobs
    </a>
    {% endif %}
    {% if filter_active %}
    <span class="text-xs text-slate-500">
      showing {{ filtered_rows }} of {{ total_rows }} rows
    </span>
    {% endif %}
  </div>
</form>
<script>
  // Repeating ``require=`` / ``exclude=`` params is how the route
  // expects multi-tag filters. Split the bare input the operator
  // typed (space / comma) into one hidden field per token so the
  // ergonomics match the refs tab.
  document.currentScript.previousElementSibling.addEventListener('submit', function (ev) {
    const form = ev.target;
    ['require', 'exclude'].forEach(function (name) {
      const inp = form.querySelector('input[name="' + name + '"]');
      if (!inp) return;
      const raw = inp.value || '';
      const parts = raw.split(/[\s,]+/).filter(Boolean);
      inp.remove();
      parts.forEach(function (p) {
        const h = document.createElement('input');
        h.type = 'hidden';
        h.name = name;
        h.value = p;
        form.appendChild(h);
      });
    });
  });
</script>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Tree (2/3) -->
  <section class="lg:col-span-2">
    {# Drill-up breadcrumb: each ancestor is a clickable focus link;
       the final entry is the focused node itself (rendered as plain
       text since it's the current scope). The "All tasks" link drops
       focus entirely but keeps the tag filter. #}
    {% if focus_id %}
    <nav class="mb-3 flex flex-wrap items-center gap-1 text-xs text-slate-500">
      <a href="/tasks{{ focus_qs(none) }}" class="hover:text-emerald-700 underline">All tasks</a>
      {% for b in breadcrumb %}
      <span class="text-slate-300">›</span>
      <a href="/tasks{{ focus_qs(b.id) }}" class="hover:text-emerald-700">#{{ b.id }} {{ b.title }}</a>
      {% endfor %}
      {% if focus_row %}
      <span class="text-slate-300">›</span>
      <span class="text-slate-800 font-medium">#{{ focus_row.id }} {{ (focus_row.title or '').split('\n', 1)[0] }}</span>
      {% endif %}
    </nav>
    {% endif %}
    {# When focused: prominent add-child form + mermaid tree toggle so
       the two most common actions on a drilled-in node are one click,
       not two (the ⋯ panel below still works the same). #}
    {% if focus_id and focus_row %}
    <section class="mb-3 rounded-lg border border-slate-200 bg-white p-3">
      <form method="post" action="/tasks/{{ focus_id }}/children" class="flex items-start gap-2">
        {{ filter_inputs() }}
        <textarea name="text" required rows="2" placeholder="Add a child under #{{ focus_id }}…"
                  class="flex-1 rounded border-slate-300 text-sm border px-2 py-1"></textarea>
        <select name="level" class="rounded border-slate-300 text-sm border px-1 py-1">
          <option value="subtask">subtask</option>
          <option value="tactical">tactical</option>
          <option value="strategic">strategic</option>
        </select>
        <button class="rounded bg-emerald-600 text-white text-sm px-3 py-1">+ child</button>
      </form>
      <div class="mt-2 flex items-center gap-1 text-xs">
        <span class="text-slate-400">Tree diagram:</span>
        {% for d in tree_depths %}
        <a href="/tasks{{ state_qs(focus_id, tree_override=d) }}"
           class="px-2 py-0.5 rounded {% if d == tree_depth %}bg-emerald-100 text-emerald-700 font-medium{% else %}border border-slate-300 text-slate-600 hover:bg-slate-100{% endif %}">
          {{ d }} deep
        </a>
        {% endfor %}
        {% if tree_depth %}
        <a href="/tasks{{ state_qs(focus_id, tree_override=0) }}" class="ml-2 text-slate-500 hover:text-slate-700 underline">hide</a>
        {% endif %}
      </div>
    </section>
    {% endif %}
    {% if tree_diagram %}
    <section class="mb-4 rounded-lg border border-slate-200 bg-white p-3 overflow-x-auto">
      <pre class="mermaid">{{ tree_diagram }}</pre>
    </section>
    <script type="module">
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
      mermaid.initialize({ startOnLoad: true, securityLevel: "strict", theme: "default" });
    </script>
    {% endif %}
    <div class="flex items-center justify-between mb-3">
      <h1 class="text-lg font-semibold">
        {% if focus_id %}Subtree of #{{ focus_id }}{% else %}Task tree{% endif %}
      </h1>
      <form method="post" action="/tasks/roots" class="flex items-center gap-2"
            x-data="{open:false}">
        {{ filter_inputs() }}
        <template x-if="open">
          <span class="flex items-start gap-2">
            <textarea name="text" required rows="2" placeholder="New strategic root…"
                      class="rounded-md border-slate-300 text-sm px-2 py-1 border w-56"></textarea>
            <select name="level" class="rounded-md border-slate-300 text-sm border px-1 py-1">
              <option value="strategic">strategic</option>
              <option value="tactical">tactical</option>
            </select>
            <button class="rounded-md bg-emerald-600 text-white text-sm px-3 py-1">Add</button>
          </span>
        </template>
        <button type="button" @click="open=!open"
                class="rounded-md border border-slate-300 text-sm px-3 py-1 hover:bg-slate-100">
          + Strategic
        </button>
      </form>
    </div>

    {% if not rows %}
      <p class="text-sm text-slate-500">No tasks yet. Add a strategic root to begin.</p>
    {% else %}
      <p class="text-xs text-slate-400 mb-2">
        Drag a task onto another to reparent it; drop on the bar below to promote it to a root.
      </p>
      <!-- Detach-to-root drop zone -->
      <div data-droptop="1"
           class="mb-2 rounded-md border border-dashed border-slate-300 text-xs text-slate-400 text-center py-1.5 transition-colors">
        ↥ drop here to move to top level
      </div>
    {% endif %}

    {# T12.2 — Tasks-tree filter chips + collapse-all/expand-all. The
       chips toggle classes on #tree which CSS uses to hide matching
       rows. Per-row collapse is below — each row with children gets
       a ▶/▼ toggle; clicking it walks subsequent rows by data-depth
       and hides those deeper than the row's depth. State persists in
       localStorage so a refresh keeps the user's view. #}
    <div class="mb-2 flex items-center gap-1.5 text-xs flex-wrap" id="task-filter-bar">
      <button type="button" data-filter-toggle="hide-done"
              class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
        <span data-when-on>👁 done hidden</span><span data-when-off>show / hide done</span>
      </button>
      <button type="button" data-filter-toggle="hide-wont-do"
              class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
        <span data-when-on>👁 won't-do hidden</span><span data-when-off>show / hide won't-do</span>
      </button>
      <button type="button" data-filter-toggle="only-recurring"
              class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
        <span data-when-on>🔁 recurring only</span><span data-when-off>recurring only</span>
      </button>
      <button type="button" data-filter-toggle="only-strategic"
              class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
        <span data-when-on>⭐ strategic only</span><span data-when-off>strategic only</span>
      </button>
      <button type="button" data-filter-toggle="only-jobs"
              class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">
        <span data-when-on>⚙ jobs only</span><span data-when-off>jobs only</span>
      </button>
      <span class="mx-1 text-slate-300">|</span>
      <button type="button" id="task-expand-all"
              class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">▼ expand all</button>
      <button type="button" id="task-collapse-all"
              class="px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">▶ collapse all</button>
      <span class="ml-auto text-slate-400" id="task-row-count"></span>
    </div>
    {# CSS rules driven by the filter classes on #tree. #}
    <style>
      #tree.hide-done li[data-status="done"] { display: none; }
      #tree.hide-wont-do li[data-status="won't-do"] { display: none; }
      #tree.only-recurring li:not([data-recurring="1"]) { display: none; }
      #tree.only-strategic li:not([data-level="strategic"]) { display: none; }
      #tree.only-jobs li:not([data-kind="job"]) { display: none; }
      /* Collapsed-row marker — JS sets data-row-collapsed on rows
         hidden because an ancestor is collapsed. */
      #tree li[data-row-collapsed="1"] { display: none; }
    </style>
    <ul id="tree" class="divide-y divide-slate-100 rounded-lg border border-slate-200 bg-white">
      {% for r in rows %}
      <li class="px-3 py-2{% if r.kind == 'job' %} bg-slate-50/60{% endif %}"
          x-data="{actions:false}"
          data-id="{{ r.id }}"
          data-kind="{{ r.kind }}"
          data-depth="{{ r.depth }}"
          data-status="{{ r.status }}"
          data-level="{{ r.level or '' }}"
          data-recurring="{{ '1' if r.level == 'recurring' else '0' }}"
          {% if r.kind == 'todo' %}draggable="true"{% endif %}>
        <div class="flex items-center gap-2" style="padding-left: {{ r.depth * 1.25 }}rem">
          {% if r.kind == 'todo' %}<span class="cursor-grab text-slate-300 select-none" title="drag to reparent">⠿</span>{% endif %}
          <span class="text-xs text-slate-400 w-10 shrink-0">#{{ r.id }}</span>
          {# Badges are clickable filter chips: click → add the
             corresponding pseudo-tag to ``require`` (composes with
             the current filter, focus, and show_jobs state). #}
          {% if r.kind == 'job' %}
          <a href="/tasks{{ state_qs(focus_id, require_add='kind:job') }}"
             class="text-xs px-1.5 py-0.5 rounded bg-slate-200 text-slate-600 hover:bg-slate-300"
             title="filter to kind:job">job</a>
          {% endif %}
          {% set sc = {'done':'bg-emerald-100 text-emerald-700','doing':'bg-amber-100 text-amber-700','blocked':'bg-rose-100 text-rose-700','paused':'bg-slate-200 text-slate-600',"won't-do":'bg-slate-200 text-slate-500'} %}
          <a href="/tasks{{ state_qs(focus_id, require_add='STATUS:' ~ r.status) }}"
             class="text-xs px-1.5 py-0.5 rounded {{ sc.get(r.status, 'bg-sky-100 text-sky-700') }} hover:opacity-80{% if r.note %} cursor-help{% endif %}"
             {% if r.note %}title="{{ r.note }} (click to filter to STATUS:{{ r.status }})"{% else %}title="filter to STATUS:{{ r.status }}"{% endif %}>{{ r.status }}{% if r.note %} ⓘ{% endif %}</a>
          {% if r.level %}
          <a href="/tasks{{ state_qs(focus_id, require_add='level:' ~ r.level) }}"
             class="text-xs px-1.5 py-0.5 rounded bg-violet-100 text-violet-700 hover:bg-violet-200"
             title="filter to level:{{ r.level }}">{{ r.level }}</a>
          {% endif %}
          {# Processing signals: live row lock and worker lease. #}
          {% if r.locked %}<span class="text-xs px-1.5 py-0.5 rounded bg-rose-600 text-white" title="row-locked right now (a worker holds it)">🔒 locked</span>{% endif %}
          {% if r.lease_active %}<span class="text-xs px-1.5 py-0.5 rounded bg-amber-500 text-white" title="leased until {{ r.lease_until }}">⏱ running</span>{% elif r.lease_until %}<span class="text-xs px-1.5 py-0.5 rounded bg-slate-200 text-slate-500" title="lease expired {{ r.lease_until }}">lease expired</span>{% endif %}
          {% for ai in r.attention_icons %}
          <a href="{{ ai.href }}" class="text-base leading-none" title="{{ ai.title }}">{{ ai.icon }}</a>
          {% endfor %}
          {# First-line + full-body popover. The body is the planner's
             prompt; rendering the whole multi-paragraph thing in the
             row blows up vertical density. First line goes in the row
             (truncated at 80 chars); the rest lives in an Alpine
             popover triggered on row-text hover (touch users tap the
             ⋯ action menu instead — same content there). #}
          <span class="relative" x-data="{ tip: false }"
                @mouseenter="tip = true" @mouseleave="tip = false">
            {# Prompt-like bodies show a 3-keyword RAKE gist in the row
               (the full text lives in the hover popover); short todos
               show their first line verbatim. #}
            {% if r.gist %}
            <span class="text-sm break-words {% if r.status in ['done',"won't-do"] %}line-through text-slate-400{% endif %}"><span class="text-slate-400 mr-1" title="3-keyword gist of the prompt; hover for full text">≡</span>{{ r.gist | linkify_refs }}</span>
            {% else %}
            <span class="text-sm break-words {% if r.status in ['done',"won't-do"] %}line-through text-slate-400{% endif %}">{{ (r.title or '').split('\n', 1)[0] | truncate(80, killwords=False, end='…') | linkify_refs }}</span>
            {% endif %}
            {% if r.title and '\n' in r.title or (r.title and r.title|length > 80) %}
            <div x-show="tip" x-cloak x-transition.opacity.duration.150ms
                 class="absolute z-40 left-0 top-full mt-1 w-[44rem] max-w-[80vw] rounded-lg border border-slate-200 bg-white p-3 shadow-xl"
                 style="white-space: pre-line">
              <p class="text-xs text-slate-700 break-words">{{ r.title | linkify_refs }}</p>
            </div>
            {% endif %}
          </span>
          {% if r.rollup and r.rollup.total %}
          {# 3-bucket rollup: active · waiting · done over direct todo
             children. Clicking opens a popover listing the children;
             each child row has its own rollup chip that drills deeper.
             Recursion is via a single htmx-loaded fragment template
             (``_children_popup.html.j2``) — depth-2 lazy. #}
          <span class="relative" x-data="{ open: false, loaded: false }"
                @click.outside="open = false"
                @keyup.escape.window="open = false">
            <button type="button"
                    @click="open = !open; if (open && !loaded) loaded = true"
                    hx-get="/tasks/{{ r.id }}/children-popup?depth=0"
                    hx-target="#popup-children-{{ r.id }}"
                    hx-trigger="click once"
                    class="inline-flex items-center gap-0.5 text-xs ml-1 cursor-pointer hover:opacity-80"
                    title="click to drill into children">
              <span class="px-1 py-0.5 rounded-l bg-sky-100 text-sky-700 font-medium">{{ r.rollup.active }}</span>
              <span class="px-1 py-0.5 bg-amber-100 text-amber-700 font-medium">{{ r.rollup.waiting }}</span>
              <span class="px-1 py-0.5 rounded-r bg-emerald-100 text-emerald-700 font-medium">{{ r.rollup.done }}</span>
            </button>
            <div id="popup-children-{{ r.id }}" x-show="open" x-cloak
                 class="absolute z-50 left-0 top-full mt-1"></div>
          </span>
          {% endif %}
          {% if r.kind == 'todo' %}
          {# Per-row navigation: 🔍 focus (drill into subtree),
             📊 tree (focus + mermaid 3 deep). 📊 collapses both into
             one click for the visual-tree path. #}
          {% if r.id != focus_id %}
          <a href="/tasks{{ state_qs(r.id) }}"
             class="ml-auto text-xs text-slate-400 hover:text-emerald-700"
             title="focus this subtree">🔍</a>
          <a href="/tasks{{ state_qs(r.id, tree_override=3) }}"
             class="text-xs text-slate-400 hover:text-emerald-700"
             title="focus + show tree diagram (3 deep)">📊</a>
          {% else %}
          <span class="ml-auto"></span>
          {% endif %}
          <button type="button" @click="actions=!actions"
                  class="text-xs text-slate-400 hover:text-slate-700">⋯</button>
          {% endif %}
        </div>
        {% if r.kind == 'todo' %}
        <!-- Tags strip: always visible (not gated by the ⋯ panel, which
             collapses on the post-redirect reload) so a just-added tag
             shows immediately. Each chip carries a right-side × that
             removes it via the tag verb. -->
        <div class="mt-1 flex flex-wrap items-center gap-1"
             style="padding-left: {{ (r.depth * 1.25) + 1.5 }}rem">
          {% for t in r.tags %}
          <span class="inline-flex items-center gap-1 text-xs pl-2 pr-1 py-0.5 rounded-full bg-slate-100 text-slate-600">
            <span>{{ t }}</span>
            <form method="post" action="/tasks/{{ r.id }}/tags" class="inline-flex">
              {{ filter_inputs() }}
              <input type="hidden" name="remove" value="{{ t }}" />
              <button class="leading-none text-slate-400 hover:text-rose-600"
                      title="remove tag" aria-label="remove tag {{ t }}">&times;</button>
            </form>
          </span>
          {% endfor %}
          <form method="post" action="/tasks/{{ r.id }}/tags" class="inline-flex items-center gap-1">
            {{ filter_inputs() }}
            <input name="add" placeholder="+ tag…"
                   class="rounded border-slate-300 text-xs border px-2 py-0.5 w-24" />
            <button class="rounded border border-slate-300 text-xs px-1.5 py-0.5 hover:bg-slate-100">add</button>
          </form>
        </div>
        {% endif %}
        {% if r.kind == 'todo' %}
        <div x-show="actions" x-cloak class="mt-2 flex flex-wrap items-center gap-2"
             style="padding-left: {{ r.depth * 1.25 }}rem">
          <!-- Edit text: in-place rewrite via the edit verb (same id).
               Textarea so multiline task bodies edit + save verbatim. -->
          <form method="post" action="/tasks/{{ r.id }}/edit" class="flex items-start gap-1 w-full">
            {{ filter_inputs() }}
            <textarea name="text" required rows="3"
                      class="rounded border-slate-300 text-xs border px-2 py-1 flex-1 font-mono">{{ r.title }}</textarea>
            <button class="rounded bg-slate-700 text-white text-xs px-2 py-0.5">Save text</button>
          </form>
          <form method="post" action="/tasks/{{ r.id }}/status" class="flex items-center gap-1">
            {{ filter_inputs() }}
            <select name="status" class="rounded border-slate-300 text-xs border px-1 py-0.5">
              {% for s in status_choices %}
              <option value="{{ s }}" {% if s == r.status %}selected{% endif %}>{{ s }}</option>
              {% endfor %}
            </select>
            <button class="rounded bg-slate-700 text-white text-xs px-2 py-0.5">Set</button>
          </form>
          <form method="post" action="/tasks/{{ r.id }}/children" class="flex items-start gap-1">
            {{ filter_inputs() }}
            <textarea name="text" required rows="2" placeholder="add child…"
                      class="rounded border-slate-300 text-xs border px-2 py-1 w-48"></textarea>
            <button class="rounded border border-slate-300 text-xs px-2 py-0.5 hover:bg-slate-100">+ child</button>
          </form>
          <!-- Manual reparent fallback (keyboard / non-DnD path). -->
          <form method="post" action="/tasks/{{ r.id }}/move" class="flex items-center gap-1">
            {{ filter_inputs() }}
            <input name="new_parent_id" type="number" min="1" placeholder="parent #"
                   class="rounded border-slate-300 text-xs border px-2 py-0.5 w-20" />
            <button class="rounded border border-slate-300 text-xs px-2 py-0.5 hover:bg-slate-100"
                    title="empty = move to top level">move</button>
          </form>
          <form method="post" action="/tasks/{{ r.id }}/delete"
                onsubmit="return confirm('Delete #{{ r.id }}? Children re-parent to top level.')">
            {{ filter_inputs() }}
            <button class="rounded text-xs px-2 py-0.5 text-rose-600 hover:bg-rose-50">delete</button>
          </form>
          <!-- History: lazy-load attempts (jobs) + event log via htmx. -->
          <button type="button"
                  class="rounded border border-slate-300 text-xs px-2 py-0.5 hover:bg-slate-100"
                  hx-get="/tasks/{{ r.id }}/history"
                  hx-target="#hist-{{ r.id }}" hx-swap="innerHTML">history</button>
          <div id="hist-{{ r.id }}" class="w-full"></div>
        </div>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>

  <!-- Doable (1/3) -->
  <section>
    <h2 class="text-lg font-semibold mb-3">Doable next</h2>
    <pre class="rounded-lg border border-slate-200 bg-white p-3 text-xs whitespace-pre-wrap text-slate-700 overflow-x-auto">{{ doable_body }}</pre>
  </section>

</div>
<style>
  [x-cloak]{display:none!important}
  .drop-target{background-color:#e0f2fe;outline:2px solid #38bdf8;outline-offset:-2px}
</style>
<script>
(function () {
  // Drag-to-reparent. A todo <li> is the draggable; dropping it on
  // another todo <li> (or the top-level bar) POSTs to /tasks/{id}/move,
  // which dispatches link(rel='parent') with the tree guards. We submit
  // a real form (full reload) to stay consistent with the no-SPA UI.
  let draggingId = null;

  // The current filter / focus / show_jobs state, threaded through
  // the synthetic DnD form so a drag-reparent lands back on the same
  // view instead of resetting.
  const REQUIRE = {{ require_tags|tojson }};
  const EXCLUDE = {{ exclude_tags|tojson }};
  const FOCUS = {{ focus_id|tojson }};
  const SHOW_JOBS = {{ show_jobs|tojson }};

  function moveTask(childId, newParentId) {
    if (childId == null) return;
    if (String(childId) === String(newParentId)) return;  // no-op onto self
    const f = document.createElement('form');
    f.method = 'post';
    f.action = '/tasks/' + childId + '/move';
    const inp = document.createElement('input');
    inp.type = 'hidden';
    inp.name = 'new_parent_id';
    inp.value = newParentId == null ? '' : String(newParentId);
    f.appendChild(inp);
    REQUIRE.forEach(function (t) {
      const h = document.createElement('input');
      h.type = 'hidden'; h.name = 'require'; h.value = t;
      f.appendChild(h);
    });
    EXCLUDE.forEach(function (t) {
      const h = document.createElement('input');
      h.type = 'hidden'; h.name = 'exclude'; h.value = t;
      f.appendChild(h);
    });
    if (FOCUS != null) {
      const h = document.createElement('input');
      h.type = 'hidden'; h.name = 'focus'; h.value = String(FOCUS);
      f.appendChild(h);
    }
    if (SHOW_JOBS && SHOW_JOBS !== 'active') {
      const h = document.createElement('input');
      h.type = 'hidden'; h.name = 'show_jobs'; h.value = String(SHOW_JOBS);
      f.appendChild(h);
    }
    document.body.appendChild(f);
    f.submit();
  }

  document.querySelectorAll('#tree li[draggable="true"]').forEach(function (li) {
    li.addEventListener('dragstart', function (e) {
      draggingId = li.dataset.id;
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', draggingId);
    });
    li.addEventListener('dragover', function (e) {
      if (draggingId && draggingId !== li.dataset.id) {
        e.preventDefault();
        li.classList.add('drop-target');
      }
    });
    li.addEventListener('dragleave', function () {
      li.classList.remove('drop-target');
    });
    li.addEventListener('drop', function (e) {
      e.preventDefault();
      li.classList.remove('drop-target');
      moveTask(draggingId, li.dataset.id);
    });
  });

  const top = document.querySelector('[data-droptop]');
  if (top) {
    top.addEventListener('dragover', function (e) {
      if (draggingId) { e.preventDefault(); top.classList.add('drop-target'); }
    });
    top.addEventListener('dragleave', function () { top.classList.remove('drop-target'); });
    top.addEventListener('drop', function (e) {
      e.preventDefault();
      top.classList.remove('drop-target');
      moveTask(draggingId, '');  // empty parent = detach to root
    });
  }
})();
</script>

<script>
/* T12.2 — Tasks-tree filter chips + per-row collapse.
   No backend, no Alpine; localStorage persists view state. */
(function () {
  const TREE = document.getElementById('tree');
  if (!TREE) return;
  const BAR = document.getElementById('task-filter-bar');
  const ROW_COUNT_BADGE = document.getElementById('task-row-count');

  // ---- filter chip toggle ------------------------------------------
  const FILTER_STORAGE_KEY = 'precis.tasks.filters';
  function loadFilters() {
    try {
      const raw = localStorage.getItem(FILTER_STORAGE_KEY);
      return raw ? JSON.parse(raw) : {};
    } catch (_) { return {}; }
  }
  function saveFilters(filters) {
    try { localStorage.setItem(FILTER_STORAGE_KEY, JSON.stringify(filters)); } catch (_) {}
  }
  function applyFilters() {
    const filters = loadFilters();
    Object.keys({
      'hide-done': 1, 'hide-wont-do': 1, 'only-recurring': 1,
      'only-strategic': 1, 'only-jobs': 1,
    }).forEach(function (cls) {
      TREE.classList.toggle(cls, !!filters[cls]);
    });
    // Reflect chip on/off state in the button labels.
    BAR.querySelectorAll('[data-filter-toggle]').forEach(function (btn) {
      const cls = btn.dataset.filterToggle;
      const on = !!filters[cls];
      btn.classList.toggle('bg-emerald-600', on);
      btn.classList.toggle('text-white', on);
      btn.classList.toggle('border-emerald-600', on);
      const onSpan = btn.querySelector('[data-when-on]');
      const offSpan = btn.querySelector('[data-when-off]');
      if (onSpan && offSpan) {
        onSpan.style.display = on ? '' : 'none';
        offSpan.style.display = on ? 'none' : '';
      }
    });
    updateRowCount();
  }
  BAR.addEventListener('click', function (e) {
    const btn = e.target.closest('[data-filter-toggle]');
    if (!btn) return;
    const filters = loadFilters();
    filters[btn.dataset.filterToggle] = !filters[btn.dataset.filterToggle];
    saveFilters(filters);
    applyFilters();
  });

  // ---- per-row collapse --------------------------------------------
  const COLLAPSE_STORAGE_KEY = 'precis.tasks.collapsed';
  function loadCollapsed() {
    try {
      const raw = localStorage.getItem(COLLAPSE_STORAGE_KEY);
      return raw ? new Set(JSON.parse(raw)) : new Set();
    } catch (_) { return new Set(); }
  }
  function saveCollapsed(s) {
    try { localStorage.setItem(COLLAPSE_STORAGE_KEY, JSON.stringify(Array.from(s))); } catch (_) {}
  }

  // Build the "has children?" lookup from the flat row list. A row has
  // children if the next row's depth is greater than its own.
  const rows = Array.from(TREE.querySelectorAll('li[data-id]'));
  const hasChildren = new Map();
  for (let i = 0; i < rows.length; i++) {
    const d = parseInt(rows[i].dataset.depth || '0', 10);
    const nd = i + 1 < rows.length ? parseInt(rows[i + 1].dataset.depth || '0', 10) : -1;
    hasChildren.set(rows[i].dataset.id, nd > d);
  }
  // Inject toggle buttons on rows with children.
  rows.forEach(function (row) {
    if (!hasChildren.get(row.dataset.id)) return;
    const firstFlex = row.querySelector('div.flex');
    if (!firstFlex) return;
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'text-xs w-5 text-slate-400 hover:text-slate-700 shrink-0';
    btn.dataset.collapseToggle = row.dataset.id;
    btn.textContent = '▼';
    btn.title = 'collapse / expand subtree';
    // Insert immediately after the indent padding (as the first child).
    firstFlex.insertBefore(btn, firstFlex.firstChild);
  });
  function applyCollapsed() {
    const collapsed = loadCollapsed();
    let hideUntilDepth = -1;
    for (let i = 0; i < rows.length; i++) {
      const row = rows[i];
      const d = parseInt(row.dataset.depth || '0', 10);
      if (hideUntilDepth >= 0 && d > hideUntilDepth) {
        row.dataset.rowCollapsed = '1';
      } else {
        delete row.dataset.rowCollapsed;
        hideUntilDepth = -1;
      }
      // Update the toggle marker on this row if it has children.
      const btn = row.querySelector('[data-collapse-toggle]');
      if (btn) {
        const isCollapsed = collapsed.has(row.dataset.id);
        btn.textContent = isCollapsed ? '▶' : '▼';
        if (isCollapsed && hideUntilDepth < 0) hideUntilDepth = d;
      }
    }
    updateRowCount();
  }
  TREE.addEventListener('click', function (e) {
    const btn = e.target.closest('[data-collapse-toggle]');
    if (!btn) return;
    e.preventDefault();
    const id = btn.dataset.collapseToggle;
    const collapsed = loadCollapsed();
    if (collapsed.has(id)) collapsed.delete(id);
    else collapsed.add(id);
    saveCollapsed(collapsed);
    applyCollapsed();
  });
  document.getElementById('task-collapse-all').addEventListener('click', function () {
    const collapsed = new Set();
    rows.forEach(function (row) {
      if (hasChildren.get(row.dataset.id)) collapsed.add(row.dataset.id);
    });
    saveCollapsed(collapsed);
    applyCollapsed();
  });
  document.getElementById('task-expand-all').addEventListener('click', function () {
    saveCollapsed(new Set());
    applyCollapsed();
  });

  // ---- visible row counter -----------------------------------------
  function updateRowCount() {
    if (!ROW_COUNT_BADGE) return;
    const total = rows.length;
    const visible = rows.filter(function (r) {
      return getComputedStyle(r).display !== 'none';
    }).length;
    ROW_COUNT_BADGE.textContent =
      visible === total ? total + ' rows' : visible + ' / ' + total + ' rows';
  }

  applyFilters();
  applyCollapsed();
})();
</script>
{% endblock %}
