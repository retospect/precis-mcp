{% extends "base.html.j2" %}
{% block title %}{{ title }}{% endblock %}
{% block content %}

<div class="mb-4 flex items-center gap-3">
  <a href="/figure" class="text-xs text-slate-400 hover:text-slate-600">← Figures</a>
  <h1 class="text-lg font-semibold">{{ title }}</h1>
  <span class="text-xs text-slate-400">{{ slug }} · canvas {{ vb_w }}×{{ vb_h }}</span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  {# ── left: the canvas ── #}
  <div>
    <div class="relative rounded border border-slate-200 bg-white overflow-hidden"
         style="aspect-ratio: {{ vb_w }} / {{ vb_h }};">
      {# the grid overlay — the shared coordinate frame (10% ticks) #}
      <div class="pointer-events-none absolute inset-0 z-10 opacity-40"
           style="background-image:
             linear-gradient(to right, #cbd5e1 1px, transparent 1px),
             linear-gradient(to bottom, #cbd5e1 1px, transparent 1px);
             background-size: 10% 10%;"></div>
      <img id="fig-canvas" src="/figure/{{ slug }}/source.svg"
           alt="figure canvas" class="absolute inset-0 w-full h-full object-contain z-0">
    </div>
    <div class="mt-1 flex items-center gap-2 text-[11px] text-slate-400">
      <span>viewBox {{ viewbox }}</span>
      <span class="ml-auto">grid = 10% of each axis</span>
    </div>
    <div id="fig-lints" class="mt-2 space-y-1 text-[11px]">
      {% for f in findings %}
      <div class="text-amber-700">⚠ [{{ f.kind }}] {{ f.message }}</div>
      {% endfor %}
    </div>
  </div>

  {# ── right: docs (two tabs) + chat ── #}
  <div class="flex flex-col gap-4">
    <div>
      <div class="flex items-center gap-1 mb-1">
        <button id="fig-tab-vocab" type="button"
                class="px-2 py-0.5 rounded text-xs font-semibold text-slate-700 bg-slate-100">Shared vocabulary</button>
        <button id="fig-tab-notes" type="button"
                class="px-2 py-0.5 rounded text-xs text-slate-500 hover:bg-slate-50">Implementation notes</button>
        <span class="ml-auto text-[10px] text-slate-400">vocab is for you · notes are the model's</span>
      </div>
      <pre id="fig-vocab" class="text-xs bg-slate-50 border border-slate-200 rounded p-2 whitespace-pre-wrap max-h-40 overflow-y-auto">{{ vocab or '(empty — the model will describe what the drawing is)' }}</pre>
      <pre id="fig-notes" class="hidden text-xs bg-slate-50 border border-slate-200 rounded p-2 whitespace-pre-wrap max-h-40 overflow-y-auto">{{ notes or "(empty — the model records ids / structure / conventions here)" }}</pre>
    </div>

    <div class="flex-1 min-h-0">
      <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Chat</h2>
      <div id="fig-chat" class="space-y-2 text-xs max-h-96 overflow-y-auto pr-1">
        {% for t in turns %}
        <pre class="bg-slate-50 border border-slate-200 rounded p-2 whitespace-pre-wrap">{{ t }}</pre>
        {% endfor %}
      </div>
    </div>

    <form id="fig-form" class="flex gap-2" data-slug="{{ slug }}">
      <input id="fig-msg" name="message" required autocomplete="off"
             placeholder="e.g. draw a round green face with two eyes…"
             class="flex-1 rounded border border-slate-300 px-3 py-1.5 text-sm">
      <button id="fig-send" class="rounded bg-slate-700 text-white px-3 py-1.5 text-sm hover:bg-slate-600">Send ▸</button>
    </form>
  </div>
</div>

{% endblock %}
{% block scripts %}
<script>
(function () {
  const form = document.getElementById('fig-form');
  const slug = form.getAttribute('data-slug');
  const chat = document.getElementById('fig-chat');
  const msg = document.getElementById('fig-msg');
  const send = document.getElementById('fig-send');
  const canvas = document.getElementById('fig-canvas');
  const vocab = document.getElementById('fig-vocab');
  const notes = document.getElementById('fig-notes');
  const lints = document.getElementById('fig-lints');
  const tabVocab = document.getElementById('fig-tab-vocab');
  const tabNotes = document.getElementById('fig-tab-notes');

  // ── the two doc tabs ──
  const ON = 'px-2 py-0.5 rounded text-xs font-semibold text-slate-700 bg-slate-100';
  const OFF = 'px-2 py-0.5 rounded text-xs text-slate-500 hover:bg-slate-50';
  function showTab(which) {
    const v = which === 'vocab';
    vocab.classList.toggle('hidden', !v);
    notes.classList.toggle('hidden', v);
    tabVocab.className = v ? ON : OFF;
    tabNotes.className = v ? OFF : ON;
  }
  tabVocab.addEventListener('click', () => showTab('vocab'));
  tabNotes.addEventListener('click', () => showTab('notes'));

  function toBottom() { chat.scrollTop = chat.scrollHeight; }

  // textContent (never innerHTML) — model output is untrusted text.
  function bubble(text, cls) {
    const pre = document.createElement('pre');
    pre.className = 'border rounded p-2 whitespace-pre-wrap ' + cls;
    pre.textContent = text;
    chat.appendChild(pre);
    toBottom();
    return pre;
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    const text = msg.value.trim();
    if (!text) return;
    bubble('user: ' + text, 'bg-white border-slate-200');
    const pending = bubble('…thinking', 'bg-slate-50 border-slate-200 text-slate-400');
    msg.value = '';
    send.disabled = true;

    const body = new URLSearchParams();
    body.set('message', text);
    fetch('/figure/' + encodeURIComponent(slug) + '/turn', { method: 'POST', body })
      .then((r) => r.json())
      .then((d) => {
        if (d.error) { pending.textContent = 'error: ' + d.error; return; }
        pending.textContent = 'assistant: ' + (d.reply || '(no reply)');
        pending.className = 'border rounded p-2 whitespace-pre-wrap bg-slate-50 border-slate-200';
        if (d.changed && d.svg) {
          // SVG-in-<img> is script-safe; a data URI avoids a round trip.
          canvas.src = 'data:image/svg+xml;utf8,' + encodeURIComponent(d.svg);
        }
        // Reload the docs — they are the memory, and the model just revised them.
        if (typeof d.vocab === 'string' && d.vocab.trim()) vocab.textContent = d.vocab;
        if (typeof d.notes === 'string' && d.notes.trim()) notes.textContent = d.notes;
        lints.innerHTML = '';
        (d.findings || []).forEach((f) => {
          const div = document.createElement('div');
          div.className = 'text-amber-700';
          div.textContent = '⚠ [' + f.kind + '] ' + f.message;
          lints.appendChild(div);
        });
      })
      .catch((err) => { pending.textContent = 'request failed: ' + err; })
      .finally(() => { send.disabled = false; toBottom(); msg.focus(); });
  });

  toBottom();  // start scrolled to the latest turn, input ready
})();
</script>
{% endblock %}
