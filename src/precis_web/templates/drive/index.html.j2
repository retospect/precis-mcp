{% extends "base.html.j2" %}
{% block title %}Drive{% endblock %}
{% block content %}

<div class="flex items-center gap-3 mb-4" x-data="{ open: false, kind: 'cad' }">
  <h1 class="text-lg font-semibold">Drive</h1>
  <span class="text-sm text-slate-500">
    folders for what you <em>make</em> — drafts, structures, CAD, project roots.
    Papers &amp; memories keep their own discovery (ADR 0045).
  </span>
  <div class="ml-auto relative">
    <button type="button" @click="open = !open"
            class="rounded bg-sky-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-sky-700">
      + New <span class="text-[9px]">▾</span>
    </button>
    {# One popup form; the action switches by kind so the existing /drafts/new
       flow is reused untouched (DRY), and cad/structure ride /drive/new. #}
    <form x-show="open" x-cloak @click.outside="open = false"
          method="post"
          :action="kind === 'draft' ? '/drafts/new' : '/drive/new'"
          class="absolute right-0 mt-1 w-64 z-20 rounded-lg border border-slate-200 bg-white p-3 shadow-lg space-y-2">
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Kind</label>
        <select x-model="kind" name="kind"
                class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm bg-white">
          <option value="cad">CAD (3D solid)</option>
          <option value="structure">DFT (atomistic cell)</option>
          <option value="draft">Draft (document)</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Title <span class="text-rose-500">*</span></label>
        <input name="title" required autocomplete="off" x-init="$el.focus()"
               placeholder="hex pocket block"
               class="w-full rounded border border-slate-300 px-2 py-1.5 text-sm">
      </div>
      <p class="text-[10px] text-slate-400" x-show="kind !== 'draft'">
        Lands you in the editor with a starter you can edit by prompt.
      </p>
      <div class="flex justify-end">
        <button type="submit"
                class="rounded bg-emerald-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-emerald-700">
          Create ▸
        </button>
      </div>
    </form>
  </div>
</div>

{% if notice %}
<div class="rounded-md border border-amber-300 bg-amber-50 px-4 py-2 text-sm text-amber-800 mb-4">
  {{ notice }}
</div>
{% endif %}

<div class="flex gap-6 items-start">

  {# ── sidebar: the folder tree + create form ─────────────────── #}
  <aside class="w-64 shrink-0">
    <div class="rounded-md border border-slate-200 overflow-hidden">
      <div class="px-3 py-2 bg-slate-50 border-b border-slate-200 text-xs font-semibold text-slate-600">
        Folders
      </div>
      <ul class="py-1 text-sm">
        <li>
          <a href="/drive"
             class="block px-3 py-1 {% if current is none %}bg-slate-100 font-medium{% else %}hover:bg-slate-50{% endif %}">
            🗂 Unfiled
          </a>
        </li>
        {% for f in folders %}
        <li>
          <a href="/drive/{{ f.ref_id }}"
             style="padding-left: {{ 0.75 + f.depth * 0.9 }}rem"
             class="block py-1 pr-3 truncate {% if current and current.ref_id == f.ref_id %}bg-slate-100 font-medium{% else %}hover:bg-slate-50{% endif %}">
            📁 {{ f.title }}
            <span class="text-slate-400 text-xs">{{ f.n_children }}</span>
          </a>
        </li>
        {% endfor %}
        {% if not folders %}
        <li class="px-3 py-1 text-slate-400 text-xs">(no folders yet)</li>
        {% endif %}
      </ul>
    </div>

    <form method="post" action="/drive/create" class="mt-3 flex gap-1">
      <input type="hidden" name="parent_id" value="{{ current.ref_id if current else '' }}">
      <input name="name" placeholder="New folder{% if current %} in {{ current.title }}{% endif %}…"
             class="flex-1 min-w-0 rounded border border-slate-300 px-2 py-1 text-sm">
      <button class="rounded bg-slate-700 text-white px-2 py-1 text-sm hover:bg-slate-600">＋</button>
    </form>
  </aside>

  {# ── main pane ──────────────────────────────────────────────── #}
  <section class="flex-1 min-w-0">

    {% if current %}
    <div class="flex items-center gap-2 mb-3 text-sm">
      <nav class="text-slate-500">
        <a href="/drive" class="hover:underline">Drive</a>
        {% for c in crumbs %}
        <span class="text-slate-300">/</span>
        {% if loop.last %}<span class="font-medium text-slate-800">{{ c.title }}</span>
        {% else %}<a href="/drive/{{ c.ref_id }}" class="hover:underline">{{ c.title }}</a>{% endif %}
        {% endfor %}
      </nav>
      <span class="text-slate-300">·</span>
      <form method="post" action="/drive/{{ current.ref_id }}/rename" class="inline-flex gap-1">
        <input name="name" value="{{ current.title }}"
               class="rounded border border-slate-300 px-2 py-0.5 text-xs w-40">
        <button class="rounded border border-slate-300 px-2 py-0.5 text-xs hover:bg-slate-50">rename</button>
      </form>
      <form method="post" action="/drive/{{ current.ref_id }}/delete" class="inline"
            onsubmit="return confirm('Delete folder “{{ current.title }}”? (refused unless empty)');">
        <button class="rounded border border-rose-300 text-rose-700 px-2 py-0.5 text-xs hover:bg-rose-50">delete</button>
      </form>
    </div>
    {% endif %}

    {% set rows = children if current else unfiled %}
    {% set pane_title = current.title if current else 'Unfiled artifacts' %}
    {% set back_url = '/drive/' ~ current.ref_id if current else '/drive' %}

    <div class="rounded-md border border-slate-200 overflow-hidden">
      <div class="px-3 py-2 bg-slate-50 border-b border-slate-200 text-xs font-semibold text-slate-600">
        {{ pane_title }} <span class="text-slate-400 font-normal">{{ rows | length }}</span>
      </div>
      {% if not rows %}
      <div class="px-4 py-6 text-sm text-slate-500">
        {% if current %}
        Empty. Place things here from their reader, from Unfiled, or via
        <code class="text-xs bg-slate-100 rounded px-1">link(kind='…', id=…, target='folder:{{ current.ref_id }}', rel='parent')</code>.
        {% else %}
        Nothing unfiled — every draft / structure / CAD design sits in a folder.
        {% endif %}
      </div>
      {% else %}
      <table class="w-full text-sm">
        <tbody>
          {% for r in rows %}
          <tr class="border-t border-slate-100 first:border-t-0">
            <td class="px-3 py-1.5 w-8">{{ r.icon }}</td>
            <td class="px-3 py-1.5 w-24 text-xs text-slate-500 font-mono">{{ r.kind }}</td>
            <td class="px-3 py-1.5">
              {% if r.kind == 'folder' %}
                <a href="/drive/{{ r.ref_id }}" class="hover:underline font-medium">{{ r.title }}</a>
              {% elif r.url %}
                <a href="{{ r.url }}" class="hover:underline">{{ r.title | truncate(90) }}</a>
              {% else %}
                {{ r.title | truncate(90) }}
                <span class="text-xs text-slate-400 font-mono">{{ r.kind }}:{{ r.ident }}</span>
              {% endif %}
            </td>
            <td class="px-3 py-1.5 w-24 text-xs text-slate-400 whitespace-nowrap">{{ r.updated }}</td>
            <td class="px-3 py-1.5 w-56 text-right whitespace-nowrap">
              <form method="post" action="/drive/move" class="inline-flex items-center gap-1">
                <input type="hidden" name="kind" value="{{ r.kind }}">
                <input type="hidden" name="id" value="{{ r.handler_id }}">
                <input type="hidden" name="back" value="{{ back_url }}">
                <select name="target_folder" class="rounded border border-slate-300 px-1 py-0.5 text-xs max-w-[9rem]">
                  <option value="">(unfile)</option>
                  {% for f in folders %}
                  {% if f.ref_id != r.ref_id %}
                  <option value="{{ f.ref_id }}" {% if current and f.ref_id == current.ref_id %}disabled{% endif %}>
                    {{ ('&nbsp;&nbsp;' * f.depth) | safe }}{{ f.title }}
                  </option>
                  {% endif %}
                  {% endfor %}
                </select>
                <button class="rounded border border-slate-300 px-2 py-0.5 text-xs hover:bg-slate-50">move</button>
              </form>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}
    </div>

    {% if current %}
    <p class="mt-3 text-xs text-slate-400">
      Scope a search to this folder:
      <code class="bg-slate-100 rounded px-1">search(q='…', folder={{ current.ref_id }})</code>
    </p>
    {% endif %}
  </section>
</div>

{% endblock %}
