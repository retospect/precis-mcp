#!/usr/bin/env bash
# scripts/nightly-timer — install/remove the LOCAL unattended nightly-build
# timer (macOS LaunchAgent) that runs `scripts/nightly` at 04:00 daily. This is
# the "actually fires without me" half of the nightly: the timer runs the suite
# and records green/red; `/whatneedsdoing` (via `scripts/nightly --check`)
# surfaces it. Deliberately a per-user LaunchAgent (not a cluster daemon, not
# GitHub) — it runs in the login session where Docker/uv are on PATH.
#
# The Mac must be awake at 04:00 (or launchd runs the missed job on next wake).
# If Docker is down at fire time, the run records a neutral skip, not a red.
#
#   scripts/nightly-timer install     write + load the LaunchAgent (idempotent)
#   scripts/nightly-timer uninstall   unload + remove it
#   scripts/nightly-timer status      show launchctl state + last result
set -euo pipefail
cd "$(dirname "$0")/.."

LABEL="com.precis.nightly"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
# Bake the MAIN checkout's script path in, so the timer always runs the shipped
# copy regardless of which worktree installed it.
MAIN_ROOT="$(dirname "$(git rev-parse --path-format=absolute --git-common-dir)")"
NIGHTLY="$MAIN_ROOT/scripts/nightly"
TIMER_LOG="$MAIN_ROOT/.nightly-timer.log"
DOMAIN="gui/$(id -u)"

cmd="${1:-status}"
case "$cmd" in
install)
    mkdir -p "$HOME/Library/LaunchAgents"
    cat > "$PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>exec "$NIGHTLY"</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>4</integer><key>Minute</key><integer>0</integer></dict>
  <key>StandardOutPath</key><string>$TIMER_LOG</string>
  <key>StandardErrorPath</key><string>$TIMER_LOG</string>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string></dict>
  <key>RunAtLoad</key><false/>
  <key>ProcessType</key><string>Background</string>
</dict>
</plist>
PLIST
    # reload cleanly: boot out any prior instance, then bootstrap the new plist
    launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || true
    launchctl bootstrap "$DOMAIN" "$PLIST"
    echo "nightly-timer: installed $LABEL → runs $NIGHTLY at 04:00 daily (log: $TIMER_LOG)"
    ;;
uninstall)
    launchctl bootout "$DOMAIN/$LABEL" 2>/dev/null || true
    rm -f "$PLIST"
    echo "nightly-timer: uninstalled $LABEL (removed $PLIST)"
    ;;
status)
    if launchctl print "$DOMAIN/$LABEL" >/dev/null 2>&1; then
        echo "nightly-timer: LOADED ($LABEL, 04:00 daily)"
    else
        echo "nightly-timer: not loaded — \`scripts/nightly-timer install\` to enable"
    fi
    [[ -x "$NIGHTLY" ]] && { "$NIGHTLY" --check || true; } || echo "nightly: (scripts/nightly not in main yet — ship first)"
    ;;
*)
    echo "usage: scripts/nightly-timer {install|uninstall|status}" >&2; exit 2 ;;
esac
