#!/usr/bin/env bash
# scripts/ship — deterministic /endsession: commit WIP → sync → gate → squash-merge to main.
#
# Replaces the LLM-orchestrated endsession steps with one script (token
# efficient + reproducible). The caller's only job is to pass a good commit
# message; everything below is mechanical. Only genuine failures (merge
# conflicts, mypy/pytest errors, a lost CAS race) exit non-zero for a human
# or the LLM to resolve.
#
# Steps, in order:
#   1. sanity      — refuse to run on main; set the git-town parent if unset
#   2. commit WIP  — stage + commit any dirty tree
#   3. sync        — `git town sync` (merges origin/main in; the squash-ship
#                    in step 5 collapses the merge commit so main stays linear)
#   4. gate        — in the precis-dev container, bind-mounting THIS worktree
#                    over /app: auto-fix ruff (`--fix` + `format`, amended),
#                    then the authoritative ruff/format/mypy/pytest gate. Any
#                    failure aborts the ship (never ship red).
#   5. ship        — squash `commit-tree` onto origin/main + `--force-with-lease`
#                    CAS push (race-safe against sibling worktree ships), then
#                    delete the remote feature branch
#   6. report      — print the new main sha
#
# Usage:  scripts/ship "fix(x): one-line summary of the branch"
#         scripts/ship            # falls back to a generated message
#
# Why a script and not `git town ship`: the latter does `git checkout main`,
# which always fails from a linked worktree (main is checked out in the
# primary). The CAS-push plumbing here is the standing workaround.
set -euo pipefail

cd "$(dirname "$0")/.."
WORKTREE="$PWD"
BRANCH="$(git branch --show-current)"
MSG="${1:-}"
CO_AUTHOR="Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>"

say() { printf '\n\033[1m▶ %s\033[0m\n' "$*"; }
die() { printf '\n\033[31m✖ %s\033[0m\n' "$*" >&2; exit 1; }

# ── 1. sanity ───────────────────────────────────────────────────────────
[[ -n "$BRANCH" ]] || die "detached HEAD — check out a feature branch first."
[[ "$BRANCH" != "main" ]] || die "on main — nothing to ship."
if ! git config --get "git-town-branch.${BRANCH}.parent" >/dev/null 2>&1; then
    git config "git-town-branch.${BRANCH}.parent" main
fi

# ── 2. commit WIP ───────────────────────────────────────────────────────
if [[ -n "$(git status --porcelain)" ]]; then
    say "committing WIP"
    git add -A
    git commit -q -m "${MSG:-wip(${BRANCH}): end-of-session snapshot}

${CO_AUTHOR}"
fi

# ── 3. sync onto main ───────────────────────────────────────────────────
say "git town sync"
git town sync || die "sync failed (merge conflict?) — resolve, git town continue, then re-run scripts/ship."

# ── 4. integration gate against THIS worktree ───────────────────────────
# `./scripts/dev` bind-mounts the MAIN repo at /app (compose default), so the
# gate must override the mount with -v "$WORKTREE":/app to test these edits.
# NB: `env UID=…` — a bare `UID=…` prefix fails in bash (UID is readonly).
INFRA_COMPOSE="${PRECIS_COMPOSE:-${HOME}/work/infrastructure/compose.yaml}"
[[ -f "$INFRA_COMPOSE" ]] || die "compose file not found at ${INFRA_COMPOSE} (set PRECIS_COMPOSE)."

gate() {
    env UID="$(id -u)" GID="$(id -g)" docker compose -f "$INFRA_COMPOSE" \
        --profile dev run --rm --no-deps -v "${WORKTREE}":/app precis-dev \
        bash -lc "$1"
}

say "auto-fixing ruff (lint --fix + format)"
gate 'uv run ruff check --fix . && uv run ruff format .' || die "ruff auto-fix failed to run."
if [[ -n "$(git status --porcelain)" ]]; then
    git add -A
    git commit -q --amend --no-edit
    say "amended ruff auto-fixes into the branch"
fi

say "integration gate (ruff · format · mypy · pytest)"
gate 'uv run ruff check . && uv run ruff format --check . && uv run mypy src tests && uv run pytest -q' \
    || die "gate is RED — not shipping. Fix the failure above and re-run scripts/ship."

# ── 5. ship: squash-merge to main via plumbing ──────────────────────────
say "shipping to main"
git fetch -q origin main
git merge-base --is-ancestor origin/main HEAD \
    || die "branch is not on top of origin/main — re-run scripts/ship (main moved under us)."

OLD_MAIN="$(git rev-parse origin/main)"
TREE="$(git rev-parse 'HEAD^{tree}')"
NEW="$(git commit-tree "$TREE" -p "$OLD_MAIN" -F - <<EOF
${MSG:-ship(${BRANCH}): squash-merge to main}

${CO_AUTHOR}
EOF
)"
git push --force-with-lease=main:"$OLD_MAIN" origin "${NEW}:refs/heads/main" \
    || die "CAS push rejected — origin/main moved (a sibling shipped first). Re-run scripts/ship."
git push origin --delete "$BRANCH" 2>/dev/null || true

# ── 6. fast-forward the local main ──────────────────────────────────────
# The CAS push moved refs/heads/main on the REMOTE only; the local main
# pointer (checked out in the primary worktree) is now behind — the
# "GitHub is ahead of local main" drift after every session. Fast-forward
# it. refs/heads/main is shared across worktrees but checked out in the
# primary, so a `merge --ff-only` THERE moves the ref + that working tree
# together and safely refuses if the primary is dirty/diverged. Best-effort:
# a failure here does NOT unship anything (the remote is already updated).
say "syncing local main"
PRIMARY="$(git worktree list --porcelain | awk '/^worktree /{print $2; exit}')"
git -C "$PRIMARY" fetch -q origin main
if [[ "$(git -C "$PRIMARY" symbolic-ref --quiet --short HEAD || true)" == "main" ]]; then
    git -C "$PRIMARY" merge --ff-only origin/main \
        && echo "local main → $(git -C "$PRIMARY" rev-parse --short main)" \
        || echo "WARNING: primary main not fast-forwarded (dirty or diverged) — run 'git merge --ff-only origin/main' there by hand."
else
    git update-ref refs/heads/main origin/main \
        && echo "local main ref → $(git rev-parse --short main)"
fi

# ── 7. report ───────────────────────────────────────────────────────────
git fetch -q origin main
say "shipped — main is now:"
git log --oneline -1 origin/main
