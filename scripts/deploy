#!/usr/bin/env bash
# scripts/deploy — non-interactive prod deploy: reinstall precis-mcp@<ref>
# into every cluster venv and bounce every daemon.
#
# The deterministic deploy backbone (the twin of scripts/ship). No LLM in the
# loop: it wraps `ansible-playbook redeploy-precis.yml` from ~/work/cluster,
# which already wires the inventory, the `deploy` SSH user, and `.vault-pass`
# via ansible.cfg. Chained after a green ship by the /go command.
#
# Steps:
#   1. reachability — `ansible all -m ping`; abort (non-zero) if any host is
#      down (a partial redeploy leaves nodes on mixed code — never do that).
#   2. deploy       — run the redeploy playbook for the ref.
#   3. report       — the play's final debug task prints installed sha +
#                     bounced daemons; a `failed=` on any host exits non-zero.
#
# Usage:  scripts/deploy            # deploy main (default)
#         scripts/deploy some-branch
set -euo pipefail

REF="${1:-main}"
CLUSTER_DIR="${PRECIS_CLUSTER_DIR:-${HOME}/work/cluster}"

say() { printf '\n\033[1m▶ %s\033[0m\n' "$*"; }
die() { printf '\n\033[31m✖ %s\033[0m\n' "$*" >&2; exit 1; }

# ── slice 12a (DARK): install-from-tree ──────────────────────────────────
# When PRECIS_DEPLOY_FROM_TREE is set, run ansible from the portable in-repo
# `deploy/` tree instead of the operator's private checkout. The tree carries
# the roles + playbooks; the per-cluster overlay (real inventory + vault) stays
# LOCAL-only at deploy/inventory/ (gitignored — the operator symlinks it there,
# along with a deploy/.vault-pass). Default UNSET → behaviour is byte-identical
# to the pre-12a path. Flip to the tree only after the Phase-2 cutover rehearsal.
if [[ -n "${PRECIS_DEPLOY_FROM_TREE:-}" ]]; then
    _script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    CLUSTER_DIR="$(cd "${_script_dir}/.." && pwd)/deploy"
    [[ -d "${CLUSTER_DIR}/inventory" ]] || die "PRECIS_DEPLOY_FROM_TREE set but ${CLUSTER_DIR}/inventory is not wired — symlink your private overlay (see deploy/README.md)."
    say "install-from-tree: deploying from ${CLUSTER_DIR} (portable tree + local overlay)"
fi

[[ -d "$CLUSTER_DIR" ]] || die "cluster dir not found at ${CLUSTER_DIR} (set PRECIS_CLUSTER_DIR)."
[[ -f "${CLUSTER_DIR}/redeploy-precis.yml" ]] || die "redeploy-precis.yml not in ${CLUSTER_DIR}."

cd "$CLUSTER_DIR"

# ── 1. reachability ─────────────────────────────────────────────────────
say "checking cluster reachability (ansible ping)"
ansible all -m ping >/tmp/precis-deploy-ping.$$ 2>&1 || {
    cat /tmp/precis-deploy-ping.$$ >&2
    rm -f /tmp/precis-deploy-ping.$$
    die "a host is unreachable — aborting (a partial redeploy mixes code versions)."
}
rm -f /tmp/precis-deploy-ping.$$

# ── 2. deploy ───────────────────────────────────────────────────────────
if [[ "$REF" == "main" ]]; then
    say "deploying main to the cluster"
    ansible-playbook redeploy-precis.yml \
        || die "redeploy failed — see the failing task above (nodes may be on mixed versions; re-run once fixed)."
else
    say "deploying ref '${REF}' to the cluster"
    ansible-playbook redeploy-precis.yml \
        -e precis_worker_git_ref="$REF" -e precis_web_git_ref="$REF" \
        || die "redeploy failed — see the failing task above (nodes may be on mixed versions; re-run once fixed)."
fi

say "deployed — cluster is running '${REF}'."
